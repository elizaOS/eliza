From 336e0a9ce95f5a3283943412f7b17cfc4fd81d49 Mon Sep 17 00:00:00 2001
From: lalalune <shawmakesmagic@gmail.com>
Date: Mon, 22 Jun 2026 13:19:14 -0700
Subject: [PATCH] ci(tee-deploy): skip Phala build/deploy when registry secrets
 are absent

The "Build, Push & Deploy to Phala Cloud" workflow has failed on every main
run for over a year: the GHCR login step dies with "Username and password
required" because DOCKER_REGISTRY_USERNAME/PASSWORD are not configured. Gate
the build-and-push job behind a preflight secret check so the run skips
cleanly (and stays green) when the deploy is not wired up; it resumes
automatically once the secrets exist.

Co-Authored-By: Claude Opus 4.8 <noreply@anthropic.com>
---
 .github/workflows/tee-build-deploy.yml | 25 +++++++++++++++++++++++++
 1 file changed, 25 insertions(+)

diff --git a/.github/workflows/tee-build-deploy.yml b/.github/workflows/tee-build-deploy.yml
index ff7ea818da..06e6d65dc2 100644
--- a/.github/workflows/tee-build-deploy.yml
+++ b/.github/workflows/tee-build-deploy.yml
@@ -58,7 +58,32 @@ permissions:
   contents: read
 
 jobs:
+  # Gate the deploy on the registry secrets being configured. This workflow has
+  # required `DOCKER_REGISTRY_USERNAME`/`DOCKER_REGISTRY_PASSWORD` secrets; when
+  # they are absent (e.g. forks, or environments where the Phala deploy is not
+  # wired up) the GHCR login fails with "Username and password required" and the
+  # whole run goes red. Skip cleanly instead so a missing optional deploy does
+  # not break the branch — the deploy resumes automatically once the secrets exist.
+  preflight:
+    runs-on: ubuntu-latest
+    outputs:
+      configured: ${{ steps.check.outputs.configured }}
+    steps:
+      - name: Check registry secrets are configured
+        id: check
+        env:
+          DOCKER_REGISTRY_PASSWORD: ${{ secrets.DOCKER_REGISTRY_PASSWORD }}
+        run: |
+          if [ -n "$DOCKER_REGISTRY_PASSWORD" ]; then
+            echo "configured=true" >> "$GITHUB_OUTPUT"
+          else
+            echo "configured=false" >> "$GITHUB_OUTPUT"
+            echo "::notice title=Phala deploy skipped::DOCKER_REGISTRY_USERNAME/PASSWORD secrets are not configured; skipping build, push & deploy."
+          fi
+
   build-and-push:
+    needs: preflight
+    if: ${{ needs.preflight.outputs.configured == 'true' }}
     permissions:
       contents: read
       packages: write
-- 
2.54.0.windows.1

