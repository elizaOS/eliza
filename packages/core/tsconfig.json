{
	"extends": "../../tsconfig.json",
	// Sources only: build emits JS to dist/; declarations via tsconfig.declarations.json + build.ts. Stray .js/.d.ts next to .ts are accidental IDE/tsc emits — remove with bun run clean.
	"compilerOptions": {
		"outDir": "./dist",
		"rootDir": "../../",
		"typeRoots": [
			"../../node_modules/@types",
			"../../node_modules/.bun/node_modules/@types",
			"../../cloud/node_modules/@types",
			"../../cloud/node_modules/.bun/node_modules/@types",
			"../../node_modules",
			"../../node_modules/.bun/node_modules",
			"../../cloud/node_modules",
			"../../cloud/node_modules/.bun/node_modules",
			"../../../node_modules/@types",
			"../../../node_modules/.bun/node_modules/@types",
			"../../../node_modules",
			"../../../node_modules/.bun/node_modules"
		],
		"types": ["node", "bun"],
		"noEmit": true,
		"composite": false,
		"declaration": false,
		"declarationMap": false,
		"skipLibCheck": true,
		"paths": {
			"@elizaos/core": ["./src/index.node.ts"],
			"@elizaos/core/*": ["./src/*"],
			"@elizaos/app-core": ["../app-core/src/index.ts"],
			"@elizaos/app-core/*": ["../app-core/src/*"],
			"@elizaos/shared": ["../shared/src/index.ts"],
			"@elizaos/shared/*": ["../shared/src/*"],
			"@elizaos/plugin-signal": ["../../plugins/plugin-signal/src/index.ts"],
			"@elizaos/plugin-signal/*": ["../../plugins/plugin-signal/src/*"]
		}
	},
	"include": [
		"src/**/*.ts",
		"../@schemas/**/*.ts",
		"../agent/src/external-modules.d.ts"
	],
	"exclude": [
		"src/**/*.test.ts",
		"src/**/*.spec.ts",
		"src/**/__tests__/**",
		"vitest.config.ts",
		"node_modules",
		"dist"
	]
}
