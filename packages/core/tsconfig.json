{
	"extends": "../../tsconfig.json",
	// Sources only: build emits JS to dist/; declarations via tsconfig.declarations.json + build.ts. Stray .js/.d.ts next to .ts are accidental IDE/tsc emits — remove with bun run clean.
	"compilerOptions": {
		"outDir": "./dist",
		"rootDir": "../../",
		"typeRoots": [
			"../../node_modules/@types",
			"../../node_modules/.bun/node_modules/@types",
			"../../cloud/node_modules/@types",
			"../../cloud/node_modules/.bun/node_modules/@types",
			"../../node_modules",
			"../../node_modules/.bun/node_modules",
			"../../cloud/node_modules",
			"../../cloud/node_modules/.bun/node_modules",
			"../../../node_modules/@types",
			"../../../node_modules/.bun/node_modules/@types",
			"../../../node_modules",
			"../../../node_modules/.bun/node_modules"
		],
		"types": ["node", "bun"],
		"noEmit": true,
		"composite": false,
		"declaration": false,
		"declarationMap": false,
		"skipLibCheck": true,
		"paths": {
			"@elizaos/core": ["./src/index.node.ts"],
			"@elizaos/core/*": ["./src/*"],
			"@elizaos/app-core": ["../app-core/src/index.ts"],
			"@elizaos/app-core/*": ["../app-core/src/*"],
			"@elizaos/ui": ["../ui/src/index.ts"],
			"@elizaos/ui/*": ["../ui/src/*"],
			"@elizaos/shared": ["../shared/src/index.ts"],
			"@elizaos/shared/*": ["../shared/src/*"],
			"@elizaos/plugin-elizacloud": ["../../plugins/plugin-elizacloud/src/index.node.ts"],
			"@elizaos/plugin-elizacloud/*": ["../../plugins/plugin-elizacloud/src/*"],
			"@elizaos/plugin-signal": ["../../plugins/plugin-signal/src/index.ts"],
			"@elizaos/plugin-signal/*": ["../../plugins/plugin-signal/src/*"],
			"@elizaos/plugin-sql": ["../../plugins/plugin-sql/typescript/index.node.ts"],
			"@elizaos/plugin-sql/*": ["../../plugins/plugin-sql/typescript/*"],
			"@elizaos/plugin-browser": ["../../plugins/plugin-browser/src/index.ts"],
			"@elizaos/plugin-browser/*": ["../../plugins/plugin-browser/src/*"],
			"@elizaos/plugin-computeruse": [
				"../../plugins/plugin-computeruse/src/index.ts"
			],
			"@elizaos/plugin-computeruse/*": [
				"../../plugins/plugin-computeruse/src/*"
			],
			"@elizaos/plugin-whatsapp": ["../../plugins/plugin-whatsapp/src/index.ts"],
			"@elizaos/plugin-whatsapp/*": ["../../plugins/plugin-whatsapp/src/*"],
			"@elizaos/app-task-coordinator": [
				"../../plugins/app-task-coordinator/src/api/coordinator-types.ts"
			],
			"@elizaos/app-task-coordinator/api/*": [
				"../../plugins/app-task-coordinator/src/api/*"
			]
		}
	},
	"include": [
		"src/**/*.ts",
		"../@schemas/**/*.ts",
		"../agent/src/external-modules.d.ts"
	],
	"exclude": [
		"src/**/*.test.ts",
		"src/**/*.spec.ts",
		"src/**/__tests__/**",
		"vitest.config.ts",
		"node_modules",
		"dist"
	]
}
