{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": false,
    "skipLibCheck": true,
    "types": ["node", "bun", "react", "react-dom"],
    "typeRoots": [
      "./node_modules/@types",
      "../app-core/node_modules/@types",
      "../ui/node_modules/@types",
      "../../node_modules/@types",
      "../../../node_modules/@types",
      "../../../node_modules/.bun/node_modules/@types"
    ],
    "declaration": false,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "paths": {
      "@elizaos/core": ["../core/src/index.node.ts"],
      "@elizaos/core/*": ["../core/src/*"],
      "@elizaos/native-activity-tracker": [
        "../native-plugins/activity-tracker/src/index.ts"
      ],
      "@elizaos/capacitor-appblocker": [
        "../native-plugins/appblocker/src/index.ts"
      ],
      "@elizaos/capacitor-mobile-signals": [
        "../native-plugins/mobile-signals/src/index.ts"
      ],
      "@elizaos/capacitor-wifi": ["../native-plugins/wifi/src/index.ts"],
      "@elizaos/capacitor-contacts": [
        "../native-plugins/contacts/src/index.ts"
      ],
      "@elizaos/capacitor-phone": ["../native-plugins/phone/src/index.ts"],
      "@elizaos/app-lifeops": ["../../plugins/app-lifeops/src/index.ts"],
      "@elizaos/app-lifeops/*": ["../../plugins/app-lifeops/src/*"],
      "@elizaos/app-phone": ["../../plugins/app-phone/src/index.ts"],
      "@elizaos/app-phone/*": ["../../plugins/app-phone/src/*"],
      "@elizaos/app-elizamaker": ["../../plugins/app-elizamaker/src/index.ts"],
      "@elizaos/app-elizamaker/*": ["../../plugins/app-elizamaker/src/*"],
      "@elizaos/plugin-form": ["../../plugins/plugin-form/src/index.ts"],
      "@elizaos/plugin-form/*": ["../../plugins/plugin-form/src/*"],
      "@elizaos/app-wifi": ["../../plugins/app-wifi/src/index.ts"],
      "@elizaos/app-wifi/*": ["../../plugins/app-wifi/src/*"],
      "@elizaos/app-core": ["../app-core/src/index.ts"],
      "@elizaos/app-core/*": ["../app-core/src/*"],
      "@elizaos/app-steward": ["../../plugins/app-steward/src/index.ts"],
      "@elizaos/app-steward/*": ["../../plugins/app-steward/src/*"],
      "@elizaos/app-shopify": ["../../plugins/app-shopify/src/index.ts"],
      "@elizaos/app-shopify/*": ["../../plugins/app-shopify/src/*"],
      "@elizaos/app-vincent": ["../../plugins/app-vincent/src/index.ts"],
      "@elizaos/app-vincent/*": ["../../plugins/app-vincent/src/*"],
      "@elizaos/ui": ["../ui/src/index.ts"],
      "@elizaos/ui/*": ["../ui/src/*"],
      "@elizaos/app-companion": ["../../plugins/app-companion/src/index.ts"],
      "@elizaos/app-companion/*": ["../../plugins/app-companion/src/*"],
      "@elizaos/app-knowledge": ["../../plugins/app-knowledge/src/index.ts"],
      "@elizaos/app-knowledge/*": ["../../plugins/app-knowledge/src/*"],
      "@elizaos/app-training": ["../../plugins/app-training/src/index.ts"],
      "@elizaos/app-training/*": ["../../plugins/app-training/src/*"],
      "@elizaos/app-task-coordinator": [
        "../../plugins/app-task-coordinator/src/index.ts"
      ],
      "@elizaos/app-task-coordinator/*": [
        "../../plugins/app-task-coordinator/src/*"
      ],
      "@elizaos/app-contacts": ["../../plugins/app-contacts/src/index.ts"],
      "@elizaos/app-contacts/*": ["../../plugins/app-contacts/src/*"],
      "@elizaos/agent": ["./src/index.ts"],
      "@elizaos/agent/*": ["./src/*"],
      "@elizaos/plugin-browser": [
        "../../plugins/plugin-browser/src/index.ts"
      ],
      "@elizaos/plugin-browser/*": [
        "../../plugins/plugin-browser/src/*"
      ],
      "@elizaos/shared": ["../shared/src/index.ts"],
      "@elizaos/shared/*": ["../shared/src/*"],
      "@elizaos/skills": ["../skills/src/index.ts"],
      "@elizaos/skills/*": ["../skills/src/*"],
      "react": ["../app-core/node_modules/@types/react/index.d.ts"],
      "react/jsx-runtime": [
        "../app-core/node_modules/@types/react/jsx-runtime.d.ts"
      ],
      "react/jsx-dev-runtime": [
        "../app-core/node_modules/@types/react/jsx-dev-runtime.d.ts"
      ],
      "react-dom": ["../app-core/node_modules/@types/react-dom/index.d.ts"],
      "@elizaos/*": ["../../node_modules/@elizaos/*"]
    }
  },
  "include": ["src"],
  "exclude": [
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.ts",
    "src/**/__tests__/**"
  ]
}
