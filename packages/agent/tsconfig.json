{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": false,
    "skipLibCheck": true,
    "types": [
      "node",
      "bun",
      "react",
      "react-dom"
    ],
    "typeRoots": [
      "./node_modules/@types",
      "../app-core/node_modules/@types",
      "../ui/node_modules/@types",
      "../../node_modules/@types"
    ],
    "declaration": false,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "paths": {
      "@elizaos/core": [
        "../core/src/index.node.ts"
      ],
      "@elizaos/native-activity-tracker": [
        "../native-plugins/activity-tracker/src/index.ts"
      ],
      "@elizaos/capacitor-appblocker": [
        "../native-plugins/appblocker/src/index.ts"
      ],
      "@elizaos/capacitor-mobile-signals": [
        "../native-plugins/mobile-signals/src/index.ts"
      ],
      "@elizaos/capacitor-wifi": [
        "../native-plugins/wifi/src/index.ts"
      ],
      "@elizaos/capacitor-contacts": [
        "../native-plugins/contacts/src/index.ts"
      ],
      "@elizaos/capacitor-phone": [
        "../native-plugins/phone/src/index.ts"
      ],
      "@elizaos/app-lifeops": [
        "../../plugins/app-lifeops/src/index.ts"
      ],
      "@elizaos/app-phone": [
        "../../plugins/app-phone/src/index.ts"
      ],
      "@elizaos/app-elizamaker": [
        "../../plugins/app-elizamaker/src/index.ts"
      ],
      "@elizaos/plugin-form": [
        "../../plugins/plugin-form/src/index.ts"
      ],
      "@elizaos/app-wifi": [
        "../../plugins/app-wifi/src/index.ts"
      ],
      "@elizaos/app-core": [
        "../app-core/src/index.ts"
      ],
      "@elizaos/app-steward": [
        "../../plugins/app-steward/src/index.ts"
      ],
      "@elizaos/app-shopify": [
        "../../plugins/app-shopify/src/index.ts"
      ],
      "@elizaos/app-vincent": [
        "../../plugins/app-vincent/src/index.ts"
      ],
      "@elizaos/ui": [
        "../ui/src/index.ts"
      ],
      "@elizaos/app-companion": [
        "../../plugins/app-companion/src/index.ts"
      ],
      "@elizaos/app-knowledge": [
        "../../plugins/app-knowledge/src/index.ts"
      ],
      "@elizaos/app-training": [
        "../../plugins/app-training/src/index.ts"
      ],
      "@elizaos/app-task-coordinator": [
        "../../plugins/app-task-coordinator/src/index.ts"
      ],
      "@elizaos/app-contacts": [
        "../../plugins/app-contacts/src/index.ts"
      ],
      "@elizaos/agent": [
        "./src/index.ts"
      ],
      "@elizaos/plugin-coding-tools": [
        "../../plugins/plugin-coding-tools/src/index.ts"
      ],
      "@elizaos/plugin-browser": [
        "../../plugins/plugin-browser/src/index.ts"
      ],
      "@elizaos/plugin-computeruse": [
        "../../plugins/plugin-computeruse/src/index.ts"
      ],
      "@elizaos/plugin-music": [
        "../../plugins/plugin-music/src/index.ts"
      ],
      "@elizaos/plugin-whatsapp": [
        "../../plugins/plugin-whatsapp/src/index.ts"
      ],
      "@elizaos/plugin-signal": [
        "../../plugins/plugin-signal/src/index.ts"
      ],
      "@elizaos/plugin-google": [
        "../../plugins/plugin-google/src/index.ts"
      ],
      "@elizaos/plugin-telegram": [
        "../../plugins/plugin-telegram/src/index.ts"
      ],
      "@elizaos/plugin-sql": [
        "../../plugins/plugin-sql/src/index.node.ts"
      ],
      "@elizaos/shared": [
        "../shared/src/index.ts"
      ],
      "@elizaos/skills": [
        "../skills/src/index.ts"
      ],
      "react": [
        "../app-core/node_modules/@types/react/index.d.ts"
      ],
      "react/jsx-runtime": [
        "../app-core/node_modules/@types/react/jsx-runtime.d.ts"
      ],
      "react/jsx-dev-runtime": [
        "../app-core/node_modules/@types/react/jsx-dev-runtime.d.ts"
      ],
      "react-dom": [
        "../app-core/node_modules/@types/react-dom/index.d.ts"
      ],
      "@elizaos/plugin-discord": ["../../plugins/plugin-discord/index.ts"],
      "@elizaos/plugin-discord/*": ["../../plugins/plugin-discord/*"],
      "@elizaos/plugin-elizacloud": [
        "../../plugins/plugin-elizacloud/src/index.node.ts"
      ],
      "@elizaos/plugin-elizacloud/*": [
        "../../plugins/plugin-elizacloud/src/*"
      ],
      "@elizaos/plugin-mcp": ["../../plugins/plugin-mcp/src/index.ts"],
      "@elizaos/plugin-mcp/*": ["../../plugins/plugin-mcp/src/*"],
      "@elizaos/plugin-local-inference": [
        "../../plugins/plugin-local-inference/src/index.ts"
      ],
      "@elizaos/plugin-local-inference/*": [
        "../../plugins/plugin-local-inference/src/*"
      ],
      "@elizaos/plugin-discord-local": [
        "../../plugins/plugin-discord-local/src/index.ts"
      ],
      "@elizaos/plugin-discord-local/*": [
        "../../plugins/plugin-discord-local/src/*"
      ],
      "@elizaos/*": ["../../node_modules/@elizaos/*"]
    }
  },
  "include": [
    "src"
  ],
  "exclude": [
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.ts",
    "src/**/__tests__/**"
  ]
}
