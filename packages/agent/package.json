    "pako": "^1.0.10",
    "pg": "^8.16.3",
    "pify": "^4.0.1",
    "readable-stream": "^4.0.0",
    "sha.js": "^2.4.12",
    "simple-get": "^4.0.1",
    "ws": "^8.19.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
