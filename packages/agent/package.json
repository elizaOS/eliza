{
  "name": "@elizaos/agent",
  "version": "2.0.0-beta.0",
  "description": "Standalone elizaOS-based agent and backend server package.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/elizaos/eliza",
  "repository": {
    "type": "git",
    "url": "https://github.com/elizaos/eliza.git",
    "directory": "packages/agent"
  },
  "keywords": [
    "eliza",
    "agent",
    "backend",
    "runtime",
    "elizaos"
  ],
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "bin": {
    "eliza-autonomous": "./dist/bin.js"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "start": "bun run src/bin.ts",
    "dev": "bun --hot src/bin.ts",
    "prepublishOnly": "bun run build:dist",
    "build": "bun run build:dist",
    "build:mobile": "bun run scripts/build-mobile-bundle.mjs",
    "build:docker-dist": "node ../../scripts/rm-path-recursive.mjs dist && tsc --noCheck -p tsconfig.build.json && node ../../scripts/prepare-package-dist.mjs packages/agent",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build:dist": "node ../../scripts/rm-path-recursive.mjs dist && tsc -p tsconfig.build.json && node ../../scripts/flatten-tsc-package-output.mjs packages/agent && node ../../scripts/prepare-package-dist.mjs packages/agent",
    "lint": "bunx @biomejs/biome check ./src/actions ./src/api ./src/auth ./src/awareness ./src/bin.ts ./src/cli ./src/config ./src/contracts ./src/diagnostics ./src/hooks ./src/index.ts ./src/middleware ./src/providers ./src/runtime ./src/security ./src/services ./src/shared ./src/testing ./src/triggers ./src/utils ./src/version-resolver.ts",
    "lint:check": "bun run lint",
    "lint:fix": "bunx @biomejs/biome check --write ./src/actions ./src/api ./src/auth ./src/awareness ./src/bin.ts ./src/cli ./src/config ./src/contracts ./src/diagnostics ./src/hooks ./src/index.ts ./src/middleware ./src/providers ./src/runtime ./src/security ./src/services ./src/shared ./src/testing ./src/triggers ./src/utils ./src/version-resolver.ts",
    "format": "bunx @biomejs/biome format src",
    "format:fix": "bunx @biomejs/biome format --write src",
    "pack:dry-run": "cd dist && npm pack --dry-run",
    "test": "vitest run --config vitest.config.ts"
  },
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json",
    "./actions": "./dist/actions/index.js",
    "./actions/workflow": "./dist/actions/workflow/index.js",
    "./actions/*": "./dist/actions/*.js",
    "./api": "./dist/api/index.js",
    "./api/*": "./dist/api/*.js",
    "./api/server": "./dist/api/server.js",
    "./api/server-auth": "./dist/api/server-auth.js",
    "./auth": "./dist/auth/index.js",
    "./auth/*": "./dist/auth/*.js",
    "./autonomy": "./dist/autonomy/index.js",
    "./autonomy/*": "./dist/autonomy/*.js",
    "./awareness": "./dist/awareness/index.js",
    "./awareness/*": "./dist/awareness/*.js",
    "./cli": "./dist/cli/index.js",
    "./cli/*": "./dist/cli/*.js",
    "./config": "./dist/config/index.js",
    "./config/*": "./dist/config/*.js",
    "./config/config": "./dist/config/config.js",
    "./contracts": "./dist/contracts/index.js",
    "./contracts/*": "./dist/contracts/*.js",
    "./diagnostics": "./dist/diagnostics/index.js",
    "./diagnostics/*": "./dist/diagnostics/*.js",
    "./hooks": "./dist/hooks/index.js",
    "./hooks/*": "./dist/hooks/*.js",
    "./middleware/x402": "./dist/middleware/x402/index.js",
    "./plugins/*": "./dist/plugins/*/index.js",
    "./providers": "./dist/providers/index.js",
    "./providers/*": "./dist/providers/*.js",
    "./runtime": "./dist/runtime/index.js",
    "./runtime/*": "./dist/runtime/*.js",
    "./runtime/eliza": "./dist/runtime/eliza.js",
    "./runtime/operations": "./dist/runtime/operations/index.js",
    "./runtime/operations/*": "./dist/runtime/operations/*.js",
    "./runtime/restart": "./dist/runtime/restart.js",
    "./security": "./dist/security/index.js",
    "./security/*": "./dist/security/*.js",
    "./services": "./dist/services/index.js",
    "./services/*": "./dist/services/*.js",
    "./shared": "./dist/shared/index.js",
    "./shared/*": "./dist/shared/*.js",
    "./test-support": "./dist/test-support/index.js",
    "./test-support/*": "./dist/test-support/*.js",
    "./testing": "./dist/testing/index.js",
    "./types/trajectory": "./dist/types/trajectory.js",
    "./triggers": "./dist/triggers/index.js",
    "./triggers/*": "./dist/triggers/*.js",
    "./utils": "./dist/utils/index.js",
    "./utils/*": "./dist/utils/*.js",
    "./version-resolver": "./dist/version-resolver.js",
    "./services/app-session-gate": "./dist/services/app-session-gate.js",
    "./services/signal-pairing": "./dist/services/signal-pairing.js",
    "./services/whatsapp-pairing": "./dist/services/whatsapp-pairing.js",
    "./services/plugin-manager-types": "./dist/services/plugin-manager-types.js",
    "./services/tts-stream-bridge": "./dist/services/tts-stream-bridge.js",
    "./services/registry-client-types": "./dist/services/registry-client-types.js",
    "./services/skill-catalog-client": "./dist/services/skill-catalog-client.js",
    "./config/paths": "./dist/config/paths.js",
    "./services/registry-client": "./dist/services/registry-client.js",
    "./services/update-checker": "./dist/services/update-checker.js",
    "./services/sandbox-engine": "./dist/services/sandbox-engine.js",
    "./services/self-updater": "./dist/services/self-updater.js",
    "./services/signing-policy": "./dist/services/signing-policy.js",
    "./providers/workspace": "./dist/providers/workspace.js",
    "./providers/workspace-provider": "./dist/providers/workspace-provider.js",
    "./api/wallet": "./dist/api/wallet.js",
    "./api/wallet-evm-balance": "./dist/api/wallet-evm-balance.js",
    "./api/wallet-rpc": "./dist/api/wallet-rpc.js",
    "./api/wallet-trading-profile": "./dist/api/wallet-trading-profile.js",
    "./api/database": "./dist/api/database.js",
    "./api/coordinator-wiring": "./dist/api/coordinator-wiring.js",
    "./actions/send-message": "./dist/actions/send-message.js",
    "./runtime/release-plugin-policy": "./dist/runtime/release-plugin-policy.js",
    "./types": "./dist/types/index.js",
    "./types/*": "./dist/types/*.js",
    "./test-utils/*": "./dist/test-utils/*.js"
  },
  "publishConfig": {
    "access": "public",
    "directory": "dist"
  },
  "dependencies": {
    "@clack/prompts": "^1.0.0",
    "@elizaos/app-task-coordinator": "workspace:*",
    "@elizaos/app-training": "workspace:*",
    "@elizaos/capacitor-contacts": "workspace:*",
    "@elizaos/capacitor-phone": "workspace:*",
    "@elizaos/capacitor-wifi": "workspace:*",
    "@elizaos/core": "workspace:*",
    "@elizaos/plugin-agent-skills": "workspace:*",
    "@elizaos/plugin-browser": "workspace:*",
    "@elizaos/plugin-elizacloud": "workspace:*",
    "@elizaos/plugin-local-embedding": "workspace:*",
    "@elizaos/plugin-ollama": "workspace:*",
    "@elizaos/plugin-pdf": "workspace:*",
    "@elizaos/plugin-sql": "workspace:*",
    "@elizaos/plugin-streaming": "workspace:*",
    "@elizaos/plugin-video": "workspace:*",
    "@elizaos/plugin-wechat": "workspace:*",
    "@elizaos/shared": "workspace:*",
    "@elizaos/skills": "workspace:*",
    "@elizaos/vault": "workspace:*",
    "@hapi/boom": "^10.0.1",
    "@noble/curves": "2.2.0",
    "@solana/web3.js": "1.98.4",
    "@whiskeysockets/baileys": "7.0.0-rc.9",
    "abitype": "^1.0.0",
    "coding-agent-adapters": "0.16.3",
    "dotenv": "^17.2.3",
    "drizzle-orm": "0.45.2",
    "ethers": "^6.16.0",
    "git-workspace-service": "0.4.5",
    "jsdom": "^29.0.0",
    "json5": "^2.2.3",
    "pg": "^8.16.3",
    "pino": "^10.3.1",
    "pty-manager": "1.11.0",
    "puppeteer-core": "^24.37.5",
    "qrcode": "^1.5.4",
    "telegram": "2.26.22",
    "viem": "^2.48.8",
    "ws": "^8.19.0",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "@elizaos/signal-native": "*"
  },
  "peerDependenciesMeta": {
    "@elizaos/signal-native": {
      "optional": true
    }
  },
  "devDependencies": {
    "@ai-sdk/openai": "^3.0.47",
    "@types/bun": "^1.3.12",
    "@types/jsdom": "^28.0.0",
    "@types/node": "^25.2.0",
    "@types/pg": "^8.15.2",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "ai": "^6.0.134",
    "bun-types": "^1.3.12",
    "canvas": "^3.0.1",
    "sharp": "^0.34.5",
    "typescript": "^6.0.3",
    "vite": "^8.0.8",
    "vitest": "^4.0.18"
  },
  "types": "./dist/index.d.ts"
}
