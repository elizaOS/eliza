{
  "name": "@elizaos/agent",
  "version": "2.0.0-beta.0",
  "description": "Standalone elizaOS-based agent and backend server package.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/elizaos/eliza",
  "repository": {
    "type": "git",
    "url": "https://github.com/elizaos/eliza.git",
    "directory": "packages/agent"
  },
  "keywords": [
    "eliza",
    "agent",
    "backend",
    "runtime",
    "elizaos"
  ],
  "main": "src/index.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "bin": {
    "eliza-autonomous": "./src/bin.ts"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "start": "bun run src/bin.ts",
    "dev": "bun --hot src/bin.ts",
    "prepublishOnly": "bun run build:dist",
    "build": "bun run build:dist",
    "build:mobile": "bun run scripts/build-mobile-bundle.mjs",
    "build:docker-dist": "rm -rf dist && tsc --noCheck -p tsconfig.build.json && node ../../scripts/prepare-package-dist.mjs packages/agent --compiled-prefix=packages/agent/src",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build:dist": "rm -rf dist && tsc --noCheck -p tsconfig.build.json && node ../../scripts/prepare-package-dist.mjs packages/agent --compiled-prefix=packages/agent/src",
    "lint": "bunx @biomejs/biome check ./src/actions ./src/api ./src/auth ./src/awareness ./src/bin.ts ./src/cli ./src/config ./src/contracts ./src/diagnostics ./src/hooks ./src/index.ts ./src/providers ./src/runtime ./src/security ./src/services ./src/shared ./src/testing ./src/triggers ./src/utils ./src/version-resolver.ts",
    "lint:check": "bun run lint",
    "lint:fix": "bunx @biomejs/biome check --write ./src/actions ./src/api ./src/auth ./src/awareness ./src/bin.ts ./src/cli ./src/config ./src/contracts ./src/diagnostics ./src/hooks ./src/index.ts ./src/providers ./src/runtime ./src/security ./src/services ./src/shared ./src/testing ./src/triggers ./src/utils ./src/version-resolver.ts",
    "format": "bunx @biomejs/biome format src",
    "format:fix": "bunx @biomejs/biome format --write src",
    "pack:dry-run": "cd dist && npm pack --dry-run",
    "test": "vitest run --config vitest.config.ts"
  },
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json",
    "./config/plugin-auto-enable": "./src/config/plugin-auto-enable.ts"
  },
  "publishConfig": {
    "access": "public",
    "directory": "dist"
  },
  "dependencies": {
    "@clack/prompts": "^1.0.0",
    "@elizaos/capacitor-contacts": "workspace:*",
    "@elizaos/capacitor-phone": "workspace:*",
    "@elizaos/capacitor-wifi": "workspace:*",
    "@elizaos/app-task-coordinator": "workspace:*",
    "@elizaos/core": "workspace:*",
    "@elizaos/plugin-agent-skills": "workspace:*",
    "@elizaos/plugin-aosp-local-inference": "workspace:*",
    "@elizaos/plugin-browser": "workspace:*",
    "@elizaos/plugin-capacitor-bridge": "workspace:*",
    "@elizaos/plugin-coding-tools": "workspace:*",
    "@elizaos/plugin-commands": "workspace:*",
    "@elizaos/plugin-computeruse": "workspace:*",
    "@elizaos/plugin-discord": "workspace:*",
    "@elizaos/plugin-discord-local": "workspace:*",
    "@elizaos/plugin-elizacloud": "workspace:*",
    "@elizaos/plugin-imessage": "workspace:*",
    "@elizaos/plugin-local-embedding": "workspace:*",
    "@elizaos/plugin-local-inference": "workspace:*",
    "@elizaos/plugin-mcp": "workspace:*",
    "@elizaos/plugin-ollama": "workspace:*",
    "@elizaos/plugin-pdf": "workspace:*",
    "@elizaos/plugin-signal": "workspace:*",
    "@elizaos/plugin-sql": "workspace:*",
    "@elizaos/plugin-streaming": "workspace:*",
    "@elizaos/plugin-video": "workspace:*",
    "@elizaos/plugin-wechat": "workspace:*",
    "@elizaos/plugin-x402": "workspace:*",
    "@elizaos/plugin-whatsapp": "workspace:*",
    "@elizaos/plugin-workflow": "workspace:*",
    "@elizaos/shared": "workspace:*",
    "@elizaos/skills": "workspace:*",
    "@elizaos/vault": "workspace:*",
    "@hapi/boom": "^10.0.1",
    "@noble/curves": "2.2.0",
    "@solana/web3.js": "1.98.4",
    "@whiskeysockets/baileys": "7.0.0-rc.9",
    "abitype": "^1.0.0",
    "coding-agent-adapters": "0.16.3",
    "dotenv": "^17.2.3",
    "drizzle-orm": "0.45.2",
    "esbuild": "^0.28.0",
    "ethers": "^6.16.0",
    "git-workspace-service": "0.4.5",
    "jsdom": "^29.0.0",
    "json5": "^2.2.3",
    "pg": "^8.16.3",
    "pino": "^10.3.1",
    "pty-manager": "1.11.0",
    "puppeteer-core": "^24.37.5",
    "qrcode": "^1.5.4",
    "telegram": "2.26.22",
    "viem": "^2.48.8",
    "ws": "^8.19.0",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "@elizaos/signal-native": "*"
  },
  "peerDependenciesMeta": {
    "@elizaos/signal-native": {
      "optional": true
    }
  },
  "devDependencies": {
    "@ai-sdk/openai": "^3.0.47",
    "@types/bun": "^1.3.12",
    "@types/jsdom": "^28.0.0",
    "@types/node": "^25.2.0",
    "@types/pg": "^8.15.2",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "ai": "^6.0.134",
    "bun-types": "^1.3.12",
    "canvas": "^3.0.1",
    "sharp": "^0.34.5",
    "typescript": "^6.0.3",
    "vite": "^8.0.8",
    "vitest": "^4.0.18"
  }
}
