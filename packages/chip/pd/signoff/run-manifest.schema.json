{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eliza.local/schemas/pd-signoff-run-manifest.schema.json",
  "title": "PD signoff run manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "design",
    "flow",
    "pdk",
    "std_cell_library",
    "openlane_image",
    "openlane_image_digest",
    "started_at",
    "completed_at",
    "status",
    "corners",
    "inputs",
    "outputs",
    "checks"
  ],
  "properties": {
    "run_id": { "type": "string", "minLength": 1 },
    "design": { "const": "e1_chip_top" },
    "flow": { "type": "string", "minLength": 1 },
    "pdk": { "type": "string", "minLength": 1 },
    "std_cell_library": { "type": "string", "minLength": 1 },
    "openlane_image": { "type": "string", "minLength": 1 },
    "openlane_image_digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "started_at": { "type": "string", "format": "date-time" },
    "completed_at": { "type": "string", "format": "date-time" },
    "status": { "enum": ["complete"] },
    "corners": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "liberty", "rc"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "liberty": { "type": "string", "minLength": 1 },
          "rc": { "type": "string", "minLength": 1 }
        }
      }
    },
    "inputs": {
      "type": "object",
      "additionalProperties": {
        "oneOf": [
          { "type": "string", "minLength": 1 },
          {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        ]
      }
    },
    "outputs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gds",
        "def",
        "gate_netlist",
        "corner_manifest",
        "sdc",
        "spef",
        "sdf",
        "tool_versions"
      ],
      "properties": {
        "gds": { "type": "string", "pattern": "\\.gds$" },
        "def": { "type": "string", "pattern": "\\.def$" },
        "gate_netlist": { "type": "string", "pattern": "\\.v$" },
        "corner_manifest": { "type": "string", "pattern": "\\.ya?ml$" },
        "sdc": { "type": "string", "pattern": "\\.sdc$" },
        "spef": { "type": "string", "pattern": "\\.spef$" },
        "sdf": { "type": "string", "pattern": "\\.sdf$" },
        "tool_versions": { "type": "string", "pattern": "\\.txt$" }
      }
    },
    "checks": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "drc",
        "lvs",
        "antenna",
        "sta",
        "utilization",
        "congestion",
        "density_fill"
      ],
      "properties": {
        "drc": { "$ref": "#/$defs/check" },
        "lvs": { "$ref": "#/$defs/check" },
        "antenna": { "$ref": "#/$defs/check" },
        "sta": { "$ref": "#/$defs/check" },
        "utilization": { "$ref": "#/$defs/check" },
        "congestion": { "$ref": "#/$defs/check" },
        "density_fill": { "$ref": "#/$defs/check" }
      }
    }
  },
  "$defs": {
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "report"],
      "properties": {
        "status": { "enum": ["clean", "waived", "blocked"] },
        "report": { "type": "string", "minLength": 1 },
        "waiver": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 }
      }
    }
  }
}
