# Minimal riscv64 kernel config fragment for the E1 CVA6 Verilator Linux boot.
#
# Merged on top of `make ARCH=riscv tinyconfig` by build_linux_kernel.py.  The
# goal is the shortest path from start_kernel() to run_init_process(/init): only
# the subsystems a tiny static PID-1 needs are enabled, so the cycle-bound
# Verilator run reaches userland (ELIZA-USERLAND-OK) inside the sim budget.
#
# What stays (load-bearing for this boot top):
#   - 64-bit RISC-V, sv39 MMU, SBI (OpenSBI hands off in S-mode)
#   - ns16550a 8250 console + 8250 earlycon (the only console; matches the DTS
#     serial@10001000 and the `earlycon=uart8250,mmio,0x10001000` bootarg)
#   - builtin initramfs (CONFIG_INITRAMFS_SOURCE) so there is no separate cpio
#     load step and no block device
#   - ELF loader + devtmpfs + the syscalls the freestanding /init issues
#   - printk + earlycon so every boot marker is observable on the UART
#
# What is cut vs the riscv defconfig (the bloat that made the boot cycle-bound):
#   SMP/NR_CPUS>1, NET, PCI, USB, netfilter, 9p, EFI stub, RISC-V vector (V),
#   most ISA extension probing, block layer, every filesystem except the
#   initramfs ramfs, all real device drivers, module support, sysfs cruft.

# --- architecture: 64-bit RISC-V with MMU ---
CONFIG_ARCH_RV64I=y
CONFIG_64BIT=y
CONFIG_MMU=y
CONFIG_RISCV_SBI=y
CONFIG_NONPORTABLE=y

# Single hart: this boot top exposes one CVA6 core.  UP cuts all the SMP
# bring-up (secondary CPU IPI/HSM dance) from the pre-userland path.
# CONFIG_SMP is not set

# Base ISA only (rv64imac per the DTS riscv,isa=rv64gc — FPU/compressed kept,
# vector and the optional Zb*/Svnapot probing dropped to shorten boot).
CONFIG_FPU=y
CONFIG_RISCV_ISA_C=y
# CONFIG_RISCV_ISA_V is not set
CONFIG_RISCV_ALTERNATIVE=y
CONFIG_RISCV_ISA_FALLBACK=y

# --- unaligned-access policy: SKIP the boot-time probe. ---
# CONFIG_RISCV_PROBE_UNALIGNED_ACCESS runs check_unaligned_access_all_cpus(), a
# timed busy-loop benchmark of unaligned loads/stores.  On the E1 CVA6, which
# traps unaligned scalar accesses and emulates them via the M-mode handler, each
# probe access is a trap round-trip, so this single core_initcall burned tens of
# millions of output-silent sim cycles — the dominant pre-userland cost (pinned
# via initcall_debug: "calling check_unaligned_access_all_cpus" did not return
# for >1M sim cycles).  EMULATED assumes emulated/slow unaligned access without
# probing — exactly the E1 behaviour — and removes the benchmark entirely.
# CONFIG_RISCV_PROBE_UNALIGNED_ACCESS is not set
CONFIG_RISCV_EMULATED_UNALIGNED_ACCESS=y

# --- size optimisation + smaller pre-userland surface ---
CONFIG_CC_OPTIMIZE_FOR_SIZE=y
CONFIG_EXPERT=y
# CONFIG_KALLSYMS is not set
# CONFIG_SLUB_TINY: smallest SLUB, fewer per-cache initcalls + no sysfs cache nodes.
CONFIG_SLUB_TINY=y
# DEBUG_KERNEL drags in extra boot-time sanity passes + the initcall_debug
# plumbing; off shortens do_initcalls() and the pre-userland sanity work.
# CONFIG_DEBUG_KERNEL is not set

# --- console: ns16550a 8250 + 8250 earlycon (the sole console) ---
CONFIG_TTY=y
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_SERIAL_8250_NR_UARTS=1
CONFIG_SERIAL_8250_RUNTIME_UARTS=1
CONFIG_SERIAL_OF_PLATFORM=y
CONFIG_SERIAL_EARLYCON=y
CONFIG_SERIAL_CORE=y
CONFIG_SERIAL_CORE_CONSOLE=y
CONFIG_OF=y
CONFIG_OF_EARLY_FLATTREE=y
CONFIG_PRINTK=y

# --- init path: builtin initramfs, ELF, devtmpfs ---
CONFIG_BLK_DEV_INITRD=y
CONFIG_INITRAMFS_SOURCE="@INITRAMFS_CPIO@"
# The builtin initramfs cpio is stored UNCOMPRESSED, so no ramdisk decompressor
# is needed.  Dropping every CONFIG_RD_* / CONFIG_DECOMPRESS_* removes their
# init/registration and shrinks the unpack path to a straight cpio copy.
CONFIG_INITRAMFS_COMPRESSION_NONE=y
# CONFIG_RD_GZIP is not set
# CONFIG_RD_BZIP2 is not set
# CONFIG_RD_LZMA is not set
# CONFIG_RD_XZ is not set
# CONFIG_RD_LZO is not set
# CONFIG_RD_LZ4 is not set
# CONFIG_RD_ZSTD is not set
CONFIG_BINFMT_ELF=y
# /init is a raw static ELF; no #! script interpreter is exec'd.
# CONFIG_BINFMT_SCRIPT is not set
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_PROC_FS=y
# SYSFS off: /init reads only /proc/cpuinfo + uname(2); nothing mounts sysfs,
# and dropping it removes the per-subsystem sysfs registration initcalls.
# CONFIG_SYSFS is not set
CONFIG_MULTIUSER=y

# --- bootargs baked into the kernel (DTS /chosen also supplies them; FORCE so
# the trimmed kernel always uses our console + rdinit regardless of bootloader).
CONFIG_CMDLINE="console=ttyS0,115200 earlycon=uart8250,mmio,0x10001000 keep_bootcon panic=-1 rdinit=/init lpj=10000 initcall_debug ignore_loglevel"
CONFIG_CMDLINE_FORCE=y

# --- shrink the timing/printk path that costs cycles in sim ---
# initcall_debug (in CMDLINE above) prints each initcall's name + duration to the
# console, so the otherwise output-silent do_initcalls() stretch becomes fully
# observable in the transcript — it pinpoints any cycle-dominant initcall and is
# itself cheap (a printk per initcall).  PRINTK_TIME is enabled so each line
# carries a kernel timestamp, making the per-initcall cost directly measurable.
CONFIG_PRINTK_TIME=y
CONFIG_HZ_100=y
# CONFIG_RCU_EXPERT is not set

# --- explicitly off: the defconfig bloat that made the boot cycle-bound ---
# CONFIG_NET is not set
# CONFIG_PCI is not set
# CONFIG_USB_SUPPORT is not set
# CONFIG_MODULES is not set
# CONFIG_BLOCK is not set
# CONFIG_EFI is not set
# CONFIG_VIRTIO_MENU is not set
# CONFIG_SOUND is not set
# CONFIG_DRM is not set
# CONFIG_FB is not set
# CONFIG_HVC_RISCV_SBI is not set
# CONFIG_SERIAL_SIFIVE is not set

# --- VT layer off: the only console is the 8250 ns16550a.  CONFIG_VT pulls in
# the dummy console ("Console: colour dummy device 80x25"), the keyboard/consolemap
# initcalls, and the VT console binding — none of which this headless boot uses.
# CONFIG_VT is not set
# CONFIG_VT_CONSOLE is not set
# CONFIG_DUMMY_CONSOLE is not set

# --- no pseudo-terminals: /init does not fork a shell or open a pty. ---
# CONFIG_UNIX98_PTYS is not set
# CONFIG_LEGACY_PTYS is not set

# --- crypto: the static /init needs no crypto; disable the manager self-tests
# (a large per-algorithm initcall cost) and the dm/keyring crypto users. ---
# CONFIG_CRYPTO is not set
CONFIG_CRYPTO_MANAGER_DISABLE_TESTS=y

# --- no security/keys/audit: nothing in the pre-userland path enforces them. ---
# CONFIG_SECURITY is not set
# CONFIG_KEYS is not set
# CONFIG_AUDIT is not set

# --- no power-management / cpufreq / thermal / suspend on the boot path. ---
# CONFIG_PM is not set
# CONFIG_CPU_FREQ is not set
# CONFIG_CPU_IDLE is not set
# CONFIG_SUSPEND is not set

# --- no tracing/ftrace/profiling/bpf: pure boot, no observability stack. ---
# CONFIG_FTRACE is not set
# CONFIG_BPF_SYSCALL is not set
# CONFIG_PROFILING is not set

# --- no extra device-driver subsystems on the boot path. ---
# CONFIG_RTC_CLASS is not set
# CONFIG_I2C is not set
# CONFIG_SPI is not set
# CONFIG_GPIOLIB is not set
# CONFIG_MTD is not set
# CONFIG_MMC is not set
# CONFIG_WATCHDOG is not set
# CONFIG_HWMON is not set
# CONFIG_INPUT is not set
# CONFIG_HW_RANDOM is not set
# CONFIG_POWER_RESET is not set
# CONFIG_THERMAL is not set
