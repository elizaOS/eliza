{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "software-bsp-evidence.schema.json",
  "title": "Eliza software BSP evidence manifest",
  "type": "object",
  "required": ["schema_version", "claim_boundary", "targets"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": 1 },
    "claim_boundary": {
      "type": "string",
      "enum": ["external_transcripts_only"]
    },
    "targets": {
      "type": "object",
      "required": ["buildroot", "linux", "opensbi", "u-boot", "aosp"],
      "additionalProperties": false,
      "properties": {
        "buildroot": { "$ref": "#/$defs/target" },
        "linux": { "$ref": "#/$defs/target" },
        "opensbi": { "$ref": "#/$defs/target" },
        "u-boot": { "$ref": "#/$defs/target" },
        "aosp": { "$ref": "#/$defs/target" }
      }
    }
  },
  "$defs": {
    "target": {
      "type": "object",
      "required": ["evidence"],
      "additionalProperties": false,
      "properties": {
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/evidence_item" }
        }
      }
    },
    "evidence_item": {
      "type": "object",
      "required": [
        "artifact",
        "path",
        "capture_command",
        "validation_command",
        "min_bytes",
        "required_strings"
      ],
      "additionalProperties": false,
      "properties": {
        "artifact": { "type": "string", "minLength": 1 },
        "claim_boundary": { "type": "string", "minLength": 1 },
        "path": {
          "type": "string",
          "pattern": "^docs/evidence/(buildroot|linux|android)/[^/]+\\.(log|txt)$"
        },
        "capture_command": { "type": "string", "minLength": 1 },
        "validation_command": {
          "type": "string",
          "pattern": "scripts/check_software_bsp.py .+ --require-evidence"
        },
        "min_bytes": { "type": "integer", "minimum": 80 },
        "required_strings": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "at_least_one": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        },
        "external_artifacts": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "forbidden_strings": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
