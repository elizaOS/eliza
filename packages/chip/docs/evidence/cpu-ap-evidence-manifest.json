{
  "schema_version": 1,
  "claim_boundary": "generated_chipyard_artifacts_and_external_transcripts_only",
  "completion_claim": "blocked_until_all_required_artifacts_and_evidence_pass",
  "target_policy": {
    "initial_linux_bringup_claim": "single_hart_rocket_rv64gc_linux_smoke_only",
    "phone_2028_ap_claim": "blocked_until_phone_class_artifacts_and_evidence_pass",
    "phone_2028_claim_requires": [
      "multi_hart_application_cpu_topology_or_documented_equivalent",
      "riscv_application_profile_and_extension_matrix",
      "cache_hierarchy_and_coherency_evidence",
      "mmu_page_table_and_tlb_evidence",
      "sustained_boot_and_benchmark_evidence",
      "power_thermal_voltage_frequency_evidence",
      "process_14a_corner_benchmark_derate_evidence",
      "android_cts_vts_and_userspace_evidence"
    ],
    "forbidden_without_evidence": [
      "phone-class AP",
      "2028 phone competitive",
      "Android compatible",
      "production silicon",
      "Linux-capable e1 chip hardware"
    ]
  },
  "selected_manifest": "generators/chipyard/eliza-rocket-manifest.json",
  "generated_manifest": "build/chipyard/eliza_rocket/ElizaRocketConfig.manifest.json",
  "capture_helper": "scripts/capture_cpu_ap_evidence.py",
  "linux_capable_gate_matrix": [
    {
      "gate": "rv64gc_isa",
      "status": "blocked",
      "evidence": "build/evidence/cpu_ap/eliza_e1_isa_cache_mmu.log",
      "pass_requires": ["ISA profile", "RV64GC", "misa", "Zicsr", "Zifencei"],
      "fail_if": [
        "missing generated AP transcript",
        "qemu-virt software reference only",
        "placeholder transcript"
      ]
    },
    {
      "gate": "s_mode_privilege",
      "status": "blocked",
      "evidence": "build/evidence/cpu_ap/eliza_e1_opensbi_boot.log",
      "pass_requires": ["mstatus", "medeleg", "mideleg", "satp", "sret"],
      "fail_if": [
        "missing CSR/trap transcript",
        "M-mode only transcript",
        "placeholder transcript"
      ]
    },
    {
      "gate": "mmu_sv39_or_stronger",
      "status": "blocked",
      "evidence": "build/evidence/cpu_ap/eliza_e1_isa_cache_mmu.log",
      "pass_requires": [
        "Sv39",
        "satp",
        "TLB",
        "page table",
        "Linux CONFIG_MMU"
      ],
      "fail_if": [
        "missing MMU transcript",
        "bare-metal only transcript",
        "placeholder transcript"
      ]
    },
    {
      "gate": "clint_timer_software_irq",
      "status": "blocked",
      "evidence": "build/evidence/cpu_ap/eliza_e1_trap_timer_irq.log",
      "pass_requires": [
        "mtime",
        "mtimecmp",
        "msip",
        "timer interrupt",
        "software interrupt"
      ],
      "fail_if": [
        "missing CLINT/ACLINT transcript",
        "polling-only timer",
        "placeholder transcript"
      ]
    },
    {
      "gate": "plic_external_irq",
      "status": "blocked",
      "evidence": "build/evidence/cpu_ap/eliza_e1_trap_timer_irq.log",
      "pass_requires": [
        "PLIC",
        "external interrupt claim/complete",
        "interrupt-controller node"
      ],
      "fail_if": [
        "missing external IRQ transcript",
        "no claim/complete evidence",
        "placeholder transcript"
      ]
    },
    {
      "gate": "uart_console",
      "status": "blocked",
      "evidence": "build/evidence/cpu_ap/eliza_e1_linux_boot.log",
      "pass_requires": ["UART console", "Linux early console", "UART node"],
      "fail_if": [
        "missing serial transcript",
        "disabled UART node",
        "placeholder transcript"
      ]
    },
    {
      "gate": "dtb_linux_boot_contract",
      "status": "blocked",
      "evidence": "build/chipyard/eliza_rocket/eliza-e1.dts",
      "pass_requires": [
        "CPU node",
        "memory node",
        "timer node",
        "interrupt-controller node",
        "UART node",
        "chosen stdout"
      ],
      "fail_if": [
        "missing generated DTS",
        "DTS does not compile",
        "DTS missing boot nodes"
      ]
    },
    {
      "gate": "opensbi_handoff",
      "status": "blocked",
      "evidence": "build/evidence/cpu_ap/eliza_e1_opensbi_boot.log",
      "pass_requires": [
        "OpenSBI next-stage handoff",
        "DRAM base",
        "timer source",
        "interrupt controller"
      ],
      "fail_if": [
        "missing OpenSBI transcript",
        "no next-stage handoff",
        "placeholder transcript"
      ]
    },
    {
      "gate": "linux_initramfs_smoke",
      "status": "blocked",
      "evidence": "build/evidence/cpu_ap/eliza_e1_linux_boot.log",
      "pass_requires": [
        "Linux early console",
        "initramfs start",
        "e1 MMIO smoke result"
      ],
      "fail_if": [
        "missing Linux transcript",
        "kernel panic before initramfs",
        "placeholder transcript"
      ]
    }
  ],
  "qemu_reference_evidence": {
    "status": "software_reference_only_not_linux_capable_cpu_evidence",
    "attempt_log": "build/reports/qemu_os_boot_attempt.log",
    "capture_command": "scripts/run_qemu.sh --check-os",
    "allowed_results": ["BLOCKED", "FAIL", "PASS"],
    "claim_limit": "QEMU virt may exercise software payloads but cannot satisfy generated Chipyard/Rocket AP evidence gates."
  },
  "generated_artifacts": {
    "generated_src": {
      "path": "build/chipyard/eliza_rocket/generated-src",
