<?xml version="1.0" encoding="UTF-8"?>
<!--
  Pinned AOSP RISC-V branch manifest for the e1 chip toolchain.

  STATUS: BLOCKED.

  As of 2026-05-19, a probe of
    https://android.googlesource.com/platform/manifest
  reveals NO branch matching `refs/heads/.*riscv.*`. The AOSP common kernel
  HAS an active RISC-V branch at
    https://android.googlesource.com/kernel/common
    refs/heads/android-mainline-riscv64
    HEAD 365b87b792fed44f4306abcea6f0c9c245a79b04 (observed 2026-05-19)
  but that is the kernel only; userland (bionic, art, external/llvm-project,
  build/soong, build/blueprint) is not yet shipped as a Tier 1 RISC-V
  manifest branch with passing CTS.

  The most recent platform release tag observed is android-16.0.0_r4 at
    15128c9e27cfa599c48d294babd39286ee8f1426
  which does NOT carry Tier-1 RISC-V CTS evidence.

  This manifest stays fail-closed: every `revision` and `<sha1>` is set to
  `TODO_PIN_AOSP_RISCV_BRANCH_SHA` and rejected by
  scripts/check_rva23_compliance.py with `BLOCKED aosp.branch_pin`.

  Refresh procedure once a stable RISC-V platform branch exists:

    1. Identify the branch (e.g. android-16.0.0_r*-riscv64).
    2. Run `repo init -u https://android.googlesource.com/platform/manifest \
         -b <branch>` and capture every project's SHA into <project sha1=...>.
    3. Commit the populated manifest plus the pinning evidence in
       docs/evidence/compiler/aosp-branch-pin.yaml.

  Until that pin lands, no AOSP RISC-V build evidence may be cited as
  release-grade.
-->
<manifest>
  <remote name="aosp" fetch="https://android.googlesource.com/" />
  <default remote="aosp"
           revision="TODO_PIN_AOSP_RISCV_BRANCH_SHA"
           sync-j="8" />

  <!-- The full project list is intentionally empty: any non-placeholder
       entry implies a tested branch SHA that does not yet exist. -->
</manifest>
