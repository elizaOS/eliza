<?xml version="1.0" encoding="utf-8"?>
<!-- VINTF manifest for the Eliza e1 AI SoC fail-closed bring-up HALs. -->
<manifest version="1.0" type="device">
    <hal format="hidl">
        <name>vendor.eliza.e1_npu</name>
        <transport>hwbinder</transport>
        <version>1.0</version>
        <interface>
            <name>IE1Npu</name>
            <instance>default</instance>
        </interface>
    </hal>
    <hal format="hidl">
        <name>android.hardware.graphics.composer</name>
        <transport>hwbinder</transport>
        <version>2.4</version>
        <interface>
            <name>IComposer</name>
            <instance>default</instance>
        </interface>
    </hal>
</manifest>
