<?xml version="1.0" encoding="utf-8"?>
<!--
  VINTF manifest for the Eliza e1 AI SoC.

  The hardware register layout is defined in
  sw/platform/e1_platform_contract.json. The active services below are
  fail-closed bring-up services: they must start only when their backing
  modules build and the runtime probe can report unsupported hardware
  explicitly instead of pretending success.

  HALs deliberately absent (no implementation, no backing Linux node):
    camera, audio, radio, GNSS, NFC, bluetooth, wifi, sensors, vibrator,
    fingerprint, thermal, power, health, USB, keymaster/gatekeeper/weaver,
    drm.
-->
<manifest version="1.0" type="device">
    <hal format="hidl">
        <name>vendor.eliza.e1_npu</name>
        <transport>hwbinder</transport>
        <version>1.0</version>
        <interface>
            <name>IE1Npu</name>
            <instance>default</instance>
        </interface>
    </hal>
    <hal format="hidl">
        <name>android.hardware.graphics.composer</name>
        <transport>hwbinder</transport>
        <version>2.4</version>
        <interface>
            <name>IComposer</name>
            <instance>default</instance>
        </interface>
    </hal>
</manifest>
