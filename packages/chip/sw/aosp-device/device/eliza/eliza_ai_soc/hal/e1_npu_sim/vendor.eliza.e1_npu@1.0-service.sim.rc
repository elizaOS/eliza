service vendor.e1_npu_sim /vendor/bin/hw/vendor.eliza.e1_npu@1.0-service.sim
    interface vendor.eliza.e1_npu@1.0::IE1Npu default
    class hal
    user system
    group system
    oneshot

on early-boot
    setprop vendor.e1_npu.ready 1

on property:vendor.e1_npu.ready=1
    start vendor.e1_npu_sim

on property:vendor.e1_npu.ready=0
    stop vendor.e1_npu_sim
