<?xml version="1.0" encoding="UTF-8"?>
<!--
  AOSP repo local-manifest fragment for the eliza_ai_soc device overlay.

  Copy this file into an AOSP source tree at .repo/local_manifests/eliza.xml
  before running `repo sync`. After the sync completes, the `linkfile` entries
  project the in-repo overlay (under
  packages/chip/sw/aosp-device/device/eliza/eliza_ai_soc/) into the AOSP tree
  at device/eliza/eliza_ai_soc/, where lunch/m can pick it up.

  This file does NOT introduce a network remote. The host-side
  build-aosp-riscv64.sh wrapper either:
    1. drops symlinks directly under device/eliza/eliza_ai_soc/ pointing at the
       repo-local overlay (default; no network round-trip), or
    2. writes this local manifest into .repo/local_manifests/ after rewriting
       the placeholder remote to point at the Milady checkout (file:// URL).

  The `remote` URL is intentionally a placeholder; build-aosp-riscv64.sh
  rewrites it to the actual Milady repo path at sync time when run in
  local-manifest mode (device-overlay-mode set to "local-manifest").
-->
<manifest>
  <remote name="eliza-local"
          fetch="REPLACE_WITH_ELIZA_REPO_PARENT_FILE_URL" />

  <project name="eliza"
           path="vendor/eliza/src"
           remote="eliza-local"
           revision="develop"
           sync-c="true"
           clone-depth="1">
    <linkfile src="packages/chip/sw/aosp-device/device/eliza/eliza_ai_soc/AndroidProducts.mk"
              dest="device/eliza/eliza_ai_soc/AndroidProducts.mk" />
    <linkfile src="packages/chip/sw/aosp-device/device/eliza/eliza_ai_soc/eliza_ai_soc.mk"
              dest="device/eliza/eliza_ai_soc/eliza_ai_soc.mk" />
    <linkfile src="packages/chip/sw/aosp-device/device/eliza/eliza_ai_soc/BoardConfig.mk"
              dest="device/eliza/eliza_ai_soc/BoardConfig.mk" />
    <linkfile src="packages/chip/sw/aosp-device/device/eliza/eliza_ai_soc/device.mk"
              dest="device/eliza/eliza_ai_soc/device.mk" />
    <linkfile src="packages/chip/sw/aosp-device/device/eliza/eliza_ai_soc/init.eliza.rc"
              dest="device/eliza/eliza_ai_soc/init.eliza.rc" />
    <linkfile src="packages/chip/sw/aosp-device/device/eliza/eliza_ai_soc/fstab.eliza"
              dest="device/eliza/eliza_ai_soc/fstab.eliza" />
    <linkfile src="packages/chip/sw/aosp-device/device/eliza/eliza_ai_soc/manifest.xml"
              dest="device/eliza/eliza_ai_soc/manifest.xml" />
    <linkfile src="packages/chip/sw/aosp-device/device/eliza/eliza_ai_soc/eliza_e1.xml"
              dest="device/eliza/eliza_ai_soc/eliza_e1.xml" />
    <linkfile src="packages/chip/sw/aosp-device/device/eliza/eliza_ai_soc/kernel/eliza_ai_soc.fragment"
              dest="device/eliza/eliza_ai_soc/kernel/eliza_ai_soc.fragment" />
    <linkfile src="packages/chip/sw/aosp-device/device/eliza/eliza_ai_soc/dts/eliza-e1-android.dts"
              dest="device/eliza/eliza_ai_soc/dts/eliza-e1-android.dts" />
    <linkfile src="packages/chip/sw/aosp-device/device/eliza/eliza_ai_soc/sepolicy/file_contexts"
              dest="device/eliza/eliza_ai_soc/sepolicy/file_contexts" />
    <linkfile src="packages/chip/sw/aosp-device/device/eliza/eliza_ai_soc/sepolicy/e1_npu.te"
              dest="device/eliza/eliza_ai_soc/sepolicy/e1_npu.te" />
    <linkfile src="packages/chip/sw/aosp-device/device/eliza/eliza_ai_soc/hal/e1_npu/Android.bp"
              dest="device/eliza/eliza_ai_soc/hal/e1_npu/Android.bp" />
    <linkfile src="packages/chip/sw/aosp-device/device/eliza/eliza_ai_soc/hal/hwcomposer/Android.bp"
              dest="device/eliza/eliza_ai_soc/hal/hwcomposer/Android.bp" />
  </project>
</manifest>
