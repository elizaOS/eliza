menuconfig ELIZA_E1_BSP
	tristate "Eliza e1 BSP drivers"
	depends on OF
	help
	  Enables importable Linux drivers for the Eliza e1 platform
	  contract described by sw/platform/e1_platform_contract.json.

if ELIZA_E1_BSP

config ELIZA_E1_NPU
	tristate "Eliza e1 NPU contract driver"
	depends on MISC_DEVICES
	help
	  Exposes the eliza,e1-npu MMIO node through /dev/e1-npu for
	  smoke tests. The register base is E1_NPU_BASE in the platform
	  contract.

config ELIZA_E1_DMA
	tristate "Eliza e1 DMA contract driver"
	help
	  Binds the eliza,e1-dma MMIO node and exports a read-only sysfs
	  contract file for fast BSP validation.

config ELIZA_E1_CLINT_TIMER
	tristate "Eliza e1 CLINT timer driver"
	depends on GENERIC_CLOCKEVENTS
	help
	  Clocksource and clock_event_device backed by the e1 chip CLINT
	  mtime/mtimecmp registers (e1,clint-1.0).  Provides the Linux
	  scheduler tick and high-resolution timer for the single e1 hart.

config ELIZA_E1_PLIC
	tristate "Eliza e1 PLIC interrupt controller driver"
	depends on IRQ_DOMAIN
	help
	  IRQ domain driver for the e1_interrupt_controller.sv PLIC-style
	  block (e1,plic-1.0).  Exposes up to 8 interrupt sources (timer,
	  DMA, NPU, display) as Linux virtual IRQs via an irq_domain.

endif
