{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "./typescript",
    "types": ["node", "bun-types"],
    "ignoreDeprecations": "6.0",
    "noEmit": false,
    "declaration": true,
    "allowImportingTsExtensions": false,
    "composite": false,
    "baseUrl": "../..",
    "paths": {
      "@elizaos/core": ["packages/typescript/dist/index.node.d.ts"]
    }
  },
  "include": ["typescript/**/*.ts"],
  "exclude": [
    "typescript/**/*.test.ts",
    "typescript/**/__tests__/**",
    "node_modules",
    "dist"
  ]
}
