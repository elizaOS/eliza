{
  "compilerOptions": {
    "target": "es2023",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "strict": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "lib": ["ES2023", "DOM"],
    "types": ["node"],
    "paths": {
      "@elizaos/core": ["../core/src/index.node.ts"],
      "@elizaos/core/*": ["../core/src/*"],
      "@elizaos/agent": ["../agent/src/index.ts"],
      "@elizaos/agent/*": ["../agent/src/*"],
      "@elizaos/shared": ["../shared/src/index.ts"],
      "@elizaos/shared/*": ["../shared/src/*"],
      "@elizaos/ui": ["../ui/dist/index.d.ts"],
      "@elizaos/ui/*": ["../ui/dist/*"],
      "@elizaos/vault": ["../vault/src/index.ts"],
      "@elizaos/vault/*": ["../vault/src/*"],
      "@elizaos/app-core": ["../app-core/src/index.ts"],
      "@elizaos/app-core/*": ["../app-core/src/*"],
      "@elizaos/plugin-browser": [
        "../../plugins/plugin-browser/dist/index.d.ts"
      ],
      "@elizaos/plugin-browser/*": ["../../plugins/plugin-browser/dist/*"],
      "@elizaos/plugin-elizacloud": [
        "../../plugins/plugin-elizacloud/dist/node/index.d.ts"
      ],
      "@elizaos/plugin-elizacloud/*": [
        "../../plugins/plugin-elizacloud/dist/*"
      ],
      "@elizaos/plugin-agent-skills": [
        "../../plugins/plugin-agent-skills/src/index.ts"
      ],
      "@elizaos/plugin-agent-orchestrator": [
        "../../plugins/plugin-agent-orchestrator/src/index.ts"
      ],
      "@elizaos/plugin-local-embedding": [
        "../../plugins/plugin-local-embedding/src/index.ts"
      ],
      "@elizaos/plugin-sql": ["../../plugins/plugin-sql/typescript/index.ts"],
      "@elizaos/plugin-telegram": [
        "../../plugins/plugin-telegram/src/index.ts"
      ],
      "@elizaos/plugin-telegram/account-auth-service": [
        "../../plugins/plugin-telegram/src/account-auth-service.ts"
      ],
      "@elizaos/plugin-streaming": [
        "../../plugins/plugin-streaming/dist/index.d.ts"
      ],
      "@elizaos/capacitor-appblocker": [
        "../native-plugins/appblocker/src/index.ts"
      ],
      "@elizaos/capacitor-mobile-signals": [
        "../native-plugins/mobile-signals/src/index.ts"
      ],
      "@elizaos/app-core/components/pages/PageScopedChatPane": [
        "../app-core/src/components/pages/PageScopedChatPane.tsx"
      ],
      "@elizaos/app-lifeops/lifeops/runtime": [
        "./src/shims/elizaos-app-lifeops-runtime.ts"
      ]
    }
  },
  "include": [
    "src/**/*.ts",
    "../../plugins/app-companion/src/ambient-modules.d.ts"
  ]
}
