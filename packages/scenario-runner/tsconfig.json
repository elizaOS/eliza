{
  "compilerOptions": {
    "target": "es2023",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "strict": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "lib": ["ES2023", "DOM"],
    "types": ["node"],
    "paths": {
      "@elizaos/core": ["../core/src/index.node.ts"],
      "@elizaos/capacitor-appblocker": [
        "../native-plugins/appblocker/src/index.ts"
      ],
      "@elizaos/capacitor-mobile-signals": [
        "../native-plugins/mobile-signals/src/index.ts"
      ]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts"
  ]
}
