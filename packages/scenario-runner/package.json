{
  "name": "@elizaos/scenario-runner",
  "version": "2.0.0-beta.1",
  "description": "Lean scenario runner for the WS7 scenario-schema architecture. Loads .scenario.ts files, executes them against a real @elizaos/core AgentRuntime with a live LLM, and emits a JSON report.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/elizaOS/eliza",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/elizaOS/eliza.git",
    "directory": "packages/scenario-runner"
  },
  "keywords": [
    "elizaos",
    "scenario",
    "testing",
    "runtime"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "bin"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "eliza-scenarios": "./bin/eliza-scenarios"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json",
    "./*.css": "./dist/*.css",
    "./*": {
      "import": "./dist/*.js",
      "default": "./dist/*.js",
      "types": "./dist/*.d.ts"
    }
  },
  "scripts": {
    "clean": "rm -rf dist",
    "prepublishOnly": "bun run build",
    "build": "tsc --noCheck -p tsconfig.build.json",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@elizaos/app-lifeops": "2.0.0-beta.1",
    "@elizaos/core": "2.0.0-beta.1",
    "@elizaos/plugin-agent-skills": "2.0.0-beta.1",
    "@elizaos/plugin-local-embedding": "2.0.0-beta.1",
    "@elizaos/plugin-sql": "2.0.0-beta.1",
    "@elizaos/scenario-schema": "2.0.0-beta.1",
    "@elizaos/shared": "2.0.0-beta.1"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^4.0.0"
  }
}
