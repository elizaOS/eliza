/**
 * Cultural Learning and Observation System
 *
 * ## WHY THIS MODULE?
 *
 * Agents need to LEARN from the Moltbook community, not just post.
 * This module enables:
 * 1. **Observation** - Remember interesting posts we've read
 * 2. **Cultural Learning** - Build knowledge about community norms
 * 3. **Notable Users** - Remember interesting community members
 * 4. **Reflection** - Process observations into actionable learnings
 *
 * ## WHY PERSIST THESE?
 *
 * Without persistence, every restart is a blank slate.
 * By storing observations in memory, the agent:
 * - Avoids repeating topics it's already seen
 * - References past discussions authentically
 * - Builds genuine relationships over time
 * - Develops a nuanced understanding of community culture
 */

import type { IAgentRuntime, Memory } from '@elizaos/core';
import { createUniqueUuid } from '@elizaos/core';
import type { MoltbookPost, MoltbookProfile, CommunityContext } from '../types';

// =============================================================================
// OBSERVATION STORAGE
// =============================================================================

/**
 * Metadata for a stored observation (interesting post)
 */
interface ObservationMetadata {
  type: 'moltbook_observation';
  postId: string;
  title: string;
  author: string;
  submolt?: string;
  observedAt: number;
  /** Why this was interesting */
  reason: string;
  /** Topics extracted from the post */
  topics: string[];
  /** Engagement stats at time of observation */
  engagement: {
    upvotes: number;
    downvotes: number;
    comments: number;
  };
}

/**
 * Store an interesting post as an observation
 *
 * WHY STORE OBSERVATIONS?
 * 1. Builds context for future posts ("I saw someone discuss X...")
 * 2. Helps avoid repetitive content
 * 3. Enables authentic community references
 */
export async function storeObservation(
  runtime: IAgentRuntime,
  post: MoltbookPost,
  reason: string,
  topics: string[] = []
): Promise<void> {
  const memoryId = createUniqueUuid(runtime, `moltbook_obs_${post.id}`);

  const metadata: ObservationMetadata = {
    type: 'moltbook_observation',
    postId: post.id,
    title: post.title,
    author: post.author.username,
    submolt: post.submolt,
    observedAt: Date.now(),
    reason,
    topics,
    engagement: {
      upvotes: post.upvotes,
      downvotes: post.downvotes,
      comments: post.commentCount,
    },
  };

  // Create memory with embedding for semantic retrieval
  await runtime.createMemory(
    {
      id: memoryId,
      agentId: runtime.agentId,
      roomId: runtime.agentId,
      entityId: runtime.agentId,
      content: {
        text: `Observed post "${post.title}" by @${post.author.username}: ${post.content.slice(0, 500)}`,
        metadata,
      },
    },
    'moltbook_observations'
  );

  runtime.logger.debug(
    { postId: post.id, title: post.title, reason },
    'Moltbook: Stored observation'
  );
}

/**
 * Get recent observations
 */
export async function getRecentObservations(
  runtime: IAgentRuntime,
  limit: number = 20
): Promise<ObservationMetadata[]> {
  try {
    const memories = await runtime.getMemories({
      tableName: 'moltbook_observations',
      roomId: runtime.agentId,
      count: limit,
    });

    return memories
      .filter((m) => (m.content.metadata as any)?.type === 'moltbook_observation')
      .map((m) => m.content.metadata as ObservationMetadata);
  } catch (error) {
    runtime.logger.warn({ error }, 'Moltbook: Failed to get observations');
    return [];
  }
}

// =============================================================================
// CULTURAL LEARNING
// =============================================================================

/**
 * A cultural learning - something the agent has learned about Moltbook
 */
interface CulturalLearning {
  type: 'moltbook_cultural_learning';
  category: 'norm' | 'topic' | 'style' | 'humor' | 'engagement';
  learning: string;
  learnedAt: number;
  confidence: number; // 0-1, increases with repeated observations
  observations: number; // How many posts informed this learning
  examples: string[]; // Example post IDs or quotes
}

/**
 * Store a cultural learning
 *
 * WHY TRACK CULTURE?
 * Each community has its own norms, humor, and style.
 * Learning these helps the agent fit in authentically.
 */
export async function storeCulturalLearning(
  runtime: IAgentRuntime,
  category: CulturalLearning['category'],
  learning: string,
  examples: string[] = [],
  confidence: number = 0.5
): Promise<void> {
  // Use a hash of the learning text to detect duplicates
  const learningKey = `moltbook_learn_${category}_${learning.slice(0, 50).replace(/\W/g, '_')}`;
  const memoryId = createUniqueUuid(runtime, learningKey);

  // Check if we already have this learning
  try {
    const existing = await runtime.getMemoryById(memoryId);
    if (existing) {
      // Update confidence and observations
      const meta = existing.content.metadata as CulturalLearning;
      meta.confidence = Math.min(1, meta.confidence + 0.1);
      meta.observations++;
      meta.examples = [...new Set([...meta.examples, ...examples])].slice(-5);

      await runtime.createMemory(
        {
          ...existing,
          content: {
            ...existing.content,
            metadata: meta,
          },
        },
        'moltbook_cultural_learnings'
      );

      runtime.logger.debug(
        { category, confidence: meta.confidence },
        'Moltbook: Reinforced cultural learning'
      );
      return;
    }
  } catch {
    // Memory doesn't exist, create new
  }

  const metadata: CulturalLearning = {
    type: 'moltbook_cultural_learning',
    category,
    learning,
    learnedAt: Date.now(),
    confidence,
    observations: 1,
    examples,
  };

  await runtime.createMemory(
    {
      id: memoryId,
      agentId: runtime.agentId,
      roomId: runtime.agentId,
      entityId: runtime.agentId,
      content: {
        text: `Cultural learning (${category}): ${learning}`,
        metadata,
      },
    },
    'moltbook_cultural_learnings'
  );

  runtime.logger.debug(
    { category, learning: learning.slice(0, 50) },
    'Moltbook: Stored new cultural learning'
  );
}

/**
 * Get cultural learnings by category
 */
export async function getCulturalLearnings(
  runtime: IAgentRuntime,
  category?: CulturalLearning['category']
): Promise<CulturalLearning[]> {
  try {
    const memories = await runtime.getMemories({
      tableName: 'moltbook_cultural_learnings',
      roomId: runtime.agentId,
      count: 100,
    });

    let learnings = memories
      .filter((m) => (m.content.metadata as any)?.type === 'moltbook_cultural_learning')
      .map((m) => m.content.metadata as CulturalLearning);

    if (category) {
      learnings = learnings.filter((l) => l.category === category);
    }

    // Sort by confidence (most confident first)
    return learnings.sort((a, b) => b.confidence - a.confidence);
  } catch (error) {
    runtime.logger.warn({ error }, 'Moltbook: Failed to get cultural learnings');
    return [];
  }
}

/**
 * Format cultural learnings for inclusion in prompts
 */
export function formatCulturalLearnings(learnings: CulturalLearning[]): string {
  if (learnings.length === 0) return '';

  const byCategory = new Map<string, CulturalLearning[]>();
  for (const l of learnings) {
    const existing = byCategory.get(l.category) || [];
    existing.push(l);
    byCategory.set(l.category, existing);
  }

  const lines: string[] = ['## What I\'ve Learned About Moltbook Culture'];

  for (const [category, items] of byCategory) {
    lines.push(`\n### ${category.charAt(0).toUpperCase() + category.slice(1)}`);
    for (const item of items.slice(0, 3)) {
      // Top 3 per category
      const stars = '★'.repeat(Math.round(item.confidence * 5));
      lines.push(`- ${item.learning} ${stars}`);
    }
  }

  return lines.join('\n');
}

// =============================================================================
// NOTABLE USERS
// =============================================================================

/**
 * A notable user the agent has encountered
 */
interface NotableUser {
  type: 'moltbook_notable_user';
  userId: string;
  username: string;
  displayName?: string;
  /** Why this user is notable */
  reason: string;
  /** Topics they frequently post about */
  topics: string[];
  /** Our relationship status */
  relationship: 'unknown' | 'following' | 'mutual' | 'engaged';
  /** When we first noticed them */
  firstSeen: number;
  /** When we last saw activity from them */
  lastSeen: number;
  /** Number of interactions we've had */
  interactions: number;
  /** Notes about this user */
  notes: string[];
}

/**
 * Remember a notable user
 *
 * WHY TRACK USERS?
 * 1. Enables @mentions of community members
 * 2. Helps build relationships over time
 * 3. Allows referencing past interactions
 */
export async function rememberNotableUser(
  runtime: IAgentRuntime,
  profile: MoltbookProfile,
  reason: string,
  topics: string[] = []
): Promise<void> {
  const memoryId = createUniqueUuid(runtime, `moltbook_user_${profile.id}`);

  // Check if we already know this user
  try {
    const existing = await runtime.getMemoryById(memoryId);
    if (existing) {
      // Update existing record
      const meta = existing.content.metadata as any as NotableUser;
      meta.lastSeen = Date.now();
      meta.interactions++;
      meta.topics = [...new Set([...meta.topics, ...topics])].slice(-10);
      if (reason && !meta.notes.includes(reason)) {
        meta.notes = [...meta.notes, reason].slice(-5);
      }
      if (profile.isFollowing) {
        meta.relationship = 'following';
      }

      await runtime.createMemory(
        {
          ...existing,
          content: {
            text: `Notable Moltbook user @${profile.username}: ${meta.reason}`,
            metadata: meta as any,
          },
        },
        'moltbook_notable_users'
      );

      runtime.logger.debug(
        { username: profile.username, interactions: meta.interactions },
        'Moltbook: Updated notable user'
      );
      return;
    }
  } catch {
    // User not remembered yet
  }

  const metadata: NotableUser = {
    type: 'moltbook_notable_user',
    userId: profile.id,
    username: profile.username,
    displayName: profile.displayName,
    reason,
    topics,
    relationship: profile.isFollowing ? 'following' : 'unknown',
    firstSeen: Date.now(),
    lastSeen: Date.now(),
    interactions: 0,
    notes: reason ? [reason] : [],
  };

  await runtime.createMemory(
    {
      id: memoryId,
      agentId: runtime.agentId,
      roomId: runtime.agentId,
      entityId: runtime.agentId,
      content: {
        text: `Notable Moltbook user @${profile.username}: ${reason}`,
        metadata: metadata as any,
      },
    },
    'moltbook_notable_users'
  );

  runtime.logger.debug(
    { username: profile.username, reason },
    'Moltbook: Remembered new notable user'
  );
}

/**
 * Get notable users
 */
export async function getNotableUsers(
  runtime: IAgentRuntime,
  limit: number = 20
): Promise<NotableUser[]> {
  try {
    const memories = await runtime.getMemories({
      tableName: 'moltbook_notable_users',
      roomId: runtime.agentId,
      count: limit,
    });

    return memories
      .filter((m) => (m.content.metadata as any)?.type === 'moltbook_notable_user')
      .map((m) => m.content.metadata as any as NotableUser)
      .sort((a, b) => b.interactions - a.interactions);
  } catch (error) {
    runtime.logger.warn({ error }, 'Moltbook: Failed to get notable users');
    return [];
  }
}

/**
 * Format notable users for inclusion in prompts
 */
export function formatNotableUsers(users: NotableUser[]): string {
  if (users.length === 0) return '';

  const lines: string[] = ['## Notable Community Members'];

  for (const user of users.slice(0, 10)) {
    const rel = user.relationship !== 'unknown' ? ` [${user.relationship}]` : '';
    lines.push(`- @${user.username}${rel}: ${user.reason}`);
    if (user.topics.length > 0) {
      lines.push(`  Topics: ${user.topics.join(', ')}`);
    }
  }

  return lines.join('\n');
}

// =============================================================================
// REFLECTION - EXTRACT LEARNINGS FROM OBSERVATIONS
// =============================================================================

/**
 * Analyze community context and extract learnings
 *
 * WHY REFLECT?
 * Raw observations are just data. Reflection turns them into
 * actionable learnings that improve future behavior.
 */
export async function reflectOnObservations(
  runtime: IAgentRuntime,
  context: CommunityContext,
  feed: { posts: MoltbookPost[] }
): Promise<void> {
  // Store notable users
  for (const profile of context.notableMoltys) {
    await rememberNotableUser(
      runtime,
      profile,
      'Active community member',
      context.activeTopics.slice(0, 3)
    );
  }

  // Extract cultural learnings from what works
  for (const norm of context.whatWorks) {
    await storeCulturalLearning(runtime, 'norm', norm, [], 0.4);
  }

  // Learn from highly engaged posts
  for (const post of feed.posts.slice(0, 5)) {
    if (post.upvotes > 10 || post.commentCount > 5) {
      await storeObservation(
        runtime,
        post,
        `High engagement: ${post.upvotes} upvotes, ${post.commentCount} comments`,
        context.activeTopics.filter((t) =>
          post.title.toLowerCase().includes(t.toLowerCase()) ||
          post.content.toLowerCase().includes(t.toLowerCase())
        )
      );
    }
  }

  // Extract topic learnings
  if (context.activeTopics.length > 0) {
    await storeCulturalLearning(
      runtime,
      'topic',
      `Hot topics: ${context.activeTopics.slice(0, 5).join(', ')}`,
      [],
      0.3
    );
  }

  // Extract vibe learnings
  if (context.vibe) {
    await storeCulturalLearning(
      runtime,
      'style',
      `Community vibe: ${context.vibe}`,
      [],
      0.5
    );
  }

  runtime.logger.debug('Moltbook: Reflection complete');
}

/**
 * Get a summary of what the agent has learned about Moltbook
 * Useful for debugging and for inclusion in high-res context
 */
export async function getLearningsSummary(runtime: IAgentRuntime): Promise<string> {
  const learnings = await getCulturalLearnings(runtime);
  const users = await getNotableUsers(runtime, 10);
  const observations = await getRecentObservations(runtime, 5);

  const parts: string[] = [];

  if (learnings.length > 0) {
    parts.push(formatCulturalLearnings(learnings));
  }

  if (users.length > 0) {
    parts.push(formatNotableUsers(users));
  }

  if (observations.length > 0) {
    parts.push('\n## Recent Observations');
    for (const obs of observations) {
      parts.push(`- "${obs.title}" by @${obs.author}: ${obs.reason}`);
    }
  }

  return parts.join('\n\n');
}
