  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json && node ../scripts/prepare-package-dist.mjs packages/cloud-routing",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "biome check src"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
