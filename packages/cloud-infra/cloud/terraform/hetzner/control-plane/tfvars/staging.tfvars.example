# Copy to staging.tfvars (gitignored) and fill in real values.

environment           = "staging"
hcloud_location       = "fsn1"
hcloud_server_type    = "cpx21"
control_plane_count   = 1
cloudflare_zone_id    = "<zone-id-for-elizacloud.ai>"

# Operator SSH public keys (NEVER paste private keys here).
ssh_public_keys = [
  # "ssh-ed25519 AAAA... operator@laptop"
]

# Tight operator IPs only; module validation rejects 0.0.0.0/0 / ::/0.
# Feeds the new hcloud_firewall.control_plane that closes the SSH-world-open
# gap on the CP VM.
operator_ingress_cidrs = ["<operator-ip>/32"]

# Branch the host's auto-deploy follows. Staging tracks 'develop' by default;
# production MUST be 'main' (enforced by validation).
deploy_branch = "develop"
