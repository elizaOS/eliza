{
  "name": "@milaidy/app",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "npx --prefix ../.. vitest run --config vitest.config.ts",
    "test:watch": "npx --prefix ../.. vitest --config vitest.config.ts",
    "cap:sync": "capacitor sync",
    "cap:sync:ios": "capacitor sync ios",
    "cap:sync:android": "capacitor sync android",
    "cap:sync:electron": "capacitor sync @capacitor-community/electron",
    "cap:open:ios": "capacitor open ios",
    "cap:open:android": "capacitor open android",
    "cap:open:electron": "capacitor open @capacitor-community/electron",
    "build:ios": "bun run build && bun run cap:sync:ios",
    "build:android": "bun run build && bun run cap:sync:android",
    "build:electron": "bun run build && bun run cap:sync:electron",
    "ios": "bun run build:ios && bun run cap:open:ios",
    "android": "bun run build:android && bun run cap:open:android",
    "electron": "bun run build:electron && bun run cap:open:electron",
    "plugin:build:gateway": "cd plugins/gateway && bun run build",
    "plugin:build:swabble": "cd plugins/swabble && bun run build",
    "plugin:build:camera": "cd plugins/camera && bun run build",
    "plugin:build:screencapture": "cd plugins/screencapture && bun run build",
    "plugin:build:canvas": "cd plugins/canvas && bun run build",
    "plugin:build:desktop": "cd plugins/desktop && bun run build",
    "plugin:build:location": "cd plugins/location && bun run build",
    "plugin:build:talkmode": "cd plugins/talkmode && bun run build",
    "plugin:build": "bun run plugin:build:gateway && bun run plugin:build:swabble && bun run plugin:build:camera && bun run plugin:build:screencapture && bun run plugin:build:canvas && bun run plugin:build:desktop && bun run plugin:build:location && bun run plugin:build:talkmode"
  },
  "dependencies": {
    "@capacitor/android": "^8.0.2",
    "@capacitor/app": "8.0.0",
    "@capacitor/core": "8.0.2",
    "@capacitor/haptics": "8.0.0",
    "@capacitor/ios": "^8.0.2",
    "@capacitor/keyboard": "8.0.0",
    "@capacitor/preferences": "8.0.0",
    "@capacitor/status-bar": "8.0.0",
    "@milaidy/capacitor-camera": "file:plugins/camera",
    "@milaidy/capacitor-canvas": "file:plugins/canvas",
    "@milaidy/capacitor-desktop": "file:plugins/desktop",
    "@milaidy/capacitor-gateway": "file:plugins/gateway",
    "@milaidy/capacitor-location": "file:plugins/location",
    "@milaidy/capacitor-screencapture": "file:plugins/screencapture",
    "@milaidy/capacitor-swabble": "file:plugins/swabble",
    "@milaidy/capacitor-talkmode": "file:plugins/talkmode",
    "@noble/ed25519": "3.0.0",
    "dompurify": "^3.3.3",
    "lit": "^3.3.2",
    "marked": "^17.0.1"
  },
  "devDependencies": {
    "@capacitor-community/electron": "^5.0.1",
    "@capacitor/cli": "8.0.2",
    "@types/dompurify": "^3.0.5",
    "esbuild": "^0.27.3",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  }
}
