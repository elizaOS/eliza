{
  "name": "@elizaos/capacitor-calendar",
  "version": "2.0.0-beta.1",
  "description": "Reads and writes Apple Calendar events through EventKit.",
  "keywords": [
    "calendar",
    "eventkit",
    "ios",
    "permissions"
  ],
  "main": "./dist/plugin.cjs.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "bun": "./src/index.ts",
      "development": "./src/index.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/plugin.cjs.js"
    },
    "./package.json": "./package.json"
  },
  "unpkg": "dist/plugin.js",
  "files": [
    "dist/",
    "ios/Sources/",
    "*.podspec",
    "dist"
  ],
  "author": "elizaOS",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/elizaOS/eliza.git"
  },
  "scripts": {
    "build": "bun run clean && tsc && bun --bun rollup -c rollup.config.mjs",
    "clean": "node ../../../scripts/rm-path-recursive.mjs dist",
    "prepublishOnly": "bun run build"
  },
  "capacitor": {
    "ios": {
      "src": "ios",
      "podName": "ElizaosCapacitorCalendar"
    }
  },
  "devDependencies": {
    "@capacitor/cli": "^8.0.0",
    "@capacitor/core": "^8.3.1",
    "@capacitor/ios": "^8.0.0",
    "rimraf": "^6.0.0",
    "rollup": "^4.60.2",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@capacitor/core": "^8.3.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "elizaos": {
    "platforms": [
      "browser",
      "node"
    ],
    "runtime": "both",
    "platformDetails": {
      "browser": "Graceful unsupported fallback.",
      "ios": true,
      "node": "macOS uses the Electrobun EventKit dylib instead."
    }
  }
}
