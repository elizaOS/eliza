{
  "name": "@elizaos/capacitor-contacts",
  "version": "2.0.0-beta.1",
  "description": "Android ContactsContract bridge for ElizaOS.",
  "main": "./dist/plugin.cjs.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "bun": "./src/index.ts",
      "development": "./src/index.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/plugin.cjs.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "android/src/main/",
    "android/build.gradle",
    "dist/",
    "dist"
  ],
  "scripts": {
    "build": "bun run clean && tsc && bun --bun rollup -c rollup.config.mjs",
    "clean": "node ../../../scripts/rm-path-recursive.mjs dist",
    "prepublishOnly": "bun run build"
  },
  "license": "MIT",
  "capacitor": {
    "android": {
      "src": "android"
    }
  },
  "devDependencies": {
    "@capacitor/cli": "^8.0.0",
    "@capacitor/core": "^8.3.1",
    "rimraf": "^6.0.0",
    "rollup": "^4.60.2",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@capacitor/core": "^8.3.1"
  },
  "elizaos": {
    "platforms": [
      "browser",
      "node"
    ],
    "runtime": "both",
    "platformDetails": {
      "browser": "Web fallback returns an empty contacts list.",
      "android": true
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
