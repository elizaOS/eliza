{
  "name": "@elizaos/capacitor-appblocker",
  "version": "2.0.0-beta.0",
  "description": "Blocks selected apps on Android with Usage Access and an overlay shield, and on iPhone with Family Controls.",
  "keywords": [
    "app-blocker",
    "focus",
    "family-controls",
    "usage-stats"
  ],
  "main": "./dist/plugin.cjs.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/plugin.cjs.js"
    },
    "./package.json": "./package.json"
  },
  "unpkg": "dist/plugin.js",
  "files": [
    "android/src/main/",
    "android/build.gradle",
    "dist/",
    "ios/Sources/",
    "*.podspec",
    "dist"
  ],
  "scripts": {
    "build": "bun run clean && tsc && rollup -c rollup.config.mjs",
    "clean": "rimraf ./dist",
    "prepublishOnly": "bun run build"
  },
  "author": "elizaOS",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/elizaOS/eliza.git",
    "directory": "packages/native-plugins/appblocker"
  },
  "capacitor": {
    "ios": {
      "src": "ios",
      "podName": "ElizaosCapacitorAppblocker"
    },
    "android": {
      "src": "android"
    }
  },
  "devDependencies": {
    "@capacitor/cli": "^8.0.0",
    "@capacitor/core": "^8.3.1",
    "rimraf": "^6.0.0",
    "rollup": "^4.60.2",
    "typescript": "^6.0.0"
  },
  "peerDependencies": {
    "@capacitor/core": "^8.3.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "elizaos": {
    "platforms": [
      "browser",
      "android",
      "ios"
    ],
    "runtime": "native",
    "platformDetails": {
      "browser": "Not available in browsers.",
      "ios": "Uses Family Controls and Managed Settings to shield selected apps.",
      "android": "Uses Usage Access polling plus a system overlay shield."
    }
  }
}
