{
  "name": "@elizaos/capacitor-appblocker",
  "version": "1.0.0",
  "description": "Blocks apps on iOS via FamilyControls/ManagedSettings and on Android via UsageStatsManager with a foreground-service overlay.",
  "keywords": [
    "app-blocker",
    "screen-time",
    "focus"
  ],
  "main": "./dist/plugin.cjs.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/plugin.cjs.js"
    },
    "./package.json": "./package.json"
  },
  "unpkg": "dist/plugin.js",
  "files": [
    "android/src/main/",
    "android/build.gradle",
    "dist/",
    "ios/Sources/",
    "*.podspec"
  ],
  "scripts": {
    "build": "npm run clean && tsc && rollup -c rollup.config.mjs",
    "clean": "rimraf ./dist"
  },
  "author": "elizaOS",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/elizaOS/eliza.git",
    "directory": "packages/native-plugins/appblocker"
  },
  "capacitor": {
    "ios": {
      "src": "ios",
      "podName": "ElizaosCapacitorAppblocker"
    },
    "android": {
      "src": "android"
    }
  },
  "devDependencies": {
    "@capacitor/cli": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "rimraf": "^5.0.0",
    "rollup": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "@capacitor/core": "^8.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "elizaos": {
    "platforms": [
      "android",
      "ios"
    ],
    "runtime": "both",
    "platformDetails": {
      "ios": "Native app blocking via FamilyControls/ManagedSettings system shield",
      "android": "Native app blocking via UsageStatsManager polling with full-screen overlay"
    }
  }
}
