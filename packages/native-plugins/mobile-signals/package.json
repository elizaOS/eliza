{
  "name": "@elizaos/capacitor-mobile-signals",
  "version": "2.0.0-beta.0",
  "description": "Bridges mobile wake, lock, battery, and protected-data state into LifeOps.",
  "keywords": [
    "mobile",
    "wake",
    "sleep",
    "battery",
    "biometric"
  ],
  "main": "./dist/plugin.cjs.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/plugin.cjs.js"
    },
    "./package.json": "./package.json"
  },
  "unpkg": "dist/plugin.js",
  "files": [
    "android/src/main/",
    "android/build.gradle",
    "dist/",
    "ios/Sources/",
    "scripts/validate-ios-screen-time.mjs",
    "*.podspec",
    "dist"
  ],
  "author": "elizaOS",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/elizaOS/eliza"
  },
  "scripts": {
    "build": "bun run clean && bunx tsc -p tsconfig.json && rollup -c rollup.config.mjs",
    "clean": "rimraf ./dist",
    "prepublishOnly": "bun run build",
    "test": "vitest run",
    "validate:ios-screen-time": "node scripts/validate-ios-screen-time.mjs",
    "watch": "tsc --watch"
  },
  "devDependencies": {
    "@capacitor/android": "^8.0.0",
    "@capacitor/core": "^8.3.1",
    "@capacitor/ios": "^8.0.0",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "rimraf": "^6.0.0",
    "rollup": "^4.60.2",
    "typescript": "^6.0.0",
    "vitest": "^4.0.17"
  },
  "peerDependencies": {
    "@capacitor/core": "^8.3.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "capacitor": {
    "ios": {
      "src": "ios",
      "podName": "ElizaosCapacitorMobileSignals"
    },
    "android": {
      "src": "android"
    }
  },
  "elizaos": {
    "platforms": [
      "browser",
      "node"
    ],
    "runtime": "both",
    "platformDetails": {
      "browser": "Graceful web fallback from document visibility, focus, and Battery Status APIs.",
      "node": "No desktop native integration; mobile signals are captured on iOS and Android only.",
      "ios": true,
      "android": true
    }
  }
}
