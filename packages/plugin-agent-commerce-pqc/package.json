{
  "name": "@elizaos/plugin-agent-commerce",
  "version": "0.2.0",
  "description": "Agent commerce policy plugin for ElizaOS: rate limiting, prompt-injection heuristics, and ERC-8183 job flow",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "type-check": "tsc --noEmit -p tsconfig.json",
    "test": "bunx vitest run --config vitest.config.ts",
    "test:watch": "bunx vitest --config vitest.config.ts",
    "verify": "bun run type-check && bun run test"
  },
  "peerDependencies": {
    "@elizaos/core": ">=1.0.0"
  },
  "devDependencies": {
    "@elizaos/core": "^1.0.0",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.3",
    "vitest": "^4.0.0"
  },
  "keywords": [
    "elizaos",
    "plugin",
    "agent-commerce",
    "erc8183",
    "ai-security",
    "prompt-injection",
    "rate-limiting"
  ],
  "author": "Stvor Labs",
  "license": "Apache-2.0"
}
