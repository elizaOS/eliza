{
  "name": "@elizaos/plugin-safety-md",
  "version": "0.1.0",
  "description": "ElizaOS plugin to verify EVM payment address safety via safety.md API",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "tsc --noEmit",
    "test": "echo \"No tests yet\" && exit 0"
  },
  "keywords": [
    "elizaos",
    "eliza",
    "plugin",
    "safety",
    "address",
    "crypto",
    "security",
    "web3"
  ],
  "author": "ElizaOS Contributors",
  "license": "MIT",
  "peerDependencies": {
    "@elizaos/core": ">=0.1.0"
  },
  "devDependencies": {
    "@elizaos/core": "^0.1.9",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
