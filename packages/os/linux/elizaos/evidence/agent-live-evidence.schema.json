{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elizaos.ai/schemas/os/linux/agent-live-evidence.v1.json",
  "title": "elizaOS Linux chip-target agent liveness evidence",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema",
    "provenance",
    "claim_boundary",
    "transcript_path",
    "fallback_payload_used",
    "full_agent_bundle",
    "service",
    "process",
    "health"
  ],
  "properties": {
    "schema": {
      "const": "eliza.os.linux.agent_live.v1"
    },
    "provenance": {
      "type": "string",
      "pattern": "(generated[_-]eliza[_-]ap|chip[_-]emulator|eliza[_-]chip)"
    },
    "claim_boundary": {
      "type": "string",
      "pattern": "(generated[_-]eliza[_-]ap|chip[_-]emulator|eliza[_-]chip)"
    },
    "transcript_path": {
      "type": "string",
      "minLength": 1
    },
    "fallback_payload_used": {
      "const": false
    },
    "full_agent_bundle": {
      "const": true
    },
    "service": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "active", "systemctl_is_active"],
      "properties": {
        "name": {
          "const": "elizaos-agent.service"
        },
        "active": {
          "const": true
        },
        "systemctl_is_active": {
          "const": "active"
        }
      }
    },
    "process": {
      "type": "object",
      "additionalProperties": true,
      "required": ["pid"],
      "properties": {
        "pid": {
          "type": "integer",
          "minimum": 1
        },
        "command": {
          "type": "string"
        },
        "executable": {
          "type": "string"
        }
      },
      "anyOf": [
        {
          "required": ["command"],
          "properties": {
            "command": {
              "pattern": "elizaos"
            }
          }
        },
        {
          "required": ["executable"],
          "properties": {
            "executable": {
              "pattern": "elizaos"
            }
          }
        }
      ]
    },
    "health": {
      "type": "object",
      "additionalProperties": true,
      "required": ["url", "http_status", "response"],
      "properties": {
        "url": {
          "type": "string",
          "pattern": "/api/health"
        },
        "http_status": {
          "const": 200
        },
        "ready": {
          "type": "boolean"
        },
        "status": {
          "enum": ["ready", "ok", "healthy"]
        },
        "response": {
          "type": "object",
          "additionalProperties": true,
          "required": ["agentId"],
          "properties": {
            "agentId": {
              "type": "string",
              "minLength": 1,
              "not": {
                "const": "fallback"
              }
            }
          }
        }
      },
      "anyOf": [
        {
          "required": ["ready"],
          "properties": {
            "ready": {
              "const": true
            }
          }
        },
        {
          "required": ["status"]
        }
      ]
    }
  }
}
