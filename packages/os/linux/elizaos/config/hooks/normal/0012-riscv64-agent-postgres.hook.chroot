#!/bin/sh
# riscv64-only agent database wiring.
#
# The riscv64 bun is a C_LOOP (no-JIT) build, and WebAssembly-backed PGlite is
# brittle on this target. Instead, provision native Postgres on this image and
# point the agent at it with both POSTGRES_URL and DATABASE_URL. This hook is a
# no-op on every other architecture.
set -eu

[ "$(dpkg --print-architecture 2>/dev/null || true)" = "riscv64" ] || exit 0
echo "[0012-rv64-pg] wiring agent -> native Postgres (riscv64)"

PGVER="$(ls /etc/postgresql 2>/dev/null | sort -n | tail -1 || true)"
if [ -z "${PGVER}" ]; then
    echo "[0012-rv64-pg] ERROR: postgresql not installed (no /etc/postgresql/*)" >&2
    exit 1
fi
PGCONF="/etc/postgresql/${PGVER}/main"

# Loopback-only listener with a fixed local appliance password. This is not
# network-exposed, but node-postgres still requires a string password for the
# default SCRAM auth path, so the runtime URL must include one.
if ! grep -q "elizaos-appliance" "${PGCONF}/postgresql.conf"; then
    printf '\n# elizaos-appliance: loopback only\nlisten_addresses = %s\n' "'127.0.0.1'" \
        >> "${PGCONF}/postgresql.conf"
fi
if ! grep -q "elizaos appliance auth" "${PGCONF}/pg_hba.conf"; then
    HBA_TMP="$(mktemp)"
    {
        echo "# elizaos appliance auth (loopback, single-user)"
        echo "host    elizaos    elizaos    127.0.0.1/32    scram-sha-256"
        echo "host    elizaos    elizaos    ::1/128         scram-sha-256"
        cat "${PGCONF}/pg_hba.conf"
    } > "${HBA_TMP}"
    cat "${HBA_TMP}" > "${PGCONF}/pg_hba.conf"
    rm -f "${HBA_TMP}"
fi

# Idempotent boot-time provisioning of the elizaos role + database.
install -d /usr/local/lib/elizaos
cat > /usr/local/lib/elizaos/provision-pg.sh <<'PROV'
#!/bin/sh
set -eu
log() { echo "elizaos-pg-provision: $*" >&2; }
PGVER="$(ls /etc/postgresql 2>/dev/null | sort -n | tail -1)"
pg_isready -h 127.0.0.1 -p 5432 >/dev/null 2>&1 || pg_ctlcluster "${PGVER}" main start || true
for _ in $(seq 1 60); do
    pg_isready -h 127.0.0.1 -p 5432 >/dev/null 2>&1 && break
    sleep 1
done
pg_isready -h 127.0.0.1 -p 5432 >/dev/null 2>&1 || { log "FATAL: postgres not ready"; exit 1; }
su - postgres -c "psql -tAc \"SELECT 1 FROM pg_roles WHERE rolname='elizaos'\"" | grep -q 1 \
    || su - postgres -c "createuser --no-superuser --createdb --no-createrole elizaos"
su - postgres -c "psql -tAc \"ALTER ROLE elizaos PASSWORD 'elizaos'\""
su - postgres -c "psql -tAc \"SELECT 1 FROM pg_database WHERE datname='elizaos'\"" | grep -q 1 \
    || su - postgres -c "createdb -O elizaos elizaos"
su - postgres -c "psql -d elizaos -v ON_ERROR_STOP=1 -c 'CREATE EXTENSION IF NOT EXISTS vector'"
su - postgres -c "psql -d elizaos -v ON_ERROR_STOP=1 -c 'CREATE EXTENSION IF NOT EXISTS fuzzystrmatch'"
su - postgres -c "psql -d elizaos -v ON_ERROR_STOP=1 -c 'CREATE EXTENSION IF NOT EXISTS pgcrypto'"
log "ready: role+db elizaos"
PROV
chmod 0755 /usr/local/lib/elizaos/provision-pg.sh

# Seed the runtime config with Postgres as the explicit provider. The runtime
# accepts POSTGRES_URL/DATABASE_URL env vars, but plugin-sql still keys off the
# persisted database.provider value when deciding whether to initialize PGlite.
cat > /var/lib/elizaos/eliza.json <<'JSON'
{
  "database": {
    "provider": "postgres",
    "postgres": {
      "connectionString": "postgresql://elizaos:elizaos@127.0.0.1:5432/elizaos"
    }
  }
}
JSON
chown elizaos:elizaos /var/lib/elizaos/eliza.json
chmod 0600 /var/lib/elizaos/eliza.json

cat > /etc/systemd/system/elizaos-pg-provision.service <<'UNIT'
[Unit]
Description=elizaOS Postgres provisioning (riscv64)
After=postgresql.service
Wants=postgresql.service
Before=elizaos-agent.service

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/usr/local/lib/elizaos/provision-pg.sh

[Install]
WantedBy=multi-user.target
UNIT

# Point the agent at Postgres and keep the health gate in the service start
# path. The standalone terminal smoke is ordered After=elizaos-agent.service; if
# the agent becomes active before /api/health is ready, the TUI probe races and
# fails. riscv64 keeps the staged Bun artifact on-image for provenance/future
# use, but the live agent service prefers Debian nodejs until Bun can run the
# full agent bundle reliably.
mkdir -p /etc/systemd/system/elizaos-agent.service.d
cat > /etc/systemd/system/elizaos-agent.service.d/10-riscv64-postgres.conf <<'DROP'
[Unit]
After=elizaos-pg-provision.service
Requires=elizaos-pg-provision.service
[Service]
Environment=POSTGRES_URL=postgresql://elizaos:elizaos@127.0.0.1:5432/elizaos
Environment=DATABASE_URL=postgresql://elizaos:elizaos@127.0.0.1:5432/elizaos
Environment=ELIZA_AGENT_RUNTIME=node-agent-bundle
Environment=ELIZA_PLATFORM=android
Environment=ELIZA_MOBILE_PLATFORM=android
Environment=ELIZA_AGENT_HEALTH_TIMEOUT_SECONDS=600
TimeoutStartSec=0
DROP

# The first-boot script is the canonical QEMU proof path: it starts the agent,
# waits for /api/health, emits the curl/agent markers to serial, then runs the
# terminal TUI smoke. Give the emulated Node/Postgres path the same 900 second
# budget as the boot harness instead of systemd's short service default.
mkdir -p /etc/systemd/system/elizaos-first-boot.service.d
cat > /etc/systemd/system/elizaos-first-boot.service.d/10-riscv64-timeout.conf <<'DROP'
[Unit]
Before=
After=network.target postgresql.service elizaos-pg-provision.service
Requires=elizaos-pg-provision.service

[Service]
Environment=ELIZA_AGENT_HEALTH_TIMEOUT_SECONDS=600
TimeoutStartSec=0
DROP

mkdir -p /etc/systemd/system/elizaos-terminal-tui-smoke.service.d
cat > /etc/systemd/system/elizaos-terminal-tui-smoke.service.d/10-riscv64-timeout.conf <<'DROP'
[Service]
Environment=ELIZA_AGENT_HEALTH_TIMEOUT_SECONDS=600
TimeoutStartSec=900
DROP

systemctl enable postgresql.service 2>/dev/null || true
systemctl enable elizaos-pg-provision.service 2>/dev/null || true
echo "[0012-rv64-pg] done"
