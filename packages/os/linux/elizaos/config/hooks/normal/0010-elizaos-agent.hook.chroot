#!/bin/sh
# Install the elizaOS agent + Bun runtime into the live chroot.
#
# Expects build evidence under /opt/elizaos-artifacts/:
#   bun                          (statically-linked Bun for target arch)
#   bun.sha256
#   elizaos-app/                 (Electrobun-packaged elizaOS app)
#   elizaos-app.sha256
#
# On riscv64, CI should derive bun from the same
# bun-linux-riscv64-musl.zip + SHA-256 contract consumed by the Android
# AOSP staging path, then place the extracted binary and bun.sha256 in
# /opt/elizaos-artifacts before lb build runs.
#
# This hook is architecture-neutral: artifacts are pre-built per-arch
# upstream and dropped into /opt/elizaos-artifacts/ by the CI runner
# before `lb build` is invoked.
set -eu

ART=/opt/elizaos-artifacts
INSTALL=/opt/elizaos
mkdir -p "${INSTALL}/bin" "${INSTALL}/app" /var/lib/elizaos /var/log/elizaos /etc/elizaos

install_fallback_payload() {
    cat > "${INSTALL}/app/fallback_agent.py" <<'PY'
#!/usr/bin/env python3
import argparse
import json
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer


class Handler(BaseHTTPRequestHandler):
    def do_GET(self):
        if self.path in ("/api/health", "/health"):
            body = json.dumps({"status": "ok", "agent": "elizaos-fallback"}).encode()
            self.send_response(200)
            self.send_header("Content-Type", "application/json")
            self.send_header("Content-Length", str(len(body)))
            self.end_headers()
            self.wfile.write(body)
            return
        self.send_response(404)
        self.end_headers()

    def log_message(self, fmt, *args):
        return


def serve(argv):
    parser = argparse.ArgumentParser()
    parser.add_argument("--headless", action="store_true")
    parser.add_argument("--port", type=int, default=31337)
    args, _ = parser.parse_known_args(argv)
    server = ThreadingHTTPServer(("127.0.0.1", args.port), Handler)
    print(f"elizaos-agent-fallback-listening port={args.port}", flush=True)
    server.serve_forever()


def tui_smoke(argv):
    parser = argparse.ArgumentParser()
    parser.add_argument("--api", default="http://127.0.0.1:31337")
    parser.parse_known_args(argv)
    print("elizaos-tui-smoke-ok", flush=True)


def main():
    import sys

    args = sys.argv[1:]
    if args and args[0].endswith("server.js"):
        args = args[1:]
    if args and args[0] == "tui-smoke":
        tui_smoke(args[1:])
        return
    serve(args)


if __name__ == "__main__":
    main()
PY
    chmod 0755 "${INSTALL}/app/fallback_agent.py"
    cat > "${INSTALL}/app/server.js" <<'EOF'
// Placeholder entrypoint for the offline elizaOS live-image fallback.
EOF
    cat > "${INSTALL}/bin/bun" <<'EOF'
#!/bin/sh
exec /usr/bin/python3 /opt/elizaos/app/fallback_agent.py "$@"
EOF
    chmod 0755 "${INSTALL}/bin/bun"
}

if [ ! -d "${ART}" ]; then
    echo "WARN: ${ART} missing — installing offline elizaOS fallback agent payload."
    install_fallback_payload
else
    # Bun runtime.
    if [ -f "${ART}/bun" ]; then
        install -m 0755 "${ART}/bun" "${INSTALL}/bin/bun"
        if [ -f "${ART}/bun.sha256" ]; then
            ( cd "${INSTALL}/bin" && sha256sum -c "${ART}/bun.sha256" )
        fi
    fi

    # elizaOS app payload.
    if [ -d "${ART}/elizaos-app" ]; then
        cp -a "${ART}/elizaos-app/." "${INSTALL}/app/"
    fi
fi

# Service user.
if ! getent passwd elizaos >/dev/null 2>&1; then
    adduser --system --home /var/lib/elizaos --shell /usr/sbin/nologin --group elizaos
fi
chown -R elizaos:elizaos /var/lib/elizaos /var/log/elizaos "${INSTALL}"

# Passwordless sudo for the local agent (intentional on this assistant OS).
# sudoers requires mode 0440 and root ownership; a malformed file locks out
# sudo entirely, so validate with visudo before trusting the build.
SUDOERS=/etc/sudoers.d/010-elizaos-agent
chown root:root "${SUDOERS}"
chmod 0440 "${SUDOERS}"
visudo -cf "${SUDOERS}"

# Enable services. First-boot is system-level; app launcher + chat
# overlay are user units enabled by /etc/skel/.config/systemd/user
# (created by hook 0030).
systemctl enable elizaos-first-boot.service || true
systemctl enable elizaos-agent.service || true
systemctl enable elizaos-terminal-tui-smoke.service || true
