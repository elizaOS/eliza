#!/bin/sh
# Install the elizaOS agent + Bun runtime into the live chroot.
#
# Expects build evidence under /opt/elizaos-artifacts/:
#   bun                          (statically-linked Bun for target arch;
#                                optional on riscv64 node-only images)
#   bun.sha256                   (present when bun is present)
#   elizaos-app/                 (Electrobun-packaged elizaOS app)
#   elizaos-app.sha256
#   riscv64-bun-provenance.json (required when bun is a riscv64 musl wrapper)
#   vector.tar.gz                (PGlite extension bundle, resolved via ../)
#   fuzzystrmatch.tar.gz         (PGlite extension bundle, resolved via ../)
#   elizaos-root-assets.sha256
#
# On riscv64, CI may omit Bun and run the Node-shebang agent bundle through
# the Debian nodejs package. When Bun is present, CI should derive it from the same
# bun-linux-riscv64-musl.zip + SHA-256 contract consumed by the Android
# AOSP staging path, then place the extracted binary and bun.sha256 in
# /opt/elizaos-artifacts before lb build runs.
#
# This hook is architecture-neutral: artifacts are pre-built per-arch
# upstream and dropped into /opt/elizaos-artifacts/ by the CI runner
# before `lb build` is invoked.
set -eu

ART=/opt/elizaos-artifacts
INSTALL=/opt/elizaos
mkdir -p "${INSTALL}/bin" "${INSTALL}/app" /var/lib/elizaos /var/log/elizaos /etc/elizaos

if [ ! -d "${ART}" ]; then
    echo "ERROR: ${ART} missing; objective images require real elizaOS agent artifacts." >&2
    exit 1
else
    for required in elizaos-app; do
        if [ ! -e "${ART}/${required}" ]; then
            echo "ERROR: required elizaOS agent artifact missing: ${ART}/${required}" >&2
            exit 1
        fi
    done
    if [ ! -e "${ART}/bun" ] && [ "$(dpkg --print-architecture 2>/dev/null || true)" != "riscv64" ]; then
        echo "ERROR: required elizaOS agent artifact missing: ${ART}/bun" >&2
        exit 1
    fi
    if [ ! -e "${ART}/bun" ] && [ ! -f "${ART}/elizaos-app/agent-bundle.js" ]; then
        echo "ERROR: riscv64 Node fallback requires ${ART}/elizaos-app/agent-bundle.js when Bun is absent." >&2
        exit 1
    fi
    if [ -e "${ART}/bun" ] && grep -q 'musl-runtime/bun' "${ART}/bun" && [ ! -x "${ART}/elizaos-app/musl-runtime/bun" ]; then
        echo "ERROR: Bun wrapper requires ${ART}/elizaos-app/musl-runtime/bun." >&2
        exit 1
    fi
    if [ -e "${ART}/bun" ] && grep -q 'musl-runtime/bun' "${ART}/bun" && [ ! -f "${ART}/riscv64-bun-provenance.json" ]; then
        echo "ERROR: riscv64 Bun wrapper requires ${ART}/riscv64-bun-provenance.json." >&2
        exit 1
    fi

    # Bun runtime.
    if [ -f "${ART}/bun" ]; then
        install -m 0755 "${ART}/bun" "${INSTALL}/bin/bun"
        if [ -f "${ART}/bun.sha256" ]; then
            ( cd "${INSTALL}/bin" && sha256sum -c "${ART}/bun.sha256" )
        fi
    fi

    # elizaOS app payload.
    if [ -d "${ART}/elizaos-app" ]; then
        cp -a "${ART}/elizaos-app/." "${INSTALL}/app/"
        if [ -f "${ART}/elizaos-app.sha256" ]; then
            ( cd "${INSTALL}/app" && sha256sum -c "${ART}/elizaos-app.sha256" )
        fi
    fi

    # PGlite contrib bundles are referenced by the mobile bundle as ../*.tar.gz.
    for asset in vector.tar.gz fuzzystrmatch.tar.gz; do
        if [ -f "${ART}/${asset}" ]; then
            install -m 0644 "${ART}/${asset}" "${INSTALL}/${asset}"
        fi
    done
    if [ -f "${ART}/elizaos-root-assets.sha256" ]; then
        ( cd "${INSTALL}" && sha256sum -c "${ART}/elizaos-root-assets.sha256" )
    fi
fi

if [ "$(dpkg --print-architecture 2>/dev/null || true)" = "riscv64" ]; then
    mkdir -p "${INSTALL}/app/node_modules"
    for module in undici ws node-fetch; do
        if [ ! -d "/usr/share/nodejs/${module}" ]; then
            echo "ERROR: riscv64 Node fallback requires Debian ${module} at /usr/share/nodejs/${module}." >&2
            exit 1
        fi
        ln -sfn "/usr/share/nodejs/${module}" "${INSTALL}/app/node_modules/${module}"
    done
fi

# Service user.
if ! getent passwd elizaos >/dev/null 2>&1; then
    adduser --system --home /var/lib/elizaos --shell /usr/sbin/nologin --group elizaos
fi
chown -R elizaos:elizaos /var/lib/elizaos /var/log/elizaos "${INSTALL}"

# Passwordless sudo for the local agent (intentional on this assistant OS).
# sudoers requires mode 0440 and root ownership; a malformed file locks out
# sudo entirely, so validate with visudo before trusting the build.
SUDOERS=/etc/sudoers.d/010-elizaos-agent
chown root:root "${SUDOERS}"
chmod 0440 "${SUDOERS}"
visudo -cf "${SUDOERS}"

# Enable services. First-boot is system-level; app launcher + chat
# overlay are user units enabled by /etc/skel/.config/systemd/user
# (created by hook 0030).
systemctl enable elizaos-first-boot.service || true
systemctl enable elizaos-agent.service || true
systemctl enable elizaos-terminal-tui-smoke.service || true
