#!/bin/sh

set -eu

interval="${ELIZAOS_KEEPER_INTERVAL:-5}"
runtime_dir=/run/user/1000
bus="unix:path=${runtime_dir}/bus"
maintenance_flag=/run/elizaos/persistence-maintenance
user_persistence_flag="${runtime_dir}/elizaos-persistence-setup"

clear_user_unit_override() {
    runuser -u amnesia -- env HOME=/home/amnesia sh -eu <<'EOF'
user_unit_dir="${HOME}/.config/systemd/user"
mkdir -p "${user_unit_dir}/default.target.wants" \
    "${user_unit_dir}/desktop.target.wants"

for path in \
    "${user_unit_dir}/elizaos-agent.service" \
    "${user_unit_dir}/elizaos-agent.service.d" \
    "${user_unit_dir}/default.target.wants/elizaos-agent.service" \
    "${user_unit_dir}/elizaos-renderer.service" \
    "${user_unit_dir}/elizaos-renderer.service.d" \
    "${user_unit_dir}/default.target.wants/elizaos-renderer.service" \
    "${user_unit_dir}/elizaos-pill.service" \
    "${user_unit_dir}/elizaos-pill.service.d" \
    "${user_unit_dir}/default.target.wants/elizaos-pill.service" \
    "${user_unit_dir}/elizaos.service" \
    "${user_unit_dir}/elizaos.service.d" \
    "${user_unit_dir}/default.target.wants/elizaos.service" \
    "${user_unit_dir}/desktop.target.wants/elizaos.service" \
    "${user_unit_dir}/tails-dump-user-env.service" \
    "${user_unit_dir}/tails-dump-user-env.service.d" \
    "${user_unit_dir}/default.target.wants/tails-dump-user-env.service"
do
    [ -e "${path}" ] || [ -L "${path}" ] || continue
    rm -rf -- "${path}" || true
done
EOF
}

while :; do
    if [ -e "${maintenance_flag}" ] || [ -e "${user_persistence_flag}" ]; then
        :
    elif [ -S "${runtime_dir}/bus" ]; then
        clear_user_unit_override || true
        runuser -u amnesia -- env \
            HOME=/home/amnesia \
            XDG_RUNTIME_DIR="${runtime_dir}" \
            DBUS_SESSION_BUS_ADDRESS="${bus}" \
            systemctl --user daemon-reload >/dev/null 2>&1 || true
        runuser -u amnesia -- env \
            HOME=/home/amnesia \
            XDG_RUNTIME_DIR="${runtime_dir}" \
            DBUS_SESSION_BUS_ADDRESS="${bus}" \
            systemctl --user reset-failed elizaos-agent.service elizaos-renderer.service elizaos-pill.service elizaos.service >/dev/null 2>&1 || true
        runuser -u amnesia -- env \
            HOME=/home/amnesia \
            XDG_RUNTIME_DIR="${runtime_dir}" \
            DBUS_SESSION_BUS_ADDRESS="${bus}" \
            systemctl --user start --no-block elizaos-agent.service >/dev/null 2>&1 || true
        runuser -u amnesia -- env \
            HOME=/home/amnesia \
            XDG_RUNTIME_DIR="${runtime_dir}" \
            DBUS_SESSION_BUS_ADDRESS="${bus}" \
            systemctl --user start --no-block elizaos-renderer.service >/dev/null 2>&1 || true
        runuser -u amnesia -- env \
            HOME=/home/amnesia \
            XDG_RUNTIME_DIR="${runtime_dir}" \
            DBUS_SESSION_BUS_ADDRESS="${bus}" \
            systemctl --user start --no-block elizaos.service >/dev/null 2>&1 || true
    fi
    sleep "${interval}"
done
