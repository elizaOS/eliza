[Unit]
Description=elizaOS first-boot bootstrap
After=local-fs.target
Before=elizaos-agent.service
ConditionPathExists=!/var/lib/elizaos/.first-boot-complete

[Service]
Type=oneshot
ExecStart=/usr/local/lib/elizaos/first-boot.sh
RemainAfterExit=yes
StandardOutput=journal+console
StandardError=journal+console

[Install]
WantedBy=multi-user.target
