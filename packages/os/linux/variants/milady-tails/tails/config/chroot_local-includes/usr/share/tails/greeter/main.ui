<?xml version="1.0" encoding="UTF-8"?>
<interface domain="tails">
  <requires version="3.20" lib="gtk+"/>
  <requires version="0.0" lib="libhandy"/>
  <object id="box_main" class="GtkBox">
    <property name="visible">True</property>
    <property name="can-focus">False</property>
    <property name="orientation">vertical</property>
    <child>
      <object id="infobar_settings_loaded" class="GtkInfoBar">
        <property name="app-paintable">True</property>
        <property name="can-focus">False</property>
        <property name="show-close-button">True</property>
        <signal swapped="no" name="close" handler="cb_infobar_close"/>
        <signal swapped="no" name="response" handler="cb_infobar_response"/>
        <child internal-child="action_area">
          <object id="infobar_settings_loaded-action_area" class="GtkButtonBox">
            <property name="can-focus">False</property>
            <property name="spacing">6</property>
            <property name="layout-style">end</property>
            <child>
              <placeholder/>
            </child>
            <child>
              <placeholder/>
            </child>
            <child>
              <placeholder/>
            </child>
          </object>
          <packing>
            <property name="expand">False</property>
            <property name="fill">False</property>
            <property name="position">0</property>
          </packing>
        </child>
        <child internal-child="content_area">
          <object id="infobar_settings_loaded-content_area" class="GtkBox">
            <property name="can-focus">False</property>
            <property name="spacing">16</property>
            <child>
              <object id="label_infobar_settings_loaded" class="GtkLabel">
                <property name="visible">True</property>
                <property name="can-focus">False</property>
                <property translatable="yes" name="label">Settings were loaded from the Persistent Storage.</property>
                <property name="xalign">0</property>
              </object>
              <packing>
                <property name="expand">False</property>
                <property name="fill">True</property>
                <property name="position">0</property>
              </packing>
            </child>
            <child>
              <placeholder/>
            </child>
            <child>
              <placeholder/>
            </child>
          </object>
          <packing>
            <property name="expand">False</property>
            <property name="fill">False</property>
            <property name="position">0</property>
          </packing>
        </child>
        <child>
          <placeholder/>
        </child>
      </object>
      <packing>
        <property name="expand">False</property>
        <property name="fill">True</property>
        <property name="position">1</property>
      </packing>
    </child>
    <child>
      <object id="box_inner" class="GtkBox">
        <property name="visible">True</property>
        <property name="can-focus">False</property>
        <property name="margin-left">18</property>
        <property name="margin-right">18</property>
        <property name="margin-top">18</property>
        <property name="margin-bottom">18</property>
        <property name="orientation">vertical</property>
        <property name="spacing">18</property>
        <child>
          <object id="box_header" class="GtkBox">
            <property name="visible">True</property>
            <property name="can-focus">False</property>
            <property name="orientation">vertical</property>
            <property name="spacing">6</property>
            <child>
              <object id="image_elizaos_logo" class="GtkImage">
                <property name="visible">True</property>
                <property name="can-focus">False</property>
                <property name="file">/usr/share/tails/greeter/icons/elizaos-logo.png</property>
                <property name="pixel-size">96</property>
              </object>
              <packing>
                <property name="expand">False</property>
                <property name="fill">True</property>
                <property name="position">0</property>
              </packing>
            </child>
            <child>
              <object id="label_header_title" class="GtkLabel">
                <property name="visible">True</property>
                <property name="can-focus">False</property>
                <property translatable="yes" name="label">Welcome to elizaOS!</property>
                <attributes>
                  <attribute value="semibold" name="weight"/>
                  <attribute value="1.5" name="scale"/>
                </attributes>
              </object>
              <packing>
                <property name="expand">False</property>
                <property name="fill">True</property>
                <property name="position">1</property>
              </packing>
            </child>
        </object>
        <packing>
            <property name="expand">True</property>
            <property name="fill">True</property>
            <property name="position">0</property>
        </packing>
    </child>
    <child>
        <object id="box_language" class="GtkBox">
            <property name="visible">True</property>
            <property name="can-focus">False</property>
            <property name="orientation">vertical</property>
            <property name="spacing">6</property>
            <child>
                <object id="box_language_header" class="GtkBox">
                    <property name="visible">True</property>
                    <property name="can-focus">False</property>
                    <child>
                        <object id="label_language_header_title" class="GtkLabel">
                            <property name="visible">True</property>
                            <property name="can-focus">False</property>
                            <property translatable="yes" name="label">Language and Formats</property>
                            <attributes>
                                <attribute value="bold" name="weight"/>
                            </attributes>
                        </object>
                        <packing>
                            <property name="expand">False</property>
                            <property name="fill">True</property>
                            <property name="position">0</property>
                        </packing>
                    </child>
                    <child>
                        <object id="linkbutton_language_help" class="GtkLinkButton">
                            <property name="visible">True</property>
                            <property name="can-focus">False</property>
                            <property name="receives-default">True</property>
                            <property name="relief">none</property>
                            <property name="uri">doc/first_steps/welcome_screen.en.html#locale</property>
                            <signal swapped="no" name="activate-link" handler="cb_linkbutton_help_activate"/>
                            <child>
                                <object id="image_language_help" class="GtkImage">
                                    <property name="visible">True</property>
                                    <property name="can-focus">False</property>
                                    <property name="icon-name">tails-help</property>
                                </object>
                            </child>
                        </object>
                        <packing>
                            <property name="expand">False</property>
                            <property name="fill">True</property>
                            <property name="position">1</property>
                        </packing>
                    </child>
                    <child>
                        <object id="label_language_header_status" class="GtkLabel">
                            <property name="can-focus">False</property>
                            <property translatable="yes" name="label">Default Settings</property>
                            <attributes>
                                <attribute value="italic" name="style"/>
                            </attributes>
                        </object>
                        <packing>
                            <property name="expand">False</property>
                            <property name="fill">True</property>
                            <property name="position">2</property>
                        </packing>
                    </child>
                </object>
                <packing>
                    <property name="expand">False</property>
                    <property name="fill">True</property>
                    <property name="position">0</property>
                </packing>
            </child>
            <child>
                <object id="frame_language" class="GtkFrame">
                    <property name="visible">True</property>
                    <property name="can-focus">False</property>
                    <property name="label-xalign">0</property>
                    <property name="shadow-type">in</property>
                    <child>
                        <object id="listbox_region" class="GtkListBox">
                            <property name="visible">True</property>
                            <property name="can-focus">False</property>
                            <signal swapped="no" name="row-activated" handler="cb_listbox_region_row_activated"/>
                        </object>
                    </child>
                </object>
                <packing>
                    <property name="expand">False</property>
                    <property name="fill">True</property>
                    <property name="position">1</property>
                </packing>
            </child>
            <child>
                <object id="save_language_keyboard_box" class="GtkBox">
                    <property name="visible">True</property>
                    <property name="can-focus">False</property>
                    <property name="valign">center</property>
                    <property name="halign">end</property>
                    <property name="margin-start">6</property>
                    <property name="spacing">6</property>
                    <child>
                        <object id="save_language_keyboard_label" class="GtkLabel">
                            <property name="visible">True</property>
                            <property name="can-focus">False</property>
                            <property translatable="yes" name="label">Save</property>
                            <property name="use-underline">False</property>
                            <accessibility>
                                <relation type="label-for" target="save_language_keyboard_switch"/>
                            </accessibility>
                        </object>
                        <packing>
                            <property name="expand">False</property>
                            <property name="fill">True</property>
                            <property name="position">0</property>
                        </packing>
                    </child>
                    <child>
                        <object id="save_language_keyboard_switch" class="GtkSwitch">
                            <property name="visible">True</property>
                            <property name="can-focus">True</property>
                            <property name="halign">end</property>
                            <property name="valign">center</property>
                            <signal swapped="no" name="state-set" handler="cb_save_language_keyboard_switch_changed"/>
                            <child internal-child="accessible">
                                <object id="save_language_keyboard_switch-atkobject" class="AtkObject">
                                    <property translatable="yes" name="AtkObject::accessible-name">Save</property>
                                </object>
                            </child>
                        </object>
                        <packing>
                            <property name="expand">False</property>
                            <property name="fill">True</property>
                            <property name="position">1</property>
                        </packing>
                    </child>
                </object>
            </child>
        </object>
        <packing>
            <property name="expand">True</property>
            <property name="fill">True</property>
            <property name="position">1</property>
        </packing>
    </child>
        <child>
          <object id="box_storagecreate" class="GtkBox">
            <property name="can-focus">False</property>
            <property name="orientation">vertical</property>
            <property name="spacing">12</property>
            <child>
              <object id="create_tps_label" class="GtkLabel">
                <property name="visible">True</property>
                <property name="can-focus">False</property>
                <property name="halign">start</property>
                <property translatable="yes" name="label">_Persistent Storage</property>
                <property name="use-underline">True</property>
                <property name="mnemonic-widget">create_tps_switch</property>
                <attributes>
                  <attribute value="bold" name="weight"/>
                </attributes>
                <accessibility>
                  <relation type="label-for" target="create_tps_settings_listbox"/>
                </accessibility>
              </object>
              <packing>
                <property name="expand">False</property>
                <property name="fill">True</property>
                <property name="position">0</property>
              </packing>
            </child>
            <child>
              <object id="label_storagecreate_explain" class="GtkLabel">
                <property name="visible">True</property>
                <property name="can-focus">False</property>
                <property translatable="yes" name="label">You can save some of your files and configuration in an encrypted Persistent Storage on your elizaOS USB stick: your documents, browser bookmarks, Wi-Fi passwords, and so on.</property>
                <property name="wrap">True</property>
                <property name="track-visited-links">False</property>
                <property name="xalign">0</property>
              </object>
              <packing>
                <property name="expand">False</property>
                <property name="fill">True</property>
                <property name="position">1</property>
              </packing>
            </child>
            <child>
              <object class="GtkFrame">
                <property name="visible">True</property>
                <property name="can-focus">False</property>
                <property name="label-xalign">0</property>
                <child>
                  <object id="create_tps_settings_listbox" class="GtkListBox">
                    <property name="visible">True</property>
                    <property name="can-focus">False</property>
                    <property name="selection-mode">none</property>
                    <child>
                      <object id="create_tps_row" class="HdyActionRow">
                        <property name="visible">True</property>
                        <property name="can-focus">False</property>
                        <property translatable="yes" name="title">Create Persistent Storage</property>
                        <property name="icon-name">elizaos</property>
                        <property translatable="yes" name="subtitle">Create and configure a Persistent Storage after starting elizaOS</property>
                        <child>
                          <object id="create_tps_row_box" class="GtkBox">
                            <property name="visible">True</property>
                            <property name="can-focus">False</property>
                            <property name="valign">center</property>
                            <property name="margin-start">6</property>
                            <property name="spacing">6</property>
                            <child>
                              <object id="create_tps_switch" class="GtkSwitch">
                                <property name="visible">True</property>
                                <property name="can-focus">True</property>
                                <property name="halign">end</property>
                                <property name="valign">center</property>
                                <signal swapped="no" name="notify::active" handler="cb_create_tps_switch_active_changed"/>
                                <child internal-child="accessible">
                                  <object id="create_tps_switch-atkobject" class="AtkObject">
                                    <property translatable="yes" name="AtkObject::accessible-name">Create Persistent Storage</property>
                                  </object>
                                </child>
                              </object>
                              <packing>
                                <property name="expand">False</property>
                                <property name="fill">True</property>
                                <property name="position">0</property>
                              </packing>
                            </child>
                          </object>
                        </child>
                      </object>
                    </child>
                    <accessibility>
                      <relation type="labelled-by" target="create_tps_label"/>
                    </accessibility>
                  </object>
                </child>
              </object>
              <packing>
                <property name="expand">True</property>
                <property name="fill">True</property>
                <property name="position">2</property>
              </packing>
            </child>
          </object>
          <packing>
            <property name="expand">False</property>
            <property name="fill">True</property>
            <property name="position">2</property>
          </packing>
        </child>
        <child>
          <object id="box_storage" class="GtkBox">
            <property name="visible">True</property>
            <property name="can-focus">False</property>
            <property name="orientation">vertical</property>
            <property name="spacing">6</property>
            <child>
              <object id="box_storage_header" class="GtkBox">
                <property name="visible">True</property>
                <property name="can-focus">False</property>
                <property name="spacing">8</property>
                <child>
                  <object id="label_storage_header_title" class="GtkLabel">
                    <property name="visible">True</property>
                    <property name="can-focus">False</property>
                    <property translatable="yes" name="label">_Persistent Storage</property>
                    <property name="use-underline">True</property>
                    <property name="mnemonic-widget">entry_storage_passphrase</property>
                    <attributes>
                      <attribute value="bold" name="weight"/>
                    </attributes>
                  </object>
                  <packing>
                    <property name="expand">False</property>
                    <property name="fill">True</property>
                    <property name="position">0</property>
                  </packing>
                </child>
                <child>
                  <object id="image_storage_state" class="GtkImage">
                    <property name="visible">True</property>
                    <property name="can-focus">False</property>
                    <property name="icon-name">tails-locked</property>
                  </object>
                  <packing>
                    <property name="expand">False</property>
                    <property name="fill">True</property>
                    <property name="position">1</property>
                  </packing>
                </child>
                <child>
                  <object id="checkbutton_storage_show_passphrase" class="GtkCheckButton">
                    <property translatable="yes" name="label">Show Passphrase</property>
                    <property name="can-focus">True</property>
                    <property name="receives-default">False</property>
                    <property name="xalign">0</property>
                    <property name="draw-indicator">True</property>
                  </object>
                  <packing>
                    <property name="expand">False</property>
                    <property name="fill">True</property>
                    <property name="pack-type">end</property>
                    <property name="position">3</property>
                  </packing>
                </child>
                <child>
                  <object id="linkbutton_storage_help" class="GtkLinkButton">
                    <property name="can-focus">True</property>
                    <property name="receives-default">True</property>
                    <property name="relief">none</property>
                    <property name="uri">doc.en.html#storage</property>
                    <signal swapped="no" name="activate-link" handler="cb_linkbutton_help_activate"/>
                    <child>
                      <object id="image_storage_help" class="GtkImage">
                        <property name="visible">True</property>
                        <property name="can-focus">False</property>
                        <property name="icon-name">tails-help</property>
                      </object>
                    </child>
                  </object>
                  <packing>
                    <property name="expand">False</property>
                    <property name="fill">True</property>
                    <property name="position">4</property>
                  </packing>
                </child>
                <child>
                  <placeholder/>
                </child>
              </object>
              <packing>
                <property name="expand">False</property>
                <property name="fill">True</property>
                <property name="position">0</property>
              </packing>
            </child>
            <child>
              <object id="box_storage_unlock" class="GtkBox">
                <property name="can-focus">False</property>
                <property name="spacing">6</property>
                <child>
                  <object class="GtkBox">
                    <property name="visible">True</property>
                    <property name="can-focus">False</property>
                    <child>
                      <object id="entry_storage_passphrase" class="GtkEntry">
                        <property name="visible">True</property>
                        <property name="can-focus">True</property>
                        <property name="visibility">False</property>
                        <property translatable="yes" name="placeholder-text">Enter your passphrase</property>
                        <signal swapped="no" name="activate" handler="cb_entry_storage_passphrase_activated"/>
                        <signal swapped="no" name="changed" handler="cb_entry_storage_passphrase_changed"/>
                        <style>
                          <class name="linked_left"/>
                        </style>
                      </object>
                      <packing>
                        <property name="expand">True</property>
                        <property name="fill">True</property>
                        <property name="position">1</property>
                      </packing>
                    </child>
                    <child>
                      <object id="button_storage_unlock" class="GtkButton">
                        <property translatable="yes" name="label">Unlock Encryption</property>
                        <property name="visible">True</property>
                        <property name="sensitive">False</property>
                        <property name="can-focus">True</property>
                        <property name="receives-default">True</property>
                        <signal swapped="no" name="clicked" handler="cb_button_storage_unlock_clicked"/>
                        <style>
                          <class name="suggested-action"/>
                          <class name="linked_right"/>
                        </style>
                      </object>
                      <packing>
                        <property name="expand">False</property>
                        <property name="fill">True</property>
                        <property name="position">2</property>
                      </packing>
                    </child>
                    <style>
                      <class name="linked"/>
                    </style>
                  </object>
                  <packing>
                    <property name="expand">True</property>
                    <property name="fill">True</property>
                    <property name="position">1</property>
                  </packing>
                </child>
              </object>
              <packing>
                <property name="expand">False</property>
                <property name="fill">True</property>
                <property name="position">2</property>
              </packing>
            </child>
            <child>
              <object id="box_storage_unlock_status" class="GtkBox">
                <property name="can-focus">False</property>
                <property name="spacing">5</property>
                <child>
                  <object id="image_storage_unlock_failed" class="GtkImage">
                    <property name="can-focus">False</property>
                    <property name="icon-name">dialog-warning</property>
                    <property name="valign">start</property>
                  </object>
                </child>
                <child>
                  <object id="spinner_storage_unlock" class="GtkSpinner">
                    <property name="can-focus">False</property>
                    <property name="active">True</property>
                  </object>
                </child>
                <child>
                  <object id="label_storage_unlock_status" class="GtkLabel">
                    <property name="can-focus">False</property>
                    <property name="xalign">0</property>
                    <property name="wrap">True</property>
                  </object>
                </child>
              </object>
            </child>
            <child>
              <object id="box_storage_error" class="GtkBox">
                <property name="can-focus">False</property>
                <child>
                  <object id="label_storage_error" class="GtkLabel">
                    <property name="visible">True</property>
                    <property name="can-focus">False</property>
                    <property translatable="yes" name="label">Impossible to unlock the Persistent Storage.</property>
                    <property name="xalign">0</property>
                  </object>
                  <packing>
                    <property name="expand">False</property>
                    <property name="fill">True</property>
                    <property name="position">0</property>
                  </packing>
                </child>
                <child>
                  <object id="linkbutton_storage_readonly_help" class="GtkLinkButton">
                    <property name="visible">True</property>
                    <property name="can-focus">True</property>
                    <property name="receives-default">True</property>
                    <property name="relief">none</property>
                    <property name="uri">doc/persistent_storage/use.en.html#read-only</property>
                    <signal swapped="no" name="activate-link" handler="cb_linkbutton_help_activate"/>
                    <child>
                      <object id="image_storage_readonly_help" class="GtkImage">
                        <property name="visible">True</property>
                        <property name="can-focus">False</property>
                        <property name="icon-name">tails-help</property>
                      </object>
                    </child>
                  </object>
                  <packing>
                    <property name="expand">False</property>
                    <property name="fill">True</property>
                    <property name="position">1</property>
                  </packing>
                </child>
              </object>
              <packing>
                <property name="expand">False</property>
                <property name="fill">True</property>
                <property name="position">4</property>
              </packing>
            </child>
          </object>
          <packing>
            <property name="expand">True</property>
            <property name="fill">True</property>
            <property name="position">3</property>
          </packing>
        </child>
        <child>
          <object id="box_partition_errors" class="GtkBox">
            <property name="visible">False</property>
            <property name="can-focus">False</property>
            <property name="orientation">vertical</property>
            <property name="spacing">6</property>
            <child>
              <object id="box_partition_errors_header" class="GtkBox">
                <property name="visible">True</property>
                <property name="can-focus">False</property>
                <property name="spacing">8</property>
                <child>
                  <object id="label_partition_errors_header_title" class="GtkLabel">
                    <property name="visible">True</property>
                    <property name="can-focus">False</property>
                    <property translatable="yes" name="label">Partitioning Errors</property>
                    <property name="use-underline">True</property>
                    <property name="mnemonic-widget">entry_storage_passphrase</property>
                    <attributes>
                      <attribute value="bold" name="weight"/>
                    </attributes>
                  </object>
                  <packing>
                    <property name="expand">False</property>
                    <property name="fill">True</property>
                    <property name="position">0</property>
                  </packing>
                </child>
                <child>
                  <object id="image_partition_errors" class="GtkImage">
                    <property name="visible">True</property>
                    <property name="can-focus">False</property>
                    <property name="icon-name">dialog-warning</property>
                  </object>
                  <packing>
                    <property name="expand">False</property>
                    <property name="fill">True</property>
                    <property name="position">1</property>
                  </packing>
                </child>
              </object>
              <packing>
                <property name="expand">False</property>
                <property name="fill">True</property>
                <property name="position">0</property>
              </packing>
            </child>
            <child>
              <object id="label_partition_errors" class="GtkLabel">
                <property name="visible">True</property>
                <property name="can-focus">False</property>
                <property translatable="yes" name="label">Errors were detected in the partitioning of your elizaOS USB stick.

Try reinstalling elizaOS. If the error persists, reinstall on a new USB stick.</property>
                <property name="xalign">0</property>
              </object>
              <packing>
                <property name="expand">False</property>
                <property name="fill">True</property>
                <property name="position">1</property>
              </packing>
            </child>
          </object>
          <packing>
            <property name="expand">True</property>
            <property name="fill">True</property>
            <property name="position">4</property>
          </packing>
        </child>
        <child>
          <object id="box_settings" class="GtkBox">
            <property name="visible">True</property>
            <property name="can-focus">False</property>
            <property name="orientation">vertical</property>
            <property name="spacing">6</property>
            <child>
              <object id="box_settings_header" class="GtkBox">
                <property name="visible">True</property>
                <property name="can-focus">False</property>
                <child>
                  <object id="label_settings_header_title" class="GtkLabel">
                    <property name="visible">True</property>
                    <property name="can-focus">False</property>
                    <property translatable="yes" name="label">_Additional Settings</property>
                    <property name="use-underline">True</property>
                    <property name="mnemonic-widget">toolbutton_settings_add</property>
                    <attributes>
                      <attribute value="bold" name="weight"/>
                    </attributes>
                  </object>
                  <packing>
                    <property name="expand">False</property>
                    <property name="fill">True</property>
                    <property name="position">0</property>
                  </packing>
                </child>
                <child>
                  <object id="linkbutton_settings_help" class="GtkLinkButton">
                    <property name="visible">True</property>
                    <property name="can-focus">False</property>
                    <property name="receives-default">True</property>
                    <property name="relief">none</property>
                    <property name="uri">doc/first_steps/welcome_screen.en.html#additional</property>
                    <signal swapped="no" name="activate-link" handler="cb_linkbutton_help_activate"/>
                    <child>
                      <object id="image_settings_help" class="GtkImage">
                        <property name="visible">True</property>
                        <property name="can-focus">False</property>
                        <property name="icon-name">tails-help</property>
                      </object>
                    </child>
                  </object>
                  <packing>
                    <property name="expand">False</property>
                    <property name="fill">True</property>
                    <property name="position">1</property>
                  </packing>
                </child>
                <child>
                  <placeholder/>
                </child>
              </object>
              <packing>
                <property name="expand">False</property>
                <property name="fill">True</property>
                <property name="position">0</property>
              </packing>
            </child>
            <child>
              <object id="box_settings_values" class="GtkBox">
                <property name="visible">True</property>
                <property name="can-focus">False</property>
                <property name="orientation">vertical</property>
                <child>
                  <object id="frame_settings" class="GtkFrame">
                    <property name="visible">True</property>
                    <property name="can-focus">False</property>
                    <property name="label-xalign">0</property>
                    <property name="shadow-type">in</property>
                    <child>
                      <object id="listbox_settings" class="GtkListBox">
                        <property name="visible">True</property>
                        <property name="can-focus">False</property>
                        <signal swapped="no" name="row-activated" handler="cb_listbox_settings_row_activated" after="yes"/>
                      </object>
                    </child>
                    <child type="label_item">
                      <placeholder/>
                    </child>
                  </object>
                  <packing>
                    <property name="expand">True</property>
                    <property name="fill">True</property>
                    <property name="position">0</property>
                  </packing>
                </child>
                <child>
                  <object id="toolbar_settings" class="GtkToolbar">
                    <property name="visible">True</property>
                    <property name="can-focus">False</property>
                    <property name="show-arrow">False</property>
                    <property name="icon_size">2</property>
                    <child>
                      <object id="toolbutton_settings_add" class="GtkToolButton">
                        <property name="visible">True</property>
                        <property name="can-focus">False</property>
                        <property translatable="yes" name="label">Add an additional setting</property>
                        <property name="icon-name">list-add-symbolic</property>
                        <signal swapped="no" name="clicked" handler="cb_toolbutton_settings_add_clicked"/>
                        <signal swapped="no" name="mnemonic-activate" handler="cb_toolbutton_settings_mnemonic_activate"/>
                      </object>
                      <packing>
                        <property name="expand">False</property>
                        <property name="homogeneous">True</property>
                      </packing>
                    </child>
                    <style>
                      <class name="inline-toolbar"/>
                    </style>
                  </object>
                  <packing>
                    <property name="expand">False</property>
                    <property name="fill">True</property>
                    <property name="position">1</property>
                  </packing>
                </child>
              </object>
              <packing>
                <property name="expand">True</property>
                <property name="fill">True</property>
                <property name="position">1</property>
              </packing>
            </child>
          </object>
          <packing>
            <property name="expand">True</property>
            <property name="fill">True</property>
            <property name="position">5</property>
          </packing>
        </child>
      </object>
      <packing>
        <property name="expand">True</property>
        <property name="fill">True</property>
        <property name="position">3</property>
      </packing>
    </child>
  </object>
  <object id="headerbar" class="GtkHeaderBar">
    <property name="visible">True</property>
    <property name="can-focus">False</property>
    <child>
      <object id="button_shutdown" class="GtkButton">
        <property translatable="yes" name="label">Shutdown</property>
        <property name="visible">True</property>
        <property name="can-focus">True</property>
        <property name="receives-default">False</property>
        <signal swapped="no" name="clicked" handler="cb_button_shutdown_clicked"/>
      </object>
    </child>
    <child>
      <object id="button_start" class="GtkButton">
        <property translatable="yes" name="label">_Start elizaOS</property>
        <property name="visible">True</property>
        <property name="can-focus">True</property>
        <property name="receives-default">False</property>
        <property name="use-underline">True</property>
        <signal swapped="no" name="clicked" handler="cb_button_start_clicked"/>
        <style>
          <class name="suggested-action"/>
        </style>
      </object>
      <packing>
        <property name="pack-type">end</property>
        <property name="position">1</property>
      </packing>
    </child>
  </object>
  <object class="GtkSizeGroup">
    <widgets>
      <widget name="button_shutdown"/>
      <widget name="button_start"/>
    </widgets>
  </object>
  <object id="label_settings_default" class="GtkLabel">
    <property name="visible">True</property>
    <property name="can-focus">False</property>
    <property name="margin-left">6</property>
    <property name="margin-right">6</property>
    <property name="margin-top">6</property>
    <property name="margin-bottom">6</property>
    <property translatable="yes" name="label">The default settings are safe in most situations. To add a custom setting, press the "+" button below.</property>
    <property name="justify">fill</property>
    <property name="wrap">True</property>
    <property name="lines">2</property>
    <property name="xalign">0</property>
    <property name="yalign">0</property>
  </object>
  <object id="listbox_add_setting" class="GtkListBox">
    <property name="width-request">400</property>
    <property name="visible">True</property>
    <property name="can-focus">False</property>
    <property name="margin-left">18</property>
    <property name="margin-right">18</property>
    <property name="margin-top">18</property>
    <property name="margin-bottom">18</property>
    <signal swapped="no" name="focus" handler="cb_listbox_add_setting_focus" after="yes"/>
    <signal swapped="no" name="row-activated" handler="cb_listbox_add_setting_row_activated"/>
  </object>
  <object id="liststore_settings_add" class="GtkListStore">
    <columns>
      
      <column type="gchararray"/>
      
      <column type="gchararray"/>
    </columns>
    <data>
      <row>
        <col id="0">admin-account</col>
        <col translatable="yes" id="1">Administration Password</col>
      </row>
      <row>
        <col id="0">mac-spoofing</col>
        <col translatable="yes" id="1">MAC Address Anonymization</col>
      </row>
      <row>
        <col id="0">network-configuration</col>
        <col translatable="yes" id="1">Network Configuration</col>
      </row>
    </data>
  </object>
</interface>