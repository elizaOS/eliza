<?xml version="1.0" encoding="UTF-8"?>
<interface domain="tails">
  <requires version="3.0" lib="gtk+"/>
  <object id="image_next" class="GtkImage">
    <property name="visible">True</property>
    <property name="can_focus">False</property>
    <property name="icon_name">next</property>
  </object>
  <object id="image_question" class="GtkImage">
    <property name="visible">True</property>
    <property name="can_focus">False</property>
    <property name="icon_name">gtk-dialog-question</property>
  </object>
  <object id="isofilter" class="GtkFileFilter">
    <patterns>
      <pattern>*.iso</pattern>
      <pattern>*.ISO</pattern>
    </patterns>
  </object>
  <object id="liststore_target" class="GtkListStore">
    <columns>
      
      <column type="gchararray"/>
      
      <column type="gchararray"/>
    </columns>
  </object>
  <object id="box_installer" class="GtkBox">
    <property name="visible">True</property>
    <property name="can_focus">False</property>
    <property name="orientation">vertical</property>
    <child>
      <object id="image_header" class="GtkImage">
        <property name="visible">True</property>
        <property name="can_focus">False</property>
        <property name="halign">baseline</property>
        <property name="xalign">0</property>
        <property name="pixbuf">tails-liveusb-header.png</property>
      </object>
      <packing>
        <property name="expand">True</property>
        <property name="fill">True</property>
        <property name="position">0</property>
      </packing>
    </child>
    <child>
      <object id="infobar" class="GtkInfoBar">
        <property name="app_paintable">True</property>
        <property name="can_focus">False</property>
        <property name="no_show_all">True</property>
        <property name="show_close_button">True</property>
        <signal swapped="no" name="response" handler="on_infobar_response"/>
        <child internal-child="action_area">
          <object id="infobar-action_area" class="GtkButtonBox">
            <property name="can_focus">False</property>
            <property name="spacing">6</property>
            <property name="layout_style">end</property>
            <child>
              <placeholder/>
            </child>
            <child>
              <placeholder/>
            </child>
            <child>
              <placeholder/>
            </child>
          </object>
          <packing>
            <property name="expand">False</property>
            <property name="fill">False</property>
            <property name="position">0</property>
          </packing>
        </child>
        <child internal-child="content_area">
          <object id="infobar-content_area" class="GtkBox">
            <property name="can_focus">False</property>
            <property name="orientation">vertical</property>
            <property name="spacing">6</property>
            <child>
              <object id="label_infobar_title" class="GtkLabel">
                <property name="visible">True</property>
                <property name="can_focus">False</property>
                <property name="wrap">True</property>
                <property name="xalign">0</property>
                <attributes>
                  <attribute value="bold" name="weight"/>
                </attributes>
              </object>
              <packing>
                <property name="expand">False</property>
                <property name="fill">True</property>
                <property name="position">0</property>
              </packing>
            </child>
            <child>
              <object id="label_infobar_details" class="GtkLabel">
                <property name="visible">True</property>
                <property name="can_focus">False</property>
                <property name="wrap">True</property>
                <property name="xalign">0</property>
              </object>
              <packing>
                <property name="expand">False</property>
                <property name="fill">True</property>
                <property name="position">1</property>
              </packing>
            </child>
            <child>
              <placeholder/>
            </child>
          </object>
          <packing>
            <property name="expand">False</property>
            <property name="fill">False</property>
            <property name="position">0</property>
          </packing>
        </child>
        <child>
          <placeholder/>
        </child>
      </object>
      <packing>
        <property name="expand">False</property>
        <property name="fill">True</property>
        <property name="position">1</property>
      </packing>
    </child>
    <child>
      <object id="help_link" class="GtkLinkButton">
        <property translatable="yes" name="label">Installation Instructions</property>
        <property name="visible">True</property>
        <property name="can_focus">False</property>
        <property name="receives_default">False</property>
        <property name="margin_right">18</property>
        <property name="xalign">1</property>
        <property name="uri">install</property>
	<signal swapped="no" name="activate-link" handler="on_activate_link_button"/>
      </object>
      <packing>
        <property name="expand">False</property>
        <property name="fill">True</property>
        <property name="position">2</property>
      </packing>
    </child>
    <child>
      <object id="box_source" class="GtkBox">
        <property name="visible">True</property>
        <property name="can_focus">False</property>
        <property name="margin_left">18</property>
        <property name="margin_right">18</property>
        <property name="margin_top">18</property>
        <property name="margin_bottom">12</property>
        <property name="orientation">vertical</property>
        <property name="spacing">6</property>
        <child>
          <object id="box_source_select" class="GtkBox">
            <property name="visible">True</property>
            <property name="can_focus">False</property>
            <property name="orientation">vertical</property>
            <property name="spacing">6</property>
            <child>
              <object id="radio_button_source_device" class="GtkRadioButton">
                <property translatable="yes" name="label">Clone the current elizaOS</property>
                <property name="visible">True</property>
                <property name="can_focus">False</property>
                <property name="receives_default">False</property>
                <property name="xalign">0</property>
                <property name="draw_indicator">True</property>
                <property name="group">radio_button_source_iso</property>
              </object>
              <packing>
                <property name="expand">False</property>
                <property name="fill">False</property>
                <property name="position">0</property>
              </packing>
            </child>
            <child>
              <object id="check_button_clone_persistent_storage" class="GtkCheckButton">
                <property translatable="yes" name="label">Clone the current Persistent Storage</property>
                <property name="visible">True</property>
                <property name="sensitive">False</property>
                <property name="margin_start">20</property>
                <property name="draw_indicator">True</property>
                <signal swapped="no" name="toggled" handler="on_check_button_clone_persistent_storage_toggled"/>
              </object>
              <packing>
                <property name="expand">False</property>
                <property name="fill">False</property>
                <property name="position">1</property>
              </packing>
            </child>
            <child>
              <object id="box_source_file" class="GtkBox">
                <property name="visible">True</property>
                <property name="can_focus">False</property>
                <property name="spacing">6</property>
                <child>
                  <object id="radio_button_source_iso" class="GtkRadioButton">
                    <property translatable="yes" name="label">Use a downloaded elizaOS ISO image</property>
                    <property name="visible">True</property>
                    <property name="can_focus">False</property>
                    <property name="receives_default">False</property>
                    <property name="xalign">0</property>
                    <property name="draw_indicator">True</property>
                    <signal swapped="no" name="toggled" handler="on_radio_button_source_iso_toggled"/>
                  </object>
                  <packing>
                    <property name="expand">False</property>
                    <property name="fill">False</property>
                    <property name="position">0</property>
                  </packing>
                </child>
                <child>
                  <object id="help_link_question" class="GtkLinkButton">
                    <property name="visible">True</property>
                    <property name="can_focus">False</property>
                    <property name="receives_default">False</property>
                    <property name="image">image_question</property>
                    <property name="always_show_image">True</property>
                    <property name="uri">https://elizaos.ai/</property>
                  </object>
                  <packing>
                    <property name="expand">False</property>
                    <property name="fill">True</property>
                    <property name="position">1</property>
                  </packing>
                </child>
                <child>
                  <object id="filechooserbutton_source_file" class="GtkFileChooserButton">
                    <property name="visible">True</property>
                    <property name="can_focus">False</property>
                    <property name="filter">isofilter</property>
                    <property name="width_chars">17</property>
                    <signal swapped="no" name="file-set" handler="on_source_file_set"/>
                  </object>
                  <packing>
                    <property name="expand">False</property>
                    <property name="fill">True</property>
                    <property name="position">2</property>
                  </packing>
                </child>
              </object>
              <packing>
                <property name="expand">False</property>
                <property name="fill">True</property>
                <property name="position">2</property>
              </packing>
            </child>
          </object>
          <packing>
            <property name="expand">False</property>
            <property name="fill">True</property>
            <property name="position">0</property>
          </packing>
        </child>
        <child>
          <placeholder/>
        </child>
      </object>
      <packing>
        <property name="expand">False</property>
        <property name="fill">True</property>
        <property name="position">3</property>
      </packing>
    </child>
    <child>
      <object id="box_target" class="GtkBox">
        <property name="visible">True</property>
        <property name="can_focus">False</property>
        <property name="margin_left">18</property>
        <property name="margin_right">18</property>
        <property name="margin_bottom">12</property>
        <property name="orientation">vertical</property>
        <property name="spacing">6</property>
        <child>
          <object id="label_target" class="GtkLabel">
            <property name="visible">True</property>
            <property name="can_focus">False</property>
            <property name="margin_top">12</property>
            <property translatable="yes" name="label">Target USB stick:</property>
            <property name="xalign">0</property>
            <attributes>
              <attribute value="bold" name="weight"/>
            </attributes>
          </object>
          <packing>
            <property name="expand">False</property>
            <property name="fill">True</property>
            <property name="position">0</property>
          </packing>
        </child>
        <child>
          <object id="combobox_target" class="GtkComboBox">
            <property name="visible">True</property>
            <property name="can_focus">False</property>
            <property name="model">liststore_target</property>
            <signal swapped="no" name="changed" handler="on_target_partitions_changed"/>
          </object>
          <packing>
            <property name="expand">False</property>
            <property name="fill">True</property>
            <property name="position">1</property>
          </packing>
        </child>
      </object>
      <packing>
        <property name="expand">False</property>
        <property name="fill">True</property>
        <property name="position">4</property>
      </packing>
    </child>
    <child>
      <object id="scrolledwindow_log" class="GtkScrolledWindow">
        <property name="visible">True</property>
        <property name="can_focus">True</property>
        <property name="margin_left">18</property>
        <property name="margin_right">18</property>
        <property name="margin_bottom">6</property>
        <property name="shadow_type">in</property>
        <property name="min_content_height">130</property>
        <child>
          <object id="textview_log" class="GtkTextView">
            <property name="visible">True</property>
            <property name="can_focus">True</property>
            <property name="editable">False</property>
            <property name="wrap_mode">word</property>
            <property name="left_margin">6</property>
            <property name="right_margin">6</property>
            <property name="cursor_visible">False</property>
            <property name="accepts_tab">False</property>
          </object>
        </child>
      </object>
      <packing>
        <property name="expand">True</property>
        <property name="fill">True</property>
        <property name="position">5</property>
      </packing>
    </child>
    <child>
      <object id="progressbar_progress" class="GtkProgressBar">
        <property name="visible">True</property>
        <property name="can_focus">False</property>
        <property name="margin_left">18</property>
        <property name="margin_right">18</property>
        <property name="margin_bottom">12</property>
      </object>
      <packing>
        <property name="expand">False</property>
        <property name="fill">True</property>
        <property name="position">6</property>
      </packing>
    </child>
    <child>
      <object id="check_force_reinstall" class="GtkLinkButton">
        <property translatable="yes" name="label">Reinstall (delete all data)</property>
        <property name="can_focus">True</property>
        <property name="receives_default">False</property>
        <property name="margin_left">18</property>
        <property name="margin_right">18</property>
        <property name="margin_bottom">18</property>
        <property name="xalign">1</property>
        <signal swapped="no" name="activate-link" handler="on_force_reinstall_clicked"/>
      </object>
      <packing>
        <property name="expand">False</property>
        <property name="fill">True</property>
        <property name="position">7</property>
      </packing>
    </child>
    <child>
      <object id="button_start" class="GtkButton">
        <property translatable="yes" name="label">Install</property>
        <property name="name">1</property>
        <property name="visible">True</property>
        <property name="can_focus">True</property>
        <property name="receives_default">True</property>
        <property name="margin_left">18</property>
        <property name="margin_right">18</property>
        <property name="margin_bottom">18</property>
        <property name="image">image_next</property>
        <signal swapped="no" name="clicked" handler="on_start_clicked"/>
      </object>
      <packing>
        <property name="expand">False</property>
        <property name="fill">True</property>
        <property name="position">8</property>
      </packing>
    </child>
  </object>
</interface>