#!/bin/sh

set -eu

runtime_dir=/run/user/1000
session_flag="${runtime_dir}/elizaos-persistence-setup"
maintenance_helper=/usr/local/lib/elizaos/persistence-maintenance

[ ! -e "${session_flag}" ] || exit 0
[ -x "${maintenance_helper}" ] || exit 0

"${maintenance_helper}" enter || true
"${maintenance_helper}" leave || true
