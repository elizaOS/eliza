<?xml version="1.0" encoding="UTF-8"?>
<interface>
  
  <requires version="3.24" lib="gtk+"/>
  <object id="box" class="GtkBox">
    <property name="margin-bottom">20</property>
    <property name="margin-end">20</property>
    <property name="margin-start">20</property>
    <property name="margin-top">20</property>
    <property name="orientation">vertical</property>
    <property name="spacing">50</property>
    <property name="visible">True</property>
    <child>
      <object class="GtkScrolledWindow">
        <property name="can-focus">True</property>
        <property name="hexpand">True</property>
        <property name="hscrollbar-policy">never</property>
        <property name="kinetic-scrolling">False</property>
        <property name="overlay-scrolling">False</property>
        <property name="vexpand">True</property>
        <property name="visible">True</property>
        <property name="window-placement-set">False</property>
        <child>
          <object class="GtkViewport">
            <property name="shadow-type">none</property>
            <property name="visible">True</property>
            <child>
              
              <object id="description_box" class="GtkGrid">
                <property name="column-spacing">40</property>
                <property name="halign">center</property>
                <property name="orientation">vertical</property>
                <property name="row-spacing">50</property>
                <property name="valign">center</property>
                <property name="vexpand">True</property>
                <property name="visible">True</property>
                <child>
                  <object id="image" class="GtkImage">
                    <property name="halign">end</property>
                    <property name="pixbuf">/usr/share/pixmaps/elizaos.svg</property>
                    <property name="valign">start</property>
                    <property name="visible">True</property>
                  </object>
                  <packing>
                    <property name="left-attach">0</property>
                    <property name="top-attach">0</property>
                  </packing>
                </child>
                <child>
                  <object id="welcome_label" class="GtkLabel">
                    <property name="can-default">False</property>
                    <property name="can-focus">True</property>
                    <property name="halign">start</property>
                    <property translatable="yes" name="label">Everything you do disappears automatically when you shut down elizaOS.

But you can save some of your files and configuration in an encrypted Persistent Storage on your elizaOS USB stick, for example:

• Your documents
• Your Wi-Fi passwords
• Your browser bookmarks
• ...

&lt;a href="doc/persistent_storage"&gt;Learn more about the Persistent Storage.&lt;/a&gt;</property>
                    <property name="max-width-chars">50</property>
                    <property name="use-markup">True</property>
                    <property name="visible">True</property>
                    <property name="wrap">True</property>
                    <signal name="activate-link" handler="on_activate_link"/>
                  </object>
                  <packing>
                    <property name="left-attach">1</property>
                    <property name="top-attach">0</property>
                  </packing>
                </child>
                <child>
                  <object id="warning_icon" class="GtkImage">
                    <property name="halign">end</property>
                    <property name="icon-name">gtk-dialog-warning</property>
                    <property name="icon-size">6</property>
                    <property name="valign">start</property>
                    <property name="visible">True</property>
                  </object>
                  <packing>
                    <property name="left-attach">0</property>
                    <property name="top-attach">1</property>
                  </packing>
                </child>
                <child>
                  <object id="device_not_supported_label" class="GtkLabel">
                    <property name="halign">start</property>
                    <property translatable="yes" name="label">Sorry, it is impossible to create a Persistent Storage on this device.

To be able to use elizaOS with a Persistent Storage, please follow our instructions on &lt;a href="install"&gt;installing elizaOS on a USB stick&lt;/a&gt;.</property>
                    <property name="max-width-chars">50</property>
                    <property name="use-markup">True</property>
                    <property name="wrap">True</property>
                    <signal name="activate-link" handler="on_activate_link"/>
                  </object>
                  <packing>
                    <property name="left-attach">1</property>
                    <property name="top-attach">1</property>
                  </packing>
                </child>
              </object>
            </child>
          </object>
        </child>
      </object>
      <packing>
        <property name="expand">True</property>
        <property name="fill">True</property>
        <property name="position">0</property>
      </packing>
    </child>
    <child>
      <object class="GtkBox">
        <property name="visible">True</property>
        <child>
          <object id="cancel_button" class="GtkButton">
            <property name="can-focus">True</property>
            <property name="halign">start</property>
            <property translatable="yes" name="label">_Cancel</property>
            <property name="receives-default">False</property>
            <property name="use-underline">True</property>
            <property name="visible">True</property>
            <signal name="clicked" handler="on_cancel_button_clicked"/>
          </object>
          <packing>
            <property name="expand">False</property>
            <property name="fill">True</property>
            <property name="position">0</property>
          </packing>
        </child>
        <child>
          <object id="continue_button" class="GtkButton">
            <property name="can-default">True</property>
            <property name="can-focus">True</property>
            <property name="halign">end</property>
            <property translatable="yes" name="label">Co_ntinue</property>
            <property name="receives-default">True</property>
            <property name="use-underline">True</property>
            <property name="visible">True</property>
            <signal name="clicked" handler="on_continue_button_clicked"/>
            <style>
              <class name="suggested-action"/>
            </style>
          </object>
          <packing>
            <property name="expand">False</property>
            <property name="fill">True</property>
            <property name="pack-type">end</property>
            <property name="position">1</property>
          </packing>
        </child>
      </object>
      <packing>
        <property name="expand">False</property>
        <property name="fill">True</property>
        <property name="pack-type">end</property>
        <property name="position">1</property>
      </packing>
    </child>
  </object>
</interface>