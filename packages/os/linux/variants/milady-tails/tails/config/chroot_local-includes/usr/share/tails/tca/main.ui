<?xml version="1.0" encoding="UTF-8"?>
<interface domain="tails">
  <requires version="3.24" lib="gtk+"/>
  <object id="box_main_container" class="GtkBox">
    <property name="visible">True</property>
    <property name="can-focus">False</property>
    <property name="orientation">vertical</property>
    <child>
      <object class="GtkBox">
        <property name="height-request">650</property>
        <property name="visible">True</property>
        <property name="can-focus">False</property>
        <property name="baseline-position">bottom</property>
        <child>
          <object id="main_img_side" class="GtkImage">
            <property name="name">main_img_side</property>
            <property name="visible">True</property>
            <property name="can-focus">False</property>
            <property name="halign">start</property>
            <property name="valign">center</property>
            <property name="stock">gtk-missing-image</property>
            <child internal-child="accessible">
              <object id="main_img_side-atkobject" class="AtkObject">
                <property translatable="no" name="AtkObject::accessible-role">image</property>
              </object>
            </child>
          </object>
          <packing>
            <property name="expand">False</property>
            <property name="fill">True</property>
            <property name="position">0</property>
          </packing>
        </child>
        <child>
          <object id="box_main_container_scroll" class="GtkScrolledWindow">
            <property name="visible">True</property>
            <property name="can-focus">True</property>
            <property name="hscrollbar-policy">never</property>
            <property name="propagate-natural-height">True</property>
            <child>
              <object class="GtkViewport">
                <property name="visible">True</property>
                <property name="can-focus">False</property>
                <child>
                  <object id="box_main_container_stack" class="GtkStack">
                    <property name="name">box_main_container_stack</property>
                    <property name="visible">True</property>
                    <property name="can-focus">False</property>
                    <property name="vhomogeneous">False</property>
                    <child>
                      <placeholder/>
                    </child>
                  </object>
                </child>
              </object>
            </child>
          </object>
          <packing>
            <property name="expand">False</property>
            <property name="fill">False</property>
            <property name="position">1</property>
          </packing>
        </child>
      </object>
      <packing>
        <property name="expand">False</property>
        <property name="fill">True</property>
        <property name="position">20</property>
      </packing>
    </child>
  </object>
  <object id="step_bridge_box" class="GtkBox">
    <property name="visible">True</property>
    <property name="can-focus">False</property>
    <property name="orientation">vertical</property>
    <child>
      <object id="step_bridge_box_heading" class="GtkLabel">
        <property name="visible">True</property>
        <property name="can-focus">False</property>
        <property name="halign">start</property>
        <property translatable="yes" name="label">Configure a Tor bridge</property>
        <accessibility>
          <relation type="label-for" target="step_bridge_box"/>
        </accessibility>
        <child internal-child="accessible">
          <object id="step_bridge_box_heading-atkobject" class="AtkObject">
            <property translatable="no" name="AtkObject::accessible-role">heading</property>
          </object>
        </child>
        <style>
          <class name="step-title"/>
        </style>
      </object>
      <packing>
        <property name="expand">False</property>
        <property name="fill">True</property>
        <property name="position">0</property>
      </packing>
    </child>
    <child>
      <object class="GtkLabel">
        <property name="visible">True</property>
        <property name="can-focus">False</property>
        <property name="halign">start</property>
        <property translatable="yes" name="label">Bridges are secret Tor relays. Use a bridge as your first Tor relay if accessing Tor is blocked from where you are.

You can use &lt;i&gt;obfs4&lt;/i&gt; and &lt;i&gt;WebTunnel&lt;/i&gt; bridges in elizaOS.
</property>
        <property name="use-markup">True</property>
        <property name="wrap">True</property>
        <property name="xalign">0</property>
      </object>
      <packing>
        <property name="expand">False</property>
        <property name="fill">True</property>
        <property name="position">1</property>
      </packing>
    </child>
    <child>
      <object class="GtkLabel">
        <property name="visible">True</property>
        <property name="can-focus">False</property>
        <property name="halign">start</property>
        <property name="margin-top">12</property>
        <property translatable="yes" name="label">&lt;a href="doc/anonymous_internet/tor"&gt;Learn more about Tor bridges&lt;/a&gt;</property>
        <property name="use-markup">True</property>
        <property name="track-visited-links">False</property>
        <signal swapped="no" name="activate-link" handler="on_link_help_clicked"/>
      </object>
      <packing>
        <property name="expand">False</property>
        <property name="fill">True</property>
        <property name="position">2</property>
      </packing>
    </child>
    <child>
      <object class="GtkBox">
        <property name="visible">True</property>
        <property name="can-focus">False</property>
        <property name="margin-top">18</property>
        <property name="orientation">vertical</property>
        <child>
          <object id="step_bridge_radio_default" class="GtkRadioButton">
            <property name="visible">True</property>
            <property name="can-focus">True</property>
            <property name="receives-default">False</property>
            <property name="margin-bottom">12</property>
            <property name="draw-indicator">True</property>
            <property name="group">step_bridge_radio_none</property>
            <signal swapped="no" name="toggled" handler="cb_step_bridge_radio_changed"/>
            <child>
              <object class="GtkBox">
                <property name="visible">True</property>
                <property name="can-focus">False</property>
                <child>
                  <object id="step_bridge_default_label" class="GtkLabel">
                    <property name="visible">True</property>
                    <property name="can-focus">False</property>
                    <property name="halign">start</property>
                    <property translatable="yes" name="label">Use a _default bridge</property>
                    <property name="use-underline">True</property>
                    <accessibility>
                      <relation type="label-for" target="step_bridge_combo"/>
                    </accessibility>
                  </object>
                  <packing>
                    <property name="expand">False</property>
                    <property name="fill">True</property>
                    <property name="position">0</property>
                  </packing>
                </child>
                <child>
                  <object id="step_bridge_combo" class="GtkComboBoxText">
                    <property name="visible">True</property>
                    <property name="sensitive">False</property>
                    <property name="can-focus">False</property>
                    <property name="halign">center</property>
                    <property name="valign">start</property>
                    <property name="margin-start">12</property>
                    <property name="active">0</property>
                    <property name="button-sensitivity">on</property>
                    <items>
                      <item translatable="yes" id="obfs4">obfs4 (recommended)</item>
                      <item translatable="yes" id="webtunnel">WebTunnel</item>
                    </items>
                    <accessibility>
                      <relation type="labelled-by" target="step_bridge_default_label"/>
                    </accessibility>
                  </object>
                  <packing>
                    <property name="expand">True</property>
                    <property name="fill">True</property>
                    <property name="position">1</property>
                  </packing>
                </child>
              </object>
            </child>
          </object>
          <packing>
            <property name="expand">False</property>
            <property name="fill">True</property>
            <property name="position">0</property>
          </packing>
        </child>
        <child>
          <object id="step_bridge_radio_none" class="GtkRadioButton">
            <property translatable="yes" name="label">None</property>
            <property name="can-focus">True</property>
            <property name="receives-default">False</property>
            <property name="halign">start</property>
            <property name="active">True</property>
            <property name="draw-indicator">True</property>
          </object>
          <packing>
            <property name="expand">False</property>
            <property name="fill">True</property>
            <property name="position">2</property>
          </packing>
        </child>
        <child>
          <object id="step_bridge_box_moat" class="GtkBox">
            <property name="visible">True</property>
            <property name="can-focus">False</property>
            <property name="halign">start</property>
            <property name="orientation">horizontal</property>
            <child>
              <object id="step_bridge_radio_moat" class="GtkRadioButton">
                <property name="visible">True</property>
                <property name="can-focus">True</property>
                <property name="receives-default">False</property>
                <property name="halign">start</property>
                <property name="margin-bottom">6</property>
                <property name="draw-indicator">True</property>
                <property name="group">step_bridge_radio_none</property>
                <signal swapped="no" name="toggled" handler="cb_step_bridge_radio_changed"/>
                <child>
                  <object id="step_bridge_label_moat" class="GtkLabel">
                    <property name="visible">True</property>
                    <property name="can-focus">False</property>
                    <property name="halign">start</property>
                    <property translatable="yes" name="label">Ask for a bridge based on your _region</property>
                    <property name="use-underline">True</property>
                  </object>
                </child>
              </object>
              <packing>
                <property name="expand">False</property>
                <property name="fill">True</property>
                <property name="position">0</property>
              </packing>
            </child>
            <child>
              <placeholder/>
            </child>
            <child>
              <object id="step_bridge_moat_region_combo" class="GtkComboBox">
                <property name="visible">True</property>
                <property name="sensitive">False</property>
                <property name="can-focus">False</property>
                <property name="button-sensitivity">on</property>
                <property name="margin-start">12</property>
                <property name="has-entry">True</property>
              </object>
              <packing>
                <property name="expand">True</property>
                <property name="fill">True</property>
                <property name="position">2</property>
              </packing>
            </child>
          </object>
          <packing>
            <property name="expand">False</property>
            <property name="fill">True</property>
            <property name="position">3</property>
          </packing>
        </child>
        <child>
          <object id="step_bridge_box_scan" class="GtkBox">
            <property name="visible">True</property>
            <property name="can-focus">False</property>
            <property name="valign">start</property>
            <property name="margin-top">18</property>
            <property name="margin-bottom">6</property>
            <property name="orientation">vertical</property>
            <child>
              <object id="step_bridge_radio_scan" class="GtkRadioButton">
                <property name="visible">True</property>
                <property name="can-focus">True</property>
                <property name="receives-default">False</property>
                <property name="halign">start</property>
                <property name="margin-bottom">6</property>
                <property name="draw-indicator">True</property>
                <property name="group">step_bridge_radio_none</property>
                <signal swapped="no" name="toggled" handler="cb_step_bridge_radio_changed"/>
                <child>
                  <object id="step_bridge_label_scan" class="GtkLabel">
                    <property name="visible">True</property>
                    <property name="can-focus">False</property>
                    <property name="halign">start</property>
                    <property translatable="yes" name="label">_Ask for a bridge by email</property>
                    <property name="use-underline">True</property>
                    <property name="mnemonic-widget">step_bridge_radio_scan</property>
                  </object>
                </child>
              </object>
              <packing>
                <property name="expand">False</property>
                <property name="fill">True</property>
                <property name="position">0</property>
              </packing>
            </child>
            <child>
              <object id="step_bridge_label_explain_scan" class="GtkLabel">
                <property name="visible">True</property>
                <property name="can-focus">False</property>
                <property name="halign">start</property>
                <property name="margin-start">24</property>
                <property name="margin-bottom">6</property>
                <property translatable="yes" name="label">Send an empty email to &lt;tt&gt;bridges@torproject.org&lt;/tt&gt; from a Gmail or Riseup email address with your phone and scan the QR code that is attached to the automatic reply.</property>
                <property name="use-markup">True</property>
                <property name="wrap">True</property>
                <property name="xalign">0</property>
              </object>
              <packing>
                <property name="expand">False</property>
                <property name="fill">True</property>
                <property name="position">1</property>
              </packing>
            </child>
            <child>
              <object id="step_bridge_btn_scanqrcode" class="GtkButton">
                <property translatable="yes" name="label">Scan _QR code</property>
                <property name="visible">True</property>
                <property name="can-focus">True</property>
                <property name="receives-default">False</property>
                <property name="margin-start">24</property>
                <property name="margin-top">6</property>
                <property name="use-underline">True</property>
                <signal swapped="no" name="clicked" handler="cb_step_bridge_btn_scanqrcode_clicked"/>
                <accessibility>
                  <relation type="controller-for" target="step_bridge_label_scanresult"/>
                </accessibility>
              </object>
              <packing>
                <property name="expand">False</property>
                <property name="fill">True</property>
                <property name="position">2</property>
              </packing>
            </child>
            <child>
              <object id="step_bridge_box_scanerror" class="GtkBox">
                <property name="can-focus">False</property>
                <property name="margin-start">24</property>
                <property name="margin-top">6</property>
                <child>
                  <object class="GtkImage">
                    <property name="visible">True</property>
                    <property name="can-focus">False</property>
                    <property name="icon-name">gtk-dialog-warning</property>
                  </object>
                  <packing>
                    <property name="expand">False</property>
                    <property name="fill">True</property>
                    <property name="position">0</property>
                  </packing>
                </child>
                <child>
                  <object id="step_bridge_label_scanerror" class="GtkLabel">
                    <property name="visible">True</property>
                    <property name="can-focus">False</property>
                    <property name="halign">start</property>
                    <property name="margin-start">12</property>
                    <property name="hexpand">True</property>
                    <property translatable="yes" name="label">Error</property>
                  </object>
                  <packing>
                    <property name="expand">False</property>
                    <property name="fill">True</property>
                    <property name="position">1</property>
                  </packing>
                </child>
              </object>
              <packing>
                <property name="expand">False</property>
                <property name="fill">True</property>
                <property name="position">3</property>
              </packing>
            </child>
            <child>
              <object id="step_bridge_label_scanresult" class="GtkLabel">
                <property name="can-focus">False</property>
                <property name="halign">start</property>
                <property name="margin-start">24</property>
                <property name="margin-top">6</property>
                <property name="use-markup">True</property>
              </object>
              <packing>
                <property name="expand">False</property>
                <property name="fill">True</property>
                <property name="position">4</property>
              </packing>
            </child>
          </object>
          <packing>
            <property name="expand">False</property>
            <property name="fill">True</property>
            <property name="position">3</property>
          </packing>
        </child>
        <child>
          <object id="step_bridge_box_type" class="GtkBox">
            <property name="visible">True</property>
            <property name="can-focus">False</property>
            <property name="valign">start</property>
            <property name="margin-top">18</property>
            <property name="margin-bottom">6</property>
            <property name="orientation">vertical</property>
            <child>
              <object id="step_bridge_radio_type" class="GtkRadioButton">
                <property name="visible">True</property>
                <property name="can-focus">True</property>
                <property name="receives-default">False</property>
                <property name="halign">start</property>
                <property name="margin-bottom">6</property>
                <property name="draw-indicator">True</property>
                <property name="group">step_bridge_radio_none</property>
                <signal swapped="no" name="toggled" handler="cb_step_bridge_radio_changed"/>
                <child>
                  <object id="step_bridge_label_type" class="GtkLabel">
                    <property name="visible">True</property>
                    <property name="can-focus">False</property>
                    <property name="halign">start</property>
                    <property translatable="yes" name="label">_Enter a bridge that you already know</property>
                    <property name="use-underline">True</property>
                    <property name="mnemonic-widget">step_bridge_radio_type</property>
                  </object>
                </child>
              </object>
              <packing>
                <property name="expand">False</property>
                <property name="fill">True</property>
                <property name="position">0</property>
              </packing>
            </child>
            <child>
              <placeholder/>
            </child>
            <child>
              <object class="GtkBox">
                <property name="visible">True</property>
                <property name="can-focus">False</property>
                <property name="margin-start">24</property>
                <property name="margin-bottom">6</property>
                <property name="spacing">12</property>
                <child>
                  <object class="GtkLabel">
                    <property name="visible">True</property>
                    <property name="can-focus">False</property>
                    <property translatable="yes" name="label">Bridge</property>
                  </object>
                  <packing>
                    <property name="expand">False</property>
                    <property name="fill">True</property>
                    <property name="position">0</property>
                  </packing>
                </child>
                <child>
                  <object id="step_bridge_text" class="GtkEntry">
                    <property name="visible">True</property>
                    <property name="sensitive">False</property>
                    <property name="can-focus">True</property>
                    <property translatable="yes" name="placeholder-text">obfs4 or webtunnel…</property>
                    <property name="input-hints">GTK_INPUT_HINT_NO_SPELLCHECK | GTK_INPUT_HINT_NO_EMOJI | GTK_INPUT_HINT_NONE</property>
                    <signal swapped="no" name="backspace" handler="cb_step_bridge_text_changed"/>
                    <accessibility>
                      <relation type="controlled-by" target="step_bridge_btn_scanqrcode"/>
                      <relation type="labelled-by" target="step_bridge_radio_type"/>
                      <relation type="labelled-by" target="step_bridge_label_type"/>
                      <relation type="described-by" target="step_bridge_label_warning"/>
                      <relation type="described-by" target="step_bridge_persistence_help_label"/>
                    </accessibility>
                  </object>
                  <packing>
                    <property name="expand">False</property>
                    <property name="fill">True</property>
                    <property name="position">1</property>
                  </packing>
                </child>
              </object>
              <packing>
                <property name="expand">True</property>
                <property name="fill">True</property>
                <property name="position">2</property>
              </packing>
            </child>
            <child>
              <object id="step_bridge_box_warning" class="GtkBox">
                <property name="visible">True</property>
                <property name="can-focus">False</property>
                <property name="margin-start">30</property>
                <child>
                  <object class="GtkImage">
                    <property name="visible">True</property>
                    <property name="can-focus">False</property>
                    <property name="icon-name">gtk-dialog-warning</property>
                  </object>
                  <packing>
                    <property name="expand">False</property>
                    <property name="fill">True</property>
                    <property name="position">0</property>
                  </packing>
                </child>
                <child>
                  <object id="step_bridge_label_warning" class="GtkLabel">
                    <property name="visible">True</property>
                    <property name="can-focus">False</property>
                    <property name="halign">start</property>
                    <property name="margin-start">12</property>
                    <property name="hexpand">True</property>
                    <property translatable="yes" name="label">Error</property>
                  </object>
                  <packing>
                    <property name="expand">False</property>
