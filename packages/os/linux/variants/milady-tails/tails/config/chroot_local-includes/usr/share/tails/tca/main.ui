                  <object id="step_bridge_persistence_switch" class="GtkSwitch">
                    <property name="visible">True</property>
                    <property name="can-focus">True</property>
                    <property name="margin-start">12</property>
                    <signal swapped="no" name="state-set" handler="cb_step_bridge_persistence_switch_toggled"/>
