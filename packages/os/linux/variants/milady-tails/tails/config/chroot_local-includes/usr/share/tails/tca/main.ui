              <packing>
                <property name="expand">False</property>
                <property name="fill">True</property>
                <property name="position">5</property>
              </packing>
            </child>
            <child>
              <object id="step_bridge_persistence_switch_box" class="GtkBox">
                <property name="visible">True</property>
                <property name="can-focus">False</property>
                <property name="margin-start">30</property>
                <property name="margin-top">6</property>
                <child>
                  <object id="step_bridge_persistence_switch_label" class="GtkLabel">
                    <property name="visible">True</property>
                    <property name="can-focus">False</property>
                    <property translatable="yes" name="label">Save bridge to _Persistent Storage</property>
                    <property name="use-underline">True</property>
                    <property name="mnemonic-widget">step_bridge_persistence_switch</property>
