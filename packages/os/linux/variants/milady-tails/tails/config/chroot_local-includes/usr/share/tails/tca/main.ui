            <property name="valign">end</property>
            <property name="use-underline">True</property>
            <signal swapped="no" name="activate" handler="cb_step_proxy_btn_submit_clicked"/>
            <signal swapped="no" name="clicked" handler="cb_step_proxy_btn_submit_clicked"/>
            <style>
              <class name="suggested-action"/>
            </style>
          </object>
          <packing>
            <property name="expand">True</property>
            <property name="fill">True</property>
            <property name="position">2</property>
          </packing>
        </child>
        <style>
          <class name="suggested-action-box"/>
        </style>
      </object>
      <packing>
        <property name="expand">False</property>
        <property name="fill">True</property>
        <property name="position">2</property>
      </packing>
    </child>
    <style>
      <class name="step-box"/>
    </style>
  </object>
</interface>