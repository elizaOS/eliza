<?xml version="1.0" encoding="UTF-8"?>
<interface>
  
  <requires version="3.24" lib="gtk+"/>
  <object id="box" class="GtkBox">
    <property name="hexpand">True</property>
    <property name="margin-bottom">20</property>
    <property name="margin-end">20</property>
    <property name="margin-start">20</property>
    <property name="margin-top">20</property>
    <property name="orientation">vertical</property>
    <property name="vexpand">True</property>
    <property name="visible">True</property>
    <child>
      <object class="GtkScrolledWindow">
        <property name="hscrollbar-policy">never</property>
        <property name="vexpand">True</property>
        <property name="visible">True</property>
        <child>
          <object class="GtkViewport">
            <property name="shadow-type">none</property>
            <property name="visible">True</property>
            <child>
              <object class="GtkBox">
                <property name="margin-bottom">20</property>
                <property name="margin-end">20</property>
                <property name="margin-start">20</property>
                <property name="margin-top">20</property>
                <property name="orientation">vertical</property>
                <property name="spacing">50</property>
                <property name="valign">center</property>
                <property name="vexpand">True</property>
                <property name="visible">True</property>
                <child>
                  <object class="GtkBox">
                    <property name="spacing">50</property>
                    <property name="visible">True</property>
                    <child>
                      <object id="image1" class="GtkImage">
                        <property name="pixbuf">/usr/share/pixmaps/elizaos.svg</property>
                        <property name="visible">True</property>
                      </object>
                      <packing>
                        <property name="expand">False</property>
                        <property name="fill">True</property>
                        <property name="position">0</property>
                      </packing>
                    </child>
                    <child>
                      <object class="GtkBox">
                        <property name="can-focus">False</property>
                        <property name="orientation">vertical</property>
                        <property name="spacing">20</property>
                        <property name="visible">True</property>
                        <child>
                          <object id="placeholder_label1" class="GtkLabel">
                            <property name="can-focus">False</property>
                            <property translatable="yes" name="label">Choose the passphrase that you will use to unlock the encryption of your Persistent Storage and all its data.</property>
                            <property name="max-width-chars">50</property>
                            <property name="use-markup">True</property>
                            <property name="visible">True</property>
                            <property name="wrap">True</property>
                            <property name="xalign">0</property>
                          </object>
                          <packing>
                            <property name="expand">False</property>
                            <property name="fill">True</property>
                            <property name="position">1</property>
                          </packing>
                        </child>
                        <child>
                          <object class="GtkBox">
                            <property name="can-focus">False</property>
                            <property name="visible">True</property>
                            <child>
                              <object id="placeholder_label2" class="GtkLabel">
                                <property name="can-focus">False</property>
                                <property translatable="yes" name="label">We recommend a long passphrase of 5 to 7 random words.</property>
                                <property name="visible">True</property>
                              </object>
                              <packing>
                                <property name="expand">False</property>
                                <property name="fill">True</property>
                                <property name="position">0</property>
                              </packing>
                            </child>
                            <child>
                              <object id="placeholder_label3" class="GtkLabel">
                                <property name="can-focus">False</property>
                                <property translatable="yes" name="label"> For example:</property>
                                <property name="visible">True</property>
                              </object>
                              <packing>
                                <property name="expand">False</property>
                                <property name="fill">True</property>
                                <property name="position">1</property>
                              </packing>
                            </child>
                          </object>
                          <packing>
                            <property name="expand">False</property>
                            <property name="fill">True</property>
                            <property name="position">2</property>
                          </packing>
                        </child>
                        <child>
                          <object class="GtkBox">
                            <property name="can-focus">False</property>
                            <property name="spacing">10</property>
                            <property name="visible">True</property>
                            <child>
                              <object id="passphrase_suggestion_label" class="GtkLabel">
                                <property name="can-focus">False</property>
                                <property name="halign">start</property>
                                <property name="selectable">True</property>
                                <property name="visible">True</property>
                                <property name="xalign">0</property>
                              </object>
                              <packing>
                                <property name="expand">False</property>
                                <property name="fill">True</property>
                                <property name="position">0</property>
                              </packing>
                            </child>
                            <child>
                              <object class="GtkEventBox">
                                <property name="visible">True</property>
                                <signal name="button-press-event" handler="on_refresh_image_clicked"/>
                                <child>
                                  <object id="refresh_image" class="GtkImage">
                                    <property name="can-focus">False</property>
                                    <property name="stock">gtk-refresh</property>
                                    <property name="visible">True</property>
                                  </object>
                                </child>
                              </object>
                              <packing>
                                <property name="expand">False</property>
                                <property name="fill">True</property>
                                <property name="position">1</property>
                              </packing>
                            </child>
                          </object>
                          <packing>
                            <property name="expand">False</property>
                            <property name="fill">True</property>
                            <property name="position">3</property>
                          </packing>
                        </child>
                      </object>
                      <packing>
                        <property name="expand">False</property>
                        <property name="fill">True</property>
                        <property name="position">1</property>
                      </packing>
                    </child>
                  </object>
                  <packing>
                    <property name="expand">False</property>
                    <property name="fill">True</property>
                    <property name="position">0</property>
                  </packing>
                </child>
                <child>
                  
                  <object class="GtkGrid">
                    <property name="column-spacing">15</property>
                    <property name="row-spacing">5</property>
                    <property name="visible">True</property>
                    <child>
                      <object id="passphrase_entry_label" class="GtkLabel">
                        <property name="halign">start</property>
                        <property translatable="yes" name="label">Passphrase:</property>
                        <property name="visible">True</property>
                        <accessibility>
                          <relation type="label-for" target="passphrase_entry"/>
                        </accessibility>
                        <child internal-child="accessible">
                          <object class="AtkObject">
                            <property name="accessible-role">label</property>
                          </object>
                        </child>
                      </object>
                      <packing>
                        <property name="left-attach">0</property>
                        <property name="top-attach">0</property>
                      </packing>
                    </child>
                    <child>
                      <object id="verify_entry_label" class="GtkLabel">
                        <property name="halign">start</property>
                        <property translatable="yes" name="label">Confirm:</property>
                        <property name="visible">True</property>
                        <accessibility>
                          <relation type="label-for" target="verify_entry"/>
                        </accessibility>
                        <child internal-child="accessible">
                          <object class="AtkObject">
                            <property name="accessible-role">label</property>
                          </object>
                        </child>
                      </object>
                      <packing>
                        <property name="left-attach">0</property>
                        <property name="top-attach">2</property>
                      </packing>
                    </child>
                    <child>
                      <object id="passphrase_entry" class="GtkEntry">
                        <property name="activates-default">True</property>
                        <property name="can-focus">True</property>
                        <property name="has-focus">True</property>
                        <property name="hexpand">True</property>
                        <property name="input-purpose">password</property>
                        <property name="visibility">False</property>
                        <property name="visible">True</property>
                        <signal name="changed" handler="on_passphrase_entry_changed"/>
                        <accessibility>
                          <relation type="labelled-by" target="passphrase_entry_label"/>
                        </accessibility>
                        <child internal-child="accessible">
                          <object class="AtkObject">
                            <property name="accessible-role">password-text</property>
                          </object>
                        </child>
                      </object>
                      <packing>
                        <property name="left-attach">1</property>
                        <property name="top-attach">0</property>
                      </packing>
                    </child>
                    <child>
                      <object id="verify_entry" class="GtkEntry">
                        <property name="activates-default">True</property>
                        <property name="can-focus">True</property>
                        <property name="hexpand">True</property>
                        <property name="input-purpose">password</property>
                        <property name="visibility">False</property>
                        <property name="visible">True</property>
                        <signal name="changed" handler="on_verify_entry_changed"/>
                        <accessibility>
                          <relation type="labelled-by" target="verify_entry_label"/>
                        </accessibility>
                        <child internal-child="accessible">
                          <object class="AtkObject">
                            <property name="accessible-role">password-text</property>
                          </object>
                        </child>
                      </object>
                      <packing>
                        <property name="left-attach">1</property>
                        <property name="top-attach">2</property>
                      </packing>
                    </child>
                    <child>
                      <object id="passphrase_hint_progress_bar" class="GtkProgressBar">
                        <property name="show-text">True</property>
                        <property name="visible">True</property>
                      </object>
                      <packing>
                        <property name="left-attach">1</property>
                        <property name="top-attach">1</property>
                      </packing>
                    </child>
                    <child>
                      <object class="GtkBox">
                        <property name="visible">True</property>
                        <child type="center">
                          <object id="verify_hint_box" class="GtkBox">
                            <property name="halign">center</property>
                            <property name="spacing">5</property>
                            <child>
                              <object class="GtkImage">
                                <property name="can-focus">False</property>
                                <property name="icon-name">dialog-warning-symbolic</property>
                                <property name="valign">start</property>
                                <property name="visible">True</property>
                              </object>
                              <packing>
                                <property name="expand">False</property>
                                <property name="fill">True</property>
                                <property name="position">0</property>
                              </packing>
                            </child>
                            <child>
                              <object id="verify_hint_label" class="GtkLabel">
                                <property translatable="yes" name="label">The passphrases do not match</property>
                                <property name="valign">start</property>
                                <property name="visible">True</property>
                                <property name="wrap">True</property>
                                <attributes>
                                  <attribute value="0.82999999999999996" name="scale"/>
                                </attributes>
                                <style>
                                  <class name="dim-label"/>
                                </style>
                              </object>
                              <packing>
                                <property name="expand">False</property>
                                <property name="fill">False</property>
                                <property name="position">1</property>
                              </packing>
                            </child>
                          </object>
                          <packing>
                            <property name="expand">False</property>
                            <property name="fill">True</property>
                            <property name="position">1</property>
                          </packing>
                        </child>
                        <child>
                          <object id="show_passphrase_checkbutton" class="GtkCheckButton">
                            <property name="can-focus">True</property>
                            <property name="draw-indicator">True</property>
                            <property translatable="yes" name="label">_Show Passphrase</property>
                            <property name="receives-default">False</property>
                            <property name="use-underline">True</property>
                            <property name="visible">True</property>
                            <property name="xalign">0</property>
                            <signal name="toggled" handler="on_show_passphrase_button_toggled"/>
                          </object>
                          <packing>
                            <property name="expand">False</property>
                            <property name="fill">True</property>
                            <property name="position">0</property>
                          </packing>
                        </child>
                      </object>
                      <packing>
                        <property name="left-attach">1</property>
                        <property name="top-attach">3</property>
                      </packing>
                    </child>
                  </object>
                  <packing>
                    <property name="expand">False</property>
                    <property name="fill">True</property>
                    <property name="position">1</property>
                  </packing>
                </child>
              </object>
            </child>
          </object>
        </child>
      </object>
      <packing>
        <property name="expand">True</property>
        <property name="fill">True</property>
        <property name="position">0</property>
      </packing>
    </child>
    <child>
      <object class="GtkBox">
        <property name="visible">True</property>
        <child>
          <object id="back_button" class="GtkButton">
            <property name="can-focus">True</property>
            <property name="halign">start</property>
            <property translatable="yes" name="label">_Back</property>
            <property name="receives-default">False</property>
            <property name="use-underline">True</property>
            <property name="visible">True</property>
            <signal name="clicked" handler="on_back_button_clicked"/>
          </object>
          <packing>
            <property name="expand">False</property>
            <property name="fill">True</property>
            <property name="position">0</property>
          </packing>
        </child>
        <child>
          <object id="create_button" class="GtkButton">
            <property name="can-default">True</property>
            <property name="can-focus">True</property>
            <property name="halign">end</property>
            <property translatable="yes" name="label">_Create Persistent Storage</property>
            <property name="receives-default">True</property>
            <property name="sensitive">False</property>
            <property name="use-underline">True</property>
            <property name="visible">True</property>
            <signal name="clicked" handler="on_create_button_clicked"/>
            <style>
              <class name="suggested-action"/>
            </style>
          </object>
          <packing>
            <property name="expand">False</property>
            <property name="fill">True</property>
            <property name="pack-type">end</property>
            <property name="position">1</property>
          </packing>
        </child>
      </object>
      <packing>
        <property name="expand">False</property>
        <property name="fill">True</property>
        <property name="position">1</property>
      </packing>
    </child>
  </object>
</interface>