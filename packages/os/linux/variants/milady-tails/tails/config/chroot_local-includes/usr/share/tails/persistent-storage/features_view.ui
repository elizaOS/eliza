                            </child>
                            <child>
                              <object id="ssh_client_row" class="HdyActionRow">
                                <property name="visible">True</property>
                                <property name="can-focus">False</property>
                                <property translatable="yes" name="title">SSH Client</property>
                                <property name="icon-name">seahorse-key-ssh</property>
                                <child>
                                  <object id="ssh_client_box" class="GtkBox">
                                    <property name="valign">center</property>
                                    <property name="margin_start">6</property>
                                    <property name="spacing">6</property>
                                    <property name="visible">True</property>
                                    <child>
                                      <object id="ssh_client_switch" class="GtkSwitch">
                                        <property name="visible">True</property>
                                        <property name="can-focus">True</property>
                                        <property name="halign">end</property>
                                        <property name="valign">center</property>
                                        <child internal-child="accessible">
                                          <object id="ssh_client_switch-atkobject" class="AtkObject">
                                            <property translatable="yes" name="AtkObject::accessible-name">Activate SSH Client</property>
                                          </object>
                                        </child>
                                      </object>
