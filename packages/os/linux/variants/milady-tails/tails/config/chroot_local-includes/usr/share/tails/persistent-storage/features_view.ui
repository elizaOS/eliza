<?xml version="1.0" encoding="UTF-8"?>
<interface>
  
  <requires version="3.24" lib="gtk+"/>
  <requires version="0.0" lib="libhandy"/>
  <object id="box" class="GtkBox">
    <property name="can-focus">False</property>
    <property name="orientation">vertical</property>
    <property name="visible">True</property>
    <child>
      <object class="GtkScrolledWindow">
        <property name="can-focus">True</property>
        <property name="hexpand">True</property>
        <property name="hscrollbar-policy">never</property>
        <property name="kinetic-scrolling">False</property>
        <property name="overlay-scrolling">False</property>
        <property name="vexpand">True</property>
        <property name="visible">True</property>
        <property name="window-placement-set">False</property>
        <child>
          <object class="GtkViewport">
            <property name="can-focus">False</property>
            <property name="visible">True</property>
            <child>
              <object class="HdyClamp">
                <property name="visible">True</property>
                <property name="can-focus">False</property>
                <property name="margin-start">12</property>
                <property name="margin-end">12</property>
                <property name="margin-top">32</property>
                <property name="margin-bottom">32</property>
                <child>
                  <object class="GtkBox">
                    <property name="visible">True</property>
                    <property name="can-focus">False</property>
                    <property name="hexpand">True</property>
                    <property name="orientation">vertical</property>
                    <property name="spacing">12</property>
                    <child>
                      <object class="GtkBox">
                        <property name="visible">True</property>
                        <property name="can-focus">False</property>
                        <property name="spacing">10</property>
                        <child>
                          <object class="GtkImage">
                            <property name="visible">True</property>
                            <property name="can-focus">False</property>
                            <property name="icon-name">tails-unlocked</property>
                            <property name="icon_size">6</property>
                          </object>
                          <packing>
                            <property name="expand">False</property>
                            <property name="fill">True</property>
                            <property name="position">0</property>
                          </packing>
                        </child>
                        <child>
                          <object class="GtkLabel">
                            <property name="visible">True</property>
                            <property name="can-focus">False</property>
                            <property translatable="yes" name="label">Your Persistent Storage is unlocked.

Its content is available until you shut down elizaOS.

&lt;a href="doc/persistent_storage/backup"&gt;Learn how to make a backup of your Persistent Storage.&lt;/a&gt;</property>
                            <property name="use-markup">True</property>
                            <property name="wrap">True</property>
                            <property name="max-width-chars">50</property>
                            <signal swapped="no" name="activate-link" handler="on_activate_link"/>
                          </object>
                          <packing>
                            <property name="expand">False</property>
                            <property name="fill">True</property>
                            <property name="position">1</property>
                          </packing>
                        </child>
                      </object>
                      <packing>
                        <property name="expand">False</property>
                        <property name="fill">True</property>
                        <property name="position">0</property>
                      </packing>
                    </child>
                    <child>
                      <object class="GtkLabel">
                        <property name="visible">True</property>
                        <property name="can-focus">False</property>
                        <property name="margin-top">18</property>
                        <property translatable="yes" name="label">Turn on the features of the Persistent Storage for the data that you want to save to your elizaOS USB stick.</property>
                        <property name="wrap">True</property>
                        <property name="max-width-chars">50</property>
                        <property name="xalign">0</property>
                      </object>
                      <packing>
                        <property name="expand">False</property>
                        <property name="fill">True</property>
                        <property name="position">1</property>
                      </packing>
                    </child>
                    <child>
                      <object id="personal_data_label" class="GtkLabel">
                        <property name="visible">True</property>
                        <property name="can-focus">False</property>
                        <property name="halign">start</property>
                        <property name="margin-top">18</property>
                        <property translatable="yes" name="label">Personal Documents</property>
                        <attributes>
                          <attribute value="bold" name="weight"/>
                        </attributes>
                        <accessibility>
                          <relation type="label-for" target="personal_data_list_box"/>
                        </accessibility>
                      </object>
                      <packing>
                        <property name="expand">False</property>
                        <property name="fill">True</property>
                        <property name="position">2</property>
                      </packing>
                    </child>
                    <child>
                      <object class="GtkFrame">
                        <property name="visible">True</property>
                        <property name="can-focus">False</property>
                        <property name="label-xalign">0</property>
                        <child>
                          <object id="personal_data_list_box" class="GtkListBox">
                            <property name="visible">True</property>
                            <property name="can-focus">False</property>
                            <property name="selection-mode">none</property>
                            <child>
                              <object id="persistent_directory_row" class="HdyActionRow">
                                <property name="visible">True</property>
                                <property name="can-focus">False</property>
                                <property translatable="yes" name="title">Persistent Folder</property>
                                <property translatable="yes" name="subtitle">A folder where you can save your documents.</property>
                                <property name="icon-name">stock_folder</property>
                                <child>
                                  <object id="persistent_directory_box" class="GtkBox">
                                    <property name="valign">center</property>
                                    <property name="margin_start">6</property>
                                    <property name="spacing">6</property>
                                    <property name="visible">True</property>
                                    <child>
                                      <object id="persistent_directory_open_button" class="GtkButton">
                                        <property name="visible">True</property>
                                        <property name="can-focus">True</property>
                                        <property name="receives-default">True</property>
                                        <property name="halign">end</property>
                                        <property name="valign">center</property>
                                        <signal swapped="no" name="clicked" handler="on_persistent_directory_open_button_clicked"/>
                                        <child>
                                          <object class="GtkImage">
                                            <property name="visible">True</property>
                                            <property name="can-focus">False</property>
                                            <property name="icon-name">folder-open-symbolic</property>
                                          </object>
                                        </child>
                                        <child internal-child="accessible">
                                          <object class="AtkObject">
                                            <property translatable="yes" name="AtkObject::accessible-name">Open Persistent Folder</property>
                                          </object>
                                        </child>
                                      </object>
                                    </child>
                                    <child>
                                      <object id="persistent_directory_switch" class="GtkSwitch">
                                        <property name="visible">True</property>
                                        <property name="can-focus">True</property>
                                        <property name="halign">end</property>
                                        <property name="valign">center</property>
                                        <child internal-child="accessible">
                                          <object id="persistent_directory_switch-atkobject" class="AtkObject">
                                            <property translatable="yes" name="AtkObject::accessible-name">Activate Persistent Folder</property>
                                          </object>
                                        </child>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                              </object>
                            </child>
                            <accessibility>
                              <relation type="labelled-by" target="personal_data_label"/>
                            </accessibility>
                          </object>
                        </child>
                      </object>
                      <packing>
                        <property name="expand">False</property>
                        <property name="fill">True</property>
                        <property name="position">3</property>
                      </packing>
                    </child>
                    <child>
                      <object id="system_settings_label" class="GtkLabel">
                        <property name="visible">True</property>
                        <property name="can-focus">False</property>
                        <property name="halign">start</property>
                        <property name="margin-top">18</property>
                        <property translatable="yes" name="label">System Settings</property>
                        <attributes>
                          <attribute value="bold" name="weight"/>
                        </attributes>
                        <accessibility>
                          <relation type="label-for" target="system_settings_list_box"/>
                        </accessibility>
                      </object>
                      <packing>
                        <property name="expand">False</property>
                        <property name="fill">True</property>
                        <property name="position">4</property>
                      </packing>
                    </child>
                    <child>
                      <object class="GtkFrame">
                        <property name="visible">True</property>
                        <property name="can-focus">False</property>
                        <property name="label-xalign">0</property>
                        <child>
                          <object id="system_settings_list_box" class="GtkListBox">
                            <property name="visible">True</property>
                            <property name="can-focus">False</property>
                            <property name="selection-mode">none</property>
                            <child>
                              <object id="welcome_screen_row" class="HdyActionRow">
                                <property name="visible">True</property>
                                <property name="can-focus">False</property>
                                <property translatable="yes" name="title">Welcome Screen</property>
                                <property name="icon-name">tps-WelcomeScreen</property>
                                <child>
                                  <object id="welcome_screen_box" class="GtkBox">
                                    <property name="valign">center</property>
                                    <property name="margin_start">6</property>
                                    <property name="spacing">6</property>
                                    <property name="visible">True</property>
                                    <child>
                                      <object id="welcome_screen_switch" class="GtkSwitch">
                                        <property name="visible">True</property>
                                        <property name="can-focus">True</property>
                                        <property name="halign">end</property>
                                        <property name="valign">center</property>
                                        <child internal-child="accessible">
                                          <object id="welcome_screen_switch-atkobject" class="AtkObject">
                                            <property translatable="yes" name="AtkObject::accessible-name">Activate Welcome Screen</property>
                                          </object>
                                        </child>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                              </object>
                            </child>
                            <child>
                              <object id="printers_row" class="HdyActionRow">
                                <property name="visible">True</property>
                                <property name="can-focus">False</property>
                                <property translatable="yes" name="title">Printers</property>
                                <property name="icon-name">printer</property>
                                <child>
                                  <object id="printers_box" class="GtkBox">
                                    <property name="valign">center</property>
                                    <property name="margin_start">6</property>
                                    <property name="spacing">6</property>
                                    <property name="visible">True</property>
                                    <child>
                                      <object id="printers_switch" class="GtkSwitch">
                                        <property name="visible">True</property>
                                        <property name="can-focus">True</property>
                                        <property name="halign">end</property>
                                        <property name="valign">center</property>
                                        <child internal-child="accessible">
                                          <object id="printers_switch-atkobject" class="AtkObject">
                                            <property translatable="yes" name="AtkObject::accessible-name">Activate Printers</property>
                                          </object>
                                        </child>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                              </object>
                            </child>
                            <accessibility>
                              <relation type="labelled-by" target="system_settings_label"/>
                            </accessibility>
                          </object>
                        </child>
                      </object>
                      <packing>
                        <property name="expand">False</property>
                        <property name="fill">True</property>
                        <property name="position">5</property>
                      </packing>
                    </child>
                    <child>
                      <object id="network_label" class="GtkLabel">
                        <property name="visible">True</property>
                        <property name="can-focus">False</property>
                        <property name="halign">start</property>
                        <property name="margin-top">18</property>
                        <property translatable="yes" name="label">Network</property>
                        <attributes>
                          <attribute value="bold" name="weight"/>
                        </attributes>
                        <accessibility>
                          <relation type="label-for" target="network_list_box"/>
                        </accessibility>
                      </object>
                      <packing>
                        <property name="expand">False</property>
                        <property name="fill">True</property>
                        <property name="position">6</property>
                      </packing>
                    </child>
                    <child>
                      <object class="GtkFrame">
                        <property name="visible">True</property>
                        <property name="can-focus">False</property>
                        <property name="label-xalign">0</property>
                        <child>
                          <object id="network_list_box" class="GtkListBox">
                            <property name="visible">True</property>
                            <property name="can-focus">False</property>
                            <property name="selection-mode">none</property>
                            <child>
                              <object id="network_connections_row" class="HdyActionRow">
                                <property name="visible">True</property>
                                <property name="can-focus">False</property>
                                <property translatable="yes" name="title">Network Connections</property>
                                <property translatable="yes" name="subtitle">Save Wi-Fi passwords and mobile broadband configuration.</property>
                                <property name="icon-name">tps-NetworkConnections</property>
                                <child>
                                  <object id="network_connections_box" class="GtkBox">
                                    <property name="valign">center</property>
                                    <property name="margin_start">6</property>
                                    <property name="spacing">6</property>
                                    <property name="visible">True</property>
                                    <child>
                                      <object id="network_connections_switch" class="GtkSwitch">
                                        <property name="visible">True</property>
                                        <property name="can-focus">True</property>
                                        <property name="halign">end</property>
                                        <property name="valign">center</property>
                                        <child internal-child="accessible">
                                          <object id="network_connections_switch-atkobject" class="AtkObject">
                                            <property translatable="yes" name="AtkObject::accessible-name">Activate Network Connections</property>
                                          </object>
                                        </child>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                              </object>
                            </child>
                            <child>
                              <object id="tor_configuration_row" class="HdyActionRow">
                                <property name="visible">True</property>
                                <property name="can-focus">False</property>
                                <property translatable="yes" name="title">Tor Bridge</property>
                                <property name="icon-name">tor-connection</property>
                                <child>
                                  <object id="tor_configuration_box" class="GtkBox">
                                    <property name="valign">center</property>
                                    <property name="margin_start">6</property>
                                    <property name="spacing">6</property>
                                    <property name="visible">True</property>
                                    <child>
                                      <object id="tor_configuration_switch" class="GtkSwitch">
                                        <property name="visible">True</property>
                                        <property name="can-focus">True</property>
                                        <property name="halign">end</property>
                                        <property name="valign">center</property>
                                        <child internal-child="accessible">
                                          <object id="tor_configuration_switch-atkobject" class="AtkObject">
                                            <property translatable="yes" name="AtkObject::accessible-name">Activate Tor Bridge</property>
                                          </object>
                                        </child>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                              </object>
                            </child>
                            <accessibility>
                              <relation type="labelled-by" target="network_label"/>
                            </accessibility>
                          </object>
                        </child>
                      </object>
                      <packing>
                        <property name="expand">False</property>
                        <property name="fill">True</property>
                        <property name="position">7</property>
                      </packing>
                    </child>
                    <child>
                      <object id="applications_label" class="GtkLabel">
                        <property name="visible">True</property>
                        <property name="can-focus">False</property>
                        <property name="halign">start</property>
                        <property name="margin-top">18</property>
                        <property translatable="yes" name="label">Applications</property>
                        <attributes>
                          <attribute value="bold" name="weight"/>
                        </attributes>
                        <accessibility>
                          <relation type="label-for" target="applications_list_box"/>
                        </accessibility>
                      </object>
                      <packing>
                        <property name="expand">False</property>
                        <property name="fill">True</property>
                        <property name="position">8</property>
                      </packing>
                    </child>
                    <child>
                      <object class="GtkFrame">
                        <property name="visible">True</property>
                        <property name="can-focus">False</property>
                        <property name="label-xalign">0</property>
                        <child>
                          <object id="applications_list_box" class="GtkListBox">
                            <property name="visible">True</property>
                            <property name="can-focus">False</property>
                            <property name="selection-mode">none</property>
                            <child>
                              <object id="milady_data_row" class="HdyActionRow">
                                <property name="visible">True</property>
                                <property name="can-focus">False</property>
                                <property translatable="yes" name="title">elizaOS Data</property>
                                <property translatable="yes" name="subtitle">Save elizaOS memory, settings, and local runtime state.</property>
                                <property name="icon-name">applications-system</property>
                                <child>
                                  <object id="milady_data_box" class="GtkBox">
                                    <property name="valign">center</property>
                                    <property name="margin_start">6</property>
                                    <property name="spacing">6</property>
                                    <property name="visible">True</property>
                                    <child>
                                      <object id="milady_data_switch" class="GtkSwitch">
                                        <property name="visible">True</property>
                                        <property name="can-focus">True</property>
                                        <property name="halign">end</property>
                                        <property name="valign">center</property>
                                        <child internal-child="accessible">
                                          <object id="milady_data_switch-atkobject" class="AtkObject">
                                            <property translatable="yes" name="AtkObject::accessible-name">Activate elizaOS Data</property>
                                          </object>
                                        </child>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                              </object>
                            </child>
                            <child>
                              <object id="browser_bookmarks_row" class="HdyActionRow">
                                <property name="visible">True</property>
                                <property name="can-focus">True</property>
                                <property translatable="yes" name="title">Tor Browser Bookmarks</property>
                                <property name="icon-name">user-bookmarks</property>
                                <child>
                                  <object id="browser_bookmarks_box" class="GtkBox">
                                    <property name="valign">center</property>
                                    <property name="margin_start">6</property>
                                    <property name="spacing">6</property>
                                    <property name="visible">True</property>
                                    <child>
                                      <object id="browser_bookmarks_switch" class="GtkSwitch">
                                        <property name="visible">True</property>
                                        <property name="can-focus">True</property>
                                        <property name="halign">end</property>
                                        <property name="valign">center</property>
                                        <child internal-child="accessible">
                                          <object id="browser_bookmarks_switch-atkobject" class="AtkObject">
                                            <property translatable="yes" name="AtkObject::accessible-name">Activate Tor Browser Bookmarks</property>
                                          </object>
                                        </child>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                              </object>
                            </child>
                            <child>
                              <object id="electrum_row" class="HdyActionRow">
                                <property name="visible">True</property>
                                <property name="can-focus">False</property>
                                <property translatable="yes" name="title">Electrum Bitcoin Wallet</property>
                                <property name="icon-name">electrum</property>
                                <child>
                                  <object id="electrum_box" class="GtkBox">
                                    <property name="valign">center</property>
                                    <property name="margin_start">6</property>
                                    <property name="spacing">6</property>
                                    <property name="visible">True</property>
                                    <child>
                                      <object id="electrum_switch" class="GtkSwitch">
                                        <property name="visible">True</property>
                                        <property name="can-focus">True</property>
                                        <property name="halign">end</property>
                                        <property name="valign">center</property>
                                        <child internal-child="accessible">
                                          <object id="electrum_switch-atkobject" class="AtkObject">
                                            <property translatable="yes" name="AtkObject::accessible-name">Activate Electrum Bitcoin Wallet</property>
                                          </object>
                                        </child>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                              </object>
                            </child>
                            <child>
                              <object id="thunderbird_row" class="HdyActionRow">
                                <property name="visible">True</property>
                                <property name="can-focus">False</property>
                                <property translatable="yes" name="title">Thunderbird Email Client</property>
                                <property name="icon-name">thunderbird</property>
                                <child>
                                  <object id="thunderbird_box" class="GtkBox">
                                    <property name="valign">center</property>
                                    <property name="margin_start">6</property>
                                    <property name="spacing">6</property>
                                    <property name="visible">True</property>
                                    <child>
                                      <object id="thunderbird_switch" class="GtkSwitch">
                                        <property name="visible">True</property>
                                        <property name="can-focus">True</property>
                                        <property name="halign">end</property>
                                        <property name="valign">center</property>
                                        <child internal-child="accessible">
                                          <object id="thunderbird_switch-atkobject" class="AtkObject">
                                            <property translatable="yes" name="AtkObject::accessible-name">Activate Thunderbird Email Client</property>
                                          </object>
                                        </child>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                              </object>
                            </child>
                            <child>
                              <object id="gnupg_row" class="HdyActionRow">
                                <property name="visible">True</property>
                                <property name="can-focus">False</property>
                                <property translatable="yes" name="title">GnuPG</property>
