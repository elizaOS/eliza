                            </child>
                            <accessibility>
                              <relation type="labelled-by" target="applications_label"/>
                            </accessibility>
                          </object>
                        </child>
                      </object>
                      <packing>
                        <property name="expand">False</property>
                        <property name="fill">True</property>
                        <property name="position">9</property>
                      </packing>
                    </child>
                    <child>
                      <object id="advanced_settings_label" class="GtkLabel">
                        <property name="visible">True</property>
                        <property name="can-focus">False</property>
                        <property name="halign">start</property>
                        <property name="margin-top">18</property>
                        <property translatable="yes" name="label">Advanced Settings</property>
                        <attributes>
                          <attribute value="bold" name="weight"/>
                        </attributes>
                        <accessibility>
                          <relation type="label-for" target="advanced_settings_list_box"/>
                        </accessibility>
                      </object>
                      <packing>
                        <property name="expand">False</property>
                        <property name="fill">True</property>
                        <property name="position">10</property>
                      </packing>
                    </child>
                    <child>
                      <object class="GtkFrame">
                        <property name="visible">True</property>
                        <property name="can-focus">False</property>
                        <property name="label-xalign">0</property>
                        <child>
                          <object id="advanced_settings_list_box" class="GtkListBox">
                            <property name="visible">True</property>
                            <property name="can-focus">False</property>
                            <property name="selection-mode">none</property>
                            <child>
                              <object id="additional_software_row" class="HdyActionRow">
                                <property name="visible">True</property>
                                <property name="can-focus">False</property>
                                <property translatable="yes" name="title">Additional Software</property>
                                <property translatable="yes" name="subtitle">Install additional software automatically when starting elizaOS.</property>
                                <property name="icon-name">package-x-generic</property>
                                <child>
                                  <object id="additional_software_box" class="GtkBox">
                                    <property name="valign">center</property>
                                    <property name="margin_start">6</property>
                                    <property name="spacing">6</property>
                                    <property name="visible">True</property>
                                    <child>
                                      <object class="GtkButton">
                                        <property name="visible">True</property>
                                        <property name="can-focus">True</property>
                                        <property name="receives-default">True</property>
                                        <property name="halign">end</property>
                                        <property name="valign">center</property>
                                        <signal swapped="no" name="clicked" handler="on_additional_software_button_clicked"/>
                                        <child>
                                          <object class="GtkImage">
                                            <property name="visible">True</property>
                                            <property name="can-focus">False</property>
                                            <property name="icon-name">applications-system-symbolic</property>
                                          </object>
                                        </child>
                                        <child internal-child="accessible">
                                          <object class="AtkObject">
                                            <property translatable="yes" name="AtkObject::accessible-name">Configure Additional Software</property>
                                          </object>
                                        </child>
                                      </object>
                                    </child>
                                    <child>
                                      <object id="additional_software_switch" class="GtkSwitch">
                                        <property name="visible">True</property>
                                        <property name="can-focus">True</property>
                                        <property name="halign">end</property>
                                        <property name="valign">center</property>
                                        <child internal-child="accessible">
                                          <object id="additional_software_switch-atkobject" class="AtkObject">
                                            <property translatable="yes" name="AtkObject::accessible-name">Activate Additional Software</property>
                                          </object>
                                        </child>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                              </object>
                            </child>
                            <child>
                              <object id="dotfiles_row" class="HdyActionRow">
                                <property name="visible">True</property>
                                <property name="can-focus">False</property>
                                <property translatable="yes" name="title">Dotfiles</property>
                                <property translatable="yes" name="subtitle">Symlink every file in the Dotfiles folder into the Home folder.</property>
                                <property name="icon-name">preferences-desktop</property>
                                <child>
                                  <object id="dotfiles_box" class="GtkBox">
                                    <property name="valign">center</property>
                                    <property name="margin_start">6</property>
                                    <property name="spacing">6</property>
                                    <property name="visible">True</property>
                                    <child>
                                      <object class="GtkLinkButton">
                                        <property name="visible">True</property>
                                        <property name="can_focus">False</property>
                                        <property name="receives_default">True</property>
                                        <property name="relief">none</property>
                                        <property name="uri">doc/persistent_storage/configure#dotfiles</property>
                                        <signal swapped="no" name="activate-link" handler="on_activate_link_button"/>
                                        <child>
                                          <object class="GtkImage">
                                            <property name="visible">True</property>
                                            <property name="can_focus">False</property>
                                            <property name="icon_name">tails-help</property>
                                          </object>
                                        </child>
                                      </object>
                                    </child>
                                    <child>
                                      <object id="dotfiles_switch" class="GtkSwitch">
                                        <property name="visible">True</property>
                                        <property name="can-focus">True</property>
                                        <property name="halign">end</property>
                                        <property name="valign">center</property>
                                        <child internal-child="accessible">
                                          <object id="dotfiles_switch-atkobject" class="AtkObject">
                                            <property translatable="yes" name="AtkObject::accessible-name">Activate Dotfiles</property>
                                          </object>
                                        </child>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                              </object>
                            </child>
                            <accessibility>
                              <relation type="labelled-by" target="advanced_settings_label"/>
                            </accessibility>
                          </object>
                        </child>
                      </object>
                      <packing>
                        <property name="expand">False</property>
                        <property name="fill">True</property>
                        <property name="position">11</property>
                      </packing>
                    </child>
                    <child>
                      <object id="custom_features_box" class="GtkBox">
                        <property name="can-focus">False</property>
                        <property name="orientation">vertical</property>
                        <property name="spacing">10</property>
                        <child>
                          <object id="custom_features_label" class="GtkLabel">
                            <property name="visible">True</property>
                            <property name="can-focus">False</property>
                            <property name="halign">start</property>
                            <property name="margin-top">18</property>
                            <property translatable="yes" name="label">Custom</property>
                            <attributes>
                              <attribute value="bold" name="weight"/>
                            </attributes>
                            <accessibility>
                              <relation type="label-for" target="custom_features_list_box"/>
                            </accessibility>
                          </object>
                          <packing>
                            <property name="expand">False</property>
                            <property name="fill">True</property>
                            <property name="position">0</property>
                          </packing>
                        </child>
                        <child>
                          <object class="GtkLabel">
                            <property name="visible">True</property>
                            <property name="can-focus">False</property>
                            <property name="halign">start</property>
                            <property translatable="yes" name="label">To add or remove custom features, modify the Persistent Storage configuration file directly.</property>
                            <property name="selectable">True</property>
                          </object>
                          <packing>
                            <property name="expand">False</property>
                            <property name="fill">True</property>
                            <property name="position">1</property>
                          </packing>
                        </child>
                        <child>
                          <object id="custom_features_frame" class="GtkFrame">
                            <property name="can-focus">False</property>
                            <property name="label-xalign">0</property>
                            <child>
                              <object id="custom_features_list_box" class="GtkListBox">
                                <property name="visible">True</property>
                                <property name="can-focus">False</property>
                                <property name="selection-mode">none</property>
                                <accessibility>
                                  <relation type="labelled-by" target="custom_features_label"/>
                                </accessibility>
                              </object>
                            </child>
                          </object>
                          <packing>
                            <property name="expand">False</property>
                            <property name="fill">True</property>
                            <property name="position">1</property>
                          </packing>
                        </child>
                      </object>
                      <packing>
                        <property name="expand">False</property>
                        <property name="fill">True</property>
                        <property name="position">12</property>
                      </packing>
                    </child>
                    <child>
                      <object class="GtkLabel">
                        <property name="visible">True</property>
                        <property name="can-focus">False</property>
                        <property name="margin-top">18</property>
                        <property translatable="yes" name="label">&lt;a href="doc/persistent_storage"&gt;Learn more about the Persistent Storage.&lt;/a&gt;</property>
                        <property name="use-markup">True</property>
                        <property name="wrap">True</property>
                        <property name="max-width-chars">50</property>
                        <property name="xalign">0</property>
                        <signal swapped="no" name="activate-link" handler="on_activate_link"/>
                      </object>
                      <packing>
                        <property name="expand">False</property>
                        <property name="fill">True</property>
                        <property name="position">13</property>
                      </packing>
                    </child>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
      </object>
      <packing>
        <property name="expand">False</property>
        <property name="fill">True</property>
        <property name="position">1</property>
      </packing>
    </child>
  </object>
</interface>