                                    <property name="valign">center</property>
                                    <property name="margin_start">6</property>
                                    <property name="spacing">6</property>
                                    <property name="visible">True</property>
                                    <child>
                                      <object id="gnupg_switch" class="GtkSwitch">
                                        <property name="visible">True</property>
                                        <property name="can-focus">True</property>
                                        <property name="halign">end</property>
                                        <property name="valign">center</property>
                                        <child internal-child="accessible">
                                          <object id="gnupg_switch-atkobject" class="AtkObject">
                                            <property translatable="yes" name="AtkObject::accessible-name">Activate GnuPG</property>
                                          </object>
                                        </child>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                              </object>
                            </child>
                            <child>
                              <object id="pidgin_row" class="HdyActionRow">
