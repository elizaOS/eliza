                                        <property name="visible">True</property>
                                        <property name="can-focus">True</property>
                                        <property name="halign">end</property>
                                        <property name="valign">center</property>
                                        <child internal-child="accessible">
                                          <object id="pidgin_switch-atkobject" class="AtkObject">
                                            <property translatable="yes" name="AtkObject::accessible-name">Activate Pidgin Internet Messenger</property>
                                          </object>
                                        </child>
                                      </object>
                                    </child>
                                  </object>
                                </child>
