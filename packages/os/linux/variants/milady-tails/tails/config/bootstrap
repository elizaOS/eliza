# config/bootstrap - options for live-build(7), bootstrap stage

# $LB_ARCHITECTURE: select chroot architecture
# (Default: autodetected)
LB_ARCHITECTURE="amd64"

# $LB_BOOTSTRAP_CONFIG: set distribution config directory
# (Default: empty)
LB_BOOTSTRAP_CONFIG="trixie"

# $LB_BOOTSTRAP_INCLUDE: include packages on base
# (Default: empty)
LB_BOOTSTRAP_INCLUDE="gnupg"

# $LB_BOOTSTRAP_EXCLUDE: exclude packages on base
# (Default: empty)
LB_BOOTSTRAP_EXCLUDE=""

# $LB_BOOTSTRAP_FLAVOUR: select flavour to use
# (Default: empty)
LB_BOOTSTRAP_FLAVOUR=""

# $LB_BOOTSTRAP_KEYRING: set distribution keyring
# (Default: empty)
LB_BOOTSTRAP_KEYRING=""

# $LB_DISTRIBUTION: select distribution to use
# (Default: trixie)
LB_DISTRIBUTION="trixie"

# $LB_MIRROR_BOOTSTRAP: set mirror to bootstrap from
# (Default: http://time-based.snapshots.deb.tails.boum.org/debian/2026042702)
LB_MIRROR_BOOTSTRAP="http://time-based.snapshots.deb.tails.boum.org/debian/2026042702"

# $LB_MIRROR_CHROOT: set mirror to fetch packages from
# (Default: http://time-based.snapshots.deb.tails.boum.org/debian/2026042702)
LB_MIRROR_CHROOT="http://time-based.snapshots.deb.tails.boum.org/debian/2026042702"

# $LB_MIRROR_CHROOT_SECURITY: set security mirror to fetch packages from
# (Default: http://time-based.snapshots.deb.tails.boum.org/debian-security/2026052003)
LB_MIRROR_CHROOT_SECURITY="http://time-based.snapshots.deb.tails.boum.org/debian-security/2026052003"

# $LB_MIRROR_CHROOT_VOLATILE: set volatile mirror to fetch packages from
# (Default: http://time-based.snapshots.deb.tails.boum.org/debian/2026042702)
LB_MIRROR_CHROOT_VOLATILE="http://time-based.snapshots.deb.tails.boum.org/debian/2026042702"

# $LB_MIRROR_CHROOT_BACKPORTS: set backports mirror to fetch packages from
# (Default: none)
LB_MIRROR_CHROOT_BACKPORTS="none"

# $LB_MIRROR_BINARY: set mirror which ends up in the image
# (Default: http://time-based.snapshots.deb.tails.boum.org/debian/2026042702)
LB_MIRROR_BINARY="http://time-based.snapshots.deb.tails.boum.org/debian/2026042702"

# $LB_MIRROR_BINARY_SECURITY: set security mirror which ends up in the image
# (Default: http://time-based.snapshots.deb.tails.boum.org/debian-security/2026052003)
LB_MIRROR_BINARY_SECURITY="http://time-based.snapshots.deb.tails.boum.org/debian-security/2026052003"

# $LB_MIRROR_BINARY_VOLATILE: set volatile mirror which ends up in the image
# (Default: http://time-based.snapshots.deb.tails.boum.org/debian/2026042702)
LB_MIRROR_BINARY_VOLATILE="http://time-based.snapshots.deb.tails.boum.org/debian/2026042702"

# $LB_MIRROR_BINARY_BACKPORTS: set backports mirror which ends up in the image
# (Default: none)
LB_MIRROR_BINARY_BACKPORTS="none"

# $LB_MIRROR_DEBIAN_INSTALLER: set debian-installer mirror
# (Default: http://time-based.snapshots.deb.tails.boum.org/debian/2026042702)
LB_MIRROR_DEBIAN_INSTALLER="http://ftp.de.debian.org/debian/"

# $LB_ARCHIVE_AREAS: select archive areas to use
# (Default: main contrib non-free non-free-firmware)
LB_ARCHIVE_AREAS="main contrib non-free non-free-firmware"
