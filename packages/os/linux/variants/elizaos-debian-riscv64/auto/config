#!/bin/sh
# live-build auto/config for elizaOS Debian RISC-V 64.
#
# Pins architecture, kernel flavour, bootloader, and archive areas so
# the variant is reproducible from a clean check-out. Stripped to a
# plain Debian Trixie live system on riscv64 — no Tails snapshot, Tor,
# or branding pipeline.
#
# Archive areas: `main` only. QEMU `virt` and the early RISC-V boards
# this image targets (TH1520, e1_soc) do not require `non-free-firmware`
# blobs; revisit if a real board lands that needs them.
set -e
set -u

lb config noauto \
    --distribution trixie \
    --architecture riscv64 \
    --linux-flavours riscv64 \
    --archive-areas "main" \
    --bootloaders grub-efi \
    --binary-image iso-hybrid \
    --apt-recommends false \
    --debian-installer none \
    --bootappend-live "boot=live components quiet earlycon=sbi console=ttyS0,115200n8" \
    "${@}"
