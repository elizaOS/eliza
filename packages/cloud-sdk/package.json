{
  "name": "@elizaos/cloud-sdk",
  "version": "2.0.0-beta.2",
  "description": "TypeScript SDK for Eliza Cloud API, auth, and agent management.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "scripts": {
    "build": "bun run build.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test src"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./cloud-setup-session": {
      "types": "./dist/cloud-setup-session/index.d.ts",
      "import": "./dist/cloud-setup-session/index.js",
      "default": "./dist/cloud-setup-session/index.js"
    },
    "./package.json": "./package.json"
  }
}
