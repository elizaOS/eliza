{
  "name": "@elizaos/shared",
  "version": "2.0.0-beta.0",
  "description": "Shared code for Eliza agent and app-core.",
  "type": "module",
  "main": "src/index.ts",
  "license": "MIT",
  "homepage": "https://github.com/elizaOS/eliza",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/elizaOS/eliza.git",
    "directory": "packages/shared"
  },
  "keywords": [
    "elizaos",
    "shared",
    "contracts",
    "i18n"
  ],
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "prepublishOnly": "bun run build",
    "build": "bun run build:i18n && bun run build:dist",
    "build:i18n": "node scripts/generate-keywords.mjs --target ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --config ./vitest.config.ts",
    "lint": "bunx @biomejs/biome check src",
    "lint:fix": "bunx @biomejs/biome check --write src",
    "format": "bunx @biomejs/biome format src",
    "format:fix": "bunx @biomejs/biome format --write src",
    "build:dist": "rm -rf dist && tsc -p tsconfig.build.json && node ../../scripts/prepare-package-dist.mjs packages/shared",
    "pack:dry-run": "cd dist && npm pack --dry-run"
  },
  "exports": {
    ".": "./src/index.ts",
    "./app-hero-art": "./src/app-hero-art.ts",
    "./connectors": "./src/connectors.ts",
    "./env-utils": "./src/env-utils.ts",
    "./format-error": "./src/format-error.ts",
    "./runtime-env": {
      "@elizaos/source": "./src/runtime-env.ts",
      "types": "./dist/runtime-env.d.ts",
      "default": "./dist/runtime-env.js"
    },
    "./contracts": "./src/contracts/index.ts",
    "./contracts/apps": "./src/contracts/apps.ts",
    "./contracts/awareness": "./src/contracts/awareness.ts",
    "./contracts/config": "./src/contracts/config.ts",
    "./contracts/drop": "./src/contracts/drop.ts",
    "./contracts/lifeops": "./src/contracts/lifeops.ts",
    "./contracts/onboarding": "./src/contracts/onboarding.ts",
    "./contracts/permissions": "./src/contracts/permissions.ts",
    "./contracts/service-routing": "./src/contracts/service-routing.ts",
    "./contracts/verification": "./src/contracts/verification.ts",
    "./contracts/content-pack": "./src/contracts/content-pack.ts",
    "./contracts/theme": "./src/contracts/theme.ts",
    "./themes": "./src/themes/index.ts",
    "./themes/presets": "./src/themes/presets.ts",
    "./contracts/wallet": "./src/contracts/wallet.ts",
    "./config": "./src/config/types.ts",
    "./config/types.agent-defaults": "./src/config/types.agent-defaults.ts",
    "./config/types.agents": "./src/config/types.agents.ts",
    "./config/types.eliza": "./src/config/types.eliza.ts",
    "./config/types.gateway": "./src/config/types.gateway.ts",
    "./config/types.hooks": "./src/config/types.hooks.ts",
    "./config/types.messages": "./src/config/types.messages.ts",
    "./config/types.tools": "./src/config/types.tools.ts",
    "./awareness": "./src/awareness/index.ts",
    "./restart": "./src/restart.ts",
    "./self-edit": "./src/self-edit.ts",
    "./spoken-text": "./src/spoken-text.ts",
    "./eliza-core-roles": "./src/eliza-core-roles.ts",
    "./validation-keywords": "./src/validation-keywords.ts",
    "./onboarding-presets": "./src/onboarding-presets.ts",
    "./dev-settings-table": {
      "@elizaos/source": "./src/dev-settings-table.ts",
      "types": "./dist/dev-settings-table.d.ts",
      "default": "./dist/dev-settings-table.js"
    },
    "./dev-settings-banner-style": {
      "@elizaos/source": "./src/dev-settings-banner-style.ts",
      "types": "./dist/dev-settings-banner-style.d.ts",
      "default": "./dist/dev-settings-banner-style.js"
    },
    "./dev-settings-figlet-heading": {
      "@elizaos/source": "./src/dev-settings-figlet-heading.ts",
      "types": "./dist/dev-settings-figlet-heading.d.ts",
      "default": "./dist/dev-settings-figlet-heading.js"
    },
    "./recent-messages-state": "./src/recent-messages-state.ts",
    "./type-guards": "./src/type-guards.ts",
    "./contracts/lifeops-extensions": "./src/contracts/lifeops-extensions.ts"
  },
  "publishConfig": {
    "access": "public",
    "directory": "dist"
  },
  "dependencies": {
    "@elizaos/core": "workspace:*",
    "zod": "^4.4.3"
  },
  "optionalDependencies": {
    "figlet": "^1.11.0"
  },
  "devDependencies": {
    "@types/figlet": "^1.7.0",
    "bun-types": "^1.3.12",
    "typescript": "^6.0.0"
  }
}
