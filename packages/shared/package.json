{
  "name": "@elizaos/shared",
  "version": "2.0.0-beta.0",
  "description": "Shared code for Eliza agent and app-core.",
  "type": "module",
  "main": "./dist/index.js",
  "license": "MIT",
  "homepage": "https://github.com/elizaOS/eliza",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/elizaOS/eliza.git",
    "directory": "packages/shared"
  },
  "keywords": [
    "elizaos",
    "shared",
    "contracts",
    "i18n"
  ],
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "prepublishOnly": "bun run build",
    "build": "bun run build:i18n && bun run build:dist",
    "build:i18n": "node scripts/generate-keywords.mjs --target ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --config ./vitest.config.ts",
    "lint": "bunx @biomejs/biome check src",
    "lint:fix": "bunx @biomejs/biome check --write src",
    "format": "bunx @biomejs/biome format src",
    "format:fix": "bunx @biomejs/biome format --write src",
    "build:dist": "node ../../scripts/rm-path-recursive.mjs dist && tsc -p tsconfig.build.json && node ../../scripts/prepare-package-dist.mjs packages/shared",
    "pack:dry-run": "cd dist && npm pack --dry-run"
  },
  "exports": {
    ".": "./dist/index.js",
    "./app-hero-art": "./dist/app-hero-art.js",
    "./connectors": "./dist/connectors.js",
    "./env-utils": "./dist/env-utils.js",
    "./format-error": "./dist/format-error.js",
    "./runtime-env": "./dist/runtime-env.js",
    "./contracts": "./dist/contracts/index.js",
    "./contracts/apps": "./dist/contracts/apps.js",
    "./contracts/awareness": "./dist/contracts/awareness.js",
    "./contracts/config": "./dist/contracts/config.js",
    "./contracts/drop": "./dist/contracts/drop.js",
    "./contracts/lifeops": "./dist/contracts/lifeops.js",
    "./contracts/onboarding": "./dist/contracts/onboarding.js",
    "./contracts/permissions": "./dist/contracts/permissions.js",
    "./contracts/service-routing": "./dist/contracts/service-routing.js",
    "./contracts/verification": "./dist/contracts/verification.js",
    "./contracts/content-pack": "./dist/contracts/content-pack.js",
    "./contracts/theme": "./dist/contracts/theme.js",
    "./themes": "./dist/themes/index.js",
    "./themes/presets": "./dist/themes/presets.js",
    "./contracts/wallet": "./dist/contracts/wallet.js",
    "./config": "./dist/config/types.js",
    "./config/allowed-hosts": "./dist/config/allowed-hosts.js",
    "./config/types.agent-defaults": "./dist/config/types.agent-defaults.js",
    "./config/types.agents": "./dist/config/types.agents.js",
    "./config/types.eliza": "./dist/config/types.eliza.js",
    "./config/types.gateway": "./dist/config/types.gateway.js",
    "./config/types.hooks": "./dist/config/types.hooks.js",
    "./config/types.messages": "./dist/config/types.messages.js",
    "./config/types.tools": "./dist/config/types.tools.js",
    "./awareness": "./dist/awareness/index.js",
    "./restart": "./dist/restart.js",
    "./self-edit": "./dist/self-edit.js",
    "./spoken-text": "./dist/spoken-text.js",
    "./eliza-core-roles": "./dist/eliza-core-roles.js",
    "./validation-keywords": "./dist/validation-keywords.js",
    "./onboarding-presets": "./dist/onboarding-presets.js",
    "./dev-settings-table": "./dist/dev-settings-table.js",
    "./dev-settings-banner-style": "./dist/dev-settings-banner-style.js",
    "./dev-settings-figlet-heading": "./dist/dev-settings-figlet-heading.js",
    "./recent-messages-state": "./dist/recent-messages-state.js",
    "./type-guards": "./dist/type-guards.js",
    "./contracts/lifeops-extensions": "./dist/contracts/lifeops-extensions.js"
  },
  "publishConfig": {
    "access": "public",
    "directory": "dist"
  },
  "dependencies": {
    "@elizaos/core": "workspace:*",
    "zod": "^4.4.3"
  },
  "optionalDependencies": {
    "figlet": "^1.11.0"
  },
  "devDependencies": {
    "@types/figlet": "^1.7.0",
    "bun-types": "^1.3.12",
    "typescript": "^6.0.3"
  },
  "types": "./dist/index.d.ts"
}
