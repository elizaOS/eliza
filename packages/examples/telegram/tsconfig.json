{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": false,
    "noEmit": true,
    "lib": [
      "ES2022"
    ],
    "types": [
      "node",
      "bun-types"
    ],
    "paths": {
      "@elizaos/core": [
        "./../../core/dist/index.d.ts"
      ],
      "@elizaos/core/*": [
        "./../../core/dist/*"
      ]
    }
  },
  "include": [
    "*.ts",
    "*.d.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
