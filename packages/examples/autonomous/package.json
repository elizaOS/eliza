{
  "name": "@elizaos/example-autonomous",
  "version": "2.0.0-beta.0",
  "description": "Sandboxed autonomous loop using local-ai + shell + inmemorydb",
  "type": "module",
  "scripts": {
    "start": "bun run autonomous.ts",
    "dev": "bun --watch run autonomous.ts",
    "lint": "bunx @biomejs/biome check --write --unsafe .",
    "typecheck": "tsc --noEmit",
    "build": "bun run typecheck"
  },
  "dependencies": {
    "@elizaos/core": "workspace:*",
    "@elizaos/plugin-inmemorydb": "workspace:*",
    "@elizaos/plugin-local-ai": "workspace:*",
    "@elizaos/plugin-shell": "workspace:*",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
