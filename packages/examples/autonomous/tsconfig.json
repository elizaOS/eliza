{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"],
    "paths": {
      "@elizaos/plugin-capacitor-bridge": [
        "../../../plugins/plugin-capacitor-bridge/src/index.ts"
      ],
      "@elizaos/plugin-inmemorydb": [
        "../../../plugins/plugin-inmemorydb/index.ts"
      ],
      "@elizaos/plugin-local-inference": [
        "../../../plugins/plugin-local-inference/src/index.ts"
      ],
      "@elizaos/shared": ["../../../packages/shared/src/index.ts"],
      "@elizaos/shared/*": ["../../../packages/shared/src/*"]
    }
  },
  "include": ["*.ts"],
  "exclude": ["node_modules", "dist"],
  "extends": "../../../tsconfig.dist-paths.json"
}
