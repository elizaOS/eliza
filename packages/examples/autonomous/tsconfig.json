{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"],
    "paths": {
      "@elizaos/core": ["../../../packages/core/dist/index.d.ts"],
      "@elizaos/agent": ["../../../packages/agent/dist/index.d.ts"],
      "@elizaos/agent/*": ["../../../packages/agent/dist/*"],
      "@elizaos/shared": ["../../../packages/shared/src/index.ts"],
      "@elizaos/shared/local-inference": [
        "../../../packages/shared/src/local-inference/index.ts"
      ],
      "@elizaos/shared/*": ["../../../packages/shared/src/*"],
      "@elizaos/app-core": ["../../../packages/app-core/dist/index.d.ts"],
      "@elizaos/app-core/*": ["../../../packages/app-core/dist/*"],
      "@elizaos/plugin-capacitor-bridge": [
        "../../../plugins/plugin-capacitor-bridge/dist/index.d.ts"
      ],
      "@elizaos/plugin-inmemorydb": [
        "../../../plugins/plugin-inmemorydb/dist/index.d.ts"
      ],
      "@elizaos/plugin-local-inference": [
        "../../../plugins/plugin-local-inference/src/index.ts"
      ],
      "@elizaos/plugin-local-inference/*": [
        "../../../plugins/plugin-local-inference/src/*"
      ],
      "@elizaos/plugin-shell": ["../../../plugins/plugin-shell/dist/index.d.ts"]
    }
  },
  "include": [
    "*.ts",
    "../../../plugins/plugin-local-inference/src/adapters/node-llama-cpp/declarations.d.ts"
  ],
  "exclude": ["node_modules", "dist"],
  "extends": "../../../tsconfig.dist-paths.json"
}
