{
  "extends": "../../../tsconfig.json",
  "compilerOptions": {
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "incremental": false,
    "noEmit": true,
    "rootDir": "../../../",
    "strict": false,
    "types": ["node", "bun-types"],
    "paths": {
      "@elizaos/plugin-hearwear": [
        "../../../plugins/plugin-hearwear/src/index.ts"
      ],
      "@elizaos/plugin-hearwear/register": [
        "../../../plugins/plugin-hearwear/src/register.ts"
      ],
      "@elizaos/plugin-hearwear/*": ["../../../plugins/plugin-hearwear/src/*"]
    }
  },
  "include": [
    "declarations.d.ts",
    "eliza-runtime-smoke.ts",
    "evenhub-smoke.ts",
    "hardware-evidence.ts",
    "hardware-report-status.ts",
    "hardware-smoke.ts",
    "noble-hardware-smoke.ts",
    "package-smoke.ts",
    "simulator-automation-smoke.ts",
    "validate-hardware-report.ts",
    "../../../plugins/plugin-hearwear/src/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
