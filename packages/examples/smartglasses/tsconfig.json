{
  "extends": "../../../tsconfig.dist-paths.json",
  "compilerOptions": {
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "incremental": false,
    "noEmit": true,
    "rootDir": ".",
    "strict": true,
    "types": ["node", "bun-types"],
    "paths": {
      "@elizaos/core": ["../../../packages/core/dist/index.d.ts"],
      "@elizaos/shared": ["../../../packages/shared/dist/index.d.ts"],
      "@elizaos/shared/*": ["../../../packages/shared/dist/*"],
      "@elizaos/ui": ["../../../packages/ui/dist/index.d.ts"],
      "@elizaos/ui/*": ["../../../packages/ui/dist/*"],
      "@elizaos/plugin-facewear": [
        "../../../plugins/plugin-facewear/dist/index.d.ts"
      ],
      "@elizaos/plugin-facewear/*": ["../../../plugins/plugin-facewear/dist/*"]
    }
  },
  "include": [
    "declarations.d.ts",
    "eliza-runtime-smoke.ts",
    "evenhub-smoke.ts",
    "hardware-evidence.ts",
    "hardware-local-bluetooth.ts",
    "hardware-report-status.ts",
    "hardware-smoke.ts",
    "noble-hardware-smoke.ts",
    "package-smoke.ts",
    "simulator-automation-smoke.ts",
    "validate-hardware-report.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
