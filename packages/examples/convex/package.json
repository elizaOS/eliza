{
  "name": "@elizaos/example-convex",
  "version": "2.0.0-beta.0",
  "description": "elizaOS agent running on Convex — messages processed via messageService.handleMessage with real-time persistence",
  "type": "module",
  "scripts": {
    "dev": "npx convex dev",
    "start": "npx convex dev",
    "test": "bun run test-client.ts --once",
    "deploy": "npx convex deploy",
    "lint": "bunx @biomejs/biome check --write --unsafe .",
    "typecheck": "if [ -d convex/_generated ]; then tsc --noEmit; else echo 'Convex generated types missing; run convex dev/codegen for full typecheck'; fi",
    "build": "bun run typecheck"
  },
  "dependencies": {
    "@elizaos/core": "workspace:*",
    "@elizaos/plugin-openai": "workspace:*",
    "@elizaos/plugin-anthropic": "workspace:*",
    "@elizaos/plugin-xai": "workspace:*",
    "@elizaos/plugin-google-genai": "workspace:*",
    "@elizaos/plugin-groq": "workspace:*",
    "@elizaos/plugin-sql": "workspace:*",
    "convex": "^1.25.2",
    "dotenv": "^17.0.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "@types/uuid": "^11.0.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
