# =============================================================================
# X Agent Example (Grok + X API)
# =============================================================================
# Copy this file to .env and fill in your credentials.
#
# SAFETY: Start with TWITTER_DRY_RUN=true so nothing is posted.
#

# =============================================================================
# Grok (xAI) API (required) — provided by @elizaos/plugin-xai
# =============================================================================
XAI_API_KEY=your-xai-api-key
# XAI_BASE_URL=https://api.x.ai/v1
# XAI_SMALL_MODEL=grok-3-mini
# XAI_MODEL=grok-3
# XAI_EMBEDDING_MODEL=grok-embedding

# =============================================================================
# X (Twitter) API v2 authentication — provided by @elizaos/plugin-twitter
# =============================================================================
# Default: OAuth 1.0a user context (env). Other modes: oauth (PKCE), broker.
TWITTER_AUTH_MODE=env
TWITTER_API_KEY=your-x-api-key
TWITTER_API_SECRET_KEY=your-x-api-secret
TWITTER_ACCESS_TOKEN=your-x-access-token
TWITTER_ACCESS_TOKEN_SECRET=your-x-access-token-secret

# Optional: app-only Bearer token for read-only endpoints.
# TWITTER_BEARER_TOKEN=your-app-only-bearer-token

# OAuth 2.0 PKCE (interactive login) — set TWITTER_AUTH_MODE=oauth and provide:
# TWITTER_CLIENT_ID=your-oauth-client-id
# TWITTER_REDIRECT_URI=http://127.0.0.1:1717/callback
# TWITTER_SCOPES=tweet.read tweet.write users.read offline.access

# Eliza Cloud broker (managed OAuth) — set TWITTER_AUTH_MODE=broker and provide:
# TWITTER_BROKER_URL=https://api.eliza.cloud/connectors/twitter

# =============================================================================
# Agent Behavior
# =============================================================================
TWITTER_DRY_RUN=true

# Reply to mentions (polls @you and replies)
TWITTER_ENABLE_REPLIES=true

# Autonomous posting loop
TWITTER_ENABLE_POST=false

# Timeline actions (likes/reposts/replies chosen by the agent)
TWITTER_ENABLE_ACTIONS=false

# Optional targeting: comma-separated handles or "*" for broad engagement.
# TWITTER_TARGET_USERS=@someuser,@anotheruser
# TWITTER_TARGET_USERS=*

# =============================================================================
# Database (optional)
# =============================================================================
# For production, use PostgreSQL:
# POSTGRES_URL=postgresql://user:password@localhost:5432/elizaos
#
# For development, PGLite is used by default (no config needed).
# PGLITE_DATA_DIR=./data/pglite
