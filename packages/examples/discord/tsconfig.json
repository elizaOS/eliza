{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": false,
    "noEmit": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": ["node"],
    "paths": {
      "@elizaos/core": ["../../../packages/core/dist/index.d.ts"],
      "@elizaos/plugin-discord": [
        "../../../plugins/plugin-discord/dist/index.d.ts"
      ],
      "@elizaos/plugin-openai": [
        "../../../plugins/plugin-openai/dist/index.d.ts"
      ],
      "@elizaos/plugin-sql": [
        "../../../plugins/plugin-sql/src/dist/index.node.d.ts"
      ]
    }
  },
  "include": ["*.ts", "__tests__/**/*.ts"],
  "exclude": ["node_modules"],
  "extends": "../../../tsconfig.dist-paths.json"
}
