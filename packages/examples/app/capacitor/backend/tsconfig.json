{
  "compilerOptions": {
    "lib": [
      "ES2022",
      "DOM"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "types": [
      "node"
    ],
    "strict": true,
    "noEmit": true,
    "paths": {
      "@elizaos/core": [
        "./../../../../../packages/core/src/index.node.ts"
      ],
      "@elizaos/core/*": [
        "./../../../../../packages/core/src/*"
      ],
      "@elizaos/shared": [
        "./../../../../../packages/shared/src/index.ts"
      ],
      "@elizaos/shared/*": [
        "./../../../../../packages/shared/src/*"
      ],
      "@elizaos/plugin-anthropic": [
        "./src/provider-plugin.d.ts"
      ],
      "@elizaos/plugin-google-genai": [
        "./src/provider-plugin.d.ts"
      ],
      "@elizaos/plugin-groq": [
        "./src/provider-plugin.d.ts"
      ],
      "@elizaos/plugin-ollama": [
        "./src/provider-plugin.d.ts"
      ],
      "@elizaos/plugin-openai": [
        "./src/provider-plugin.d.ts"
      ],
      "@elizaos/plugin-openrouter": [
        "./src/provider-plugin.d.ts"
      ]
    }
  },
  "include": [
    "src/**/*.ts"
  ]
}
