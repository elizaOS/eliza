{
  "compilerOptions": {
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "types": ["node", "electron"],
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": false,
    "noEmit": false,
    "rewriteRelativeImportExtensions": true,
    "paths": {
      "@elizaos/plugin-localdb": [
        "./../../../../../plugins/plugin-localdb/dist/index.d.ts"
      ],
      "@elizaos/plugin-elizacloud": [
        "./../../../../../plugins/plugin-elizacloud/dist/node/index.d.ts"
      ],
      "@elizaos/plugin-groq": ["./src/provider-plugin.d.ts"],
      "@elizaos/plugin-ollama": ["./src/provider-plugin.d.ts"],
      "@elizaos/plugin-openrouter": ["./src/provider-plugin.d.ts"]
    }
  },
  "include": ["src/**/*.ts"],
  "extends": "../../../../../tsconfig.dist-paths.json"
}
