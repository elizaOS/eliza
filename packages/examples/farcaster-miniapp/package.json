{
  "name": "eliza-multichain-miniapp",
  "version": "2.0.0-beta.0",
  "type": "module",
  "description": "ElizaOS Multi-chain Trading Platform - Farcaster Mini App",
  "scripts": {
    "dev": "bun --bun vite",
    "build": "tsc && bun --bun vite build",
    "preview": "bun --bun vite preview",
    "start": "node server.js",
    "test": "vitest run --passWithNoTests",
    "test:real": "USE_REAL_API=true vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run __tests__/integration",
    "lint": "bunx @biomejs/biome check --write --unsafe .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@farcaster/miniapp-sdk": "^0.3.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.5.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/react": "^19.2.3",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "@vitest/coverage-v8": "^4.0.17",
    "@vitest/ui": "^4.0.17",
    "jsdom": "^29.0.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.8",
    "vitest": "^4.0.17"
  }
}
