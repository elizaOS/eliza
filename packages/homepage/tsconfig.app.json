{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "paths": {
      "@/*": ["./src/*"],
      "@elizaos/ui/button": ["../ui/src/cloud-ui/components/button.tsx"],
      "@elizaos/ui/dropdown-menu": [
        "../ui/src/cloud-ui/components/dropdown-menu.tsx"
      ],
      "@elizaos/ui/input": ["../ui/src/cloud-ui/components/input.tsx"],
      "@elizaos/ui/product-switcher": [
        "../ui/src/cloud-ui/components/product-switcher.tsx"
      ]
    },
    "types": ["vite/client"]
  },
  "include": ["src"]
}
