# ============================================================================
# ELIZA APP - ENVIRONMENT CONFIGURATION
# ============================================================================
# Copy this file to .env.local and configure for your environment

# Base URL for elizacloud API (used by React Query / API client)
#
# For production (default):
# NEXT_PUBLIC_ELIZACLOUD_API_URL=https://www.elizacloud.ai
#
# For local development with eliza-cloud-v2:
# NEXT_PUBLIC_ELIZACLOUD_API_URL=http://localhost:3000
#
# Note: When running locally, start eliza-cloud-v2 on port 3000 first,
# then run eliza-app on port 4444 (npm run dev)

NEXT_PUBLIC_ELIZACLOUD_API_URL=https://www.elizacloud.ai

# ============================================================================
# TELEGRAM AUTHENTICATION
# ============================================================================
# Bot numeric ID (first part of bot token before the colon)
# Example: If token is 8202935775:AAGL9Dhf..., use 8202935775
NEXT_PUBLIC_TELEGRAM_BOT_ID=

# Bot username for Telegram Login Widget (without @ prefix)
# This must match the bot configured in eliza-cloud-v2 ELIZA_APP_TELEGRAM_BOT_TOKEN
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=

# -----------------------------------------------------------------------------
# Discord Configuration
# -----------------------------------------------------------------------------
# Discord Application ID (from Discord Developer Portal > General Information)
# This is also the OAuth2 Client ID
NEXT_PUBLIC_DISCORD_CLIENT_ID=

# -----------------------------------------------------------------------------
# WhatsApp Configuration
# -----------------------------------------------------------------------------
# WhatsApp Business phone number displayed to users (E.164 format)
NEXT_PUBLIC_WHATSAPP_PHONE_NUMBER=
