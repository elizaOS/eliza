    "predev": "node ../app-core/scripts/write-homepage-release-data.mjs",
    "dev": "bun --bun vite --port 4444",
    "prebuild": "node ../app-core/scripts/write-homepage-release-data.mjs",
    "build": "bun --bun vite build",
    "test": "vitest run",
    "typecheck": "node ../app-core/scripts/write-homepage-release-data.mjs && tsc -b",
    "preview": "bun --bun vite preview --port 4444",
