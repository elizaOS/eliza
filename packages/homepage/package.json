    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@tanstack/react-query": "^5.90.20",
    "@use-gesture/react": "^10.3.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "country-flag-icons": "^1.6.12",
    "framer-motion": "^12.29.2",
    "libphonenumber-js": "^1.12.35",
    "lucide-react": "^1.0.0",
