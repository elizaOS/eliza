{
  "name": "@elizaos/os-usb-installer",
  "version": "0.1.0",
  "private": true,
  "description": "Electrobun microapp scaffold for preparing bootable elizaOS USB installers.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "predev": "node ../shared-brand/scripts/sync-to-public.mjs ./public",
    "dev": "vite",
    "prebuild": "node ../shared-brand/scripts/sync-to-public.mjs ./public",
    "build": "tsc --noEmit -p tsconfig.json && vite build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --config ./vitest.config.ts",
    "lint": "bunx @biomejs/biome check src vite.config.ts vitest.config.ts",
    "server": "bun run server.ts",
    "start": "bash run-dev.sh",
    "build:app": "electrobun build",
    "package:darwin": "electrobun build --platform darwin",
    "package:linux": "electrobun build --platform linux",
    "package:win32": "electrobun build --platform win32"
  },
  "dependencies": {
    "@elizaos/shared-brand": "workspace:*",
    "@fontsource-variable/open-sans": "^5.2.7",
    "vite": "^8.0.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^25.0.0",
    "@types/react": "^18.0.0 || ^19.0.0",
    "@types/react-dom": "^18.0.0 || ^19.0.0",
    "jsdom": "^29.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.0.0"
  }
}
