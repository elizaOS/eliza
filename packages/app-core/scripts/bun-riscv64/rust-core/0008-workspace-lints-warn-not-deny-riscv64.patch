Subject: [PATCH] riscv64 Rust-core bun: demote arch-sensitive lints deny->warn

bun's root Cargo.toml [workspace.lints.rust] makes every rustc warning an error
and additionally pins dead_code / unreachable_pub / the unused_* + unreachable_*
family to "deny". On the riscv64gc-unknown-linux-musl cross-build (a target
upstream does not compile), arch-gated code legitimately leaves items unused on
riscv64 — e.g. `bun_core::debug::PC_OFFSET` is only read by `return_address()`'s
`#[cfg(any(target_arch = "x86_64", target_arch = "aarch64"))]` arm, so on riscv64
it is dead and the build fails:

    error: constant `PC_OFFSET` is never used  (src/bun_core/debug.rs:269)

These are true for the lint but false for code quality (the items ARE used on the
supported arches). Rather than scatter #[cfg]/#[allow] across dozens of upstream
sites, demote just the arch-sensitive family from "deny" to "warn" (their
priority 0 beats the `warnings` group's -1, per the block's own comment), so they
stay printed but non-fatal. `warnings = "deny"` is left unchanged, so any OTHER
warning class still fails the build. Off-riscv64 builds use upstream prebuilts
and never see this patched tree.

diff --git a/Cargo.toml b/Cargo.toml
index 99eac8be..65e7f113 100644
--- a/Cargo.toml
+++ b/Cargo.toml
@@ -194,20 +194,25 @@ unexpected_cfgs = { level = "warn", check-cfg = ['cfg(bun_asan)'] }
 # there is no linker flag to suppress it. The lint already exempts itself
 # from `-D warnings`, so this only silences the noise.
 linker_messages = "allow"
-dead_code = "deny"
-# Every crate in this workspace is an internal implementation detail of one
-# binary, so `pub` is a claim that *another crate* imports the item. If it
-# doesn't, write `pub(crate)` — that keeps the item under `dead_code` analysis
-# instead of being exempted as an external API root. Macro-generated items that
-# must stay `pub` carry `#[allow(unreachable_pub)]` at the expansion site.
-unreachable_pub = "deny"
-unused_imports = "deny"
-unused_variables = "deny"
-unused_mut = "deny"
-unused_assignments = "deny"
-unused_macros = "deny"
-unreachable_code = "deny"
-unreachable_patterns = "deny"
+# riscv64 cross-build relaxation (bun-riscv64 rust-core port): upstream Bun does
+# not compile the riscv64gc-unknown-linux-musl target, so arch-gated code
+# (`#[cfg(any(target_arch = "x86_64", target_arch = "aarch64"))]` blocks and the
+# items they reference) legitimately leaves consts/imports/fns unused on riscv64.
+# These are real for the lint but false for code quality (the items ARE used on
+# the supported arches), so demote the arch-sensitive family from "deny" to
+# "warn" — still printed, but non-fatal — instead of scattering #[cfg]/#[allow]
+# across dozens of upstream sites. `warnings = "deny"` (above) is unchanged, so
+# any OTHER warning class still fails the build. Off-riscv64 builds use upstream
+# prebuilts and never see this patched tree.
+dead_code = "warn"
+unreachable_pub = "warn"
+unused_imports = "warn"
+unused_variables = "warn"
+unused_mut = "warn"
+unused_assignments = "warn"
+unused_macros = "warn"
+unreachable_code = "warn"
+unreachable_patterns = "warn"

 [workspace.lints.clippy]
 # == provenance-safe pointer casts ==
