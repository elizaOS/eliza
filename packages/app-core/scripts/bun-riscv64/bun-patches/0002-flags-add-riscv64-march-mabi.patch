From e230919866ddbc93faa7ea4a91096899a60d29d2 Mon Sep 17 00:00:00 2001
From: bun-riscv64 build <bun-riscv64@milady.local>
Date: Tue, 19 May 2026 04:35:05 -0700
Subject: [PATCH 2/7] flags: add riscv64 CPU target flags (rv64gc/lp64d)

Adds an entry to cpuTargetFlags emitting -march=rv64gc -mabi=lp64d for

linux/riscv64. Canonical defaults for Alpine v3.21, Debian sid, Ubuntu 24.
---
 scripts/build/flags.ts | 5 +++++
 1 file changed, 5 insertions(+)

diff --git a/scripts/build/flags.ts b/scripts/build/flags.ts
index 1ac5b4d..455e26c 100644
--- a/scripts/build/flags.ts
+++ b/scripts/build/flags.ts
@@ -51,6 +51,11 @@ export const cpuTargetFlags: Flag[] = [
     when: c => c.windows && c.arm64,
     desc: "ARM64 Windows: clang-cl prefix required (/clang: passes to clang)",
   },
+  {
+    flag: ["-march=rv64gc", "-mabi=lp64d"],
+    when: c => c.linux && c.riscv64,
+    desc: "RISC-V 64 Linux: rv64gc (IMAFDC + Zicsr/Zifencei) + lp64d ABI",
+  },
   {
     flag: "-march=nehalem",
     when: c => c.x64 && c.baseline,
-- 
