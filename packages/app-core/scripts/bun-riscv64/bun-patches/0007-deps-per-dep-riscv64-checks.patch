From cc9ed5d967599f14da31b6c6e6da90d173ac5d74 Mon Sep 17 00:00:00 2001
From: bun-riscv64 build <bun-riscv64@milady.local>
Date: Tue, 19 May 2026 04:36:42 -0700
Subject: [PATCH 7/7] deps/lolhtml: set rustTarget for linux/riscv64
 cross-compile

lol-html is the only cargo-built dep. cargo defaults to the host triple, which is wrong for riscv64 cross-compile; explicit rustTarget fixes it.
---
 scripts/build/deps/lolhtml.ts | 11 ++++++++---
 1 file changed, 8 insertions(+), 3 deletions(-)

diff --git a/scripts/build/deps/lolhtml.ts b/scripts/build/deps/lolhtml.ts
index 901f12f..65363f7 100644
--- a/scripts/build/deps/lolhtml.ts
+++ b/scripts/build/deps/lolhtml.ts
@@ -38,11 +38,16 @@ export const lolhtml: Dependency = {
       spec.rustflags = ["-Cpanic=abort", "-Cdebuginfo=0", "-Cforce-unwind-tables=no", "-Copt-level=s"];
     }
 
-    // arm64-windows: cargo defaults to the host triple, but CI builds arm64
-    // windows binaries on x64 runners. Explicit triple forces the cross-compile.
-    // (x64-windows doesn't need this — host IS target.)
+    // Cross-compile targets: cargo defaults to the host triple, which is
+    // wrong for any non-host arch build. Explicit rustTarget forces it.
+    // (Native builds — host IS target — don't need this.)
     if (cfg.windows && cfg.arm64) {
       spec.rustTarget = "aarch64-pc-windows-msvc";
+    } else if (cfg.linux && cfg.riscv64) {
+      // Tier-2 prebuilt-std target; install via:
+      //   rustup target add riscv64gc-unknown-linux-musl
+      // build.sh stage 3 does this.
+      spec.rustTarget = `riscv64gc-unknown-linux-${cfg.abi}`;
     }
 
     return spec;
