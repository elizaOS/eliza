{
  "id": "acp",
  "name": "Acp",
  "description": "Agent Communication Protocol connector for linking agents through an ACP gateway.",
  "npmName": "@elizaos/plugin-acp",
  "version": "2.0.0-alpha.4",
  "source": "bundled",
  "tags": [
    "connector",
    "agents",
    "gateway",
    "realtime",
    "acp"
  ],
  "config": {
    "ACP_VERBOSE": {
      "type": "boolean",
      "required": false,
      "sensitive": false,
      "label": "Verbose",
      "help": "Enable verbose logging",
      "advanced": true
    },
    "ACP_AGENT_ID": {
      "type": "string",
      "required": false,
      "sensitive": false,
      "label": "Agent Id",
      "help": "Agent identifier",
      "advanced": false
    },
    "ACP_PREFIX_CWD": {
      "type": "string",
      "required": false,
      "sensitive": false,
      "label": "Prefix Cwd",
      "help": "Prefix current working directory",
      "advanced": false
    },
    "ACP_CLIENT_MODE": {
      "type": "string",
      "required": false,
      "sensitive": false,
      "label": "Client Mode",
      "help": "Operating mode",
      "advanced": false
    },
    "ACP_CLIENT_NAME": {
      "type": "string",
      "required": false,
      "sensitive": false,
      "label": "Client Name",
      "help": "Display name",
      "advanced": false
