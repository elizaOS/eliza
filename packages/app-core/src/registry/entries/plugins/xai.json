{
  "id": "xai",
  "name": "Xai",
  "description": "TypeScript package for elizaOS xAI integration.",
  "npmName": "@elizaos/plugin-xai",
  "version": "2.0.0-alpha.4",
  "source": "bundled",
  "tags": [
    "ai-provider",
    "llm",
    "xai"
  ],
  "config": {
    "XAI_MODEL": {
      "type": "string",
      "required": false,
      "sensitive": false,
      "default": "grok-3",
      "label": "Model",
      "help": "xAI Grok model for text generation (grok-3, grok-3-mini).",
      "placeholder": "e.g., gpt-4o, claude-sonnet-4-20250514",
      "advanced": false
    },
    "X_API_KEY": {
      "type": "secret",
      "required": false,
      "sensitive": true,
      "label": "Api Key",
      "help": "X (formerly Twitter) API key for OAuth 1.0a.",
      "advanced": false
    },
    "X_DRY_RUN": {
      "type": "boolean",
      "required": false,
      "sensitive": false,
      "default": "False",
      "label": "Dry Run",
      "help": "When true, all X actions are simulated.",
      "advanced": false
    },
    "XAI_API_KEY": {
      "type": "secret",
      "required": true,
      "sensitive": true,
      "label": "Api Key",
      "help": "xAI API key for Grok model access and X (formerly Twitter) integration.",
      "advanced": false
    },
    "X_AUTH_MODE": {
      "type": "string",
      "required": false,
      "sensitive": false,
      "default": "env",
      "label": "Auth Mode",
      "help": "X (formerly Twitter) auth mode: 'env' (API keys), 'oauth' (OAuth2 PKCE), or 'bearer'.",
      "advanced": false
    },
    "X_CLIENT_ID": {
      "type": "string",
      "required": false,
      "sensitive": false,
      "label": "Client Id",
      "help": "X (formerly Twitter) OAuth2 client ID.",
      "advanced": false
    },
    "XAI_BASE_URL": {
      "type": "url",
      "required": false,
      "sensitive": false,
      "default": "https://api.x.ai/v1",
      "label": "Base Url",
      "help": "xAI API base URL.",
      "advanced": false
    },
    "X_API_SECRET": {
      "type": "secret",
      "required": false,
      "sensitive": true,
      "label": "Api Secret",
      "help": "X (formerly Twitter) API secret key for OAuth 1.0a.",
      "advanced": false
    },
    "X_ENABLE_POST": {
      "type": "boolean",
      "required": false,
      "sensitive": false,
      "default": "False",
      "label": "Enable Post",
      "help": "Enable autonomous posting.",
      "advanced": false
    },
    "X_ACCESS_TOKEN": {
      "type": "secret",
      "required": false,
      "sensitive": true,
      "label": "Access Token",
      "help": "X (formerly Twitter) access token for OAuth 1.0a.",
      "advanced": false
    },
    "X_BEARER_TOKEN": {
      "type": "secret",
      "required": false,
      "sensitive": true,
      "label": "Bearer Token",
      "help": "X (formerly Twitter) Bearer token for app-only authentication.",
      "advanced": false
    },
    "X_REDIRECT_URI": {
      "type": "string",
      "required": false,
      "sensitive": false,
      "label": "Redirect Uri",
      "help": "OAuth2 redirect URI.",
      "advanced": false
    },
    "XAI_SMALL_MODEL": {
      "type": "string",
      "required": false,
      "sensitive": false,
      "default": "grok-3-mini",
      "label": "Small Model",
      "help": "xAI Grok model for faster/smaller tasks.",
      "placeholder": "e.g., gpt-4o, claude-sonnet-4-20250514",
      "advanced": false
    },
    "X_ENABLE_ACTIONS": {
      "type": "boolean",
      "required": false,
      "sensitive": false,
      "default": "False",
      "label": "Enable Actions",
      "help": "Enable timeline actions (like, repost).",
      "advanced": false
    },
    "X_ENABLE_REPLIES": {
      "type": "boolean",
      "required": false,
      "sensitive": false,
      "default": "True",
      "label": "Enable Replies",
      "help": "Enable reply handling.",
      "advanced": false
    },
    "X_MAX_POST_LENGTH": {
      "type": "number",
      "required": false,
      "sensitive": false,
      "default": "280",
      "label": "Max Post Length",
      "help": "Maximum post length (up to 4000 for premium).",
      "advanced": false
    },
    "XAI_EMBEDDING_MODEL": {
      "type": "string",
      "required": false,
      "sensitive": false,
      "default": "grok-embedding",
      "label": "Embedding Model",
      "help": "xAI model for text embeddings.",
      "placeholder": "e.g., text-embedding-3-small",
      "advanced": false
    },
    "X_ACCESS_TOKEN_SECRET": {
      "type": "secret",
      "required": false,
      "sensitive": true,
      "label": "Access Token Secret",
      "help": "X (formerly Twitter) access token secret for OAuth 1.0a.",
      "advanced": false
    }
  },
  "render": {
    "visible": true,
    "pinTo": [],
    "style": "card",
    "icon": "Hash",
    "group": "ai-provider",
    "groupOrder": 0,
    "actions": [
      "enable",
      "configure"
    ]
  },
  "resources": {
    "homepage": "https://github.com/elizaos-plugins/plugin-xai#readme",
    "repository": "https://github.com/elizaos-plugins/plugin-xai",
    "setupGuideUrl": "https://docs.eliza.ai/plugin-setup-guide#xai-grok"
  },
  "dependsOn": [],
  "kind": "plugin",
  "subtype": "ai-provider"
}
