{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elizalabs.ai/schemas/eliza-1.manifest.v1.json",
  "title": "Eliza-1 bundle manifest",
  "description": "Canonical manifest for an Eliza-1 on-device fused bundle. Source of truth: packages/inference/AGENTS.md §6. Schema version 1.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "tier",
    "version",
    "publishedAt",
    "lineage",
    "files",
    "kernels",
    "evals",
    "ramBudgetMb",
    "defaultEligible"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "const": "https://elizalabs.ai/schemas/eliza-1.manifest.v1.json"
    },
    "id": { "type": "string", "minLength": 1 },
    "tier": {
      "type": "string",
      "enum": ["0_8b", "2b", "4b", "9b", "27b", "27b-256k", "27b-1m"]
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(?:-[A-Za-z0-9.-]+)?$"
    },
    "publishedAt": { "type": "string", "format": "date-time" },
    "lineage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text", "voice", "drafter"],
      "properties": {
        "text": { "$ref": "#/$defs/lineageEntry" },
        "voice": { "$ref": "#/$defs/lineageEntry" },
        "drafter": { "$ref": "#/$defs/lineageEntry" },
        "asr": { "$ref": "#/$defs/lineageEntry" },
        "embedding": { "$ref": "#/$defs/lineageEntry" },
        "vision": { "$ref": "#/$defs/lineageEntry" },
        "vad": { "$ref": "#/$defs/lineageEntry" },
        "wakeword": { "$ref": "#/$defs/lineageEntry" }
      }
    },
    "files": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text", "voice", "asr", "vision", "dflash", "cache"],
      "properties": {
        "text": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/fileEntry" }
        },
        "voice": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/fileEntry" }
        },
        "asr": { "type": "array", "items": { "$ref": "#/$defs/fileEntry" } },
        "vision": { "type": "array", "items": { "$ref": "#/$defs/fileEntry" } },
        "dflash": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/fileEntry" }
        },
        "cache": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/fileEntry" }
        },
        "embedding": {
          "type": "array",
          "items": { "$ref": "#/$defs/fileEntry" }
        },
        "vad": { "type": "array", "items": { "$ref": "#/$defs/fileEntry" } },
        "wakeword": {
          "type": "array",
          "items": { "$ref": "#/$defs/fileEntry" }
        }
      }
    },
    "kernels": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "optional", "verifiedBackends"],
      "properties": {
        "required": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/kernelName" }
        },
        "optional": {
          "type": "array",
          "items": { "$ref": "#/$defs/kernelName" }
        },
        "verifiedBackends": {
          "type": "object",
          "additionalProperties": false,
          "required": ["metal", "vulkan", "cuda", "rocm", "cpu"],
          "properties": {
            "metal": { "$ref": "#/$defs/backendStatus" },
            "vulkan": { "$ref": "#/$defs/backendStatus" },
            "cuda": { "$ref": "#/$defs/backendStatus" },
            "rocm": { "$ref": "#/$defs/backendStatus" },
            "cpu": { "$ref": "#/$defs/backendStatus" }
          }
        },
        "recipeManifest": {
          "description": "Recipe-level kernel layout pins folded in from the quantization recipes' kernel_manifest sidecar fragments (packages/training/scripts/quantization/_kernel_manifest.py). Keyed by recipe kernel-target name (turbo3 / turbo4 / turbo3_tcq / qjl1_256 / polar_q4), NOT the manifest-level capability names in kernelName.",
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "blockLayoutVersion",
              "codebookHash",
              "perBlockTolerance"
            ],
            "properties": {
              "blockLayoutVersion": { "type": "string", "minLength": 1 },
              "codebookHash": { "type": "string", "minLength": 1 },
              "perBlockTolerance": { "type": "number", "exclusiveMinimum": 0 }
            }
          }
        }
      }
    },
    "evals": {
      "type": "object",
      "additionalProperties": false,
      "required": ["textEval", "voiceRtf", "e2eLoopOk", "thirtyTurnOk"],
      "properties": {
        "textEval": {
          "type": "object",
          "additionalProperties": false,
          "required": ["score", "passed"],
          "properties": {
            "score": { "type": "number", "minimum": 0, "maximum": 1 },
            "passed": { "type": "boolean" }
          }
        },
        "voiceRtf": {
          "type": "object",
          "additionalProperties": false,
          "required": ["rtf", "passed"],
          "properties": {
            "rtf": { "type": "number", "minimum": 0 },
            "passed": { "type": "boolean" }
          }
        },
        "e2eLoopOk": { "type": "boolean" },
        "thirtyTurnOk": { "type": "boolean" },
        "asrWer": {
          "type": "object",
          "additionalProperties": false,
          "required": ["wer", "passed"],
          "properties": {
            "wer": { "type": "number", "minimum": 0 },
            "passed": { "type": "boolean" }
          }
        },
        "embedMteb": {
          "type": "object",
          "additionalProperties": false,
          "required": ["score", "passed"],
          "properties": {
            "score": { "type": "number", "minimum": 0, "maximum": 1 },
            "passed": { "type": "boolean" }
          }
        },
        "vadLatencyMs": {
          "type": "object",
          "additionalProperties": false,
          "required": ["median", "passed"],
          "properties": {
            "median": { "type": "number", "minimum": 0 },
            "boundaryMs": { "type": "number", "minimum": 0 },
            "endpointMs": { "type": "number", "minimum": 0 },
            "falseBargeInRate": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "passed": { "type": "boolean" }
          }
        },
        "expressive": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "tagFaithfulness",
            "mosExpressive",
            "tagLeakage",
            "passed"
          ],
          "properties": {
            "tagFaithfulness": { "type": "number", "minimum": 0, "maximum": 1 },
            "mosExpressive": { "type": "number", "minimum": 0 },
            "tagLeakage": { "type": "number", "minimum": 0 },
            "passed": { "type": "boolean" }
          }
        },
        "dflash": {
          "type": "object",
          "additionalProperties": false,
          "required": ["acceptanceRate", "speedup", "passed"],
          "properties": {
            "acceptanceRate": {
              "type": ["number", "null"],
              "minimum": 0,
              "maximum": 1
            },
            "speedup": { "type": ["number", "null"], "minimum": 0 },
            "passed": { "type": "boolean" }
          }
        }
      }
    },
    "ramBudgetMb": {
      "type": "object",
      "additionalProperties": false,
      "required": ["min", "recommended"],
      "properties": {
        "min": { "type": "integer", "minimum": 1 },
        "recommended": { "type": "integer", "minimum": 1 }
      }
    },
    "voice": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "frozen", "cache", "capabilities"],
      "properties": {
        "version": { "type": "string", "minLength": 1 },
        "frozen": { "const": true },
        "cache": {
          "type": "object",
          "additionalProperties": false,
          "required": ["speakerPreset", "phraseCacheSeed"],
          "properties": {
            "speakerPreset": { "type": "string", "minLength": 1 },
            "phraseCacheSeed": { "type": "string", "minLength": 1 }
          }
        },
        "capabilities": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["tts", "emotion-tags", "singing"]
          }
        }
      }
    },
    "provenance": {
      "description": "Optional. Present on `base-v1` bundles — the upstream BASE models, GGUF-converted via the elizaOS/llama.cpp fork and fully Eliza-optimized, NOT fine-tuned. Records the release state, the not-fine-tuned flag, and the upstream source repo per shipped component. The runtime validator requires per-component coverage when releaseState === 'base-v1'.",
      "type": "object",
      "additionalProperties": false,
      "required": ["releaseState", "finetuned", "sourceModels"],
      "properties": {
        "releaseState": {
          "type": "string",
          "enum": [
            "local-standin",
            "base-v1",
            "finetuned-v2",
            "upload-candidate",
            "final"
          ]
        },
        "finetuned": { "type": "boolean" },
        "sourceModels": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "text": { "$ref": "#/$defs/sourceModelEntry" },
            "voice": { "$ref": "#/$defs/sourceModelEntry" },
            "asr": { "$ref": "#/$defs/sourceModelEntry" },
            "vad": { "$ref": "#/$defs/sourceModelEntry" },
            "embedding": { "$ref": "#/$defs/sourceModelEntry" },
            "vision": { "$ref": "#/$defs/sourceModelEntry" },
            "drafter": { "$ref": "#/$defs/sourceModelEntry" }
          }
        }
      }
    },
    "defaultEligible": { "type": "boolean" }
  },
  "$defs": {
    "sourceModelEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repo"],
      "properties": {
        "repo": { "type": "string", "minLength": 1 },
        "file": { "type": "string", "minLength": 1 },
        "convertedVia": { "type": "string", "minLength": 1 },
        "note": { "type": "string", "minLength": 1 }
      }
    },
    "lineageEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["base", "license"],
      "properties": {
        "base": { "type": "string", "minLength": 1 },
        "license": { "type": "string", "minLength": 1 }
      }
    },
    "fileEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "ctx": { "type": "integer", "minimum": 1 }
      }
    },
    "kernelName": {
      "type": "string",
      "enum": [
        "turboquant_q3",
        "turboquant_q4",
        "qjl",
        "polarquant",
        "dflash",
        "turbo3_tcq"
      ]
    },
    "backendStatus": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "atCommit", "report"],
      "properties": {
        "status": { "type": "string", "enum": ["pass", "fail", "skipped"] },
        "atCommit": { "type": "string", "minLength": 1 },
        "report": { "type": "string", "minLength": 1 },
        "device": { "type": "string", "minLength": 1 },
        "caveat": { "type": "string", "minLength": 1 }
      }
    }
  }
}
