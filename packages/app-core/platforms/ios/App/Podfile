require_relative '../../../../app/node_modules/@capacitor/ios/scripts/pods_helpers'

platform :ios, '15.0'
use_frameworks!

# workaround to avoid Xcode caching of Pods that requires
# Product -> Clean Build Folder after new Cordova plugins installed
# Requires CocoaPods 1.6 or newer
install! 'cocoapods', :disable_input_output_paths => true

def capacitor_pods
  pod 'Capacitor', :path => '../../../../app/node_modules/@capacitor/ios'
  pod 'CapacitorCordova', :path => '../../../../app/node_modules/@capacitor/ios'
  pod 'CapacitorApp', :path => '../../../../app/node_modules/@capacitor/app'
  pod 'CapacitorBarcodeScanner', :path => '../../../../app/node_modules/@capacitor/barcode-scanner'
  pod 'CapacitorHaptics', :path => '../../../../app/node_modules/@capacitor/haptics'
  pod 'CapacitorKeyboard', :path => '../../../../app/node_modules/@capacitor/keyboard'
  pod 'CapacitorPreferences', :path => '../../../../app/node_modules/@capacitor/preferences'
  pod 'LlamaCppCapacitor', :path => '../../../../app/node_modules/llama-cpp-capacitor'
  pod 'CapacitorPushNotifications', :path => '../../../../app/node_modules/@capacitor/push-notifications'
  pod 'ElizaosCapacitorAgent', :path => '../../../../native-plugins/agent'
  pod 'ElizaosCapacitorCamera', :path => '../../../../native-plugins/camera'
  pod 'ElizaosCapacitorCanvas', :path => '../../../../native-plugins/canvas'
  pod 'ElizaosCapacitorGateway', :path => '../../../../native-plugins/gateway'
  pod 'ElizaosCapacitorLocation', :path => '../../../../native-plugins/location'
  pod 'ElizaosCapacitorMobileSignals', :path => '../../../../native-plugins/mobile-signals'
  pod 'ElizaosCapacitorScreencapture', :path => '../../../../native-plugins/screencapture'
  pod 'ElizaosCapacitorSwabble', :path => '../../../../native-plugins/swabble'
  pod 'ElizaosCapacitorTalkmode', :path => '../../../../native-plugins/talkmode'
  pod 'ElizaosCapacitorWebsiteblocker', :path => '../../../../native-plugins/websiteblocker'
end

target 'App' do
  capacitor_pods
  # Add your Pods here
end

post_install do |installer|
  assertDeploymentTarget(installer)
end
