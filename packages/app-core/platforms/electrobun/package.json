{
	"name": "@elizaos/electrobun",
	"version": "2.0.0-beta.0",
	"type": "module",
	"scripts": {
		"dev": "bun run build:preload && PATH=\"$PWD/scripts/bin:$PATH\" bunx electrobun dev",
		"build": "bun run build:preload && ELECTROBUN_SKIP_CODESIGN=1 PATH=\"$PWD/scripts/bin:$PATH\" bunx electrobun build",
		"typecheck": "tsc --noEmit",
		"test": "bunx vitest run --config vitest.electrobun.config.ts --passWithNoTests",
		"lint": "bunx @biomejs/biome check src",
		"build:preload": "node ../../scripts/build-electrobun-preload.mjs",
		"build:whisper": "bash scripts/build-whisper.sh",
		"build:whisper:universal": "bash scripts/build-whisper-universal.sh",
		"build:native-effects": "bash scripts/build-macos-effects.sh"
	},
	"dependencies": {
		"@elizaos/shared": "workspace:*",
		"bonjour-service": "1.3.0",
		"electrobun": "^1.18.1"
	},
	"devDependencies": {
		"typescript": "^6.0.0",
		"@types/bun": "^1.3.8",
		"vitest": "^4.0.18",
		"@biomejs/biome": "^2.4.14"
	},
	"publishConfig": {
		"access": "public"
	}
}
