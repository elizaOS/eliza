{
  "id": "eliza.git",
  "name": "Eliza Git",
  "version": "0.1.0",
  "description": "Git Satellite for ElizaLaunch. Provides trusted local Git operations for Eliza Orbit.",
  "mode": "background",
  "permissions": {
    "host": {
      "storage": true,
      "manage-carrots": true
    },
    "bun": {
      "read": true,
      "write": true,
      "env": true,
      "run": true,
      "worker": true
    },
    "isolation": "isolated-process"
  },
  "view": {
    "relativePath": "src/web/index.html",
    "title": "Eliza Git Satellite",
    "width": 480,
    "height": 320,
    "hidden": true
  },
  "worker": {
    "relativePath": "src/bun/worker.ts"
  }
}
