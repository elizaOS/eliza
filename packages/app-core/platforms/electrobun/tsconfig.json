{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"allowImportingTsExtensions": true,
		"noEmit": true,
		"declaration": false,
		"outDir": "./dist",
		"rootDir": "../../../..",
		"types": ["bun-types"],
		"paths": {
			"@elizaos/app-core": ["../../src/index.ts"],
			"@elizaos/app-core/*": ["../../src/*"],
			"@elizaos/agent": ["../../../agent/src/index.ts"],
			"@elizaos/agent/*": ["../../../agent/src/*"],
			"@elizaos/core": ["../../../core/src/index.node.ts"],
			"@elizaos/core/*": ["../../../core/src/*"],
			"@elizaos/shared": ["../../../shared/src/index.ts"],
			"@elizaos/shared/*": ["../../../shared/src/*"],
			"@elizaos/plugin-signal": [
				"../../../../plugins/plugin-signal/src/index.ts"
			],
			"@elizaos/plugin-signal/*": [
				"../../../../plugins/plugin-signal/src/*"
			]
		}
	},
	"include": ["src/**/*.ts", "scripts/**/*.ts"],
	"exclude": ["node_modules", "dist"]
}
