# Cloud-specific dockerignore for packages/app-core/deploy/Dockerfile.cloud
# The cloud build does a fresh `bun install --production` in the deps stage,
# so we exclude the host node_modules entirely (they'd bloat the build context ~4.5GB).
# Only the manifests, lockfile, patches, pre-built dist artifacts, workspace source
# packages, and runtime scripts are needed.

.git
.github
.claude
.devin
.vscode
.idea
.env
.env.local
.env.*.local

# Exclude ALL node_modules from build context — deps stage reinstalls from scratch
node_modules/
packages/**/node_modules
plugins/**/node_modules
apps/**/node_modules
.turbo
packages/benchmarks
packages/examples
apps

# Exclude heavy app dirs not needed at runtime
# (but keep package.json manifests that the deps stage needs for bun install)
packages/app/android
packages/app-core/platforms/electrobun
!packages/app-core/platforms/electrobun/package.json
packages/app/.vite
packages/app/src
packages/app/public
packages/app/test
packages/app/.eliza

# Test / tooling / packaging / docs
docs/
coverage/
benchmarks/
test/
skills/
packaging/
artifacts/
dev.log
install.sh
install.ps1
deploy/

# Other deploy Docker recipes — cloud image build only needs Dockerfile.cloud
packages/app-core/deploy/Dockerfile.ci
packages/app-core/deploy/Dockerfile.cloud-agent
packages/app-core/deploy/Dockerfile.sandbox
!packages/app-core/deploy/Dockerfile.cloud
