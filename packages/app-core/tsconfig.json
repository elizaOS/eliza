{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "types": ["node", "bun-types"],
    "typeRoots": [
      "./node_modules/@types",
      "../../node_modules/@types",
      "../../node_modules"
    ],
    "allowImportingTsExtensions": true,
    "declaration": false,
    "noEmit": true,
    "paths": {
      "@elizaos/plugin-lifeops-browser": [
        "../../plugins/plugin-lifeops-browser/src/index.ts"
      ],
      "@elizaos/plugin-lifeops-browser/*": [
        "../../plugins/plugin-lifeops-browser/src/*"
      ],
      "@elizaos/plugin-browser": ["../../plugins/plugin-browser/src/index.ts"],
      "@elizaos/plugin-browser/*": ["../../plugins/plugin-browser/src/*"],
      "@elizaos/plugin-video": ["../../plugins/plugin-video/dist/index.d.ts"],
      "@elizaos/app-core": ["./src/index.ts"],
      "@elizaos/app-core/*": ["./src/*"],
      "@elizaos/app-wallet": ["../../plugins/app-wallet/src/index.ts"],
      "@elizaos/app-wallet/*": ["../../plugins/app-wallet/src/*"],
      "@elizaos/plugin-wallet": ["../../plugins/plugin-wallet/src/index.ts"],
      "@elizaos/plugin-wallet/*": ["../../plugins/plugin-wallet/src/*"],
      "@elizaos/app-training": ["../../plugins/app-training/src/index.ts"],
      "@elizaos/app-training/*": ["../../plugins/app-training/src/*"],
      "@elizaos/ui": ["../ui/src/index.ts"],
      "@elizaos/ui/*": ["../ui/src/*"],
      "@elizaos/agent": ["../agent/src/index.ts"],
      "@elizaos/agent/*": ["../agent/src/*"],
      "@elizaos/plugin-elizacloud": [
        "../../plugins/plugin-elizacloud/src/index.node.ts"
      ],
      "@elizaos/plugin-elizacloud/*": ["../../plugins/plugin-elizacloud/src/*"],
      "@elizaos/plugin-computeruse": [
        "../../plugins/plugin-computeruse/src/index.ts"
      ],
      "@elizaos/plugin-computeruse/*": [
        "../../plugins/plugin-computeruse/src/*"
      ],
      "@elizaos/plugin-whatsapp": [
        "../../plugins/plugin-whatsapp/src/index.ts"
      ],
      "@elizaos/plugin-whatsapp/*": ["../../plugins/plugin-whatsapp/src/*"],
      "@elizaos/plugin-signal": ["../../plugins/plugin-signal/src/index.ts"],
      "@elizaos/plugin-signal/*": ["../../plugins/plugin-signal/src/*"],
      "@elizaos/app-task-coordinator": [
        "../../plugins/app-task-coordinator/src/index.ts"
      ],
      "@elizaos/app-task-coordinator/*": [
        "../../plugins/app-task-coordinator/src/*"
      ],
      "@elizaos/plugin-google": ["../../plugins/plugin-google/src/index.ts"],
      "@elizaos/plugin-google/*": ["../../plugins/plugin-google/src/*"],
      "@elizaos/plugin-telegram": [
        "../../plugins/plugin-telegram/src/index.ts"
      ],
      "@elizaos/plugin-telegram/*": ["../../plugins/plugin-telegram/src/*"],
      "@elizaos/plugin-sql": [
        "../../plugins/plugin-sql/typescript/index.node.ts"
      ],
      "@elizaos/plugin-sql/*": ["../../plugins/plugin-sql/typescript/*"],
      "@elizaos/shared": ["../shared/src/index.ts"],
      "@elizaos/shared/*": ["../shared/src/*"],
      "@elizaos/skills": ["../skills/src/index.ts"],
      "@elizaos/skills/*": ["../skills/src/*"],
      "@elizaos/core": ["../core/src/index.node.ts"],
      "@elizaos/core/*": ["../core/src/*"],
      "@elizaos/capacitor-*": ["../native-plugins/*/src/index.ts"],
      "@elizaos/native-activity-tracker": [
        "../native-plugins/activity-tracker/src/index.ts"
      ],
      "drizzle-orm": ["../../plugins/plugin-sql/node_modules/drizzle-orm"],
      "drizzle-orm/*": ["../../plugins/plugin-sql/node_modules/drizzle-orm/*"],
      "react": ["./node_modules/@types/react/index.d.ts"],
      "react/jsx-runtime": ["./node_modules/@types/react/jsx-runtime.d.ts"],
      "react/jsx-dev-runtime": [
        "./node_modules/@types/react/jsx-dev-runtime.d.ts"
      ],
      "react-dom": ["./node_modules/@types/react-dom/index.d.ts"],
      "@elizaos/*": ["../../node_modules/@elizaos/*"],
      "lucide-react": ["./node_modules/lucide-react"]
    }
  },
  "exclude": [
    "src/cli/**",
    "src/benchmark/**",
    "src/**/*.stories.ts",
    "src/**/*.stories.tsx",
    "src/**/*.test.ts",
    "src/**/*.test.tsx"
  ],
  "include": ["src", "../agent/src/external-modules.d.ts", "vite-env.d.ts"]
}
