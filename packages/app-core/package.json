{
  "name": "@elizaos/app-core",
  "version": "2.0.0-beta.0",
  "description": "Shared application core for elizaOS white-label agent apps.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/elizaOS/eliza",
  "repository": {
    "type": "git",
    "url": "https://github.com/elizaOS/eliza.git",
    "directory": "packages/app-core"
  },
  "keywords": [
    "elizaos",
    "app-core",
    "react",
    "white-label",
    "agent-framework"
  ],
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "prepublishOnly": "bun run build:dist",
    "build": "bun run build:dist",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --config vitest.config.ts",
    "test:auth": "vitest run --config vitest.config.ts --no-file-parallelism src/api/auth src/api/auth-bootstrap-routes src/api/auth-session-routes src/services/auth-store src/cli/program/register.auth",
    "lint": "bunx @biomejs/biome check src",
    "lint:fix": "bunx @biomejs/biome check --write src",
    "format": "bunx @biomejs/biome format src",
    "format:fix": "bunx @biomejs/biome format --write src",
    "build:dist": "node ../../scripts/rm-path-recursive.mjs dist && tsc -p tsconfig.build.json && node ../../scripts/flatten-tsc-package-output.mjs packages/app-core && node ../../scripts/copy-package-assets.mjs packages/app-core src/styles scripts platforms packaging patches test/scripts test/helpers && node ../../scripts/prepare-package-dist.mjs packages/app-core",
    "pack:dry-run": "cd dist && npm pack --dry-run",
    "benchmark:server": "node --import tsx src/benchmark/server.ts"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./api/auth": {
      "types": "./dist/api/auth.d.ts",
      "import": "./dist/api/auth.js",
      "default": "./dist/api/auth.js"
    },
    "./api/automation-node-contributors": {
      "types": "./dist/api/automation-node-contributors.d.ts",
      "import": "./dist/api/automation-node-contributors.js",
      "default": "./dist/api/automation-node-contributors.js"
    },
    "./api/client-base": {
      "types": "./dist/api/client-base.d.ts",
      "import": "./dist/api/client-base.js",
      "default": "./dist/api/client-base.js"
    },
    "./api/compat-route-shared": {
      "types": "./dist/api/compat-route-shared.d.ts",
      "import": "./dist/api/compat-route-shared.js",
      "default": "./dist/api/compat-route-shared.js"
    },
    "./api/response": {
      "types": "./dist/api/response.d.ts",
      "import": "./dist/api/response.js",
      "default": "./dist/api/response.js"
    },
    "./platform/empty-node-module": {
      "types": "./dist/platform/empty-node-module.d.ts",
      "import": "./dist/platform/empty-node-module.js",
      "default": "./dist/platform/empty-node-module.js"
    },
    "./runtime/app-route-plugin-registry": {
      "types": "./dist/runtime/app-route-plugin-registry.d.ts",
      "import": "./dist/runtime/app-route-plugin-registry.js",
      "default": "./dist/runtime/app-route-plugin-registry.js"
    },
    "./services/plugin-installer": {
      "types": "./dist/services/plugin-installer.d.ts",
      "import": "./dist/services/plugin-installer.js",
      "default": "./dist/services/plugin-installer.js"
    },
    "./services/steward-sidecar": {
      "types": "./dist/services/steward-sidecar.d.ts",
      "import": "./dist/services/steward-sidecar.js",
      "default": "./dist/services/steward-sidecar.js"
    },
    "./services/steward-sidecar/helpers": {
      "types": "./dist/services/steward-sidecar/helpers.d.ts",
      "import": "./dist/services/steward-sidecar/helpers.js",
      "default": "./dist/services/steward-sidecar/helpers.js"
    },
    "./package.json": "./package.json"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.184.0"
  },
  "optionalDependencies": {
    "node-llama-cpp": "3.18.1",
    "sharp": "^0.34.5"
  },
  "trustedDependencies": [
    "node-llama-cpp"
  ],
  "dependencies": {
    "@capacitor/barcode-scanner": "^3.0.0",
    "@capacitor/core": "8.3.1",
    "@capacitor/haptics": "8.0.2",
    "@capacitor/keyboard": "8.0.3",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/push-notifications": "^8.0.0",
    "@clack/prompts": "^1.0.0",
    "@elizaos/agent": "workspace:*",
    "@elizaos/app-training": "workspace:*",
    "@elizaos/core": "workspace:*",
    "@elizaos/plugin-browser": "workspace:*",
    "@elizaos/plugin-sql": "workspace:*",
    "@elizaos/plugin-wechat": "workspace:*",
    "@elizaos/shared": "workspace:*",
    "@elizaos/ui": "workspace:*",
    "@elizaos/vault": "workspace:*",
    "@node-rs/argon2": "^2.0.2",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@simplewebauthn/browser": "^13.0.0",
    "@stwd/sdk": "^0.8.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "@xyflow/react": "^12.10.2",
    "chalk": "^5.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "commander": "^14.0.0",
    "cron-parser": "^5.5.0",
    "dotenv": "^17.2.3",
    "drizzle-orm": "0.45.2",
    "ethers": "^6.16.0",
    "jose": "^6.2.2",
    "json5": "^2.2.3",
    "lucide-react": "^1.0.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.0.0",
    "telegraf": "^4.16.3",
    "undici": "^8.0.0",
    "ws": "^8.19.0",
    "zod": "^4.4.3"
  },
  "publishConfig": {
    "access": "public",
    "directory": "dist"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.184.0",
    "@types/ws": "^8.18.1",
    "bun-types": "^1.3.12",
    "playwright-core": "^1.58.2",
    "react-test-renderer": "^19.2.4",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.18",
    "typescript": "^6.0.3",
    "vite": "^8.0.8",
    "vitest": "^4.0.18"
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts"
}
