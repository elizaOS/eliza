    "sonner": "^2.0.7",
    "tailwind-merge": "^3.0.0",
    "telegraf": "^4.16.3",
    "undici": "8.2.0",
    "ws": "^8.19.0",
    "zod": "^4.4.3"
  },
  "publishConfig": {
    "access": "public",
    "directory": "dist"
  },
  "devDependencies": {
    "yaml": "^2.7.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.184.0",
    "@types/ws": "^8.18.1",
    "bun-types": "^1.3.12",
    "playwright-core": "^1.58.2",
    "react-test-renderer": "^19.2.4",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.18",
    "typescript": "^6.0.3",
    "vite": "^8.0.8",
    "vitest": "^4.0.18"
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts"
}
