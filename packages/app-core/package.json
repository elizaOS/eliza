{
  "name": "@elizaos/app-core",
  "version": "2.0.0-beta.3",
  "description": "Shared application core for elizaOS white-label agent apps.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/elizaOS/eliza",
  "repository": {
    "type": "git",
    "url": "https://github.com/elizaOS/eliza.git",
    "directory": "packages/app-core"
  },
  "keywords": [
    "elizaos",
    "app-core",
    "react",
    "white-label",
    "agent-framework"
  ],
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "prepublishOnly": "bun run build:dist",
    "build": "bun run build:dist",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --config vitest.config.ts",
    "test:auth": "vitest run --config vitest.config.ts --no-file-parallelism src/api/auth src/api/auth-bootstrap-routes src/api/auth-session-routes src/services/auth-store src/cli/program/register.auth",
    "lint": "bunx @biomejs/biome check src",
    "lint:fix": "bunx @biomejs/biome check --write src",
    "format": "bunx @biomejs/biome format src",
    "format:fix": "bunx @biomejs/biome format --write src",
    "build:dist": "node ../../scripts/rm-path-recursive.mjs dist && tsc --noCheck -p tsconfig.build.json && node ../../scripts/flatten-tsc-package-output.mjs packages/app-core && node ../../scripts/copy-package-assets.mjs packages/app-core src/styles src/registry/entries scripts platforms packaging patches test/scripts test/helpers && node ../../scripts/prepare-package-dist.mjs packages/app-core",
    "pack:dry-run": "cd dist && npm pack --dry-run",
    "benchmark:server": "node --import tsx src/benchmark/server.ts",
    "voice:interactive": "bun ./scripts/voice-interactive.mjs",
    "voice:duet": "bun ./scripts/voice-duet.mjs",
    "build:flatpak": "node ./scripts/build-flatpak.mjs",
    "build:flatpak:store": "ELIZA_BUILD_VARIANT=store node ./scripts/build-flatpak.mjs",
    "build:flatpak:direct": "ELIZA_BUILD_VARIANT=direct node ./scripts/build-flatpak.mjs",
    "codesign:mas": "node ./scripts/codesign-mas.mjs",
    "codesign:mas:dry-run": "node ./scripts/codesign-mas.mjs --dry-run"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./platform/native-plugin-entrypoints": {
      "types": "./dist/platform/native-plugin-entrypoints.d.ts",
      "import": "./dist/platform/native-plugin-entrypoints.js",
      "default": "./dist/platform/native-plugin-entrypoints.js"
    },
    "./platform/empty-node-module": {
      "types": "./dist/platform/empty-node-module.d.ts",
      "import": "./dist/platform/empty-node-module.js",
      "default": "./dist/platform/empty-node-module.js"
    }
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.184.0"
  },
  "optionalDependencies": {
    "@elizaos/capacitor-appblocker": "2.0.0-beta.1",
    "@elizaos/capacitor-bun-runtime": "0.1.0",
    "@elizaos/capacitor-camera": "2.0.0-beta.1",
    "@elizaos/capacitor-canvas": "2.0.0-beta.1",
    "@elizaos/capacitor-contacts": "2.0.0-beta.1",
    "@elizaos/capacitor-gateway": "2.0.0-beta.1",
    "@elizaos/capacitor-location": "2.0.0-beta.1",
    "@elizaos/capacitor-messages": "2.0.0-beta.1",
    "@elizaos/capacitor-mobile-signals": "2.0.0-beta.1",
    "@elizaos/capacitor-phone": "2.0.0-beta.1",
    "@elizaos/capacitor-screencapture": "2.0.0-beta.1",
    "@elizaos/capacitor-swabble": "2.0.0-beta.1",
    "@elizaos/capacitor-system": "2.0.0-beta.1",
    "@elizaos/capacitor-talkmode": "2.0.0-beta.1",
    "@elizaos/capacitor-websiteblocker": "2.0.0-beta.1",
    "node-llama-cpp": "3.18.1",
    "onnxruntime-node": "1.24.3",
    "sharp": "^0.34.5"
  },
  "trustedDependencies": [
    "node-llama-cpp",
    "onnxruntime-node"
