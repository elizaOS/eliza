{
  "$schema": "https://biomejs.dev/schemas/2.4.14/schema.json",
  "root": false,
  "extends": ["../../biome.json"],
  "files": {
    "includes": ["src/**", "!src/**/*.d.ts", "!src/**/*.d.ts.map"]
  },
  "linter": {
    "rules": {
      "style": {
        "noDescendingSpecificity": "warn"
      },
      "a11y": {
        "useSemanticElements": "warn"
      },
      "suspicious": {
        "noArrayIndexKey": "warn"
      }
    }
  }
}
