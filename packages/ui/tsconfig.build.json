{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "declaration": true,
    "declarationMap": true,
    "noEmit": false,
    "outDir": "./dist",
    "rootDir": "./src",
    "rewriteRelativeImportExtensions": true,
    "stripInternal": true,
    "tsBuildInfoFile": "./dist/.tsbuildinfo",
    "paths": {
      "@elizaos/ui": ["./src/index.ts"],
      "@elizaos/ui/*": ["./src/*"],
      "@elizaos/core": ["../core/dist/index.d.ts"],
      "@elizaos/core/*": ["../core/dist/*"],
      "@elizaos/shared": ["../shared/dist/index.d.ts"],
      "@elizaos/shared/*": ["../shared/dist/*"],
      "@elizaos/agent": ["../agent/dist/index.d.ts"],
      "@elizaos/agent/*": ["../agent/dist/*"],
      "@elizaos/app-core": ["../app-core/dist/index.d.ts"],
      "@elizaos/app-core/*": ["../app-core/dist/*"],
      "@elizaos/app-wallet": ["../../plugins/app-wallet/src/index.ts"],
      "@elizaos/app-wallet/*": ["../../plugins/app-wallet/src/*"],
      "@elizaos/plugin-browser": ["../../plugins/plugin-browser/src/index.ts"],
      "@elizaos/plugin-browser/contracts": [
        "../../plugins/plugin-browser/src/contracts.ts"
      ],
      "@elizaos/plugin-browser/workspace": [
        "../../plugins/plugin-browser/src/workspace/index.ts"
      ],
      "@elizaos/plugin-browser/*": ["../../plugins/plugin-browser/src/*"],
      "@elizaos/plugin-video": ["../../plugins/plugin-video/dist/index.d.ts"],
      "@elizaos/capacitor-*": ["../native-plugins/*/dist/index.d.ts"],
      "@elizaos/native-activity-tracker": [
        "../native-plugins/activity-tracker/dist/index.d.ts"
      ],
      "@elizaos/native-activity-tracker/*": [
        "../native-plugins/activity-tracker/dist/*"
      ],
      "@elizaos/*": ["../../node_modules/@elizaos/*"]
    }
  },
  "exclude": [
    "src/**/*.stories.ts",
    "src/**/*.stories.tsx",
    "src/**/*.test.ts",
    "src/**/*.test.tsx"
  ],
  "include": ["src"]
}
