{
  "name": "@elizaos/ui",
  "version": "2.0.0-beta.0",
  "description": "Shared UI primitives, composites, and layout utilities for elizaOS apps.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/elizaOS/eliza",
  "repository": {
    "type": "git",
    "url": "https://github.com/elizaOS/eliza.git",
    "directory": "packages/ui"
  },
  "keywords": [
    "elizaos",
    "ui",
    "react",
    "design-system"
  ],
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "clean": "node ../../scripts/rm-path-recursive.mjs dist",
    "prepublishOnly": "bun run build:dist",
    "build": "bun run build:dist",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --config ./vitest.config.ts",
    "lint": "bunx @biomejs/biome check src",
    "lint:fix": "bunx @biomejs/biome check --write src",
    "format": "bunx @biomejs/biome format src",
    "format:fix": "bunx @biomejs/biome format --write src",
    "build:dist": "bun run clean && tsc --noCheck -p tsconfig.build.json && node ../../scripts/flatten-tsc-package-output.mjs packages/ui && node ../../scripts/copy-package-assets.mjs packages/ui src/styles && node ../../scripts/prepare-package-dist.mjs packages/ui && node ../../scripts/rewrite-dist-relative-imports-node-esm.mjs packages/ui",
    "pack:dry-run": "cd dist && npm pack --dry-run"
  },
  "exports": {
    ".": "./dist/index.js",
    "./api/client-types-cloud": "./dist/api/client-types-cloud.js",
    "./config/app-config": "./dist/config/app-config.js",
    "./onboarding-config": "./dist/onboarding-config.js"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@elizaos/core": "workspace:*",
    "@elizaos/plugin-browser": "workspace:*",
    "@elizaos/shared": "workspace:*",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@xyflow/react": "^12.10.2",
    "cron-parser": "^5.5.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "chalk": "^5.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "0.45.2",
    "lucide-react": "^1.0.0",
    "tailwind-merge": "^3.0.0"
  },
  "devDependencies": {
    "@capacitor/core": "8.3.1",
    "@capacitor/haptics": "8.0.2",
    "@capacitor/keyboard": "8.0.3",
    "@capacitor/preferences": "^8.0.1",
    "@storybook/react": "^10.3.5",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "storybook": "^10.3.5",
    "typescript": "^6.0.3",
    "vitest": "^4.0.18"
  },
  "publishConfig": {
    "access": "public",
    "directory": "dist"
  },
  "types": "./dist/index.d.ts"
}
