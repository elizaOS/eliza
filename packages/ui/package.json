{
  "name": "@elizaos/ui",
  "version": "2.0.0-beta.2",
  "description": "Shared UI primitives, composites, and layout utilities for elizaOS apps.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/elizaOS/eliza",
  "repository": {
    "type": "git",
    "url": "https://github.com/elizaOS/eliza.git",
    "directory": "packages/ui"
  },
  "keywords": [
    "elizaos",
    "ui",
    "react",
    "design-system"
  ],
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "clean": "node ../scripts/rm-path-recursive.mjs dist",
    "prepublishOnly": "bun run build:dist",
    "build": "bun run build:dist",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "NODE_OPTIONS=\"${NODE_OPTIONS:-} --no-experimental-webstorage --disable-warning=ExperimentalWarning\" vitest run --config ./vitest.config.ts",
    "lint": "bunx @biomejs/biome check src",
    "lint:fix": "bunx @biomejs/biome check --write src",
    "format": "bunx @biomejs/biome format src",
    "format:fix": "bunx @biomejs/biome format --write src",
    "build:dist": "bun run clean && tsc --noCheck -p tsconfig.build.json && node ../scripts/flatten-tsc-package-output.mjs packages/ui && node ../scripts/copy-package-assets.mjs packages/ui src/styles src/cloud-ui/index.css src/cloud-ui/styles src/components/onboarding/states/onboarding.css && node ../scripts/prepare-package-dist.mjs packages/ui && node ../scripts/rewrite-dist-relative-imports-node-esm.mjs packages/ui",
    "pack:dry-run": "cd dist && npm pack --dry-run"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json",
    "./docs.css": "./dist/cloud-ui/styles/docs.css",
    "./styles": "./dist/styles.js",
    "./styles/docs.css": "./dist/cloud-ui/styles/docs.css",
    "./styles/*.css": "./dist/styles/*.css",
    "./cloud-ui": {
      "types": "./dist/cloud-ui/index.d.ts",
      "import": "./dist/cloud-ui/index.js",
      "default": "./dist/cloud-ui/index.js"
    },
    "./cloud-ui/index.css": "./dist/cloud-ui/index.css",
    "./cloud-ui/styles": "./dist/cloud-ui/index.css",
    "./cloud-ui/styles/*.css": "./dist/cloud-ui/styles/*.css",
    "./cloud-ui/*": {
      "types": "./dist/cloud-ui/*.d.ts",
      "import": "./dist/cloud-ui/*.js",
      "default": "./dist/cloud-ui/*.js"
    },
    "./button": {
      "types": "./dist/cloud-ui/components/button.d.ts",
      "import": "./dist/cloud-ui/components/button.js",
      "default": "./dist/cloud-ui/components/button.js"
    },
    "./card": {
      "types": "./dist/components/ui/card.d.ts",
      "import": "./dist/components/ui/card.js",
      "default": "./dist/components/ui/card.js"
    },
    "./dropdown-menu": {
      "types": "./dist/cloud-ui/components/dropdown-menu.d.ts",
      "import": "./dist/cloud-ui/components/dropdown-menu.js",
      "default": "./dist/cloud-ui/components/dropdown-menu.js"
    },
    "./input": {
      "types": "./dist/cloud-ui/components/input.d.ts",
      "import": "./dist/cloud-ui/components/input.js",
      "default": "./dist/cloud-ui/components/input.js"
    },
    "./api/client-types-cloud": "./dist/api/client-types-cloud.js",
    "./components/character/CharacterEditor": "./dist/components/character/CharacterEditor.js",
    "./components/chat/widgets/types": "./dist/components/chat/widgets/types.js",
    "./config/app-config": "./dist/config/app-config.js",
    "./onboarding-config": "./dist/onboarding-config.js",
    "./api": {
      "types": "./dist/api/index.d.ts",
      "import": "./dist/api/index.js",
      "default": "./dist/api/index.js"
    },
    "./bridge": {
      "types": "./dist/bridge/index.d.ts",
      "import": "./dist/bridge/index.js",
      "default": "./dist/bridge/index.js"
    },
    "./chat": {
      "types": "./dist/chat/index.d.ts",
      "import": "./dist/chat/index.js",
      "default": "./dist/chat/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js",
      "default": "./dist/components/index.js"
    },
    "./components/*": {
      "types": "./dist/components/*.d.ts",
      "import": "./dist/components/*.js",
      "default": "./dist/components/*.js"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "import": "./dist/config/index.js",
      "default": "./dist/config/index.js"
    },
    "./content-packs": {
      "types": "./dist/content-packs/index.d.ts",
      "import": "./dist/content-packs/index.js",
      "default": "./dist/content-packs/index.js"
    },
    "./desktop-runtime": {
      "types": "./dist/desktop-runtime/index.d.ts",
      "import": "./dist/desktop-runtime/index.js",
      "default": "./dist/desktop-runtime/index.js"
    },
    "./events": {
      "types": "./dist/events/index.d.ts",
      "import": "./dist/events/index.js",
      "default": "./dist/events/index.js"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "import": "./dist/hooks/index.js",
      "default": "./dist/hooks/index.js"
    },
    "./i18n": {
      "types": "./dist/i18n/index.d.ts",
      "import": "./dist/i18n/index.js",
      "default": "./dist/i18n/index.js"
    },
    "./layouts": {
      "types": "./dist/layouts/index.d.ts",
      "import": "./dist/layouts/index.js",
      "default": "./dist/layouts/index.js"
    },
    "./navigation": {
      "types": "./dist/navigation/index.d.ts",
      "import": "./dist/navigation/index.js",
      "default": "./dist/navigation/index.js"
    },
    "./platform": {
      "types": "./dist/platform/index.d.ts",
      "import": "./dist/platform/index.js",
      "default": "./dist/platform/index.js"
    },
    "./platform/*": {
      "types": "./dist/platform/*.d.ts",
      "import": "./dist/platform/*.js",
      "default": "./dist/platform/*.js"
    },
    "./providers": {
      "types": "./dist/providers/index.d.ts",
      "import": "./dist/providers/index.js",
      "default": "./dist/providers/index.js"
    },
    "./state": {
      "types": "./dist/state/index.d.ts",
      "import": "./dist/state/index.js",
      "default": "./dist/state/index.js"
    },
    "./state/*": {
      "types": "./dist/state/*.d.ts",
      "import": "./dist/state/*.js",
      "default": "./dist/state/*.js"
    },
    "./slots/*": {
      "types": "./dist/slots/*.d.ts",
      "import": "./dist/slots/*.js",
      "default": "./dist/slots/*.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js",
      "default": "./dist/types/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js",
      "default": "./dist/utils/index.js"
    },
    "./voice": {
      "types": "./dist/voice/index.d.ts",
      "import": "./dist/voice/index.js",
      "default": "./dist/voice/index.js"
    },
    "./widgets": {
      "types": "./dist/widgets/index.d.ts",
      "import": "./dist/widgets/index.js",
      "default": "./dist/widgets/index.js"
    },
    "./dist/styles/*.css": "./dist/styles/*.css",
    "./*.css": "./dist/*.css",
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "default": "./dist/*.js"
    }
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "optionalDependencies": {
    "@elizaos/capacitor-bun-runtime": "workspace:*"
  },
  "dependencies": {
    "@elizaos/core": "workspace:*",
    "@elizaos/shared": "workspace:*",
    "@fontsource-variable/open-sans": "^5.2.7",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@radix-ui/react-use-controllable-state": "^1.2.2",
    "@stwd/react": "^0.7.2",
    "@tsparticles/basic": "^3.9.1",
    "@tsparticles/engine": "^3.9.1",
    "@tsparticles/react": "^3.0.0",
    "@xyflow/react": "^12.10.2",
    "ai": "^6.0.48",
    "chalk": "^5.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cron-parser": "^5.5.0",
    "embla-carousel-react": "^8.6.0",
    "lucide-react": "^1.0.0",
    "motion": "^12.38.0",
    "nanoid": "^5.1.6",
    "nprogress": "^0.2.0",
    "react-day-picker": "^9.14.0",
    "react-hook-form": "^7.74.0",
    "react-router-dom": "^7.0.0",
    "react-syntax-highlighter": "^16.1.0",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "streamdown": "^2.0.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "tokenlens": "^1.3.1",
    "use-stick-to-bottom": "^1.1.1",
    "vaul": "^1.1.2",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@capacitor/core": "8.3.1",
    "@capacitor/haptics": "8.0.2",
    "@capacitor/keyboard": "8.0.3",
    "@capacitor/preferences": "^8.0.1",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.3.2",
    "@types/nprogress": "^0.2.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.0",
    "@types/ws": "^8.18.1",
    "jsdom": "^29.0.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.8",
    "vitest": "^4.0.18"
  },
  "publishConfig": {
    "access": "public",
    "directory": "dist"
  },
  "types": "./dist/index.d.ts"
}
