{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "types": ["node", "react"],
    "allowImportingTsExtensions": true,
    "declaration": false,
    "noEmit": true,
    "paths": {
      "drizzle-orm": ["../../plugins/plugin-sql/node_modules/drizzle-orm"],
      "drizzle-orm/*": ["../../plugins/plugin-sql/node_modules/drizzle-orm/*"],
      "@elizaos/plugin-lifeops": ["../../plugins/plugin-lifeops/src/index.ts"],
      "@elizaos/plugin-task-coordinator": [
        "../../plugins/plugin-task-coordinator/src/index.ts"
      ],
      "@elizaos/plugin-steward-app": ["../../plugins/plugin-steward-app/src/index.ts"],
      "@elizaos/plugin-shopify-ui": ["../../plugins/plugin-shopify-ui/src/index.ts"],
      "@elizaos/plugin-training": ["../../plugins/plugin-training/src/index.ts"],
      "@elizaos/plugin-vincent": ["../../plugins/plugin-vincent/src/index.ts"],
      "@elizaos/plugin-lifeops-browser": [
        "../../plugins/plugin-lifeops-browser/src/index.ts"
      ],
      "@elizaos/plugin-video": ["../../plugins/plugin-video/dist/index.d.ts"],
      "@elizaos/plugin-elizacloud": [
        "../../plugins/plugin-elizacloud/src/index.node.ts"
      ],
      "@elizaos/plugin-computeruse": [
        "../../plugins/plugin-computeruse/src/index.ts"
      ],
      "@elizaos/plugin-whatsapp": [
        "../../plugins/plugin-whatsapp/src/index.ts"
      ],
      "@elizaos/plugin-app-manager": [
        "../../plugins/plugin-app-manager/src/index.ts"
      ],
      "@elizaos/plugin-app-manager/*": [
        "../../plugins/plugin-app-manager/src/*"
      ],
      "@elizaos/plugin-signal": ["../../plugins/plugin-signal/src/index.ts"],
      "@elizaos/app-core": ["../app-core/src/index.ts"],
      "@elizaos/agent": ["../agent/src/index.ts"],
      "@elizaos/plugin-coding-tools": [
        "../../plugins/plugin-coding-tools/src/index.ts"
      ],
      "@elizaos/plugin-companion": ["../../plugins/plugin-companion/src/index.ts"],
      "@elizaos/plugin-elizamaker": ["../../plugins/plugin-elizamaker/src/index.ts"],
      "@capacitor/app": [
        "../app/node_modules/@capacitor/app/dist/esm/index.d.ts"
      ],
      "@elizaos/capacitor-appblocker": [
        "../native-plugins/appblocker/src/index.ts"
      ],
      "@elizaos/capacitor-bun-runtime": [
        "../native-plugins/bun-runtime/src/index.ts"
      ],
      "@elizaos/capacitor-calendar": [
        "../native-plugins/calendar/src/index.ts"
      ],
      "@elizaos/capacitor-mobile-signals": [
        "../native-plugins/mobile-signals/src/index.ts"
      ],
      "@elizaos/shared": ["../shared/src/index.ts"],
      "@elizaos/shared/*": ["../shared/src/*"],
      "@elizaos/skills": ["../skills/src/index.ts"],
      "@elizaos/skills/*": ["../skills/src/*"],
      "@elizaos/core": ["../core/src/index.ts"],
      "@elizaos/core/*": ["../core/src/*"],
      "@elizaos/plugin-wallet-ui": ["../../plugins/plugin-wallet-ui/src/index.ts"],
      "@elizaos/plugin-wallet-ui/*": ["../../plugins/plugin-wallet-ui/src/*"],
      "@elizaos/ui": ["./src/index.ts"],
      "@elizaos/ui/navigation": ["./src/navigation/index.ts"],
      "@elizaos/ui/*": ["./src/*"],
      "@elizaos/*": ["../../node_modules/@elizaos/*"]
    }
  },
  "exclude": [
    "src/**/*.stories.ts",
    "src/**/*.stories.tsx",
    "../../plugins/plugin-companion/src/**/*.stories.tsx",
    "../../plugins/plugin-companion/src/**/*.stories.ts"
  ],
  "include": [
    "src",
    "../app-core/src/ambient-modules.d.ts",
    "../agent/src/external-modules.d.ts"
  ]
}
