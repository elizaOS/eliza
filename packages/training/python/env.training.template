# Babylon RL Continuous Training Configuration
# Copy this file to .env.training and fill in your values

# === REQUIRED ===
DATABASE_URL=postgresql://user:password@host:port/database

# === ENVIRONMENT ===
TRAINING_ENV=local

# === DATA COLLECTION ===
WINDOW_DURATION_HOURS=1
MIN_AGENTS_PER_WINDOW=3
MIN_ACTIONS_PER_TRAJECTORY=5

# === TRAINING (Atropos) ===
TRAINING_FREQUENCY_WINDOWS=1
MODEL_NAME=unsloth/Qwen3-4B-128K
BATCH_SIZE=4
GRADIENT_ACCUMULATION_STEPS=2
ITERATIONS_PER_WINDOW=10
LEARNING_RATE=1e-6
KL_PENALTY=0.05

# === DEPLOYMENT ===
LOCAL_ENDPOINT=http://localhost:8000
DEPLOYMENT_STRATEGY=replace

# === STORAGE ===
CHECKPOINT_DIR=./checkpoints
LOGS_DIR=./logs
METRICS_DIR=./metrics

# === MONITORING (optional) ===
LOG_LEVEL=INFO

# === MODES ===
MODE=continuous
BACKFILL_HOURS=24

# === ATROPOS API ===
ATROPOS_API_URL=http://localhost:8000
VLLM_PORT=9001

# === JUDGE MODEL (for RLAIF) ===
JUDGE_MODEL=gpt-4o-mini
OPENAI_API_KEY=your_openai_api_key_here
