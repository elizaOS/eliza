{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": ".",
    "tsBuildInfoFile": "./dist/.tsbuildinfo",
    "types": ["bun-types"],
    "paths": {
      "@babylon/shared": ["./../shared/src/index.ts"],
      "@babylon/shared/*": ["./../shared/src/*"],
      "@babylon/db": ["./../db/src/index.ts"],
      "@babylon/db/*": ["./../db/src/*"],
      "@babylon/engine": ["./../engine/src/index.ts"],
      "@babylon/engine/*": ["./../engine/src/*"],
      "@babylon/sim": ["./core/index.ts"],
      "@babylon/sim/*": ["./core/*"]
    }
  },
  "include": [
    "core/**/*",
    "cli/**/*",
    "systems/**/*",
    "tests/**/*",
    "babylon.config.ts"
  ],
  "exclude": ["node_modules", "dist"],
  "references": [
    { "path": "../shared" },
    { "path": "../db" },
    { "path": "../engine" }
  ]
}
