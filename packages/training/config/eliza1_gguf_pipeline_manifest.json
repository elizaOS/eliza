{
  "schemaVersion": 1,
  "asOf": "2026-05-15",
  "policy": {
    "modelFamily": "Use Qwen3.6 for release sizes where an official Qwen repo exists; otherwise fall back to Qwen3.5.",
    "qwen36OfficialReposChecked": [
      "Qwen/Qwen3.6-27B",
      "Qwen/Qwen3.6-35B-A3B"
    ],
    "qwen36LowerTierPolicy": "No official Qwen/Qwen3.6 0.8B, 2B, 4B, or 9B repos were found in the Qwen Hugging Face namespace, so those tiers stay on Qwen3.5.",
    "longContextPolicy": "27B context variants reuse Qwen/Qwen3.6-27B. The model is native at 262144 tokens and extensible to about 1010000 tokens; the training pipeline records 27b-1m as source-staging only until the runtime catalog/publish manifest enables it."
  },
  "tiers": {
    "0_8b": {
      "elizaTier": "eliza-1-0_8b",
      "sourceModel": "Qwen/Qwen3.5-0.8B-Base",
      "family": "qwen3.5",
      "contextTokens": 262144,
      "ggufSeed": {
        "repo": "unsloth/Qwen3.5-0.8B-GGUF",
        "file": "Qwen3.5-0.8B-Q8_0.gguf",
        "role": "source-only seed before Eliza training and quantization"
      }
    },
    "2b": {
      "elizaTier": "eliza-1-2b",
      "sourceModel": "Qwen/Qwen3.5-2B-Base",
      "family": "qwen3.5",
      "contextTokens": 262144,
      "ggufSeed": {
        "repo": "unsloth/Qwen3.5-2B-GGUF",
        "file": "Qwen3.5-2B-Q8_0.gguf",
        "role": "source-only seed before Eliza training and quantization"
      }
    },
    "4b": {
      "elizaTier": "eliza-1-4b",
      "sourceModel": "Qwen/Qwen3.5-4B-Base",
      "family": "qwen3.5",
      "contextTokens": 262144,
      "ggufSeed": {
        "repo": "unsloth/Qwen3.5-4B-GGUF",
        "file": "Qwen3.5-4B-Q8_0.gguf",
        "role": "source-only seed before Eliza training and quantization"
      }
    },
    "9b": {
      "elizaTier": "eliza-1-9b",
      "sourceModel": "Qwen/Qwen3.5-9B-Base",
      "family": "qwen3.5",
      "contextTokens": 262144,
      "ggufSeed": {
        "repo": "unsloth/Qwen3.5-9B-GGUF",
        "file": "Qwen3.5-9B-Q8_0.gguf",
        "role": "source-only seed before Eliza training and quantization"
      }
    },
    "27b": {
      "elizaTier": "eliza-1-27b",
      "sourceModel": "Qwen/Qwen3.6-27B",
      "family": "qwen3.6",
      "contextTokens": 262144,
      "ggufSeed": {
        "repo": "unsloth/Qwen3.6-27B-GGUF",
        "file": "Qwen3.6-27B-Q8_0.gguf",
        "role": "source-only seed before Eliza training and quantization"
      }
    },
    "27b-256k": {
      "elizaTier": "eliza-1-27b-256k",
      "sourceModel": "Qwen/Qwen3.6-27B",
      "family": "qwen3.6",
      "contextTokens": 262144,
      "ggufSeed": {
        "repo": "unsloth/Qwen3.6-27B-GGUF",
        "file": "Qwen3.6-27B-Q8_0.gguf",
        "role": "source-only seed before long-context Eliza training and quantization"
      }
    },
    "27b-1m": {
      "elizaTier": "eliza-1-27b-1m",
      "sourceModel": "Qwen/Qwen3.6-27B",
      "family": "qwen3.6",
      "contextTokens": 1010000,
      "ggufFilenameContextSuffix": "1m",
      "ggufSeed": {
        "repo": "unsloth/Qwen3.6-27B-GGUF",
        "file": "Qwen3.6-27B-Q8_0.gguf",
        "role": "source-staging extension point; not runtime-default until catalog/publish manifest enables it"
      }
    }
  },
  "quantization": {
    "runtimeStack": [
      {
        "name": "polarquant",
        "script": "scripts/quantization/polarquant_apply.py",
        "outputSidecars": [
          "polarquant_config.json",
          "polarquant_artifacts.safetensors"
        ]
      },
      {
        "name": "qjl",
        "script": "scripts/quantization/qjl_apply.py",
        "outputSidecars": [
          "qjl_config.json"
        ]
      },
      {
        "name": "turboquant",
        "script": "scripts/quantization/turboquant_apply.py",
        "outputSidecars": [
          "turboquant.json"
        ]
      },
      {
        "name": "fused_turboquant",
        "script": "scripts/quantization/fused_turboquant_apply.py",
        "outputSidecars": [
          "fused_turboquant.json"
        ]
      }
    ],
    "ggufKQuantLadder": [
      {
        "quant": "Q3_K_M",
        "script": "scripts/quantization/gguf-q3_k_m_apply.py"
      },
      {
        "quant": "Q4_K_M",
        "script": "scripts/quantization/gguf-q4_k_m_apply.py"
      },
      {
        "quant": "Q5_K_M",
        "script": "scripts/quantization/gguf-q5_k_m_apply.py"
      },
      {
        "quant": "Q6_K",
        "script": "scripts/quantization/gguf-q6_k_apply.py"
      }
    ],
    "sourceSeedQuant": {
      "quant": "Q8_0",
      "source": "HF GGUF seed mirrors listed per tier; local Q8_0 conversion remains an extension point when a checked-in apply hook is restored."
    }
  }
}
