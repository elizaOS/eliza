# Babylon RL continuous training config
# Copy this file to .env.training and fill in your values

# === REQUIRED ===
DATABASE_URL=postgresql://user:password@host:port/database

# === ENVIRONMENT ===
TRAINING_ENV=local

# === DATA COLLECTION ===
WINDOW_DURATION_HOURS=1
MIN_AGENTS_PER_WINDOW=3
MIN_ACTIONS_PER_TRAJECTORY=5

# === TRAINING (Atropos) ===
TRAINING_FREQUENCY_WINDOWS=1
MODEL_NAME=unsloth/Qwen3-4B-128K
BATCH_SIZE=4
GRADIENT_ACCUMULATION_STEPS=2
ITERATIONS_PER_WINDOW=10
LEARNING_RATE=1e-6
KL_PENALTY=0.05

# === DEPLOYMENT ===
LOCAL_ENDPOINT=http://localhost:8000
DEPLOYMENT_STRATEGY=replace

# === STORAGE ===
CHECKPOINT_DIR=./checkpoints
LOGS_DIR=./logs
METRICS_DIR=./metrics

# === MONITORING (optional) ===
LOG_LEVEL=INFO
# Optional alert webhook for failed, blocked, or promotion-blocked canonical runs.
# CANONICAL_PIPELINE_ALERT_WEBHOOK_URL=https://hooks.example.com/services/...
# BABYLON_LOCAL_MLX_MODEL=mlx-community/Qwen3.5-4B-MLX-4bit
# BABYLON_LOCAL_CUDA_MODEL=Qwen/Qwen3.5-4B
# BABYLON_LOCAL_CPU_MODEL=Qwen/Qwen3.5-4B

# === MODES ===
MODE=continuous
BACKFILL_HOURS=24

# === ATROPOS API ===
ATROPOS_API_URL=http://localhost:8000
VLLM_PORT=9001

# === JUDGE MODEL (for RLAIF) ===
JUDGE_MODEL=gpt-5-mini
OPENAI_API_KEY=your_openai_api_key_here
