{
  "name": "@babylon/training",
  "version": "2.0.0-beta.0",
  "private": true,
  "description": "Babylon Training Pipeline - RL training, benchmarking, and HuggingFace integration",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./src/index.ts"
    }
  },
  "scripts": {
    "lint": "biome lint src/",
    "typecheck": "tsc -b .",
    "train": "bun run scripts/train-and-test.ts",
    "train:test": "bun run scripts/train-and-test.ts --skip-training --ticks 100",
    "train:gametest": "bun run scripts/train-and-test.ts --skip-training --ticks 500",
    "benchmark": "bun run scripts/run-benchmark-suite.ts",
    "benchmark:quick": "bun run scripts/run-benchmark-suite.ts --quick",
    "benchmark:scenarios": "bun run scripts/generate-benchmark-scenarios.ts",
    "assess": "bun run scripts/assess-training-data.ts",
    "e2e": "bun run scripts/e2e-training-test.ts",
    "export-rubrics": "bun run scripts/export-rubrics.ts",
    "research-report": "bun run scripts/generate-research-report.ts"
  },
  "dependencies": {
    "@huggingface/hub": "^2.6.12",
    "@vercel/blob": "2.3.2",
    "ethers": "^6.16.0",
    "uuid": "^14.0.0"
  },
  "peerDependencies": {
    "@babylon/core": "workspace:*",
    "@babylon/db": "workspace:*",
    "@babylon/shared": "workspace:*",
    "@elizaos/core": "workspace:*",
    "drizzle-orm": "^0.44.7"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "@types/uuid": "^11.0.0",
    "bun-types": "^1.3.2",
    "typescript": "^5.9.3"
  }
}
