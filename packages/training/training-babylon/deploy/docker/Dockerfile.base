# Babylon Training Base Image
#
# Uses the official vLLM OpenAI image as base, which includes:
# - CUDA runtime
# - PyTorch with CUDA support  
# - vLLM with FlashInfer attention backend (no flash-attn compilation needed!)
#
# Build this ONCE and push to your registry:
#   docker build -f deploy/docker/Dockerfile.base -t yourorg/babylon-base:0.2.0 .
#   docker push yourorg/babylon-base:0.2.0
#
# Then use Dockerfile which extends this and builds in ~2 minutes.
#
# ============================================================================
FROM vllm/vllm-openai:v0.14.0

# Note: vllm/vllm-openai uses Python 3.12 and includes:
# - PyTorch with CUDA
# - vLLM with FlashInfer backend
# - No flash-attn by default (uses FlashInfer instead - actually better for inference!)

# Install system dependencies
USER root
RUN apt-get update && apt-get install -y \
    curl \
    wget \
    unzip \
    postgresql-client \
    && rm -rf /var/lib/apt/lists/*

# Install Bun for database migrations
# Use pipefail to ensure curl failures don't silently succeed
SHELL ["/bin/bash", "-o", "pipefail", "-c"]
RUN curl -fsSL https://bun.sh/install | bash
SHELL ["/bin/sh", "-c"]
ENV PATH="/root/.bun/bin:$PATH"

# Create app directory
WORKDIR /app

# Install additional ML dependencies for training
# Versions pinned for reproducible builds (update periodically)
RUN pip install --no-cache-dir \
    transformers==4.47.1 \
    peft==0.14.0 \
    accelerate==1.2.1 \
    atroposlib==0.1.2 \
    wandb==0.19.1 \
    huggingface-hub==0.27.1 \
    tenacity==9.0.0 \
    python-dotenv==1.0.1 \
    psycopg2-binary==2.9.10 \
    aiohttp==3.11.11

# Verify installations (consolidated into single layer)
RUN python3 -c "\
import torch; \
import vllm; \
print(f'PyTorch {torch.__version__}, CUDA available: {torch.cuda.is_available()}'); \
print(f'vLLM {vllm.__version__}')"

# Set environment defaults
ENV PYTHONPATH=/app/python
ENV HF_HOME="/app/.cache/huggingface"
# Note: CUDA_VISIBLE_DEVICES should be set at runtime (docker run --gpus or env var)
# to allow flexibility across different GPU configurations

# FlashInfer is the default attention backend in vLLM - no need to set explicitly
# But we document it here for clarity
ENV VLLM_ATTENTION_BACKEND="FLASHINFER"

# Create directories
RUN mkdir -p /app/trained_models /app/logs /app/data /app/rollout_dumps /app/.cache

# Labels for tracking
LABEL maintainer="babylon-team"
LABEL version="0.2.1"
LABEL description="Babylon Training Base Image - vLLM with FlashInfer"
LABEL vllm.version="0.14.0"
