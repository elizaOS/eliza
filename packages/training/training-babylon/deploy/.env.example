# Babylon RL Training - Environment Configuration
#
# This is the master environment file for all deployment targets.
#
# Usage:
#   1. Copy to .env:     cp env.example .env
#   2. Fill in values
#   3. Use with Docker:  docker run --env-file .env ...
#   4. Or with scripts:  python setup.py train --env-file .env
#
# =============================================================================
# TRAJECTORY SOURCE (choose one mode)
# =============================================================================

# Source for trajectory data: "db" (PostgreSQL) or "huggingface"
# Default: "db" - loads from DATABASE_URL
# Set to "huggingface" to load from a frozen HuggingFace dataset
TRAJECTORY_SOURCE=db

# =============================================================================
# DATABASE SOURCE (used when TRAJECTORY_SOURCE=db)
# =============================================================================

# PostgreSQL database containing trajectory data for GRPO training
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/babylon

# =============================================================================
# HUGGINGFACE SOURCE (used when TRAJECTORY_SOURCE=huggingface)
# =============================================================================

# HuggingFace dataset ID for trajectory data
# Example: "elizaos/enkidu-trajectories-raw"
HF_TRAJECTORY_DATASET=

# Dataset split to use: "raw" (for GRPO), "preferences" (for DPO), "sft"
HF_TRAJECTORY_SPLIT=raw

# Minimum trajectories per window (set to 1 if windows have single trajectories)
MIN_AGENTS_PER_WINDOW=1

# =============================================================================
# EXPERIMENT TRACKING (Weights & Biases)
# =============================================================================

# Your W&B API key (get from: https://wandb.ai/settings)
WANDB_API_KEY=

# W&B project name
WANDB_PROJECT=babylon-training

# W&B entity (team or username) - leave empty for default
WANDB_ENTITY=

# Mode: "online" (track live), "offline" (local only), "disabled"
WANDB_MODE=offline

# Custom run name (auto-generated if empty)
WANDB_RUN_NAME=

# =============================================================================
# HUGGINGFACE HUB (model access and push)
# =============================================================================

# HuggingFace token for private/gated models AND pushing models
# Get from: https://huggingface.co/settings/tokens
# Required for: private datasets, gated models, model push
HF_TOKEN=

# HuggingFace cache directory (inside container)
HF_HOME=/app/.cache/huggingface

# =============================================================================
# MODEL PUSH TO HUGGINGFACE (optional, post-training)
# =============================================================================

# Push final model to HuggingFace Hub after training
# Leave empty to skip model push
# Example: "elizaos/gilgamesh-qwen2.5-0.5b-grpo-v0.1"
HF_PUSH_REPO=

# Model codename (used in model card, one of: ishtar, marduk, gilgamesh, etc.)
HF_MODEL_CODENAME=gilgamesh

# Make the pushed model private (true/false)
HF_MODEL_PRIVATE=false

# Also push intermediate checkpoints (true/false)
HF_PUSH_CHECKPOINTS=false

# =============================================================================
# POST-TRAINING BENCHMARK (optional)
# =============================================================================

# Run benchmark suite after training completes (true/false)
BENCHMARK_ENABLED=false

# Benchmark mode: "quick" (7-day scenarios) or "full" (22-day)
BENCHMARK_MODE=quick

# Specific scenarios to run (comma-separated, empty = all)
# Options: bull-market, bear-market, scandal-unfolds, pump-and-dump
BENCHMARK_SCENARIOS=

# Output directory for benchmark reports
BENCHMARK_OUTPUT_DIR=./benchmark-results

# =============================================================================
# GPU CONFIGURATION
# =============================================================================

# Which GPUs to use (comma-separated indices, e.g., "0" or "0,1,2,3")
CUDA_VISIBLE_DEVICES=0

# GPU profile: "12gb", "24gb", "l40", "a100", "h100", or "auto"
# "auto" will detect GPU and select appropriate settings
# Profiles determine base model:
#   12gb -> Qwen/Qwen2.5-0.5B-Instruct
#   24gb -> Qwen/Qwen2.5-3B-Instruct
#   h100 -> Qwen/Qwen2.5-14B-Instruct
TRAINING_PROFILE=auto

# =============================================================================
# TRAINING SETTINGS
# =============================================================================

# Number of training steps
TRAINING_STEPS=1000

# Steps between checkpoints (0 = disabled)
TRAINING_CHECKPOINT_EVERY=100

# Resume from checkpoint path (leave empty to start fresh)
TRAINING_RESUME_FROM=

# =============================================================================
# VLLM CONFIGURATION
# =============================================================================

# Attention backend: "FLASHINFER" (recommended) or "FLASH_ATTN"
# FLASHINFER is built into vLLM, FLASH_ATTN requires separate installation
VLLM_ATTENTION_BACKEND=FLASHINFER

# GPU memory fraction for vLLM inference (0.0-1.0)
# Lower = more memory for training, higher = faster inference
VLLM_GPU_MEMORY=0.25

# =============================================================================
# DOCKER REGISTRY
# =============================================================================

# Your Docker registry username or organization
DOCKER_REGISTRY=revlentless

# Image tag for builds
TAG=latest

# =============================================================================
# PLATFORM: RUNPOD
# =============================================================================

# RunPod API key for programmatic pod management
# Get from: https://runpod.io/console/user/settings
RUNPOD_API_KEY=
