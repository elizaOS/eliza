# Training Package Ignores
# (Patterns specific to this package - general patterns in root .gitignore)

# Data exports (keep .gitkeep files)
data/*.csv
data/**/*.parquet
data/**/scored_*.json
!data/**/.gitkeep

# E2E test output
training-data/e2e-test-results.json

# Python logs
python/logs/

# Python test caches (pytest)
python/.pytest_cache/
python/**/.pytest_cache/

# Local generated datasets/benchmarks
should_respond_data.jsonl
should_respond_eval.jsonl
benchmark_results.json
benchmark_chart.png

#tmp
TRAINING_ROADMAP.mdRUNPOD_QUICKSTART.md
training-data-output/