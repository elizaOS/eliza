__pycache__/
*.pyc
.venv/
vendor/
data/
checkpoints/
# Generated benchmark outputs (parquet datasets, ablation dumps) are
# ignored, but the checked-in gate definition is tracked — the publish
# orchestrator reads `benchmarks/eliza1_gates.yaml` (Eliza-1
# publish-blocking eval gates). The gate engine (`eliza1_gates.py`) +
# package marker, when added, should be un-ignored here too.
benchmarks/*
!benchmarks/eliza1_gates.yaml
previews/
local-corpora/
wandb/
*.parquet
.vast_instance_id
.preflight.ok
.cloud_instance.json
.DS_Store
scripts/synth/scenarios/*.jsonl
