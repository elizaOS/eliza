{
  "name": "@elizaos/cloud-api",
  "version": "0.1.0",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "dev": "bun run ../scripts/cloud/admin/sync-api-dev-vars.ts && wrangler dev --port ${API_DEV_PORT:-8787} --local",
    "build": "tsc --noEmit",
    "deploy": "wrangler deploy",
    "codegen": "node src/_generate-router.mjs",
    "typecheck": "tsc --noEmit",
    "test:audit": "node test/_audit-coverage.mjs",
    "test:e2e": "node test/e2e/run-e2e-batches.mjs",
    "test:e2e:foundation": "TEST_SERVER_SCRIPT=dev bun test --preload test/e2e/preload.ts test/e2e/agent-token-flow.test.ts --timeout 120000"
  },
  "dependencies": {
    "@ai-sdk/gateway": "^3.0.37",
    "@ai-sdk/openai": "^3.0.54",
    "@cloudflare/workers-types": "^4.20260429.1",
    "@elizaos/cloud-shared": "workspace:*",
    "@fal-ai/client": "^1.10.1",
    "@fal-ai/server-proxy": "^1.2.1",
    "@neondatabase/serverless": "^1.1.0",
    "@upstash/redis": "^1.37.0",
    "ai": "^6.0.170",
    "drizzle-orm": "^0.45.1",
    "file-type": "^22.0.1",
    "hono": "4.12.18",
    "music-metadata": "^11.12.3",
    "nanoid": "^5.1.9",
    "stripe": "^22.0.0",
    "telegraf": "^4.16.3",
    "uuid": "^14.0.0",
    "viem": "^2.48.8",
    "wrangler": "^4.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "dotenv": "^17.4.2",
    "typescript": "^6.0.3"
  }
}
