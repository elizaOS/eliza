{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023", "WebWorker", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "types": ["@cloudflare/workers-types", "node", "bun-types"],
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "isolatedModules": true,
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "esModuleInterop": true,
    "strict": true,
    "resolveJsonModule": true,
    "paths": {
      "@/api-app/*": ["./src/*"],
      "@/api-queue/*": ["./src/queue/*"],
      "@/lib/*": ["../cloud-shared/src/lib/*"],
      "@/db/*": ["../cloud-shared/src/db/*"],
      "@/types/*": ["../cloud-shared/src/types/*"],
      "@/billing/*": ["../cloud-shared/src/billing/*"],
      "@/api/*": ["./*"],
      "@elizaos/cloud-shared": ["../cloud-shared/src/index.ts"],
      "@elizaos/cloud-shared/billing": ["../cloud-shared/src/billing/index.ts"],
      "@elizaos/cloud-shared/db": ["../cloud-shared/src/db/index.ts"],
      "@elizaos/cloud-shared/db/*": ["../cloud-shared/src/db/*"],
      "@elizaos/cloud-shared/lib": ["../cloud-shared/src/lib/index.ts"],
      "@elizaos/cloud-shared/lib/*": ["../cloud-shared/src/lib/*"],
      "@elizaos/cloud-shared/types": ["../cloud-shared/src/types/index.ts"],
      "@elizaos/cloud-shared/types/*": ["../cloud-shared/src/types/*"],
      "@elizaos/cloud-shared/routing": ["../cloud-shared/src/routing/index.ts"],
      "@/*": ["../cloud-shared/*"]
    }
  },
  "include": [
    ".well-known/**/*.ts",
    "./**/*.ts",
    "./**/*.tsx",
    "../cloud-shared/src/**/*.ts",
    "../cloud-shared/src/db/**/*.ts",
    "../cloud-shared/src/types/**/*"
  ],
  "exclude": [
    "node_modules",
    "../../node_modules",
    "__tests__",
    "test",
    "../cloud-shared/src/**/__tests__",
    "../cloud-shared/src/**/*.test.ts"
  ]
}
