{
  "name": "@elizaos/app",
  "version": "2.0.0-beta.1",
  "type": "module",
  "scripts": {
    "dev": "bun --bun vite",
    "preview": "bun --bun vite preview",
    "design-review": "node --import tsx test/design-review/run-design-review.ts",
    "lint": "bunx @biomejs/biome check src scripts vite.config.ts vitest.config.ts vitest.e2e.config.ts playwright.ui-smoke.config.ts playwright.ui-packaged.config.ts playwright.electrobun.packaged.config.ts playwright.web-views.config.ts package.json capacitor.config.ts",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "test": "vitest run --config vitest.config.ts",
    "test:e2e": "node scripts/run-ui-playwright.mjs --config playwright.ui-smoke.config.ts",
    "test:e2e:cloud-wallet": "node scripts/run-ui-playwright.mjs --config playwright.ui-smoke.config.ts test/ui-smoke/cloud-wallet-import.spec.ts",
    "test:sim:local-chat": "node scripts/mobile-local-chat-smoke.mjs --platform ios",
    "test:sim:local-chat:android": "node scripts/mobile-local-chat-smoke.mjs --platform android",
    "test:sim:local-chat:android:live": "node scripts/mobile-local-chat-smoke.mjs --platform android --require-installed --live --android-select-local",
    "test:sim:local-chat:android:background": "node scripts/mobile-local-chat-smoke.mjs --platform android --require-installed --live --android-select-local --android-background",
    "test:sim:local-chat:both": "node scripts/mobile-local-chat-smoke.mjs --platform both",
    "test:sim:local-chat:ios": "node scripts/mobile-local-chat-smoke.mjs --platform ios",
    "test:sim:local-chat:ios:live": "node scripts/mobile-local-chat-smoke.mjs --platform ios --require-installed",
    "test:sim:auth": "node ../../packages/app-core/scripts/mobile-auth-simulator-smoke.mjs --platform both",
    "test:sim:auth:android": "node ../../packages/app-core/scripts/mobile-auth-simulator-smoke.mjs --platform android",
    "test:sim:auth:contract": "node ../../packages/app-core/scripts/mobile-auth-simulator-smoke.mjs --registration-only",
    "test:sim:auth:ios": "node ../../packages/app-core/scripts/mobile-auth-simulator-smoke.mjs --platform ios",
    "test:watch": "vitest --config vitest.config.ts",
    "plugin:build": "bun scripts/plugin-build.mjs",
    "build": "bun scripts/build.mjs",
    "build:ios": "node ../../packages/app-core/scripts/run-mobile-build.mjs ios",
    "build:ios:local": "node ../../packages/app-core/scripts/run-mobile-build.mjs ios-local",
    "build:ios:local:sim": "ELIZA_IOS_BUILD_DESTINATION='generic/platform=iOS Simulator' ELIZA_IOS_BUILD_SDK=iphonesimulator node ../../packages/app-core/scripts/run-mobile-build.mjs ios-local",
    "build:ios:local:device": "ELIZA_IOS_BUILD_DESTINATION='generic/platform=iOS' ELIZA_IOS_BUILD_SDK=iphoneos node ../../packages/app-core/scripts/run-mobile-build.mjs ios-local",
    "build:ios:local:sim:full-bun": "ELIZA_IOS_FULL_BUN_ENGINE=1 ELIZA_IOS_BUILD_DESTINATION='generic/platform=iOS Simulator' ELIZA_IOS_BUILD_SDK=iphonesimulator node ../../packages/app-core/scripts/run-mobile-build.mjs ios-local",
    "build:ios:local:device:full-bun": "ELIZA_IOS_FULL_BUN_ENGINE=1 ELIZA_IOS_BUILD_DESTINATION='generic/platform=iOS' ELIZA_IOS_BUILD_SDK=iphoneos node ../../packages/app-core/scripts/run-mobile-build.mjs ios-local",
    "build:android": "node ../../packages/app-core/scripts/run-mobile-build.mjs android",
    "build:android:cloud": "node ../../packages/app-core/scripts/run-mobile-build.mjs android-cloud",
    "build:android:system": "node ../../packages/app-core/scripts/run-mobile-build.mjs android-system",
    "ios": "bun run build:ios && capacitor open ios",
    "ios:local": "bun run build:ios:local && capacitor open ios",
    "android": "bun run build:android && capacitor open android",
    "cap:sync": "node scripts/ensure-capacitor-platform.mjs ios && node scripts/ensure-capacitor-platform.mjs android && capacitor sync",
    "cap:sync:ios": "node scripts/ensure-capacitor-platform.mjs ios && capacitor sync ios",
    "cap:sync:android": "node scripts/ensure-capacitor-platform.mjs android && capacitor sync android",
    "cap:open:ios": "node scripts/ensure-capacitor-platform.mjs ios && capacitor open ios",
    "cap:open:android": "node scripts/ensure-capacitor-platform.mjs android && capacitor open android",
    "build:web": "bun --bun vite build"
  },
  "dependencies": {
    "@capacitor/android": "8.3.1",
    "@capacitor/app": "8.1.0",
    "@capacitor/barcode-scanner": "3.0.2",
    "@capacitor-community/background-runner": "npm:@capacitor/background-runner@^3.0.0",
    "@capacitor/browser": "8.0.3",
    "@capacitor/core": "8.3.1",
    "@capacitor/haptics": "8.0.2",
    "@capacitor/ios": "8.3.1",
    "@capacitor/keyboard": "8.0.3",
    "@capacitor/network": "^8.0.0",
    "@capacitor/preferences": "8.0.1",
    "@capacitor/push-notifications": "8.0.3",
    "@capacitor/status-bar": "8.0.2",
    "@elizaos/app-clawville": "2.0.0-beta.1",
    "@elizaos/app-2004scape": "2.0.0-beta.1",
    "@elizaos/app-babylon": "2.0.0-beta.1",
    "@elizaos/app-companion": "2.0.0-beta.1",
    "@elizaos/app-contacts": "2.0.0-beta.1",
    "@elizaos/app-core": "2.0.0-beta.1",
    "@elizaos/app-defense-of-the-agents": "2.0.0-beta.1",
    "@elizaos/app-hyperscape": "2.0.0-beta.1",
    "@elizaos/app-lifeops": "2.0.0-beta.1",
    "@elizaos/app-phone": "2.0.0-beta.1",
    "@elizaos/app-scape": "2.0.0-beta.1",
    "@elizaos/app-shopify": "2.0.0-beta.1",
    "@elizaos/app-steward": "2.0.0-beta.1",
    "@elizaos/app-task-coordinator": "2.0.0-beta.1",
    "@elizaos/app-training": "2.0.0-beta.1",
    "@elizaos/app-trajectory-logger": "2.0.0-beta.1",
    "@elizaos/app-vincent": "2.0.0-beta.1",
    "@elizaos/app-wallet": "2.0.0-beta.1",
    "@elizaos/app-wifi": "2.0.0-beta.1",
    "@elizaos/capacitor-agent": "2.0.0-beta.1",
    "@elizaos/capacitor-appblocker": "2.0.0-beta.1",
    "@elizaos/capacitor-camera": "2.0.0-beta.1",
    "@elizaos/capacitor-calendar": "2.0.0-beta.1",
    "@elizaos/capacitor-canvas": "2.0.0-beta.1",
    "@elizaos/capacitor-contacts": "2.0.0-beta.1",
    "@elizaos/capacitor-desktop": "2.0.0-beta.1",
    "@elizaos/capacitor-gateway": "2.0.0-beta.1",
    "@elizaos/capacitor-llama": "2.0.0-beta.1",
    "@elizaos/capacitor-location": "2.0.0-beta.1",
    "@elizaos/capacitor-messages": "2.0.0-beta.1",
    "@elizaos/capacitor-mobile-signals": "2.0.0-beta.1",
    "@elizaos/capacitor-phone": "2.0.0-beta.1",
    "@elizaos/capacitor-screencapture": "2.0.0-beta.1",
    "@elizaos/capacitor-swabble": "2.0.0-beta.1",
    "@elizaos/capacitor-system": "2.0.0-beta.1",
    "@elizaos/capacitor-talkmode": "2.0.0-beta.1",
    "@elizaos/capacitor-websiteblocker": "2.0.0-beta.1",
    "@elizaos/capacitor-wifi": "2.0.0-beta.1",
    "@elizaos/plugin-agent-orchestrator": "2.0.0-beta.1",
    "@elizaos/plugin-background-runner": "2.0.0-beta.1",
    "@elizaos/plugin-elizacloud": "2.0.0-beta.1",
    "@elizaos/plugin-wallet": "2.0.0-beta.1",
    "@elizaos/plugin-workflow": "2.0.0-beta.1",
    "@elizaos/shared": "2.0.0-beta.1",
    "@elizaos/ui": "2.0.0-beta.1",
    "@pixiv/three-vrm": "^3.4.5",
    "llama-cpp-capacitor": "^0.1.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@capacitor/cli": "8.3.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.1.18",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.0",
    "bun-types": "^1.3.12",
    "jsdom": "^29.0.0",
    "pathe": "^2.0.3",
    "tailwindcss": "^4.1.18",
    "typescript": "^6.0.3",
    "vite": "^8.0.0",
    "vitest": "^4.0.0",
    "ws": "^8.18.3"
  },
  "private": true
}
