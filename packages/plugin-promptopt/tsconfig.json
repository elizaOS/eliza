{
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"noEmit": false,
		"emitDeclarationOnly": true,
		"allowImportingTsExtensions": true,
		"outDir": "./dist",
		"rootDir": "./src",
		"composite": false,
		"module": "ESNext",
		"moduleResolution": "bundler",
		"declaration": true,
		"declarationMap": true
	},
	"include": ["src/**/*.ts"],
	"exclude": ["node_modules", "dist", "src/__tests__/**"]
}
