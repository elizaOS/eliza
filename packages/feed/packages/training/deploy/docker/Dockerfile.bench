# =============================================================================
# Babylon Benchmark Docker Image
# =============================================================================
#
# Multi-stage build for running benchmarks against trained models using vLLM.
#
# Features:
# - vLLM for local model inference (same base as training)
# - Bun for TypeScript benchmark execution
# - Support for LoRA adapters via volume mounts
# - Support for HuggingFace model downloads
# - Full benchmark suite with scenario generation
#
# Build:
#   docker build -f deploy/docker/Dockerfile.bench -t babylon-benchmark:latest ../../..
#
# Run with local model:
#   docker run --gpus all \
#     -v ./trained_models:/models \
#     -e MODEL_PATH=/models/final_model \
#     babylon-benchmark:latest
#
# Run with HuggingFace model:
#   docker run --gpus all \
#     -e HF_MODEL=elizaos/ishtar-v0.1 \
#     -e HF_TOKEN=hf_xxx \
#     babylon-benchmark:latest
#
# =============================================================================

# -----------------------------------------------------------------------------
# Stage 1: vLLM Base (same as training)
# -----------------------------------------------------------------------------
FROM vllm/vllm-openai:v0.14.0 AS vllm-base

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    git \
    unzip \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Install Bun (with pipefail to catch curl failures)
SHELL ["/bin/bash", "-o", "pipefail", "-c"]
RUN curl -fsSL https://bun.sh/install | bash
ENV PATH="/root/.bun/bin:$PATH"
SHELL ["/bin/sh", "-c"]

# Verify installations
RUN bun --version && python3 --version

# -----------------------------------------------------------------------------
# Stage 2: Build TypeScript Dependencies
# -----------------------------------------------------------------------------
FROM vllm-base AS builder

WORKDIR /build

# Copy package files for dependency installation
# Turborepo monorepo - need all workspace package.json files for resolution
COPY package.json bun.lock turbo.json ./
COPY packages/a2a/package.json ./packages/a2a/
COPY packages/agents/package.json ./packages/agents/
COPY packages/api/package.json ./packages/api/
COPY packages/contracts/package.json ./packages/contracts/
COPY packages/core/package.json ./packages/core/
COPY packages/db/package.json ./packages/db/
COPY packages/engine/package.json ./packages/engine/
COPY packages/examples/package.json ./packages/examples/
COPY packages/mcp/package.json ./packages/mcp/
COPY packages/shared/package.json ./packages/shared/
COPY packages/testing/package.json ./packages/testing/
COPY packages/training/package.json ./packages/training/

# Install dependencies (skip postinstall scripts - not needed for benchmark)
RUN bun install --ignore-scripts

# Copy source code for training and required workspace deps
COPY packages/training/ ./packages/training/
COPY packages/db/ ./packages/db/
COPY packages/shared/ ./packages/shared/
COPY packages/core/ ./packages/core/
COPY packages/engine/ ./packages/engine/

# Verify build (fail on typecheck errors)
WORKDIR /build/packages/training
RUN bun run typecheck

# -----------------------------------------------------------------------------
# Stage 3: Final Benchmark Image
# -----------------------------------------------------------------------------
FROM vllm-base AS benchmark

LABEL maintainer="Eliza Labs"
LABEL description="Babylon benchmark image with vLLM for trained model evaluation"
LABEL version="1.0.0"

# Set working directory
WORKDIR /app

# Copy built application from builder
COPY --from=builder /build /app

# Set workdir to training package
WORKDIR /app/packages/training

# Create directories for models and results
RUN mkdir -p /models /benchmark-results /app/packages/training/benchmark-results

# Environment variables
ENV VLLM_URL=http://localhost:9001
ENV BASE_MODEL=Qwen/Qwen2.5-0.5B-Instruct
ENV BENCHMARK_OUTPUT_DIR=/benchmark-results
ENV BENCHMARK_QUICK=false

# vLLM configuration
ENV VLLM_GPU_MEMORY_UTILIZATION=0.85
ENV VLLM_MAX_MODEL_LEN=4096

# HuggingFace configuration (optional)
ENV HF_HOME=/root/.cache/huggingface

# Copy entrypoint scripts
COPY packages/training/deploy/docker/scripts/benchmark-entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

# Expose vLLM port
EXPOSE 9001

# Volume mounts
VOLUME ["/models", "/benchmark-results"]

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=120s --retries=3 \
    CMD curl -f http://localhost:9001/health || exit 1

# Entrypoint - runs benchmark by default, pass --help to see options
ENTRYPOINT ["/entrypoint.sh"]
CMD []

