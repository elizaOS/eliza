# Babylon RL training config
# Backends: Tinker, CUDA, MLX, CPU

# === Canonical Pipeline ===

# Database connection for trajectory data.
# Not required when training from a Hugging Face export.
DATABASE_URL=postgresql://user:password@localhost:5432/babylon

# Trajectory source for the canonical pipeline:
# - db
# - huggingface
TRAJECTORY_SOURCE=db
# HF_TRAJECTORY_DATASET=your-org/scambench-trajectories
# HF_TRAJECTORY_SPLIT=raw

# OpenAI API key is only required for judge-driven scripts and RL paths.
OPENAI_API_KEY=sk-...

# === Tinker Cloud Training ===
# Get your API key from: https://tinker-docs.thinkingmachines.ai/

TINKER_API_KEY=

# Tinker model selection.
# TINKER_BASE_MODEL=Qwen/Qwen3.5-4B
# TINKER_BASE_MODEL=Qwen/Qwen3.5-27B
# TINKER_BASE_MODEL=Qwen/Qwen3-30B-A3B-Instruct-2507
# TINKER_BASE_MODEL=meta-llama/Llama-3.1-70B

# Canonical Tinker pipeline entrypoint:
# python scripts/run_pipeline.py --training-backend tinker --trajectory-source huggingface --hf-dataset your-org/scambench-trajectories --tinker-steps 500 --rl-steps 100

# Optional alert webhook for failed, blocked, or promotion-blocked canonical runs.
# CANONICAL_PIPELINE_ALERT_WEBHOOK_URL=https://hooks.example.com/services/...

# === Local Atropos Training ===
# Only needed when not using Tinker.

# Atropos API server URL
ATROPOS_API_URL=http://localhost:8000

# vLLM inference server port
VLLM_PORT=9001

# === Local Backend Selection ===
# If none is set, auto-detect: CUDA > MLX > CPU.

# USE_MLX_BACKEND=true      # Apple Silicon Mac (fastest on Mac)
# USE_LOCAL_BACKEND=true    # CUDA GPU (auto-falls back to MLX/CPU if no CUDA)
# USE_CPU_BACKEND=true      # CPU only

# === Local Model Selection ===
# Leave blank to auto-select for the chosen backend.

# BASE_MODEL=Qwen/Qwen3.5-4B
# BASE_MODEL=Qwen/Qwen3.5-9B
# BABYLON_LOCAL_MLX_MODEL=mlx-community/Qwen3.5-4B-MLX-4bit
# BABYLON_LOCAL_CUDA_MODEL=Qwen/Qwen3.5-4B
# BABYLON_LOCAL_CPU_MODEL=Qwen/Qwen3.5-4B

BASE_MODEL=

# === Training ===

# Data selection
MIN_AGENTS_PER_WINDOW=1
# WINDOW_ID=              # Specific window to train (optional)
# MAX_EXAMPLES=2000       # Limit trajectories
# MAX_STEPS_PER_TRAJECTORY=20

# Training hyperparameters.
# LEARNING_RATE=4e-5      # Tinker default
# LEARNING_RATE=1e-5      # Atropos default
# MAX_SEQ_LENGTH=4096     # Context length
# LORA_RANK=32            # LoRA rank (Tinker)
# GROUP_SIZE=4            # GRPO group size
# TRAINING_STEPS=100      # Number of steps

# === Judge Model ===

JUDGE_MODEL=gpt-4o-mini
# JUDGE_MODEL=gpt-4o    # Higher quality, higher cost
# JUDGE_TEMPERATURE=0.3
