# E2E test output
training-data/e2e-test-results.json

# Python logs
python/logs/

# Python test caches (pytest)
python/.pytest_cache/
python/**/.pytest_cache/
deploy/**/.pytest_cache/

# Training logs
logs/

# HuggingFace dataset exports
hf_datasets/

# tmp
deploy/phala/
