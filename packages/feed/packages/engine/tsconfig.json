{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "tsBuildInfoFile": "./dist/.tsbuildinfo",
    "types": ["bun-types"],
    // Disable unused locals check - engine has some batch methods reserved for future optimization
    "noUnusedLocals": false,
    "baseUrl": ".",
    "paths": {
      "@babylon/shared": ["../shared/src/index.ts"],
      "@babylon/shared/*": ["../shared/src/*"],
      "@babylon/db": ["../db/src/index.ts"],
      "@babylon/db/*": ["../db/src/*"],
      "@babylon/core": ["../core/markets/index.ts"],
      "@babylon/core/*": ["../core/*"],
      "@babylon/pack-default": ["../pack-default/src/index.ts"],
      "@babylon/pack-default/*": ["../pack-default/src/*"]
    }
  },
  "include": ["src/**/*", "src/**/*.json"],
  "exclude": ["node_modules", "dist", "**/__tests__/**/*"],
  "references": [
    { "path": "../shared" },
    { "path": "../db" },
    { "path": "../core" },
    { "path": "../pack-default" }
  ]
}
