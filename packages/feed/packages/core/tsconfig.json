{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": ".",
    "tsBuildInfoFile": "./dist/.tsbuildinfo",
    "types": ["bun-types"],
    "baseUrl": ".",
    "paths": {
      "@babylon/shared": ["../shared/src/index.ts"],
      "@babylon/shared/*": ["../shared/src/*"],
      "@babylon/db": ["../db/src/index.ts"],
      "@babylon/db/*": ["../db/src/*"]
    }
  },
  "include": ["markets/**/*", "storage/**/*"],
  "exclude": ["node_modules", "dist", "**/scripts/**"],
  "references": [{ "path": "../shared" }, { "path": "../db" }]
}
