{
  "name": "@elizaos/os-homepage",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --bun vite --port 4455",
    "build": "bun --bun vite build",
    "deploy": "bunx wrangler pages deploy dist --project-name elizaos-homepage --branch main",
    "preview": "bun --bun vite preview --port 4455",
    "typecheck": "tsc -b",
    "test:e2e": "../../node_modules/.bin/playwright test",
    "screenshots": "node scripts/capture-screenshots.mjs",
    "lint": "bunx @biomejs/biome check --write --unsafe .",
    "lint:check": "bunx @biomejs/biome check .",
    "format": "bunx @biomejs/biome format --write .",
    "format:check": "bunx @biomejs/biome format ."
  },
  "dependencies": {
    "@elizaos/ui": "workspace:*",
    "@fontsource-variable/open-sans": "^5.2.7",
    "@tailwindcss/vite": "^4",
    "@vitejs/plugin-react": "^6.0.0",
    "lucide-react": "^1.0.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "vite": "^8.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@types/node": "^24.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "playwright": "^1.59.1",
    "typescript": "^6.0.3"
  }
}
