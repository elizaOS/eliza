{
  "name": "@elizaos/shared-brand",
  "version": "0.1.0",
  "description": "Canonical brand assets and tokens shared across every elizaOS surface (homepages, cloud frontend, docs, app, electrobun).",
  "type": "module",
  "private": true,
  "license": "MIT",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./brand.css": "./src/brand.css",
    "./assets/*": "./assets/*",
    "./sync": "./scripts/sync-to-public.mjs"
  },
  "files": [
    "assets",
    "src",
    "scripts"
  ],
  "scripts": {
    "sync": "node scripts/sync-to-public.mjs"
  }
}
