{
  "name": "@elizaos/plugin-abu-solana",
  "version": "1.0.0",
  "description": "Abu - Autonomous Solana DeFi Agent plugin for ElizaOS. Provides arbitrage signals, market analysis, reputation scoring, and agent collaboration.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch --preserveWatchOutput",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "keywords": [
    "elizaos",
    "plugin",
    "solana",
    "defi",
    "arbitrage",
    "ai-agent",
