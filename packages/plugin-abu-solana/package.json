    "type": "git",
    "url": "git+https://github.com/elizaos/eliza.git",
    "directory": "packages/plugin-abu-solana"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {},
  "peerDependencies": {
    "@elizaos/core": "^2.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
