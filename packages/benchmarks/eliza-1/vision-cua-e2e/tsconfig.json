{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "paths": {
      "@elizaos/plugin-computeruse": [
        "../../../../plugins/plugin-computeruse/dist/index.d.ts"
      ]
    },
    "lib": ["ES2022"]
  },
  "include": ["src/**/*.ts", "*.ts", "scripts/**/*.mjs"]
}
