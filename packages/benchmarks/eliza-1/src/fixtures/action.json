        {
          "name": "text",
          "type": "string",
          "description": "Message body.",
          "required": true
        }
      ],
      "context": "User said: 'message alice and tell her the report is ready'. Emit parameters for the MESSAGE action.",
      "expected_params": { "recipient": "alice", "text": "<<any>>" }
