      "parameters": [
        {
          "name": "text",
          "type": "string",
          "description": "User-facing reply text.",
          "required": true
        }
      ],
      "context": "User asked 'are you still working on that?'. The task is complete. Produce a short confirmation.",
      "expected_params": { "text": "<<any>>" }
    },
    {
      "id": "message-recipient-text",
      "actionName": "MESSAGE",
