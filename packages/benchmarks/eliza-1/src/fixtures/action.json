{
  "note": "Per-action fixtures. The runner streams context through a single-action grammar/schema; the model emits the action's parameter object only. Free-text fields like REPLY.text use the sentinel '<<any>>' so the matcher only checks the field exists with non-empty string content — the LLM never produces byte-identical prose. Structured fields (recipients, op enums, etc.) require exact match.",
  "cases": [
    {
      "id": "reply-greeting",
      "actionName": "REPLY",
      "parameters": [
        {
          "name": "text",
          "type": "string",
          "description": "User-facing reply text.",
          "required": true
        }
      ],
      "context": "User just said 'hi'. Produce a brief friendly greeting back.",
      "expected_params": { "text": "<<any>>" }
    },
    {
