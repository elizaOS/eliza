+JNIEXPORT jobject JNICALL
+Java_ai_annadata_plugin_capacitor_LlamaCpp_embeddingNative(
+    JNIEnv * env,
+    jobject,
+    jlong context_id,
+    jstring text,
+    jobject params_object) {
+    try {
+        NativeContext * native = nullptr;
+        {
+            std::lock_guard<std::mutex> lock(g_contexts_mutex);
+            auto it = g_contexts.find(context_id);
+            if (it == g_contexts.end()) throw std::runtime_error("Invalid context ID");
+            native = it->second.get();
+        }
+        std::lock_guard<std::mutex> context_lock(native->mutex);
+        native->n_past = 0;
+        native->interrupted.store(false);
+        llama_memory_clear(llama_get_memory(native->ctx), true);
+        llama_set_embeddings(native->ctx, true);
+        llama_set_causal_attn(native->ctx, false);
+
+        auto tokens = tokenize_text(native->vocab, jstring_to_string(env, text), true);
+        decode_tokens(*native, tokens, true);
+        llama_synchronize(native->ctx);
+
+        float * embedding = llama_get_embeddings_seq(native->ctx, 0);
+        if (embedding == nullptr) embedding = llama_get_embeddings_ith(native->ctx, -1);
+        if (embedding == nullptr) throw std::runtime_error("Embedding output unavailable; initialize the context with embedding=true");
+
+        const json params = jobject_to_json(env, params_object);
+        const int normalize = json_i32(params, "embd_normalize", 0);
+        const int n_embd = llama_model_n_embd(native->model);
+        std::vector<float> values(embedding, embedding + n_embd);
+        if (normalize != 0) {
+            double sum = 0.0;
+            for (float value : values) sum += static_cast<double>(value) * value;
+            const double norm = std::sqrt(sum);
+            if (norm > 0.0) {
+                for (float & value : values) value = static_cast<float>(value / norm);
+            }
+        }
+
+        jobject result = new_hash_map(env);
+        jobject list = new_array_list(env);
+        for (float value : values) {
+            jobject boxed = new_boxed_double(env, static_cast<double>(value));
+            array_list_add(env, list, boxed);
+            env->DeleteLocalRef(boxed);
+        }
+        map_put(env, result, "embedding", list);
+        env->DeleteLocalRef(list);
+        map_put_int(env, result, "tokens", static_cast<int>(tokens.size()));
+        return result;
+    } catch (const std::exception & e) {
+        LOGE("embeddingNative failed: %s", e.what());
+        throw_java_exception(env, "java/lang/RuntimeException", e.what());
+        return nullptr;
+    }
+}
