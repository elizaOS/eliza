+JNIEXPORT jobject JNICALL
+Java_ai_annadata_plugin_capacitor_LlamaCpp_tokenizeNative(
+    JNIEnv * env,
+    jobject,
+    jlong context_id,
+    jstring text,
+    jobjectArray) {
+    try {
+        NativeContext * native = nullptr;
+        {
+            std::lock_guard<std::mutex> lock(g_contexts_mutex);
+            auto it = g_contexts.find(context_id);
+            if (it == g_contexts.end()) throw std::runtime_error("Invalid context ID");
+            native = it->second.get();
+        }
+        auto tokens = tokenize_text(native->vocab, jstring_to_string(env, text), true);
+        jobject result = new_hash_map(env);
+        jobject token_list = new_array_list(env);
+        for (llama_token token : tokens) {
+            jobject boxed = new_boxed_int(env, static_cast<jint>(token));
+            array_list_add(env, token_list, boxed);
+            env->DeleteLocalRef(boxed);
+        }
+        map_put(env, result, "tokens", token_list);
+        env->DeleteLocalRef(token_list);
+        map_put_bool(env, result, "has_images", false);
+        jobject empty_a = new_array_list(env);
+        jobject empty_b = new_array_list(env);
+        jobject empty_c = new_array_list(env);
+        map_put(env, result, "bitmap_hashes", empty_a);
+        map_put(env, result, "chunk_pos", empty_b);
+        map_put(env, result, "chunk_pos_images", empty_c);
+        env->DeleteLocalRef(empty_a);
+        env->DeleteLocalRef(empty_b);
+        env->DeleteLocalRef(empty_c);
+        return result;
+    } catch (const std::exception & e) {
+        throw_java_exception(env, "java/lang/RuntimeException", e.what());
+        return nullptr;
+    }
+}
