+++ b/android/src/main/eliza-dflash-jni.cpp
@@ -0,0 +1,999 @@
+#include <android/log.h>
+#include <jni.h>
+
+#include "json-schema-to-grammar.h"
+#include "llama.h"
+
+#include <nlohmann/json.hpp>
+
+#include <algorithm>
+#include <atomic>
+#include <chrono>
+#include <cmath>
+#include <cctype>
+#include <cstdint>
+#include <filesystem>
+#include <fstream>
+#include <limits>
+#include <map>
+#include <memory>
+#include <mutex>
+#include <sstream>
+#include <stdexcept>
+#include <string>
+#include <thread>
+#include <vector>
+
+#define LOG_TAG "ElizaDFlashJNI"
+#define LOGI(...) __android_log_print(ANDROID_LOG_INFO, LOG_TAG, __VA_ARGS__)
+#define LOGW(...) __android_log_print(ANDROID_LOG_WARN, LOG_TAG, __VA_ARGS__)
+#define LOGE(...) __android_log_print(ANDROID_LOG_ERROR, LOG_TAG, __VA_ARGS__)
+
+using json = nlohmann::ordered_json;
+
+std::string string_join(const std::vector<std::string> & values, const std::string & separator) {
+    std::ostringstream joined;
+    for (size_t i = 0; i < values.size(); ++i) {
+        if (i > 0) joined << separator;
+        joined << values[i];
+    }
+    return joined.str();
+}
+
+std::vector<std::string> string_split(const std::string & str, const std::string & delimiter) {
+    std::vector<std::string> result;
+    if (delimiter.empty()) {
+        result.push_back(str);
+        return result;
+    }
+    size_t start = 0;
+    while (true) {
+        const size_t next = str.find(delimiter, start);
+        if (next == std::string::npos) {
+            result.push_back(str.substr(start));
+            return result;
+        }
+        result.push_back(str.substr(start, next - start));
+        start = next + delimiter.size();
+    }
+}
+
+std::string string_repeat(const std::string & str, size_t n) {
+    std::string result;
+    result.reserve(str.size() * n);
+    for (size_t i = 0; i < n; ++i) result += str;
+    return result;
+}
+
+namespace {
+
+struct NativeContext {
+    llama_model * model = nullptr;
+    llama_context * ctx = nullptr;
+    const llama_vocab * vocab = nullptr;
+    std::string model_path;
+    int32_t n_batch = 512;
+    int32_t n_past = 0;
+    bool embeddings = false;
+    std::atomic_bool interrupted{false};
+    std::mutex mutex;
+
+    ~NativeContext() {
+        if (ctx != nullptr) {
+            llama_free(ctx);
+            ctx = nullptr;
+        }
+        if (model != nullptr) {
+            llama_model_free(model);
+            model = nullptr;
+        }
+    }
+};
+
+std::mutex g_contexts_mutex;
+std::map<jlong, std::unique_ptr<NativeContext>> g_contexts;
+std::atomic<jlong> g_next_context_id{1};
+std::once_flag g_backend_once;
+std::atomic_bool g_native_log_enabled{false};
+
+void ensure_backend() {
+    std::call_once(g_backend_once, [] {
+        llama_backend_init();
+        LOGI("llama backend initialized");
+    });
+}
+
+void throw_java_exception(JNIEnv * env, const char * class_name, const std::string & message) {
+    jclass clazz = env->FindClass(class_name);
+    if (clazz != nullptr) {
+        env->ThrowNew(clazz, message.c_str());
+    }
+}
+
+std::string jstring_to_string(JNIEnv * env, jstring value) {
+    if (value == nullptr) return "";
+    const char * chars = env->GetStringUTFChars(value, nullptr);
+    if (chars == nullptr) return "";
+    std::string result(chars);
+    env->ReleaseStringUTFChars(value, chars);
+    return result;
+}
+
+jstring string_to_jstring(JNIEnv * env, const std::string & value) {
+    return env->NewStringUTF(value.c_str());
+}
+
+std::vector<std::string> jstring_array_to_vector(JNIEnv * env, jobjectArray array) {
+    std::vector<std::string> result;
+    if (array == nullptr) return result;
+    const jsize length = env->GetArrayLength(array);
+    result.reserve(static_cast<size_t>(length));
+    for (jsize i = 0; i < length; ++i) {
+        auto item = static_cast<jstring>(env->GetObjectArrayElement(array, i));
+        result.push_back(jstring_to_string(env, item));
+        env->DeleteLocalRef(item);
+    }
+    return result;
+}
+
+json jobject_to_json(JNIEnv * env, jobject object) {
+    if (object == nullptr) return json::object();
+    jclass clazz = env->GetObjectClass(object);
+    jmethodID to_string = env->GetMethodID(clazz, "toString", "()Ljava/lang/String;");
+    if (to_string == nullptr) {
+        if (env->ExceptionCheck()) env->ExceptionClear();
+        return json::object();
+    }
+    auto value = static_cast<jstring>(env->CallObjectMethod(object, to_string));
+    if (env->ExceptionCheck() || value == nullptr) {
+        if (env->ExceptionCheck()) env->ExceptionClear();
+        return json::object();
+    }
+    const std::string serialized = jstring_to_string(env, value);
+    env->DeleteLocalRef(value);
+    auto parsed = json::parse(serialized, nullptr, false);
+    return parsed.is_discarded() || !parsed.is_object() ? json::object() : parsed;
+}
+
+bool json_bool(const json & object, const char * key, bool fallback) {
+    auto it = object.find(key);
+    if (it == object.end() || it->is_null()) return fallback;
+    if (it->is_boolean()) return it->get<bool>();
+    if (it->is_number_integer()) return it->get<int>() != 0;
+    if (it->is_string()) {
+        const std::string value = it->get<std::string>();
+        return value == "1" || value == "true" || value == "TRUE" || value == "yes";
+    }
+    return fallback;
+}
+
+int32_t json_i32(const json & object, const char * key, int32_t fallback) {
+    auto it = object.find(key);
+    if (it == object.end() || it->is_null()) return fallback;
+    if (it->is_number_integer()) return it->get<int32_t>();
+    if (it->is_number_float()) return static_cast<int32_t>(it->get<double>());
+    if (it->is_string()) {
+        try {
+            return static_cast<int32_t>(std::stol(it->get<std::string>()));
+        } catch (...) {
+            return fallback;
+        }
+    }
+    return fallback;
+}
+
+float json_f32(const json & object, const char * key, float fallback) {
+    auto it = object.find(key);
+    if (it == object.end() || it->is_null()) return fallback;
+    if (it->is_number()) return it->get<float>();
+    if (it->is_string()) {
+        try {
+            return std::stof(it->get<std::string>());
+        } catch (...) {
+            return fallback;
+        }
+    }
+    return fallback;
+}
+
+std::string json_string(const json & object, const char * key, const std::string & fallback = "") {
+    auto it = object.find(key);
+    if (it == object.end() || it->is_null()) return fallback;
+    if (it->is_string()) return it->get<std::string>();
+    return fallback;
+}
+
+std::vector<std::string> json_string_array(const json & object, const char * key) {
+    std::vector<std::string> values;
+    auto it = object.find(key);
+    if (it == object.end()) return values;
+    if (it->is_string()) {
+        values.push_back(it->get<std::string>());
+        return values;
+    }
+    if (!it->is_array()) return values;
+    for (const auto & item : *it) {
+        if (item.is_string()) values.push_back(item.get<std::string>());
+    }
+    return values;
+}
+
+jobject new_boxed_int(JNIEnv * env, jint value) {
+    jclass clazz = env->FindClass("java/lang/Integer");
+    jmethodID ctor = env->GetMethodID(clazz, "<init>", "(I)V");
+    return env->NewObject(clazz, ctor, value);
+}
+
+jobject new_boxed_long(JNIEnv * env, jlong value) {
+    jclass clazz = env->FindClass("java/lang/Long");
+    jmethodID ctor = env->GetMethodID(clazz, "<init>", "(J)V");
+    return env->NewObject(clazz, ctor, value);
+}
+
+jobject new_boxed_double(JNIEnv * env, jdouble value) {
+    jclass clazz = env->FindClass("java/lang/Double");
+    jmethodID ctor = env->GetMethodID(clazz, "<init>", "(D)V");
+    return env->NewObject(clazz, ctor, value);
+}
+
+jobject new_boxed_bool(JNIEnv * env, bool value) {
+    jclass clazz = env->FindClass("java/lang/Boolean");
+    jmethodID ctor = env->GetMethodID(clazz, "<init>", "(Z)V");
+    return env->NewObject(clazz, ctor, value ? JNI_TRUE : JNI_FALSE);
+}
+
+jobject new_hash_map(JNIEnv * env) {
+    jclass clazz = env->FindClass("java/util/HashMap");
+    jmethodID ctor = env->GetMethodID(clazz, "<init>", "()V");
+    return env->NewObject(clazz, ctor);
+}
+
+jmethodID hash_map_put_method(JNIEnv * env, jobject map) {
+    jclass clazz = env->GetObjectClass(map);
+    return env->GetMethodID(clazz, "put", "(Ljava/lang/Object;Ljava/lang/Object;)Ljava/lang/Object;");
+}
+
+void map_put(JNIEnv * env, jobject map, const char * key, jobject value) {
+    jmethodID put = hash_map_put_method(env, map);
+    jstring jkey = string_to_jstring(env, key);
+    env->CallObjectMethod(map, put, jkey, value);
+    env->DeleteLocalRef(jkey);
+}
+
+void map_put_string(JNIEnv * env, jobject map, const char * key, const std::string & value) {
+    jstring jvalue = string_to_jstring(env, value);
+    map_put(env, map, key, jvalue);
+    env->DeleteLocalRef(jvalue);
+}
+
+void map_put_int(JNIEnv * env, jobject map, const char * key, int value) {
+    jobject boxed = new_boxed_int(env, static_cast<jint>(value));
+    map_put(env, map, key, boxed);
+    env->DeleteLocalRef(boxed);
+}
+
+void map_put_long(JNIEnv * env, jobject map, const char * key, int64_t value) {
+    jobject boxed = new_boxed_long(env, static_cast<jlong>(value));
+    map_put(env, map, key, boxed);
+    env->DeleteLocalRef(boxed);
+}
+
+void map_put_double(JNIEnv * env, jobject map, const char * key, double value) {
+    jobject boxed = new_boxed_double(env, static_cast<jdouble>(value));
+    map_put(env, map, key, boxed);
+    env->DeleteLocalRef(boxed);
+}
+
+void map_put_bool(JNIEnv * env, jobject map, const char * key, bool value) {
+    jobject boxed = new_boxed_bool(env, value);
+    map_put(env, map, key, boxed);
+    env->DeleteLocalRef(boxed);
+}
