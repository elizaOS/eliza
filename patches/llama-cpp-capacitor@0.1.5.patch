+JNIEXPORT jobject JNICALL
+Java_ai_annadata_plugin_capacitor_LlamaCpp_modelInfoNative(JNIEnv * env, jobject, jstring model_path) {
+    try {
+        ensure_backend();
+        const std::string full_path = resolve_model_path(jstring_to_string(env, model_path), {});
+        llama_model_params params = llama_model_default_params();
+        params.n_gpu_layers = 0;
+        params.use_mmap = true;
+        params.no_alloc = true;
+        llama_model * model = llama_model_load_from_file(full_path.c_str(), params);
+        if (model == nullptr) throw std::runtime_error("Failed to read model metadata: " + full_path);
+
+        char desc[1024] = {};
+        llama_model_desc(model, desc, sizeof(desc));
+        jobject result = new_hash_map(env);
+        map_put_string(env, result, "path", full_path);
+        map_put_string(env, result, "desc", desc);
+        map_put_long(env, result, "size", static_cast<int64_t>(llama_model_size(model)));
+        map_put_long(env, result, "nParams", static_cast<int64_t>(llama_model_n_params(model)));
+        map_put_int(env, result, "nEmbd", llama_model_n_embd(model));
+        map_put_int(env, result, "nContextTrain", llama_model_n_ctx_train(model));
+        map_put_string(env, result, "architecture", model_meta_value(model, "general.architecture"));
+        map_put_string(env, result, "basename", model_meta_value(model, "general.basename"));
+        llama_model_free(model);
+        return result;
+    } catch (const std::exception & e) {
+        LOGE("modelInfoNative failed: %s", e.what());
+        throw_java_exception(env, "java/lang/RuntimeException", e.what());
+        return nullptr;
+    }
+}
