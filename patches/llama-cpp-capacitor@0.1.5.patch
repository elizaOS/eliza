+JNIEXPORT jstring JNICALL
+Java_ai_annadata_plugin_capacitor_LlamaCpp_detokenizeNative(JNIEnv * env, jobject, jlong context_id, jintArray tokens_array) {
+    try {
+        NativeContext * native = nullptr;
+        {
+            std::lock_guard<std::mutex> lock(g_contexts_mutex);
+            auto it = g_contexts.find(context_id);
+            if (it == g_contexts.end()) throw std::runtime_error("Invalid context ID");
+            native = it->second.get();
+        }
+        jsize length = env->GetArrayLength(tokens_array);
+        jint * values = env->GetIntArrayElements(tokens_array, nullptr);
+        std::vector<llama_token> tokens;
+        tokens.reserve(static_cast<size_t>(length));
+        for (jsize i = 0; i < length; ++i) tokens.push_back(static_cast<llama_token>(values[i]));
+        env->ReleaseIntArrayElements(tokens_array, values, JNI_ABORT);
+        return string_to_jstring(env, detokenize_tokens(native->vocab, tokens));
+    } catch (const std::exception & e) {
+        throw_java_exception(env, "java/lang/RuntimeException", e.what());
+        return nullptr;
+    }
+}
