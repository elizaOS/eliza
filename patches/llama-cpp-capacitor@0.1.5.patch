+JNIEXPORT jlong JNICALL
+Java_ai_annadata_plugin_capacitor_LlamaCpp_initContextNative(
+    JNIEnv * env,
+    jobject,
+    jstring model_path,
+    jobjectArray search_paths,
+    jobject params_object) {
+    try {
+        ensure_backend();
+        const json params = jobject_to_json(env, params_object);
+        std::string requested = json_string(params, "model", jstring_to_string(env, model_path));
+        std::string full_path = resolve_model_path(requested, jstring_array_to_vector(env, search_paths));
+
+        llama_model_params model_params = llama_model_default_params();
+        model_params.n_gpu_layers = json_i32(params, "n_gpu_layers", 0);
+        model_params.use_mmap = json_bool(params, "use_mmap", true);
+        model_params.use_mlock = json_bool(params, "use_mlock", false);
+        model_params.check_tensors = json_bool(params, "check_tensors", false);
+
+        llama_model * model = llama_model_load_from_file(full_path.c_str(), model_params);
+        if (model == nullptr) {
+            throw std::runtime_error("Failed to load model with DFlash llama.cpp: " + full_path);
+        }
+
+        llama_context_params context_params = llama_context_default_params();
+        context_params.n_ctx = static_cast<uint32_t>(std::max<int32_t>(1, json_i32(params, "n_ctx", 4096)));
+        context_params.n_batch = static_cast<uint32_t>(std::max<int32_t>(1, json_i32(params, "n_batch", 512)));
+        context_params.n_ubatch = static_cast<uint32_t>(std::max<int32_t>(1, json_i32(params, "n_ubatch", std::min<int32_t>(512, context_params.n_batch))));
+        context_params.n_seq_max = 1;
+        int32_t threads = json_i32(params, "n_threads", 0);
+        if (threads <= 0) {
+            threads = static_cast<int32_t>(std::max(1u, std::min(4u, std::thread::hardware_concurrency())));
+        }
+        context_params.n_threads = threads;
+        context_params.n_threads_batch = json_i32(params, "n_threads_batch", threads);
+        context_params.flash_attn_type = json_bool(params, "flash_attn", false)
+            ? LLAMA_FLASH_ATTN_TYPE_ENABLED
+            : LLAMA_FLASH_ATTN_TYPE_DISABLED;
+        context_params.type_k = parse_ggml_type(json_string(params, "cache_type_k", ""), context_params.type_k);
+        context_params.type_v = parse_ggml_type(json_string(params, "cache_type_v", ""), context_params.type_v);
+
+        const bool embedding_mode = json_bool(params, "embedding", false);
+        if (embedding_mode) {
+            context_params.embeddings = true;
+            context_params.pooling_type = LLAMA_POOLING_TYPE_MEAN;
+            context_params.attention_type = LLAMA_ATTENTION_TYPE_NON_CAUSAL;
+        }
+
+        llama_context * ctx = llama_init_from_model(model, context_params);
+        if (ctx == nullptr) {
+            llama_model_free(model);
+            throw std::runtime_error("Failed to initialize llama context for: " + full_path);
+        }
+
+        auto native = std::make_unique<NativeContext>();
+        native->model = model;
+        native->ctx = ctx;
+        native->vocab = llama_model_get_vocab(model);
+        native->model_path = full_path;
+        native->n_batch = static_cast<int32_t>(context_params.n_batch);
+        native->embeddings = embedding_mode;
+
+        const jlong id = g_next_context_id.fetch_add(1);
+        {
+            std::lock_guard<std::mutex> lock(g_contexts_mutex);
+            g_contexts[id] = std::move(native);
+        }
+
+        LOGI("Initialized DFlash context %lld for %s (ctx=%u, batch=%u, threads=%d, gpu_layers=%d)",
+             static_cast<long long>(id),
+             full_path.c_str(),
+             context_params.n_ctx,
+             context_params.n_batch,
+             threads,
+             model_params.n_gpu_layers);
+        return id;
+    } catch (const std::exception & e) {
+        LOGE("initContextNative failed: %s", e.what());
+        throw_java_exception(env, "java/lang/RuntimeException", e.what());
+        return -1;
+    }
+}
