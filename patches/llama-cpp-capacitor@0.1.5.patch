+JNIEXPORT jstring JNICALL
+Java_ai_annadata_plugin_capacitor_LlamaCpp_getFormattedChatNative(
+    JNIEnv * env,
+    jobject,
+    jlong context_id,
+    jstring messages,
+    jstring chat_template) {
+    try {
+        NativeContext * native = nullptr;
+        {
+            std::lock_guard<std::mutex> lock(g_contexts_mutex);
+            auto it = g_contexts.find(context_id);
+            if (it == g_contexts.end()) throw std::runtime_error("Invalid context ID");
+            native = it->second.get();
+        }
+
+        const std::string messages_json = jstring_to_string(env, messages);
+        std::string tmpl = jstring_to_string(env, chat_template);
+        if (tmpl.empty()) {
+            const char * model_template = llama_model_chat_template(native->model, nullptr);
+            if (model_template != nullptr) tmpl = model_template;
+        }
+
+        auto parsed = json::parse(messages_json, nullptr, false);
+        if (parsed.is_discarded() || !parsed.is_array()) {
+            return string_to_jstring(env, messages_json);
+        }
+
+        std::vector<std::string> roles;
+        std::vector<std::string> contents;
+        for (const auto & item : parsed) {
+            if (!item.is_object()) continue;
+            roles.push_back(json_string(item, "role", "user"));
+            contents.push_back(json_string(item, "content", ""));
+        }
+        std::vector<llama_chat_message> chat;
+        chat.reserve(roles.size());
+        for (size_t i = 0; i < roles.size(); ++i) {
+            chat.push_back({roles[i].c_str(), contents[i].c_str()});
+        }
+        int32_t needed = llama_chat_apply_template(tmpl.empty() ? nullptr : tmpl.c_str(), chat.data(), chat.size(), true, nullptr, 0);
+        if (needed < 0) {
+            needed = llama_chat_apply_template(nullptr, chat.data(), chat.size(), true, nullptr, 0);
+            tmpl.clear();
+        }
+        if (needed < 0) return string_to_jstring(env, messages_json);
+        std::vector<char> buffer(static_cast<size_t>(needed) + 8);
+        int32_t written = llama_chat_apply_template(tmpl.empty() ? nullptr : tmpl.c_str(), chat.data(), chat.size(), true, buffer.data(), static_cast<int32_t>(buffer.size()));
+        if (written < 0) return string_to_jstring(env, messages_json);
+        return string_to_jstring(env, std::string(buffer.data(), static_cast<size_t>(written)));
+    } catch (const std::exception & e) {
+        LOGE("getFormattedChatNative failed: %s", e.what());
+        throw_java_exception(env, "java/lang/RuntimeException", e.what());
+        return nullptr;
+    }
+}
