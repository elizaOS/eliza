@@ -5,6 +5,22 @@ ext {
     androidxEspressoCoreVersion = project.hasProperty('androidxEspressoCoreVersion') ? rootProject.ext.androidxEspressoCoreVersion : '3.6.1'
 }
 
+def resolveElizaRepoRoot = { ->
+    return rootProject.projectDir.toPath().resolve('../../..').normalize().toFile().absolutePath
+}
+
+def resolveElizaDflashAndroidLibDir = { ->
+    def fromProp = project.findProperty('eliza.dflash.android.libdir')
+    if (fromProp) return fromProp.toString()
+    def fromEnv = System.getenv('ELIZA_DFLASH_ANDROID_LIBDIR')
+    if (fromEnv) return fromEnv
+    def stateDir = System.getenv('ELIZA_STATE_DIR') ?: "${System.getProperty('user.home')}/.eliza"
+    def candidates = ['vulkan', 'cpu'].collect { backend ->
+        "${stateDir}/local-inference/bin/dflash/android-arm64-${backend}"
+    }
+    return candidates.find { new File(it).isDirectory() } ?: ''
+}
+
 buildscript {
     repositories {
         google()
