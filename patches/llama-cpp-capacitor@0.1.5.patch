+JNIEXPORT jobject JNICALL
+Java_ai_annadata_plugin_capacitor_LlamaCpp_completionNative(
+    JNIEnv * env,
+    jobject,
+    jlong context_id,
+    jobject params_object) {
+    try {
+        NativeContext * native = nullptr;
+        {
+            std::lock_guard<std::mutex> lock(g_contexts_mutex);
+            auto it = g_contexts.find(context_id);
+            if (it == g_contexts.end()) throw std::runtime_error("Invalid context ID");
+            native = it->second.get();
+        }
+
+        std::lock_guard<std::mutex> context_lock(native->mutex);
+        native->interrupted.store(false);
+        native->n_past = 0;
+        llama_memory_clear(llama_get_memory(native->ctx), true);
+
+        const json params = jobject_to_json(env, params_object);
+        std::string prompt = json_string(params, "prompt", "");
+        int32_t n_predict = json_i32(params, "n_predict", json_i32(params, "max_tokens", 128));
+        n_predict = std::clamp<int32_t>(n_predict, 1, 4096);
+        std::vector<std::string> stops = json_string_array(params, "stop");
+        std::vector<std::string> stop_sequences = json_string_array(params, "stop_sequences");
+        stops.insert(stops.end(), stop_sequences.begin(), stop_sequences.end());
+
+        auto prompt_tokens = tokenize_text(native->vocab, prompt, true);
+        const uint32_t n_ctx = llama_n_ctx(native->ctx);
+        if (n_ctx > 8) {
+            const size_t context_slots = static_cast<size_t>(n_ctx);
+            const size_t requested_generation = static_cast<size_t>(std::max<int32_t>(1, n_predict));
+            const size_t generation_reserve = std::min<size_t>(
+                std::max<size_t>(8, std::min<size_t>(requested_generation, 256)),
+                std::max<size_t>(1, context_slots / 2));
+            const size_t prompt_budget = std::max<size_t>(2, context_slots - generation_reserve - 1);
+            if (prompt_tokens.size() > prompt_budget) {
+                const size_t keep_tail = prompt_budget - 1;
+                std::vector<llama_token> trimmed;
+                trimmed.reserve(prompt_budget);
+                trimmed.push_back(prompt_tokens.front());
+                trimmed.insert(trimmed.end(), prompt_tokens.end() - static_cast<std::ptrdiff_t>(keep_tail), prompt_tokens.end());
+                prompt_tokens.swap(trimmed);
+                LOGW(
+                    "Prompt exceeded context; kept BOS plus last %zu tokens and reserved %zu generation slots",
+                    keep_tail,
+                    generation_reserve);
+            }
+        }
+
+        const auto prompt_started = std::chrono::steady_clock::now();
+        decode_tokens(*native, prompt_tokens, true);
+        const auto prompt_finished = std::chrono::steady_clock::now();
+
+        llama_sampler * sampler = build_sampler(*native, params);
+        std::string generated;
+        int32_t predicted = 0;
+        bool stopped_eos = false;
+        bool stopped_limit = false;
+        bool stopped_word = false;
+
+        const auto predict_started = std::chrono::steady_clock::now();
+        while (predicted < n_predict && !native->interrupted.load()) {
+            if (n_ctx > 0 && native->n_past >= static_cast<int32_t>(n_ctx - 1)) {
+                stopped_limit = true;
+                break;
+            }
+            llama_token token = llama_sampler_sample(sampler, native->ctx, -1);
+            llama_sampler_accept(sampler, token);
+            if (llama_vocab_is_eog(native->vocab, token)) {
+                stopped_eos = true;
+                break;
+            }
+
+            std::string piece = token_to_piece(native->vocab, token, false);
+            generated += piece;
+            predicted += 1;
+
+            for (const auto & stop : stops) {
+                if (stop.empty()) continue;
+                const size_t found = generated.find(stop);
+                if (found != std::string::npos) {
+                    generated.erase(found);
+                    stopped_word = true;
+                    break;
+                }
+            }
+            if (stopped_word) break;
+
+            std::vector<llama_token> one{token};
+            decode_tokens(*native, one, true);
+        }
+        if (predicted >= n_predict) stopped_limit = true;
+        const auto predict_finished = std::chrono::steady_clock::now();
+        llama_sampler_free(sampler);
+
+        const double prompt_ms = std::chrono::duration<double, std::milli>(prompt_finished - prompt_started).count();
+        const double predicted_ms = std::chrono::duration<double, std::milli>(predict_finished - predict_started).count();
+
+        jobject result = new_hash_map(env);
+        map_put_string(env, result, "text", generated);
+        map_put_string(env, result, "content", generated);
+        map_put_string(env, result, "reasoning_content", "");
+        jobject tool_calls = new_array_list(env);
+        map_put(env, result, "tool_calls", tool_calls);
+        env->DeleteLocalRef(tool_calls);
+        map_put_int(env, result, "chat_format", 0);
+        map_put_int(env, result, "tokens_predicted", predicted);
+        map_put_int(env, result, "tokens_evaluated", static_cast<int>(prompt_tokens.size()));
+        map_put_bool(env, result, "truncated", false);
+        map_put_bool(env, result, "stopped_eos", stopped_eos);
+        map_put_bool(env, result, "stopped_limit", stopped_limit);
+        map_put_bool(env, result, "stopped_word", stopped_word);
+        map_put_string(env, result, "stopping_word", stopped_word && !stops.empty() ? stops.front() : "");
+        map_put_bool(env, result, "context_full", false);
+        map_put_bool(env, result, "interrupted", native->interrupted.load());
+        map_put_int(env, result, "tokens_cached", 0);
+        add_timing_map(env, result, static_cast<int>(prompt_tokens.size()), predicted, prompt_ms, predicted_ms);
+        LOGI("Generated %d token(s) for context %lld", predicted, static_cast<long long>(context_id));
+        return result;
+    } catch (const std::exception & e) {
+        LOGE("completionNative failed: %s", e.what());
+        throw_java_exception(env, "java/lang/RuntimeException", e.what());
+        return nullptr;
+    }
+}
