+jobject new_array_list(JNIEnv * env) {
+    jclass clazz = env->FindClass("java/util/ArrayList");
+    jmethodID ctor = env->GetMethodID(clazz, "<init>", "()V");
+    return env->NewObject(clazz, ctor);
+}
+
+void array_list_add(JNIEnv * env, jobject list, jobject value) {
+    jclass clazz = env->GetObjectClass(list);
+    jmethodID add = env->GetMethodID(clazz, "add", "(Ljava/lang/Object;)Z");
+    env->CallBooleanMethod(list, add, value);
+}
+
+std::string basename(const std::string & path) {
+    const auto slash = path.find_last_of('/');
+    return slash == std::string::npos ? path : path.substr(slash + 1);
+}
+
+bool is_valid_gguf(const std::string & path) {
+    std::ifstream file(path, std::ios::binary);
+    if (!file.good()) return false;
+    char magic[4] = {};
+    file.read(magic, sizeof(magic));
+    return file.gcount() == 4 && magic[0] == 'G' && magic[1] == 'G' && magic[2] == 'U' && magic[3] == 'F';
+}
+
+std::string resolve_model_path(const std::string & requested, const std::vector<std::string> & search_paths) {
+    std::vector<std::string> candidates;
+    if (!requested.empty()) candidates.push_back(requested);
+    const std::string name = basename(requested);
+    for (const auto & dir : search_paths) {
+        if (dir.empty()) continue;
+        candidates.push_back(dir + "/" + name);
+    }
+    if (!name.empty()) {
+        candidates.push_back("/data/data/app.eliza/files/.eliza/local-inference/models/" + name);
+        candidates.push_back("/storage/emulated/0/Android/data/app.eliza/files/.eliza/local-inference/models/" + name);
+        candidates.push_back("/storage/emulated/0/Download/" + name);
+    }
+    for (const auto & candidate : candidates) {
+        if (candidate.empty()) continue;
+        if (std::filesystem::exists(candidate) && is_valid_gguf(candidate)) return candidate;
+    }
+    std::ostringstream message;
+    message << "GGUF model not found or invalid";
+    if (!requested.empty()) message << ": " << requested;
+    throw std::runtime_error(message.str());
+}
+
+ggml_type parse_ggml_type(const std::string & value, ggml_type fallback) {
+    std::string normalized = value;
+    std::transform(normalized.begin(), normalized.end(), normalized.begin(), [](unsigned char ch) {
+        return static_cast<char>(std::tolower(ch));
+    });
+    std::replace(normalized.begin(), normalized.end(), '-', '_');
+    if (normalized == "f32") return GGML_TYPE_F32;
+    if (normalized == "f16") return GGML_TYPE_F16;
+    if (normalized == "q4_0") return GGML_TYPE_Q4_0;
+    if (normalized == "q4_1") return GGML_TYPE_Q4_1;
+    if (normalized == "q8_0") return GGML_TYPE_Q8_0;
+    if (normalized == "q8_1") return GGML_TYPE_Q8_1;
+    if (normalized == "q4_k") return GGML_TYPE_Q4_K;
+    if (normalized == "q8_k") return GGML_TYPE_Q8_K;
+    if (normalized == "iq4_nl") return GGML_TYPE_IQ4_NL;
+    if (normalized == "iq4_xs") return GGML_TYPE_IQ4_XS;
+    if (normalized == "tbq3_0") return GGML_TYPE_TBQ3_0;
+    if (normalized == "tbq4_0") return GGML_TYPE_TBQ4_0;
+    if (normalized == "tbq3_tcq") return GGML_TYPE_TBQ3_TCQ;
+    if (normalized == "tbq3_k") return GGML_TYPE_TBQ3_K;
+    if (normalized == "tbq4_k") return GGML_TYPE_TBQ4_K;
+    if (normalized == "qjl1_256") return GGML_TYPE_QJL1_256;
+    if (normalized == "q4_polar" || normalized == "polar_q4") return GGML_TYPE_Q4_POLAR;
+    return fallback;
+}
+
+std::vector<llama_token> tokenize_text(const llama_vocab * vocab, const std::string & text, bool add_special) {
+    int32_t count = llama_tokenize(vocab, text.c_str(), static_cast<int32_t>(text.size()), nullptr, 0, add_special, true);
+    if (count == INT32_MIN) throw std::runtime_error("Tokenization overflow");
+    if (count < 0) count = -count;
+    std::vector<llama_token> tokens(static_cast<size_t>(std::max(count, 0)));
+    if (tokens.empty()) return tokens;
+    const int32_t written = llama_tokenize(vocab, text.c_str(), static_cast<int32_t>(text.size()), tokens.data(), count, add_special, true);
+    if (written < 0) throw std::runtime_error("Tokenization failed");
+    tokens.resize(static_cast<size_t>(written));
+    return tokens;
+}
+
+std::string token_to_piece(const llama_vocab * vocab, llama_token token, bool special = false) {
+    char stack_buffer[256];
+    int32_t written = llama_token_to_piece(vocab, token, stack_buffer, sizeof(stack_buffer), 0, special);
+    if (written >= 0 && written <= static_cast<int32_t>(sizeof(stack_buffer))) {
+        return std::string(stack_buffer, static_cast<size_t>(written));
+    }
+    if (written < 0) written = -written;
+    std::vector<char> buffer(static_cast<size_t>(written) + 8);
+    written = llama_token_to_piece(vocab, token, buffer.data(), static_cast<int32_t>(buffer.size()), 0, special);
+    if (written < 0) return "";
+    return std::string(buffer.data(), static_cast<size_t>(written));
+}
+
+std::string detokenize_tokens(const llama_vocab * vocab, const std::vector<llama_token> & tokens) {
+    if (tokens.empty()) return "";
+    int32_t size = static_cast<int32_t>(tokens.size() * 16 + 64);
+    std::vector<char> buffer(static_cast<size_t>(size));
+    int32_t written = llama_detokenize(vocab, tokens.data(), static_cast<int32_t>(tokens.size()), buffer.data(), size, false, true);
+    if (written < 0) {
+        size = -written + 8;
+        buffer.assign(static_cast<size_t>(size), '\0');
+        written = llama_detokenize(vocab, tokens.data(), static_cast<int32_t>(tokens.size()), buffer.data(), size, false, true);
+    }
+    if (written < 0) throw std::runtime_error("Detokenization failed");
+    return std::string(buffer.data(), static_cast<size_t>(written));
+}
+
+void decode_tokens(NativeContext & native, const std::vector<llama_token> & tokens, bool output_last) {
+    if (tokens.empty()) return;
+    const int32_t chunk_size = std::max<int32_t>(1, native.n_batch);
+    size_t offset = 0;
+    while (offset < tokens.size()) {
+        const int32_t count = static_cast<int32_t>(std::min<size_t>(tokens.size() - offset, static_cast<size_t>(chunk_size)));
+        llama_batch batch = llama_batch_init(count, 0, 1);
+        batch.n_tokens = count;
+        for (int32_t i = 0; i < count; ++i) {
+            const bool is_last = offset + static_cast<size_t>(i) + 1 == tokens.size();
+            batch.token[i] = tokens[offset + static_cast<size_t>(i)];
+            batch.pos[i] = native.n_past + i;
+            batch.n_seq_id[i] = 1;
+            batch.seq_id[i][0] = 0;
+            batch.logits[i] = output_last && is_last ? 1 : 0;
+        }
+        const int rc = llama_decode(native.ctx, batch);
+        llama_batch_free(batch);
+        if (rc != 0) {
+            throw std::runtime_error("llama_decode failed with code " + std::to_string(rc));
+        }
+        native.n_past += count;
+        offset += static_cast<size_t>(count);
+    }
+}
+
+llama_sampler * build_sampler(const NativeContext & native, const json & params) {
+    auto chain_params = llama_sampler_chain_default_params();
+    llama_sampler * sampler = llama_sampler_chain_init(chain_params);
+
+    std::string grammar = json_string(params, "grammar", "");
+    const std::string schema = json_string(params, "json_schema", "");
+    if (grammar.empty() && !schema.empty()) {
+        auto parsed = json::parse(schema, nullptr, false);
+        if (!parsed.is_discarded()) {
+            grammar = json_schema_to_grammar(parsed, true);
+        }
+    }
+    if (!grammar.empty()) {
+        llama_sampler_chain_add(sampler, llama_sampler_init_grammar(native.vocab, grammar.c_str(), "root"));
+    }
+
+    const int32_t repeat_last_n = json_i32(params, "penalty_last_n", json_i32(params, "repeat_last_n", 64));
+    const float repeat_penalty = json_f32(params, "penalty_repeat", json_f32(params, "repeat_penalty", 1.0f));
+    const float frequency_penalty = json_f32(params, "frequency_penalty", 0.0f);
+    const float presence_penalty = json_f32(params, "presence_penalty", 0.0f);
+    if (repeat_penalty != 1.0f || frequency_penalty != 0.0f || presence_penalty != 0.0f) {
+        llama_sampler_chain_add(sampler, llama_sampler_init_penalties(repeat_last_n, repeat_penalty, frequency_penalty, presence_penalty));
+    }
+
+    const int32_t top_k = json_i32(params, "top_k", 40);
+    const float top_p = json_f32(params, "top_p", 0.95f);
+    const float min_p = json_f32(params, "min_p", 0.0f);
+    if (top_k > 0) llama_sampler_chain_add(sampler, llama_sampler_init_top_k(top_k));
+    if (top_p > 0.0f && top_p < 1.0f) llama_sampler_chain_add(sampler, llama_sampler_init_top_p(top_p, 1));
+    if (min_p > 0.0f) llama_sampler_chain_add(sampler, llama_sampler_init_min_p(min_p, 1));
+
+    const float temp = json_f32(params, "temperature", json_f32(params, "temp", 0.7f));
+    if (temp <= 0.0f) {
+        llama_sampler_chain_add(sampler, llama_sampler_init_greedy());
+    } else {
+        llama_sampler_chain_add(sampler, llama_sampler_init_temp(temp));
+        llama_sampler_chain_add(sampler, llama_sampler_init_dist(static_cast<uint32_t>(json_i32(params, "seed", LLAMA_DEFAULT_SEED))));
+    }
+    return sampler;
+}
+
+jobject empty_string_array_map(JNIEnv * env) {
+    jobject map = new_hash_map(env);
+    jobject list = new_array_list(env);
+    map_put(env, map, "items", list);
+    env->DeleteLocalRef(list);
+    return map;
+}
+
+void add_timing_map(JNIEnv * env, jobject result, int prompt_tokens, int predicted_tokens, double prompt_ms, double predicted_ms) {
+    jobject timings = new_hash_map(env);
+    map_put_int(env, timings, "prompt_n", prompt_tokens);
+    map_put_double(env, timings, "prompt_ms", prompt_ms);
+    map_put_double(env, timings, "prompt_per_second", prompt_ms > 0.0 ? prompt_tokens * 1000.0 / prompt_ms : 0.0);
+    map_put_int(env, timings, "predicted_n", predicted_tokens);
+    map_put_double(env, timings, "predicted_ms", predicted_ms);
+    map_put_double(env, timings, "predicted_per_second", predicted_ms > 0.0 ? predicted_tokens * 1000.0 / predicted_ms : 0.0);
+    map_put(env, result, "timings", timings);
+    env->DeleteLocalRef(timings);
+}
+
+std::string model_meta_value(llama_model * model, const char * key) {
+    int32_t required = llama_model_meta_val_str(model, key, nullptr, 0);
+    if (required <= 0) return "";
+    std::vector<char> buffer(static_cast<size_t>(required) + 1);
+    int32_t written = llama_model_meta_val_str(model, key, buffer.data(), buffer.size());
+    if (written < 0) return "";
+    return std::string(buffer.data(), static_cast<size_t>(written));
+}
