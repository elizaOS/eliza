+JNIEXPORT jobject JNICALL
+Java_ai_annadata_plugin_capacitor_LlamaCpp_getAvailableModelsNative(JNIEnv * env, jobject) {
+    jobject list = new_array_list(env);
+    const std::vector<std::string> dirs = {
+        "/data/data/app.eliza/files/.eliza/local-inference/models",
+        "/storage/emulated/0/Android/data/app.eliza/files/.eliza/local-inference/models",
+        "/storage/emulated/0/Download",
+    };
+    for (const auto & dir : dirs) {
+        if (!std::filesystem::exists(dir)) continue;
+        for (const auto & entry : std::filesystem::directory_iterator(dir)) {
+            if (!entry.is_regular_file() || entry.path().extension() != ".gguf") continue;
+            jobject info = new_hash_map(env);
+            map_put_string(env, info, "name", entry.path().filename().string());
+            map_put_string(env, info, "path", entry.path().string());
+            map_put_long(env, info, "size", static_cast<int64_t>(entry.file_size()));
+            array_list_add(env, list, info);
+            env->DeleteLocalRef(info);
+        }
+    }
+    return list;
+}
