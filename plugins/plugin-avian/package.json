{
  "name": "@elizaos/plugin-avian-root",
  "private": true,
  "version": "2.0.0-alpha.1",
  "description": "Avian AI model provider plugin for ElizaOS",
  "type": "module",
  "main": "typescript/dist/index.js",
  "types": "typescript/dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./typescript/dist/index.d.ts",
      "import": "./typescript/dist/index.js",
      "default": "./typescript/dist/index.js"
    }
  },
  "files": [
    "typescript/dist",
    "README.md"
  ],
  "keywords": [
    "elizaos",
    "plugin",
    "ai",
    "avian",
    "llm",
    "deepseek",
    "inference"
  ],
  "author": "Avian",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/elizaos/eliza.git",
    "directory": "plugins/plugin-avian"
  },
  "scripts": {
    "build": "bun run build:ts",
    "build:ts": "cd typescript && bun run build.ts",
    "dev": "cd typescript && bun --hot build.ts",
    "test": "bun run test:ts",
    "test:ts": "cd typescript && vitest run || echo 'TypeScript tests skipped - no tests found'",
    "typecheck": "tsc --noEmit -p typescript/tsconfig.json",
    "lint": "bunx @biomejs/biome check --write ./typescript",
    "lint:check": "bunx @biomejs/biome check ./typescript",
    "clean": "rm -rf typescript/dist .turbo node_modules"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@types/bun": "^1.3.5",
    "@types/node": "^25.0.3",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@elizaos/core": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  },
  "agentConfig": {
    "pluginType": "elizaos:plugin:1.0.0",
    "pluginParameters": {
      "AVIAN_API_KEY": {
        "type": "string",
        "description": "API key for Avian inference API. Get yours at https://avian.io",
        "required": true,
        "sensitive": true
      },
      "AVIAN_BASE_URL": {
        "type": "string",
        "description": "Custom base URL for the Avian API",
        "required": false,
        "default": "https://api.avian.io/v1"
      },
      "AVIAN_SMALL_MODEL": {
        "type": "string",
        "description": "Model to use for TEXT_SMALL requests",
        "required": false,
        "default": "deepseek/deepseek-v3.2"
      },
      "AVIAN_LARGE_MODEL": {
        "type": "string",
        "description": "Model to use for TEXT_LARGE requests",
        "required": false,
        "default": "moonshotai/kimi-k2.5"
      }
    }
  }
}
