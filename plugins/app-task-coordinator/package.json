{
  "name": "@elizaos/app-task-coordinator",
  "version": "2.0.0-beta.0",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./pty-status-dots": {
      "types": "./src/pty-status-dots.ts",
      "import": "./dist/pty-status-dots.js",
      "default": "./dist/pty-status-dots.js"
    },
    "./register-slots": {
      "types": "./src/register-slots.ts",
      "import": "./dist/register-slots.js",
      "default": "./dist/register-slots.js"
    },
    "./api/*": {
      "types": "./src/api/*.ts",
      "import": "./dist/api/*.js",
      "default": "./dist/api/*.js"
    },
    "./evals/*": {
      "types": "./src/evals/*.ts",
      "import": "./dist/evals/*.js",
      "default": "./dist/evals/*.js"
    },
    "./*": {
      "types": "./src/*",
      "import": "./dist/*.js",
      "default": "./dist/*.js"
    }
  },
  "dependencies": {
    "@elizaos/core": "workspace:*",
    "@elizaos/ui": "workspace:*",
    "lucide-react": "^1.0.0",
    "@xterm/xterm": "^6.0.0",
    "@xterm/addon-fit": "^0.11.0"
  },
  "elizaos": {
    "app": {
      "heroImage": "assets/hero.png"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "types": "./src/index.ts",
  "scripts": {
    "build": "bun run build:js && bun run build:types",
    "clean": "rm -rf dist",
    "build:js": "tsup --config ../tsup.plugin-packages.shared.ts",
    "build:types": "tsc -p ../tsconfig.build.shared.json"
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "tsup": "^8.5.1"
  }
}
