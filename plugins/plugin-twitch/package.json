{
  "name": "@elizaos/plugin-twitch",
  "version": "2.0.0-alpha.1",
  "description": "Twitch chat integration plugin for elizaOS agents",
  "type": "module",
  "main": "typescript/dist/index.js",
  "types": "typescript/dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./typescript/dist/index.js",
      "types": "./typescript/dist/index.d.ts"
    }
  },
  "files": [
    "typescript/dist",
    "python",
    "rust"
  ],
  "scripts": {
    "build": "cd typescript && bun run build",
    "test": "bun test",
    "lint": "biome lint .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@twurple/auth": "^7.2.0",
    "@twurple/chat": "^7.2.0",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@elizaos/core": "workspace:*"
  },
  "devDependencies": {
    "@elizaos/core": "workspace:*",
    "@types/bun": "^1.1.0",
    "typescript": "^5.3.0"
  },
  "keywords": [
    "elizaos",
    "plugin",
    "twitch",
    "chat",
    "streaming"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/elizaos-plugins/plugin-twitch.git"
  },
  "agentConfig": {
    "pluginType": "elizaos:plugin:1.0.0",
    "pluginParameters": {
      "TWITCH_USERNAME": {
        "type": "string",
        "description": "Twitch bot username (the account that will send messages)",
        "required": true,
        "sensitive": false
      },
      "TWITCH_CLIENT_ID": {
        "type": "string",
        "description": "Twitch application client ID from developer portal",
        "required": true,
        "sensitive": false
      },
      "TWITCH_ACCESS_TOKEN": {
        "type": "string",
        "description": "OAuth access token with chat:read and chat:edit scopes",
        "required": true,
        "sensitive": true
      },
      "TWITCH_CLIENT_SECRET": {
        "type": "string",
        "description": "Twitch application client secret (optional, for token refresh)",
        "required": false,
        "sensitive": true
      },
      "TWITCH_REFRESH_TOKEN": {
        "type": "string",
        "description": "OAuth refresh token (optional, for automatic token refresh)",
        "required": false,
        "sensitive": true
      },
      "TWITCH_CHANNEL": {
        "type": "string",
        "description": "Default Twitch channel name to join (without # prefix)",
        "required": true,
        "sensitive": false
      },
      "TWITCH_CHANNELS": {
        "type": "string",
        "description": "Comma-separated list of additional channels to join",
        "required": false,
        "sensitive": false
      },
      "TWITCH_REQUIRE_MENTION": {
        "type": "boolean",
        "description": "Only respond when the bot is @mentioned",
        "required": false,
        "sensitive": false
      },
      "TWITCH_ALLOWED_ROLES": {
        "type": "string",
        "description": "Comma-separated roles allowed to interact (moderator,vip,subscriber,all)",
        "required": false,
        "sensitive": false
      }
    }
  }
}
