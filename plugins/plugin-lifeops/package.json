{
  "name": "@elizaos/plugin-lifeops",
  "version": "2.0.0-beta.2",
  "type": "module",
  "description": "LifeOps app plugin: routines, goals, Google Workspace, Apple Calendar, Apple Reminders, Twilio, browser companion control, hosts-file blocking (self-control), and related agent surfaces.",
  "sideEffects": [
    "./src/widgets/index.ts",
    "./src/api/client-lifeops.ts",
    "./src/ui.ts",
    "./dist/widgets/index.js",
    "./dist/api/client-lifeops.js",
    "./dist/ui.js"
  ],
  "main": "./dist/index.js",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./plugin": {
      "types": "./dist/plugin.d.ts",
      "import": "./dist/plugin.js",
      "default": "./dist/plugin.js"
    },
    "./*.css": "./dist/*.css",
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "lint:default-packs": "node scripts/lint-default-packs.mjs",
    "verify": "bun run lint:default-packs && bun run build:types && bun run test",
    "pretest": "node scripts/lint-default-packs.mjs",
    "test": "vitest run --config vitest.config.ts",
    "test:app-state": "vitest run --config vitest.config.ts eliza/plugins/plugin-lifeops/test/lifeops-app-state.test.ts",
    "test:background-real": "vitest run --config vitest.background-real.config.ts test/scheduled-task-end-to-end.e2e.test.ts test/reminder-review-job.real.e2e.test.ts test/lifeops-scheduling.real.test.ts test/schedule-merged-state.real.test.ts",
    "test:integration": "cd ../../.. && vitest run --config eliza/packages/test/vitest/integration.config.ts eliza/plugins/plugin-lifeops/test/life-smoke.integration.test.ts",
    "test:scenarios": "cd ../../.. && bun run scenarios:lifeops",
    "bench:work-threads": "cd ../.. && bun plugins/plugin-lifeops/scripts/work-thread-benchmark.ts",
    "verify:live-schedule": "bun run ./scripts/verify-live-schedule-data.ts",
    "build": "bun run build:js && bun run build:views && bun run build:types",
    "clean": "rm -rf dist",
    "build:js": "bun run clean && tsup --config tsup.config.ts",
    "build:views": "vite build --config vite.config.views.ts",
    "build:types": "tsc --noCheck -p tsconfig.build.json"
  },
  "dependencies": {
    "@capacitor/core": "8.3.1",
    "@elizaos/agent": "workspace:*",
    "@elizaos/app-core": "workspace:*",
    "@elizaos/capacitor-calendar": "workspace:*",
    "@elizaos/capacitor-mobile-signals": "workspace:*",
    "@elizaos/core": "workspace:*",
    "@elizaos/native-activity-tracker": "workspace:*",
    "@elizaos/plugin-browser": "workspace:*",
    "@elizaos/plugin-calendly": "workspace:*",
    "@elizaos/plugin-discord": "workspace:*",
    "@elizaos/plugin-elizacloud": "workspace:*",
    "@elizaos/plugin-google": "workspace:*",
    "@elizaos/plugin-health": "workspace:*",
    "@elizaos/plugin-whatsapp": "workspace:*",
    "@elizaos/scenario-schema": "workspace:*",
    "@elizaos/shared": "workspace:*",
    "@elizaos/ui": "workspace:*",
    "drizzle-orm": "0.45.2",
    "lucide-react": "^1.0.0",
    "react-plaid-link": "^4.0.1",
    "sharp": "^0.34.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.4.0",
    "@types/jsdom": "^28.0.0",
    "bun-types": "1.3.14",
    "dotenv": "^17.2.3",
    "google-auth-library": "^10.0.0",
    "jsdom": "^29.0.0",
    "json5": "^2.2.3",
    "ts-morph": "28.0.0",
    "tsup": "^8.5.1",
    "vitest": "^4.0.17",
    "vite": "^8.0.0"
  },
  "peerDependencies": {
    "react": "*"
  },
  "agentConfig": {
    "pluginType": "elizaos:plugin:1.0.0",
    "pluginParameters": {}
  },
  "elizaos": {
    "app": {
      "heroImage": "assets/hero.png",
      "permissions": [
        "reminders",
        "calendar",
        "health",
        "screentime",
        "notes"
      ]
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ]
}
