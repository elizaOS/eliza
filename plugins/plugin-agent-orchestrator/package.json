{
  "name": "@elizaos/plugin-agent-orchestrator",
  "version": "0.2.0",
  "description": "Canonical ElizaOS plugin for spawning and orchestrating coding agents via the Agent Client Protocol (acpx) — combined with workspace lifecycle, GitHub integration, task share, runtime-driven sub-agent routing, and supporting services.",
  "type": "module",
  "main": "dist/node/index.node.js",
  "module": "dist/node/index.node.js",
  "types": "dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/elizaos/eliza.git",
    "directory": "plugins/plugin-agent-orchestrator"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "node": {
        "types": "./dist/node/index.d.ts",
        "import": "./dist/node/index.node.js",
        "default": "./dist/node/index.node.js"
      },
      "bun": {
        "types": "./dist/node/index.d.ts",
        "default": "./dist/node/index.node.js"
      },
      "require": "./dist/cjs/index.node.cjs",
      "default": "./dist/node/index.node.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "PROJECT.md",
    "LICENSE",
    "docs"
  ],
  "sideEffects": false,
  "keywords": [
    "elizaos",
    "plugin",
    "acpx",
    "agent-client-protocol",
    "coding-agent",
    "subagent",
    "task"
  ],
  "author": "@stwd / 0xSolace",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "@elizaos/core": "workspace:*",
    "git-workspace-service": "0.4.5",
    "pty-manager": "1.11.0"
  },
  "dependencies": {
    "@elizaos/agent": "workspace:*",
    "@elizaos/app-core": "workspace:*",
    "@elizaos/app-task-coordinator": "workspace:*",
    "coding-agent-adapters": "0.16.3",
    "drizzle-orm": "^0.45.1",
    "pty-console": "0.3.1",
    "pty-state-capture": "0.2.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@electric-sql/pglite": "^0.4.0",
    "@elizaos/core": "workspace:*",
    "@types/bun": "^1.3.9",
    "@types/node": "^25.2.3",
    "bun-types": "latest",
    "git-workspace-service": "0.4.5",
    "pty-manager": "1.11.0",
    "typescript": "^6.0.3",
    "vitest": "^4.0.0"
  },
  "scripts": {
    "postinstall": "node ./scripts/ensure-node-pty.mjs",
    "dev": "bun run build.ts --watch",
    "clean": "rm -rf dist .turbo node_modules .turbo-tsconfig.json tsconfig.tsbuildinfo tsconfig.build.tsbuildinfo",
    "format": "bunx @biomejs/biome format --write .",
    "format:check": "bunx @biomejs/biome format .",
    "lint": "bunx @biomejs/biome check --write --unsafe .",
    "lint:check": "bunx @biomejs/biome check . --no-errors-on-unmatched",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "bunx vitest run --config vitest.config.ts",
    "test:unit": "bunx vitest run --config vitest.config.ts --dir __tests__/unit",
    "test:integration": "bunx vitest run --config vitest.config.ts --dir tests/e2e --passWithNoTests",
    "test:watch": "bunx vitest --config vitest.config.ts",
    "build": "bun run build.ts",
    "build:ts": "bun run build.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "agentConfig": {
    "pluginType": "elizaos:plugin:1.0.0",
    "pluginParameters": {
      "ELIZA_ACP_CLI": {
        "type": "string",
        "description": "Path or command name for the acpx CLI used to spawn Agent Client Protocol subprocess sessions.",
        "required": false,
        "default": "acpx",
        "sensitive": false
      },
      "ACPX_DEFAULT_TIMEOUT_MS": {
        "type": "number",
        "description": "Default timeout in milliseconds for ACPX prompt/session subprocess calls when an action does not provide a timeout.",
        "required": false,
        "sensitive": false
      },
      "ACPX_APPROVE_ALL": {
        "type": "boolean",
        "description": "When true, defaults ACPX sessions to the approve-all approval preset unless an action overrides approvalPreset.",
        "required": false,
        "default": false,
        "sensitive": false
      },
      "ACPX_FORMAT": {
        "type": "string",
        "description": "Output format passed to acpx. The plugin expects typed JSON/NDJSON Agent Client Protocol events.",
        "required": false,
        "default": "json",
        "sensitive": false
      },
      "ACPX_NO_TERMINAL": {
        "type": "boolean",
        "description": "When true, passes --no-terminal so coding agents communicate through ACP events rather than PTY terminal UI.",
        "required": false,
        "default": true,
        "sensitive": false
      },
      "ACPX_DEFAULT_CWD": {
        "type": "string",
        "description": "Default working directory for ACPX sessions when an action does not provide workdir.",
        "required": false,
        "sensitive": false
      }
    }
  },
  "eliza": {
    "platforms": [
      "node"
    ],
    "runtime": "node",
    "platformDetails": {
      "node": "Node.js subprocess integration available via exports.node; browser export is a compatibility shim for package resolution."
    }
  }
}
