{
  "name": "@elizaos/plugin-cli",
  "version": "2.0.0-alpha.1",
  "description": "CLI framework plugin for elizaOS agents - provides command registration, execution, and utilities",
  "type": "module",
  "main": "./typescript/dist/index.js",
  "types": "./typescript/dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./typescript/dist/index.d.ts",
      "import": "./typescript/dist/index.js",
      "default": "./typescript/dist/index.js"
    }
  },
  "files": [
    "typescript/dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "cd typescript && tsc",
    "build:watch": "cd typescript && tsc --watch",
    "test": "vitest run --passWithNoTests",
    "lint": "biome check --write --unsafe typescript/src/"
  },
  "dependencies": {
    "@elizaos/core": "workspace:*",
    "commander": "^12.1.0"
  },
  "peerDependencies": {
    "@elizaos/core": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "agentConfig": {
    "pluginType": "elizaos:plugin:1.0.0",
    "pluginParameters": {
      "CLI_NAME": {
        "type": "string",
        "description": "CLI command name",
        "required": false,
        "sensitive": false
      },
      "CLI_VERSION": {
        "type": "string",
        "description": "CLI version string",
        "required": false,
        "sensitive": false
      }
    }
  },
  "keywords": [
    "elizaos",
    "plugin",
    "cli",
    "command-line",
    "terminal"
  ],
  "license": "MIT"
}
