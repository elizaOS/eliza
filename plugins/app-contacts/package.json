{
  "name": "@elizaos/app-contacts",
  "version": "2.0.0-beta.0",
  "type": "module",
  "description": "Android Contacts overlay app — wraps the @elizaos/capacitor-contacts native plugin.",
  "main": "./dist/index.js",
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "biome check src/",
    "test": "bunx vitest run --config ./vitest.config.ts",
    "build": "tsup --config ../tsup.plugin-packages.shared.ts",
    "clean": "rm -rf dist"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./ui": {
      "types": "./src/ui.ts",
      "import": "./dist/ui.js",
      "default": "./dist/ui.js"
    },
    "./plugin": {
      "types": "./src/plugin.ts",
      "import": "./dist/plugin.js",
      "default": "./dist/plugin.js"
    },
    "./register": {
      "types": "./src/register.ts",
      "import": "./dist/register.js",
      "default": "./dist/register.js"
    }
  },
  "dependencies": {
    "@elizaos/app-core": "workspace:*",
    "@elizaos/capacitor-contacts": "workspace:*",
    "@elizaos/core": "workspace:*",
    "@elizaos/shared": "workspace:*",
    "@elizaos/ui": "workspace:*",
    "lucide-react": "^1.0.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "elizaos": {
    "app": {
      "displayName": "Contacts",
      "category": "system",
      "androidOnly": true,
      "heroImage": "assets/hero.png"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "types": "./src/index.ts",
  "files": [
    "dist"
  ],
  "devDependencies": {
    "tsup": "^8.5.1"
  }
}
