{
  "name": "@elizaos/app-contacts",
  "version": "0.0.0",
  "type": "module",
  "description": "Android Contacts overlay app — wraps the @elizaos/capacitor-contacts native plugin.",
  "main": "./src/index.ts",
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "biome check src/",
    "test": "bunx vitest run --config ./vitest.config.ts"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": "./src/index.ts",
    "./ui": "./src/ui.ts",
    "./plugin": "./src/plugin.ts",
    "./register": "./src/register.ts"
  },
  "dependencies": {
    "@elizaos/app-core": "workspace:*",
    "@elizaos/capacitor-contacts": "workspace:*",
    "@elizaos/core": "workspace:*",
    "@elizaos/shared": "workspace:*",
    "@elizaos/ui": "workspace:*",
    "lucide-react": "^1.0.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "elizaos": {
    "app": {
      "displayName": "Contacts",
      "category": "system",
      "androidOnly": true,
      "heroImage": "assets/hero.png"
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
