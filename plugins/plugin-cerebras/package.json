{
  "name": "@elizaos/plugin-cerebras",
  "version": "2.0.0-beta.0",
  "type": "module",
  "main": "dist/node/index.node.js",
  "module": "dist/node/index.node.js",
  "types": "dist/node/index.d.ts",
  "browser": "dist/browser/index.browser.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/elizaos-plugins/plugin-cerebras.git"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/node/index.d.ts",
      "browser": {
        "types": "./dist/browser/index.d.ts",
        "import": "./dist/browser/index.browser.js",
        "default": "./dist/browser/index.browser.js"
      },
      "node": {
        "types": "./dist/node/index.d.ts",
        "import": "./dist/node/index.node.js",
        "default": "./dist/node/index.node.js"
      },
      "default": "./dist/node/index.node.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "dependencies": {
    "@elizaos/core": "workspace:*"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@types/bun": "^1.3.10",
    "@types/node": "^25.0.3",
    "typescript": "^6.0.0",
    "vitest": "^4.1.4"
  },
  "scripts": {
    "dev": "bun run build.ts --watch",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "clean": "rm -rf dist node_modules",
    "format": "bunx @biomejs/biome format --write .",
    "format:check": "bunx @biomejs/biome format .",
    "lint": "bunx @biomejs/biome check --write --unsafe .",
    "lint:check": "bunx @biomejs/biome check .",
    "test": "vitest run --config vitest.config.ts",
    "build": "bun run build.ts",
    "build:ts": "bun run build.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "agentConfig": {
    "pluginType": "elizaos:plugin:1.0.0",
    "pluginParameters": {
      "CEREBRAS_API_KEY": {
        "type": "string",
        "description": "Cerebras API key.",
        "required": true,
        "sensitive": true
      },
      "CEREBRAS_BASE_URL": {
        "type": "string",
        "description": "Cerebras OpenAI-compatible API base URL.",
        "required": false,
        "default": "https://api.cerebras.ai/v1",
        "sensitive": false
      },
      "CEREBRAS_SMALL_MODEL": {
        "type": "string",
        "description": "Small Cerebras chat model.",
        "required": false,
        "default": "gpt-oss-120b",
        "sensitive": false
      },
      "CEREBRAS_LARGE_MODEL": {
        "type": "string",
        "description": "Large Cerebras chat model.",
        "required": false,
        "default": "gpt-oss-120b",
        "sensitive": false
      },
      "CEREBRAS_PROMPT_CACHE_KEY": {
        "type": "string",
        "description": "Optional default prompt_cache_key forwarded to Cerebras chat completions.",
        "required": false,
        "sensitive": false
      }
    }
  },
  "eliza": {
    "platforms": [
      "browser",
      "node"
    ],
    "runtime": "both",
    "platformDetails": {
      "browser": "Browser-compatible build available via exports.browser; use a proxy unless CEREBRAS_ALLOW_BROWSER_API_KEY=true.",
      "node": "Node.js build available via exports.node"
    }
  }
}
