{
  "name": "@elizaos/plugin-secrets-manager",
  "version": "1.0.0",
  "description": "Multi-level secret management plugin for elizaOS with encryption and dynamic plugin activation",
  "main": "dist/index.js",
  "type": "module",
  "types": "dist/index.d.ts",
  "keywords": [
    "elizaos",
    "plugin",
    "secrets",
    "encryption",
    "api-keys",
    "credentials",
    "security"
  ],
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "dependencies": {
    "@elizaos/core": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "tsup": "8.4.0",
    "typescript": "5.8.2",
    "uuid": "^11.0.3",
    "vitest": "3.1.4"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "lint": "prettier --write ./src",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "publishConfig": {
    "access": "public"
  },
  "agentConfig": {
    "pluginType": "elizaos:plugin:1.0.0",
    "pluginParameters": {
      "ENCRYPTION_SALT": {
        "type": "string",
        "description": "Custom salt for encryption key derivation (optional)",
        "required": false
      },
      "ENABLE_ENCRYPTION": {
        "type": "boolean",
        "description": "Enable encryption for stored secrets (default: true)",
        "required": false,
        "example": "true"
      },
      "ENABLE_ACCESS_LOGGING": {
        "type": "boolean",
        "description": "Enable access logging for audit (default: true)",
        "required": false,
        "example": "true"
      }
    }
  },
  "milaidy": {
    "platforms": [
      "node"
    ],
    "runtime": "node",
    "platformDetails": {
      "node": "ESM build available via exports.import"
    }
  }
}
