{
    "name": "@elizaos/plugin-whatsapp",
    "version": "2.0.0-alpha.1",
    "description": "WhatsApp Cloud API plugin",
    "type": "module",
    "main": "dist/index.js",
    "module": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        "./package.json": "./package.json",
        ".": {
            "import": {
                "@elizaos/source": "./src/index.ts",
                "types": "./dist/index.d.ts",
                "default": "./dist/index.js"
            }
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "npm run build:ts && npm run build:py && npm run build:rs",
        "build:ts": "tsup --format esm --dts",
        "build:py": "test -n \"$SKIP_PYTHON_BUILD\" && echo 'Python build skipped (SKIP_PYTHON_BUILD set)' || (cd python && pip install -e .)",
        "build:rs": "test -d rust && cd rust && cargo build --release || echo 'Rust build skipped - no rust directory'",
        "dev": "tsup --format esm --dts --watch",
        "test": "npm run test:ts && npm run test:py && npm run test:rs",
        "test:ts": "vitest run",
        "test:py": "cd python && pytest",
        "test:rs": "cd rust && cargo test",
        "coverage": "vitest run --coverage",
        "lint": "npm run lint:ts && npm run lint:py && npm run lint:rs",
        "lint:ts": "biome check --apply-unsafe src/",
        "lint:py": "cd python && ruff check --fix --unsafe-fixes .",
        "lint:rs": "cd rust && cargo clippy",
        "lint:fix": "biome check --apply src/",
        "format": "biome format src/",
        "format:fix": "biome format --write src/"
    },
    "dependencies": {
        "axios": "1.7.8"
    },
    "devDependencies": {
        "@biomejs/biome": "1.5.3",
        "@types/node": "20.17.9",
        "@typescript-eslint/eslint-plugin": "8.16.0",
        "@typescript-eslint/parser": "8.16.0",
        "typescript": "5.6.3",
        "vitest": "^3.0.0"
    },
    "publishConfig": {
        "access": "public"
    },
    "agentConfig": {
        "pluginType": "elizaos:client:1.0.0",
        "pluginParameters": {
            "WHATSAPP_ACCESS_TOKEN": {
                "type": "string",
                "minLength": 1,
                "description": "WhatsApp Cloud API access token",
                "optional": false
            },
            "WHATSAPP_PHONE_NUMBER_ID": {
                "type": "string",
                "minLength": 1,
                "description": "WhatsApp business phone number ID",
                "optional": false
            },
            "WHATSAPP_WEBHOOK_TOKEN": {
                "type": "string",
                "minLength": 1,
                "description": "Webhook verification token",
                "optional": true
            },
            "WHATSAPP_BUSINESS_ID": {
                "type": "string",
                "minLength": 1,
                "description": "Business account ID",
                "optional": true
            }
        }
    },
    "gitHead": "05d4ca11d769db8c7f54a722ee24b2ce2b951543"
}
