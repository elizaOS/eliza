{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"esModuleInterop": true,
		"strict": false,
		"strictNullChecks": true,
		"skipLibCheck": true,
		"ignoreDeprecations": "6.0",
		"declaration": true,
		"declarationMap": true,
		"outDir": "./dist",
		"rootDir": "../../../",
		"lib": ["ES2022", "DOM"],
		"types": ["node", "bun"],
		"allowImportingTsExtensions": true,
		"rewriteRelativeImportExtensions": true,
		"paths": {
			"@elizaos/core": ["../../packages/core/src/index.node.ts"],
			"@elizaos/agent": ["../../packages/agent/src/index.ts"],
			"@elizaos/agent/api": ["../../packages/agent/src/api/index.ts"],
			"@elizaos/agent/runtime": ["../../packages/agent/src/runtime/index.ts"]
		}
	},
	"include": ["src/**/*"],
	"exclude": [
		"node_modules",
		"dist",
		"src/**/__tests__/**",
		"src/**/*.test.ts",
		"src/**/*.test.tsx",
		"**/__tests__/**",
		"**/*.test.ts",
		"**/*.test.tsx",
		"**/*.e2e.test.ts"
	]
}
