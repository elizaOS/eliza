{
  "name": "@elizaos/app-2004scape",
  "version": "2.0.0-beta.1",
  "description": "2004scape game service — autonomous RS agent with SDK WebSocket layer",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./*.css": "./dist/*.css",
    "./*": {
      "import": "./dist/*.js",
      "default": "./dist/*.js",
      "types": "./dist/*.d.ts"
    }
  },
  "dependencies": {
    "@elizaos/agent": "2.0.0-beta.2",
    "@elizaos/app-core": "2.0.0-beta.3",
    "@elizaos/core": "2.0.0-beta.1",
    "@elizaos/shared": "2.0.0-beta.1",
    "@elizaos/ui": "2.0.0-beta.2"
  },
  "peerDependencies": {
    "@elizaos/core": "2.0.0-beta.1"
  },
  "elizaos": {
    "app": {
      "heroImage": "assets/hero.png",
      "launchType": "connect",
      "launchUrl": "/api/apps/2004scape/viewer",
      "uiExtension": {
        "detailPanelId": "2004scape-operator-dashboard"
      },
      "viewer": {
        "url": "/api/apps/2004scape/viewer",
        "embedParams": {
          "bot": "",
          "password": ""
        },
        "postMessageAuth": true,
        "sandbox": "allow-scripts allow-same-origin allow-popups allow-forms"
      },
      "session": {
        "mode": "spectate-and-steer",
        "features": [
          "commands",
          "telemetry",
          "pause",
          "resume",
          "suggestions"
        ]
      }
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "bun run build:js && bun run build:types",
    "clean": "rm -rf dist",
    "build:js": "tsup --config ../tsup.plugin-packages.shared.ts",
    "build:types": "tsc --noCheck -p tsconfig.build.json"
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "tsup": "^8.5.1"
  }
}
