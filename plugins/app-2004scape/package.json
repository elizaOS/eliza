{
  "name": "@elizaos/app-2004scape",
  "version": "2.0.0-beta.0",
  "description": "2004scape game service — autonomous RS agent with SDK WebSocket layer",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./routes": {
      "types": "./dist/routes.d.ts",
      "import": "./dist/routes.js",
      "default": "./dist/routes.js"
    },
    "./ui": {
      "types": "./dist/ui/index.d.ts",
      "import": "./dist/ui/index.js",
      "default": "./dist/ui/index.js"
    }
  },
  "dependencies": {
    "@elizaos/agent": "workspace:*",
    "@elizaos/app-core": "workspace:*",
    "@elizaos/core": "workspace:*",
    "@elizaos/shared": "workspace:*",
    "@elizaos/ui": "workspace:*"
  },
  "peerDependencies": {
    "@elizaos/core": "workspace:*"
  },
  "elizaos": {
    "app": {
      "heroImage": "assets/hero.png",
      "launchType": "connect",
      "launchUrl": "/api/apps/2004scape/viewer",
      "uiExtension": {
        "detailPanelId": "2004scape-operator-dashboard"
      },
      "viewer": {
        "url": "/api/apps/2004scape/viewer",
        "embedParams": {
          "bot": "",
          "password": ""
        },
        "postMessageAuth": true,
        "sandbox": "allow-scripts allow-same-origin allow-popups allow-forms"
      },
      "session": {
        "mode": "spectate-and-steer",
        "features": [
          "commands",
          "telemetry",
          "pause",
          "resume",
          "suggestions"
        ]
      }
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "bun run build:js && bun run build:types",
    "clean": "rm -rf dist",
    "build:js": "tsup --config ../tsup.plugin-packages.shared.ts",
    "build:types": "tsc -p ../tsconfig.build.shared.json"
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "tsup": "^8.5.1"
  }
}
