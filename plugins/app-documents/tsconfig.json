{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "paths": {
      "@elizaos/core": [
        "../../packages/core/src/index.node.ts"
      ],
      "@elizaos/agent": [
        "../../packages/agent/src/index.ts"
      ],
      "@elizaos/shared": [
        "../../packages/shared/src/index.ts"
      ]
    }
  },
  "include": [
    "src"
  ]
}
