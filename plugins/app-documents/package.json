{
  "name": "@elizaos/app-documents",
  "version": "2.0.0-beta.0",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./routes": {
      "types": "./src/routes.ts",
      "import": "./dist/routes.js",
      "default": "./dist/routes.js"
    },
    "./service-loader": {
      "types": "./src/service-loader.ts",
      "import": "./dist/service-loader.js",
      "default": "./dist/service-loader.js"
    },
    "./setup-routes": {
      "types": "./src/setup-routes.ts",
      "import": "./dist/setup-routes.js",
      "default": "./dist/setup-routes.js"
    },
    "./package.json": "./package.json"
  },
  "dependencies": {
    "@elizaos/agent": "workspace:*",
    "@elizaos/core": "workspace:*",
    "@elizaos/shared": "workspace:*"
  },
  "agentConfig": {
    "pluginType": "elizaos:plugin:1.0.0",
    "pluginParameters": {}
  },
  "elizaos": {
    "app": {
      "heroImage": "assets/hero.png"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsup --config ../tsup.plugin-packages.shared.ts",
    "clean": "rm -rf dist"
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "tsup": "^8.5.1"
  }
}
