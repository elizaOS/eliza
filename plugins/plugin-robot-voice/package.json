{
  "name": "@elizaos/plugin-robot-voice",
  "version": "2.0.0-alpha.536",
  "description": "Retro 1980s SAM Text-to-Speech plugin for ElizaOS agents",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "browser": "dist/index.js",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "browser": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "node": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "tsc --watch",
    "test": "vitest run src/__tests__/types.test.ts --config vitest.config.ts",
    "lint": "bunx @biomejs/biome check --write --unsafe .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "lint:check": "bun run lint",
    "build": "bun run build.ts",
    "build:ts": "bun run build.ts",
    "format": "bunx @biomejs/biome format --write .",
    "format:check": "bunx @biomejs/biome format ."
  },
  "keywords": [
    "elizaos",
    "plugin",
    "tts",
    "text-to-speech",
    "sam",
    "retro",
    "voice-synthesis",
    "1980s"
  ],
  "author": "ElizaOS Team",
  "license": "MIT",
  "dependencies": {
    "@elizaos/core": "workspace:*",
    "sam-js": "^0.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@types/bun": "^1.3.5",
    "@types/node": "^25.0.3",
    "bun": "^1.0.0",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@elizaos/core": "workspace:*"
  },
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ai16z/eliza.git",
    "directory": "plugins/plugin-robot-voice"
  },
  "publishConfig": {
    "access": "public"
  },
  "eliza": {
    "platforms": [
      "browser",
      "node"
    ],
    "runtime": "both",
    "platformDetails": {
      "browser": "Browser-compatible build available via exports.browser",
      "node": "Node.js build available via exports.node"
    }
  }
}
