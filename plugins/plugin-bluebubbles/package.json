{
  "name": "@elizaos/plugin-bluebubbles",
  "version": "2.0.0-alpha.1",
  "description": "BlueBubbles iMessage bridge plugin for elizaOS agents",
  "license": "MIT",
  "type": "module",
  "main": "./typescript/dist/index.js",
  "types": "./typescript/dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./typescript/dist/index.js",
      "types": "./typescript/dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "npm run build:ts && (npm run build:py || echo 'Python build skipped (e.g. externally-managed env)')",
    "build:ts": "cd typescript && npm run build",
    "build:py": "cd python && pip install -e .",
    "build:rs": "cd rust && cargo build --release",
    "test": "npm run test:ts && npm run test:py && npm run test:rs",
    "test:ts": "cd typescript && npm test",
    "test:py": "cd python && pytest",
    "test:rs": "cd rust && cargo test",
    "lint": "npm run lint:ts && npm run lint:py",
    "lint:ts": "cd typescript && npm run lint",
    "lint:py": "cd python && ruff check --fix --unsafe-fixes .",
    "lint:rs": "cd rust && cargo clippy"
  },
  "keywords": [
    "elizaos",
    "plugin",
    "bluebubbles",
    "imessage",
    "apple",
    "macos",
    "messaging"
  ],
  "peerDependencies": {
    "@elizaos/core": "workspace:*"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "agentConfig": {
    "pluginType": "elizaos:plugin:bluebubbles:1.0.0",
    "pluginParameters": {
      "BLUEBUBBLES_SERVER_URL": {
        "type": "string",
        "description": "BlueBubbles server URL (e.g., http://192.168.1.100:1234)",
        "required": true
      },
      "BLUEBUBBLES_PASSWORD": {
        "type": "string",
        "description": "BlueBubbles server password",
        "required": true,
        "encrypted": true
      },
      "BLUEBUBBLES_WEBHOOK_PATH": {
        "type": "string",
        "description": "Webhook endpoint path for receiving messages",
        "default": "/webhooks/bluebubbles"
      },
      "BLUEBUBBLES_DM_POLICY": {
        "type": "string",
        "description": "DM policy: open, pairing, allowlist, disabled",
        "default": "pairing",
        "enum": [
          "open",
          "pairing",
          "allowlist",
          "disabled"
        ]
      },
      "BLUEBUBBLES_GROUP_POLICY": {
        "type": "string",
        "description": "Group message policy: open, allowlist, disabled",
        "default": "allowlist",
        "enum": [
          "open",
          "allowlist",
          "disabled"
        ]
      },
      "BLUEBUBBLES_ALLOW_FROM": {
        "type": "string",
        "description": "Comma-separated handles/phone numbers for allowlist"
      },
      "BLUEBUBBLES_SEND_READ_RECEIPTS": {
        "type": "boolean",
        "description": "Send read receipts for incoming messages",
        "default": true
      },
      "BLUEBUBBLES_ENABLED": {
        "type": "boolean",
        "description": "Enable or disable the BlueBubbles plugin",
        "default": true
      }
    }
  }
}
