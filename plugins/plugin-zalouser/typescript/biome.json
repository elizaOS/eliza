{
  "$schema": "https://biomejs.dev/schemas/2.3.14/schema.json",
  "root": false,
  "extends": ["../../../biome.json"],
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noControlCharactersInRegex": "off"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  }
}
