{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "composite": false,
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"],
    "typeRoots": [
      "./node_modules/@types",
      "../../node_modules/@types",
      "../../../node_modules/@types",
      "../../../node_modules/.bun/node_modules/@types",
      "../../../node_modules",
      "../../../node_modules/.bun/node_modules",
      "../../packages/ui/node_modules/@types"
    ],
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "paths": {
      "drizzle-orm": ["../plugin-sql/node_modules/drizzle-orm"],
      "drizzle-orm/*": ["../plugin-sql/node_modules/drizzle-orm/*"],
      "@elizaos/plugin-lifeops": ["../plugin-lifeops/src/index.ts"],
      "@elizaos/plugin-steward-app": ["../plugin-steward-app/src/index.ts"],
      "@elizaos/plugin-wallet-ui": ["../plugin-wallet-ui/src/index.ts"],
      "@elizaos/app-core": ["../../packages/app-core/src/index.ts"],
      "@elizaos/ui": ["../../packages/ui/src/index.ts"],
      "@elizaos/ui/*": ["../../packages/ui/src/*"],
      "@elizaos/ui/api/client-types-cloud": [
        "../../packages/ui/src/api/client-types-cloud.ts"
      ],
      "@elizaos/plugin-companion": ["./src/index.ts"],
      "@elizaos/core": ["../../packages/core/src/index.ts"],
      "@elizaos/agent": ["../../packages/agent/src/index.ts"],
      "@elizaos/agent/services/app-session-gate": [
        "../../packages/agent/src/services/app-session-gate.d.ts"
      ],
      "@elizaos/shared": ["../../packages/shared/src/index.ts"],
      "@elizaos/capacitor-appblocker": [
        "../../plugins/plugin-native-appblocker/src/index.ts"
      ],
      "@elizaos/capacitor-contacts": [
        "../../plugins/plugin-native-contacts/src/index.ts"
      ],
      "@elizaos/capacitor-messages": [
        "../../plugins/plugin-native-messages/src/index.ts"
      ],
      "@elizaos/capacitor-mobile-signals": [
        "../../plugins/plugin-native-mobile-signals/src/index.ts"
      ],
      "@elizaos/capacitor-phone": [
        "../../plugins/plugin-native-phone/src/index.ts"
      ],
      "@elizaos/capacitor-system": [
        "../../plugins/plugin-native-system/src/index.ts"
      ],
      "@elizaos/plugin-browser": ["../plugin-browser/src/index.ts"],
      "react": ["../../packages/app-core/node_modules/@types/react/index.d.ts"],
      "react/jsx-runtime": [
        "../../packages/app-core/node_modules/@types/react/jsx-runtime.d.ts"
      ],
      "react/jsx-dev-runtime": [
        "../../packages/app-core/node_modules/@types/react/jsx-dev-runtime.d.ts"
      ],
      "react-dom": [
        "../../packages/app-core/node_modules/@types/react-dom/index.d.ts"
      ],
      "lucide-react": ["./node_modules/lucide-react"],
      "@elizaos/shared/*": ["../../packages/shared/src/*"],
      "three/webgpu": ["../../packages/ui/node_modules/@types/three/build/three.webgpu.d.ts"],
      "three/tsl": ["../../packages/ui/node_modules/@types/three/build/three.tsl.d.ts"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.d.ts",
    "../../packages/app-core/src/ambient-modules.d.ts"
  ],
  "exclude": ["src/**/*.stories.ts", "src/**/*.stories.tsx"]
}
