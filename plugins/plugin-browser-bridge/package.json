{
  "name": "@elizaos/plugin-browser-bridge",
  "version": "0.1.1",
  "type": "module",
  "description": "Agent Browser Bridge plugin: schema, contracts, routes, and packaging utilities for Chrome/Safari browser companions. Generic counterpart to LifeOps' workflow-bound browser sessions.",
  "main": "./src/index.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts",
    "./contracts": "./src/contracts.ts",
    "./packaging": "./src/packaging.ts",
    "./routes": "./src/routes.ts",
    "./service": "./src/service.ts",
    "./actions": "./src/actions.ts",
    "./plugin": "./src/plugin.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@elizaos/agent": "^2.0.0-alpha.537",
    "@elizaos/core": "^2.0.0-alpha.537",
    "@elizaos/shared": "^2.0.0-alpha.537",
    "drizzle-orm": "0.45.2"
  },
  "devDependencies": {
    "bun-types": "^1.3.12",
    "typescript": "^6.0.0"
  },
  "agentConfig": {
    "pluginType": "elizaos:plugin:1.0.0",
    "pluginParameters": {}
  },
  "publishConfig": {
    "access": "public"
  }
}
