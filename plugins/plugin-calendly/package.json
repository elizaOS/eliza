{
  "name": "@elizaos/plugin-calendly",
  "version": "2.0.3",
  "description": "Calendly integration plugin for elizaOS agents — event types, scheduled events, cancellations, and booking-link handoff via Calendly v2 API",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./*.css": "./dist/*.css",
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "default": "./dist/*.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --clean && tsc --declaration --emitDeclarationOnly --noEmit false",
    "test": "vitest run",
    "typecheck": "tsgo --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@elizaos/core": "workspace:*"
  },
  "peerDependencies": {
    "@elizaos/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "24.12.2",
    "tsup": "8.5.1",
    "typescript": "^6.0.3",
    "vitest": "4.1.7"
  },
  "publishConfig": {
    "access": "public"
  }
}
