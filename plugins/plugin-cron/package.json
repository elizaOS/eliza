{
  "name": "@elizaos/plugin-cron",
  "version": "2.0.0-alpha.1",
  "description": "Cron scheduling plugin for elizaOS agents - schedule recurring or one-time jobs that execute actions, run prompts, or trigger events",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsup src/index.ts src/otto/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts src/otto/index.ts --format esm --dts --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@elizaos/core": "workspace:*",
    "@elizaos/plugin-cli": "workspace:*",
    "croner": "9.0.0",
    "json5": "^2.2.3",
    "uuid": "11.0.5"
  },
  "devDependencies": {
    "@types/node": "22.10.9",
    "@types/uuid": "10.0.0",
    "tsup": "8.4.0",
    "typescript": "5.7.3",
    "vitest": "3.0.5"
  },
  "peerDependencies": {
    "@elizaos/core": "workspace:*"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./otto": {
      "import": "./dist/otto/index.js",
      "types": "./dist/otto/index.d.ts"
    }
  },
  "typesVersions": {
    "*": {
      "otto": [
        "./dist/otto/index.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  }
}
