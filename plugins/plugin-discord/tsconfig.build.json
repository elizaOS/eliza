{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"noEmit": false,
		"declaration": true,
		"declarationMap": true,
		"emitDeclarationOnly": true,
		"ignoreDeprecations": "6.0",
		"outDir": "dist",
		"baseUrl": ".",
		"types": ["node", "bun-types"]
	},
	"include": ["**/*.ts"],
	"exclude": [
		"**/__tests__/**",
		"**/*.test.ts",
		"**/*.spec.ts",
		"test/**",
		"build.ts"
	]
}
