{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"noEmit": false,
		"declaration": true,
		"declarationMap": true,
		"emitDeclarationOnly": true,
		"outDir": "dist",
		"rootDir": ".",
		"paths": {
			"@elizaos/plugin-browser": ["../plugin-browser/dist/index.d.ts"]
		},
		"types": ["node", "bun-types"]
	},
	"include": ["**/*.ts"],
	"exclude": [
		"**/__tests__/**",
		"**/*.test.ts",
		"**/*.spec.ts",
		"test/**",
		"dist",
		"node_modules",
		"build.ts"
	]
}
