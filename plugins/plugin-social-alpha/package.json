{
	"name": "@elizaos/plugin-social-alpha",
	"version": "2.0.0-alpha.8",
	"description": "Social Alpha Plugin — Tracks token recommendations (shills/FUD), builds trust scores based on P&L outcomes, and exposes a Social Alpha Provider with win rate, rank, and recommender analytics.",
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "bunx vite build",
		"dev": "vite",
		"test": "vitest run src/__tests__/balancedTrustScore.test.ts src/__tests__/historicalPriceService.test.ts src/__tests__/service.test.ts --passWithNoTests",
		"clean": "rm -rf dist .turbo node_modules",
		"lint": "echo \"Lint skipped for release\"",
		"lint:check": "bun run lint",
		"format": "echo \"Format skipped (source is gitignored vendor code)\"",
		"format:check": "echo \"Format check skipped (source is gitignored vendor code)\"",
		"typecheck": "echo \"Typecheck skipped for release\""
	},
	"dependencies": {
		"@elizaos/core": "workspace:*",
		"bignumber.js": "^9.3.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"dotenv": "^16.5.0",
		"fast-xml-parser": "^5.2.5",
		"p-limit": "^5.0.0",
		"tailwindcss-animate": "^1.0.7",
		"uuid": "^11.1.0",
		"zod": "^4.3.6"
	},
	"peerDependencies": {
		"@elizaos/core": "workspace:*"
	},
	"devDependencies": {
		"@cypress/react": "^8.0.0",
		"@tanstack/react-query": "^5.62.0",
		"@testing-library/cypress": "^10.0.0",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"@vitejs/plugin-react-swc": "^4.0.0",
		"autoprefixer": "^10.4.21",
		"cypress": "^13.7.0",
		"postcss": "^8.5.4",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"tailwindcss": "^3.4.0",
		"tsconfig-paths": "^4.2.0",
		"tsup": "8.5.0",
		"tsx": "4.19.4",
		"typescript": "^6.0.3",
		"vite": "^6.0.0",
		"lucide-react": "^0.468.0",
		"@radix-ui/react-slot": "^1.0.0",
		"@radix-ui/react-tabs": "^1.0.0",
		"tailwind-merge": "^3.4.0",
		"vitest": "^3.1.4",
		"@biomejs/biome": "^2.3.11"
	},
	"publishConfig": {
		"access": "public"
	},
	"keywords": [
		"plugin",
		"elizaos",
		"social-alpha",
		"trust-score",
		"shill-tracker"
	],
	"agentConfig": {
		"pluginParameters": {
			"BIRDEYE_API_KEY": {
				"type": "string",
				"description": "API key for Birdeye",
				"required": true,
				"sensitive": true
			},
			"DEXSCREENER_API_KEY": {
				"type": "string",
				"description": "API key for Dexscreener",
				"required": true,
				"sensitive": true
			},
			"JUPITER_API_KEY": {
				"type": "string",
				"description": "API key for Jupiter",
				"required": true,
				"sensitive": true
			},
			"HELIUS_API_KEY": {
				"type": "string",
				"description": "API key for Helius",
				"required": true,
				"sensitive": true
			},
			"COINGECKO_API_KEY": {
				"type": "string",
				"description": "API key for Coingecko",
				"required": true,
				"sensitive": true
			},
			"MORALIS_API_KEY": {
				"type": "string",
				"description": "API key for Moralis",
				"required": true,
				"sensitive": true
			}
		}
	}
}
