{
  "name": "@elizaos/plugin-browser",
  "version": "2.0.0-beta.0",
  "type": "module",
  "description": "Browser plugin: unified BROWSER action and MANAGE_BROWSER_BRIDGE management action. Owns the workspace browser (electrobun-embedded + jsdom fallback) and the Chrome/Safari companion bridge. Targets are registered with the BrowserService; the agent uses what is available.",
  "main": "./dist/index.js",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "import": "./dist/schema.js",
      "default": "./dist/schema.js"
    },
    "./contracts": {
      "types": "./dist/contracts.d.ts",
      "import": "./dist/contracts.js",
      "default": "./dist/contracts.js"
    },
    "./packaging": {
      "types": "./dist/packaging.d.ts",
      "import": "./dist/packaging.js",
      "default": "./dist/packaging.js"
    },
    "./routes": {
      "types": "./dist/routes.d.ts",
      "import": "./dist/routes.js",
      "default": "./dist/routes.js"
    },
    "./service": {
      "types": "./dist/service.d.ts",
      "import": "./dist/service.js",
      "default": "./dist/service.js"
    },
    "./actions/*": {
      "types": "./dist/actions/*.d.ts",
      "import": "./dist/actions/*.js",
      "default": "./dist/actions/*.js"
    },
    "./workspace": {
      "types": "./dist/workspace/index.d.ts",
      "import": "./dist/workspace/index.js",
      "default": "./dist/workspace/index.js"
    },
    "./workspace/*": {
      "types": "./dist/workspace/*.d.ts",
      "import": "./dist/workspace/*.js",
      "default": "./dist/workspace/*.js"
    },
    "./plugin": {
      "types": "./dist/plugin.d.ts",
      "import": "./dist/plugin.js",
      "default": "./dist/plugin.js"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build": "bun run build:js && bun run build:types",
    "clean": "rm -rf dist",
    "build:js": "tsup --config ../tsup.plugin-packages.shared.ts",
    "build:types": "tsc -p tsconfig.build.json"
  },
  "dependencies": {
    "@elizaos/core": "workspace:*",
    "@elizaos/shared": "workspace:*",
    "@elizaos/vault": "workspace:*",
    "drizzle-orm": "0.45.2"
  },
  "devDependencies": {
    "bun-types": "^1.3.12",
    "typescript": "^6.0.0",
    "tsup": "^8.5.1"
  },
  "agentConfig": {
    "pluginType": "elizaos:plugin:1.0.0",
    "pluginParameters": {}
  },
  "publishConfig": {
    "access": "public"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ]
}
