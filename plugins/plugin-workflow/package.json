{
  "name": "@elizaos/plugin-workflow",
  "version": "2.0.0-beta.0",
  "description": "ElizaOS plugin for generating and running p1p3s workflows in-process",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./plugin-routes": {
      "types": "./dist/plugin-routes.d.ts",
      "import": "./dist/plugin-routes.js",
      "default": "./dist/plugin-routes.js"
    },
    "./register-routes": {
      "types": "./dist/register-routes.d.ts",
      "import": "./dist/register-routes.js",
      "default": "./dist/register-routes.js"
    },
    "./routes/*": {
      "types": "./dist/routes/*.d.ts",
      "import": "./dist/routes/*.js",
      "default": "./dist/routes/*.js"
    },
    "./lib/*": {
      "types": "./dist/lib/*.d.ts",
      "import": "./dist/lib/*.js",
      "default": "./dist/lib/*.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:unit": "bun test __tests__/unit/",
    "test:e2e": "bun test __tests__/e2e/",
    "lint": "bunx @biomejs/biome check --write --unsafe .",
    "lint:check": "bunx @biomejs/biome check .",
    "format": "bunx @biomejs/biome format --write .",
    "format:check": "bunx @biomejs/biome format ."
  },
  "keywords": [
    "elizaos",
    "plugin",
    "p1p3s",
    "workflow",
    "automation",
    "ai"
  ],
  "author": "Eliza Cloud Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/elizaos-plugins/plugin-workflow.git"
  },
  "bugs": {
    "url": "https://github.com/elizaos-plugins/plugin-workflow/issues"
  },
  "homepage": "https://github.com/elizaos-plugins/plugin-workflow#readme",
  "peerDependencies": {
    "@elizaos/agent": "workspace:*",
    "@elizaos/app-core": "workspace:*",
    "@elizaos/core": "workspace:*",
    "@elizaos/p1p3s": "workspace:*"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@electric-sql/pglite": "^0.2.17",
    "@types/bun": "^1.3.8",
    "@types/node": "^25.1.0",
    "bun-types": "^1.3.8",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "agentConfig": {
    "pluginType": "elizaos:plugin:1.0.0",
    "pluginParameters": {}
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@elizaos/agent": "workspace:*",
    "@elizaos/app-core": "workspace:*",
    "@elizaos/core": "workspace:*",
    "@elizaos/p1p3s": "workspace:*",
    "drizzle-orm": "^0.45.1",
    "quickjs-emscripten": "0.32.0"
  }
}
