{
  "name": "@elizaos/app-training",
  "version": "2.0.0-beta.1",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./*.css": "./dist/*.css",
    "./*": {
      "import": "./dist/*.js",
      "default": "./dist/*.js",
      "types": "./dist/*.d.ts"
    }
  },
  "scripts": {
    "train": "bun run src/cli/train.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "bun run build:js && bun run build:types",
    "clean": "rm -rf dist",
    "build:js": "tsup --config ../tsup.plugin-packages.shared.ts",
    "build:types": "tsc --noCheck -p tsconfig.build.json"
  },
  "dependencies": {
    "@elizaos/agent": "2.0.0-beta.1",
    "@elizaos/core": "2.0.0-beta.1",
    "@elizaos/shared": "2.0.0-beta.1",
    "@elizaos/ui": "2.0.0-beta.1"
  },
  "peerDependencies": {
    "react": "*"
  },
  "agentConfig": {
    "pluginType": "elizaos:plugin:1.0.0",
    "pluginParameters": {}
  },
  "elizaos": {
    "app": {
      "heroImage": "assets/hero.png"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "devDependencies": {
    "dotenv": "^17.2.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.0.17"
  }
}
