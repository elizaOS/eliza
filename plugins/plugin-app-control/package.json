{
  "name": "@elizaos/plugin-app-control-root",
  "private": true,
  "version": "2.0.0-alpha.1",
  "type": "module",
  "description": "App control plugin for Milady agents — launch, close, and list running apps via the local dashboard API.",
  "main": "typescript/dist/index.js",
  "types": "typescript/dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": {
        "types": "./typescript/dist/index.d.ts",
        "default": "./typescript/dist/index.js"
      }
    }
  },
  "files": [
    "typescript/dist"
  ],
  "scripts": {
    "build": "cd typescript && bun run build",
    "dev": "cd typescript && bun run dev",
    "test": "cd typescript && bun run test",
    "lint": "cd typescript && bunx @biomejs/biome check --write --config-path ./biome.json .",
    "typecheck": "cd typescript && tsc --noEmit",
    "clean": "rm -rf typescript/dist .turbo node_modules"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "typescript": "^6.0.0",
    "@biomejs/biome": "^2.3.11"
  }
}
