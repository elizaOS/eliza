{
  "name": "@elizaos/plugin-signal-root",
  "version": "2.0.0-alpha",
  "description": "Signal messaging integration plugin for elizaOS agents",
  "type": "module",
  "main": "typescript/dist/index.js",
  "module": "typescript/dist/index.js",
  "types": "typescript/dist/index.d.ts",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/elizaos-plugins/plugin-signal.git"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": {
        "types": "./typescript/dist/index.d.ts",
        "default": "./typescript/dist/index.js"
      }
    }
  },
  "files": [
    "typescript/dist"
  ],
  "keywords": [
    "elizaos",
    "plugin",
    "signal",
    "messaging",
    "secure",
    "encrypted"
  ],
  "author": "elizaOS",
  "license": "MIT",
  "scripts": {
    "build": "bun run build:ts",
    "build:ts": "cd typescript && bun run build.ts",
    "dev": "cd typescript && bun run build.ts --watch",
    "clean": "rm -rf typescript/dist .turbo typescript/node_modules .turbo-tsconfig.json typescript/tsconfig.tsbuildinfo",
    "test": "cd typescript && vitest run --passWithNoTests",
    "typecheck": "cd typescript && tsc --noEmit -p tsconfig.json",
    "lint": "bunx @biomejs/biome check --apply typescript/",
    "lint:check": "bunx @biomejs/biome check typescript/",
    "format": "bunx @biomejs/biome format --write typescript/",
    "format:check": "bunx @biomejs/biome format typescript/"
  },
  "dependencies": {
    "@elizaos/core": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "typescript": "^5.9.3",
    "@biomejs/biome": "^2.3.11"
  },
  "peerDependencies": {
    "@elizaos/core": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  },
  "agentConfig": {
    "pluginType": "elizaos:plugin:1.0.0",
    "pluginParameters": {
      "SIGNAL_ACCOUNT_NUMBER": {
        "type": "string",
        "description": "Signal account phone number in E.164 format (e.g., +1234567890)",
        "required": true,
        "sensitive": false
      },
      "SIGNAL_HTTP_URL": {
        "type": "string",
        "description": "Signal CLI REST API URL (e.g., http://localhost:8080)",
        "required": false,
        "sensitive": false
      },
      "SIGNAL_CLI_PATH": {
        "type": "string",
        "description": "Path to signal-cli executable (alternative to HTTP API)",
        "required": false,
        "sensitive": false
      },
      "SIGNAL_SHOULD_IGNORE_GROUP_MESSAGES": {
        "type": "boolean",
        "description": "If true, the bot will only respond to direct messages",
        "required": false,
        "sensitive": false
      }
    }
  }
}
