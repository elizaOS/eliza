{
	"name": "@elizaos/plugin-local-inference",
	"version": "2.0.0-beta.2",
	"description": "Unified Eliza-1 local provider plus HTTP routes for local model catalog, downloads, hardware detection, and chat commands.",
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./*.css": "./dist/*.css",
		"./*": {
			"import": "./dist/*.js",
			"default": "./dist/*.js",
			"types": "./dist/*.d.ts"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup src/index.ts src/runtime/index.ts src/routes/index.ts src/services/index.ts --format esm --dts --clean",
		"dev": "tsup src/index.ts src/runtime/index.ts src/routes/index.ts src/services/index.ts --format esm --dts --watch",
		"test": "vitest run",
		"clean": "rm -rf dist .turbo node_modules",
		"lint": "bunx @biomejs/biome check --write --unsafe .",
		"lint:check": "bunx @biomejs/biome check .",
		"format": "bunx @biomejs/biome format --write .",
		"format:check": "bunx @biomejs/biome format .",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@elizaos/core": "workspace:*",
		"@elizaos/shared": "workspace:*",
		"@elizaos/plugin-capacitor-bridge": "workspace:*"
	},
	"optionalDependencies": {
		"node-llama-cpp": "3.18.1",
		"onnxruntime-node": "1.24.3",
		"@huggingface/transformers": "^4.0.0",
		"whisper-node": "^1.1.1"
	},
	"peerDependencies": {
		"@elizaos/core": "workspace:*",
		"@elizaos/shared": "workspace:*",
		"@elizaos/plugin-capacitor-bridge": "workspace:*"
	},
	"peerDependenciesMeta": {
		"node-llama-cpp": {
			"optional": true
		},
		"onnxruntime-node": {
			"optional": true
		},
		"@huggingface/transformers": {
			"optional": true
		},
		"whisper-node": {
			"optional": true
		}
	},
	"trustedDependencies": [
		"node-llama-cpp",
		"onnxruntime-node"
	],
	"devDependencies": {
		"@biomejs/biome": "^2.4.14",
		"@types/node": "24.12.2",
		"tsup": "8.5.1",
		"typescript": "^6.0.3",
		"vitest": "^4.1.4"
	},
	"publishConfig": {
		"access": "public"
	}
}
