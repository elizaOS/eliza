{
  "name": "@elizaos/app-elizamaker",
  "version": "2.0.0-beta.0",
  "type": "module",
  "description": "ElizaMaker: ERC-8041 NFT drop/mint/whitelist routes, Twitter-verified Merkle proofs, and OG code tracking.",
  "main": "./src/index.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": "./src/index.ts",
    "./plugin": "./src/plugin.ts",
    "./routes/drop-routes": "./src/drop-routes.ts",
    "./drop-service-registry": "./src/drop-service-registry.ts",
    "./drop-service": "./src/drop-service.ts",
    "./registry-service-registry": "./src/registry-service-registry.ts",
    "./init-registry-services": "./src/init-registry-services.ts",
    "./nft-verify": "./src/nft-verify.ts",
    "./twitter-verify": "./src/twitter-verify.ts",
    "./merkle-tree": "./src/merkle-tree.ts",
    "./og-tracker": "./src/og-tracker.ts"
  },
  "dependencies": {
    "@elizaos/core": "workspace:*",
    "ethers": "^6.15.0"
  },
  "peerDependencies": {
    "@elizaos/agent": "workspace:*"
  },
  "agentConfig": {
    "pluginType": "elizaos:plugin:1.0.0",
    "pluginParameters": {}
  },
  "elizaos": {
    "app": {
      "heroImage": "assets/hero.png"
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
