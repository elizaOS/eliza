{
  "name": "@elizaos/app-browser",
  "version": "2.0.0-beta.0",
  "type": "module",
  "description": "Eliza app-browser: desktop browser workspace control, Steward wallet actions, and (eventually) browser UI exported for the dashboard.",
  "main": "./dist/index.js",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./register-routes": {
      "types": "./src/register-routes.ts",
      "import": "./dist/register-routes.js",
      "default": "./dist/register-routes.js"
    },
    "./setup-routes": {
      "types": "./src/setup-routes.ts",
      "import": "./dist/setup-routes.js",
      "default": "./dist/setup-routes.js"
    },
    "./routes/browser-workspace-routes": {
      "types": "./src/routes/browser-workspace-routes.ts",
      "import": "./dist/routes/browser-workspace-routes.js",
      "default": "./dist/routes/browser-workspace-routes.js"
    }
  },
  "dependencies": {
    "@elizaos/agent": "workspace:*",
    "@elizaos/app-core": "workspace:*",
    "@elizaos/core": "workspace:*",
    "@elizaos/plugin-browser": "workspace:*"
  },
  "agentConfig": {
    "pluginType": "elizaos:plugin:1.0.0",
    "pluginParameters": {
      "ELIZA_BROWSER_WORKSPACE_URL": {
        "type": "string",
        "description": "Loopback bridge URL for the Eliza desktop browser workspace.",
        "required": false,
        "sensitive": false
      },
      "ELIZA_BROWSER_WORKSPACE_TOKEN": {
        "type": "string",
        "description": "Bearer token for the Eliza desktop browser workspace bridge.",
        "required": false,
        "sensitive": true
      },
      "STEWARD_API_URL": {
        "type": "string",
        "description": "Base URL for the Steward wallet API used by Eliza wallet actions.",
        "required": false,
        "sensitive": false
      },
      "STEWARD_AGENT_TOKEN": {
        "type": "string",
        "description": "Bearer token for Steward wallet signing requests.",
        "required": false,
        "sensitive": true
      },
      "STEWARD_API_KEY": {
        "type": "string",
        "description": "Fallback API key for Steward wallet requests when no agent token exists.",
        "required": false,
        "sensitive": true
      },
      "STEWARD_TENANT_ID": {
        "type": "string",
        "description": "Optional Steward tenant identifier for wallet requests.",
        "required": false,
        "sensitive": false
      },
      "ELIZA_STEWARD_AGENT_ID": {
        "type": "string",
        "description": "Optional Steward agent ID override for Eliza wallet requests.",
        "required": false,
        "sensitive": false
      }
    }
  },
  "elizaos": {
    "app": {
      "heroImage": "assets/hero.png"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "types": "./src/index.ts",
  "scripts": {
    "test": "vitest run --config vitest.config.ts",
    "build": "tsup --config ../tsup.plugin-packages.shared.ts",
    "clean": "rm -rf dist"
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "tsup": "^8.5.1",
    "vitest": "^4.0.17"
  }
}
