{
  "version": "1.0.0",
  "actions": [
    {
      "name": "TRANSFER",
      "description": "Transfer SOL or SPL tokens from the agent's Solana wallet to another address",
      "similes": [
        "SEND_SOL",
        "SEND_TOKEN",
        "SEND_TOKENS",
        "TRANSFER_SOL",
        "TRANSFER_TOKEN",
        "TRANSFER_TOKENS",
        "PAY"
      ],
      "parameters": ["subaction", "chain", "fromToken", "amount", "recipient", "mode", "dryRun"]
    },
    {
      "name": "SWAP",
      "description": "Perform a token swap from one token to another on Solana. Works with SOL and SPL tokens.",
      "similes": [
        "SWAP_SOL",
        "SWAP_SOLANA",
        "SWAP_TOKENS_SOLANA",
        "TOKEN_SWAP_SOLANA",
        "TRADE_TOKENS_SOLANA",
        "EXCHANGE_TOKENS_SOLANA"
      ],
      "parameters": [
        "subaction",
        "chain",
        "fromToken",
        "toToken",
        "amount",
        "slippageBps",
        "mode",
        "dryRun"
      ]
    }
  ]
}
