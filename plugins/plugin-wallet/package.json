{
  "name": "@elizaos/plugin-wallet",
  "version": "0.1.0",
  "description": "Unified non-custodial wallet for elizaOS agents — EVM + Solana chains, ERC-6551 token-bound accounts, on-chain spend policies, x402 micropayments, CCTP bridge, Li.Fi + Jupiter swap routing, multi-DEX LP management (Raydium / Orca / Meteora on Solana, Uniswap / PancakeSwap / Aerodrome on EVM), Hyperliquid perps, Polymarket, Aave / Morpho lending, Clanker token launches, and integrated market-data analytics (Birdeye, DexScreener, DeFi news, Steer + Kamino LP info).",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/eliza-ai/eliza/tree/main/eliza/plugins/plugin-wallet",
  "repository": {
    "type": "git",
    "url": "https://github.com/eliza-ai/eliza.git",
    "directory": "eliza/plugins/plugin-wallet"
  },
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    },
    "./sdk": {
      "import": {
        "types": "./dist/sdk/index.d.mts",
        "default": "./dist/sdk/index.mjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src",
    "SDK-LICENSE"
  ],
  "scripts": {
    "build": "tsdown --no-config src/index.ts --format esm --dts --clean -d dist && tsdown --no-config src/sdk/index.ts --format esm --dts --no-clean -d dist/sdk && mv dist/index-*.d.ts dist/index.d.ts 2>/dev/null || true && mv dist/sdk/index-*.d.ts dist/sdk/index.d.ts 2>/dev/null || true",
    "check": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "vitest run --config ./vitest.config.ts",
    "test:watch": "vitest --config ./vitest.config.ts",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@elizaos/core": "workspace:*",
    "form-data": "4.0.5",
    "whatwg-url": "^16.0.0"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@elizaos/cloud-routing": "workspace:*",
    "@kamino-finance/klend-sdk": "latest",
    "@kamino-finance/kliquidity-sdk": "^12.0.0",
    "@lifi/data-types": "^6.0.0",
    "@lifi/sdk": "^3.7.9",
    "@lifi/types": "^17.18.0",
    "@meteora-ag/dlmm": "^1.9.7",
    "@orca-so/whirlpools": "^7.0.0",
    "@orca-so/whirlpools-client": "^6.0.0",
    "@orca-so/whirlpools-sdk": "^0.20.0",
    "@pancakeswap/sdk": "^5.8.0",
    "@pancakeswap/v3-sdk": "^3.9.7",
    "@raydium-io/raydium-sdk": "^1.3.1-beta.58",
    "@solana/spl-token": "0.4.14",
    "@solana/spl-token-metadata": "^0.1.6",
    "@solana/web3.js": "^1.98.4",
    "@steerprotocol/sdk": "^3.0.0",
    "@uniswap/sdk-core": "^7.0.0",
    "@uniswap/smart-order-router": "^4.0.0",
    "@uniswap/v3-sdk": "^3.13.1",
    "axios": "^1.16.0",
    "bignumber.js": "^11.0.0",
    "bn.js": "^5.2.1",
    "bs58": "^6.0.0",
    "decimal.js": "^10.4.3",
    "fomo-sdk-solana": "^1.3.2",
    "node-cache": "^5.1.2",
    "pumpdotfun-sdk": "^1.4.2",
    "tweetnacl": "^1.0.3",
    "viem": "^2.48.8",
    "zod": "^4.4.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@elizaos/app-steward": "workspace:*",
    "@elizaos/core": "workspace:*",
    "@types/node": "^24.0.0",
    "tsdown": "^0.21.0",
    "typescript": "^6.0.0",
    "vitest": "^4.0.18"
  },
  "agentConfig": {
    "pluginType": "elizaos:plugin:1.0.0",
    "pluginParameters": {
      "ELIZA_WALLET_BACKEND": {
        "type": "string",
        "required": false,
        "description": "Wallet backend selection: 'local' | 'steward' | 'auto'. Default: auto (desktop=local, cloud/mobile=steward).",
        "default": "auto"
      },
      "EVM_PRIVATE_KEY": {
        "type": "string",
        "required": false,
        "sensitive": true,
        "description": "EVM private key (32-byte hex, 0x-prefixed). Local backend only. Hydrated from OS keychain when available."
      },
      "SOLANA_PRIVATE_KEY": {
        "type": "string",
        "required": false,
        "sensitive": true,
        "description": "Solana private key, base58-encoded. Local backend only. Hydrated from OS keychain when available."
      },
      "STEWARD_API_URL": {
        "type": "string",
        "required": false,
        "description": "Steward API base URL. Required when ELIZA_WALLET_BACKEND=steward."
      },
      "STEWARD_AGENT_ID": {
        "type": "string",
        "required": false,
        "description": "Steward agent identifier. Required when ELIZA_WALLET_BACKEND=steward."
      },
      "STEWARD_AGENT_TOKEN": {
        "type": "string",
        "required": false,
        "sensitive": true,
        "description": "Steward agent bearer token. Required when ELIZA_WALLET_BACKEND=steward."
      },
      "STEWARD_TENANT_ID": {
        "type": "string",
        "required": false,
        "description": "Steward tenant identifier (typically the user ID)."
      }
    }
  },
  "keywords": [
    "plugin",
    "elizaos",
    "wallet",
    "non-custodial",
    "evm",
    "solana",
    "erc-6551",
    "x402",
    "cctp",
    "lifi",
    "jupiter",
    "raydium",
    "orca",
    "meteora",
    "uniswap",
    "pancakeswap",
    "aerodrome",
    "kamino",
    "steer",
    "birdeye",
    "dexscreener",
    "hyperliquid",
    "polymarket",
    "aave",
    "morpho",
    "clanker",
    "lp-management",
    "trading",
    "automation"
  ],
  "packageType": "plugin"
}
