{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "composite": false,
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "types": [
      "node",
      "bun"
    ],
    "typeRoots": [
      "./node_modules/@types",
      "../../node_modules/@types",
      "../../../node_modules/@types",
      "../../../node_modules/.bun/node_modules/@types",
      "../../../node_modules",
      "../../../node_modules/.bun/node_modules"
    ],
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "paths": {
      "drizzle-orm": [
        "../plugin-sql/node_modules/drizzle-orm"
      ],
      "drizzle-orm/*": [
        "../plugin-sql/node_modules/drizzle-orm/*"
      ],
      "@elizaos/capacitor-phone": [
        "../../packages/native-plugins/phone/src/index.ts"
      ],
      "@elizaos/plugin-browser": [
        "../plugin-browser/src/index.ts"
      ],
      "@elizaos/app-core": ["../../packages/app-core/src/index.ts"],
      "@elizaos/app-core/*": ["../../packages/app-core/src/*"],
      "@elizaos/agent": ["../../packages/agent/src/index.ts"],
      "@elizaos/agent/*": ["../../packages/agent/src/*"],
      "@elizaos/core": ["../../packages/core/src/index.ts"],
      "@elizaos/core/*": ["../../packages/core/src/*"],
      "@elizaos/app-wallet": ["../../plugins/app-wallet/src/index.ts"],
      "@elizaos/app-wallet/*": ["../../plugins/app-wallet/src/*"],
      "@elizaos/ui": ["../../packages/ui/src/index.ts"],
      "@elizaos/ui/*": ["../../packages/ui/src/*"],
      "@elizaos/shared": ["../../packages/shared/src/index.ts"],
      "@elizaos/plugin-signal": ["../plugin-signal/src/index.ts"],
      "@elizaos/plugin-signal/*": ["../plugin-signal/src/*"],
      "react": [
        "../../packages/app-core/node_modules/@types/react/index.d.ts"
      ],
      "react/jsx-runtime": [
        "../../packages/app-core/node_modules/@types/react/jsx-runtime.d.ts"
      ],
      "react/jsx-dev-runtime": [
        "../../packages/app-core/node_modules/@types/react/jsx-dev-runtime.d.ts"
      ],
      "react-dom": [
        "../../packages/app-core/node_modules/@types/react-dom/index.d.ts"
      ],
      "lucide-react": [
        "../app-companion/node_modules/lucide-react"
      ]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.d.ts",
    "../../packages/agent/src/external-modules.d.ts",
    "../../packages/app-core/src/ambient-modules.d.ts"
  ],
  "exclude": [
    "src/**/*.stories.ts",
    "src/**/*.stories.tsx",
    "src/**/*.test.ts",
    "src/**/*.test.tsx"
  ]
}
