{
  "name": "@elizaos/app-phone",
  "version": "2.0.0-beta.0",
  "type": "module",
  "description": "Phone app for Eliza — Android dialer/call-log overlay (@elizaos/capacitor-phone) and the iOS Phone Companion (pairing, chat-mirror, remote-session).",
  "main": "./dist/index.js",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./ui": {
      "types": "./src/ui.ts",
      "import": "./dist/ui.js",
      "default": "./dist/ui.js"
    },
    "./plugin": {
      "types": "./src/plugin.ts",
      "import": "./dist/plugin.js",
      "default": "./dist/plugin.js"
    },
    "./register": {
      "types": "./src/register.ts",
      "import": "./dist/register.js",
      "default": "./dist/register.js"
    },
    "./register-companion-page": {
      "types": "./src/register-companion-page.ts",
      "import": "./dist/register-companion-page.js",
      "default": "./dist/register-companion-page.js"
    },
    "./companion": {
      "types": "./src/companion/index.ts",
      "import": "./dist/companion/index.js",
      "default": "./dist/companion/index.js"
    },
    "./companion/services": {
      "types": "./src/companion/services/index.ts",
      "import": "./dist/companion/services/index.js",
      "default": "./dist/companion/services/index.js"
    },
    "./actions/place-call": {
      "types": "./src/actions/place-call.ts",
      "import": "./dist/actions/place-call.js",
      "default": "./dist/actions/place-call.js"
    },
    "./providers/call-log": {
      "types": "./src/providers/call-log.ts",
      "import": "./dist/providers/call-log.js",
      "default": "./dist/providers/call-log.js"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "bunx @biomejs/biome check src",
    "test": "bunx vitest run --config ./vitest.config.ts",
    "build": "tsup --config ../tsup.plugin-packages.shared.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@capacitor/barcode-scanner": "^3.0.0",
    "@capacitor/core": "8.3.1",
    "@capacitor/haptics": "8.0.2",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/push-notifications": "^8.0.0",
    "@elizaos/app-core": "workspace:*",
    "@elizaos/capacitor-phone": "workspace:*",
    "@elizaos/core": "workspace:*",
    "@elizaos/shared": "workspace:*",
    "@elizaos/ui": "workspace:*",
    "@toon-format/toon": "2.1.0",
    "lucide-react": "^1.0.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "elizaos": {
    "app": {
      "displayName": "Phone",
      "category": "system",
      "androidOnly": true,
      "heroImage": "assets/hero.png"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "types": "./src/index.ts",
  "files": [
    "dist"
  ],
  "devDependencies": {
    "tsup": "^8.5.1"
  }
}
