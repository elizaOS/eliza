{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "composite": false,
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "types": [
      "bun-types",
      "node"
    ],
    "paths": {
      "drizzle-orm": [
        "../plugin-sql/node_modules/drizzle-orm"
      ],
      "drizzle-orm/*": [
        "../plugin-sql/node_modules/drizzle-orm/*"
      ],
      "@elizaos/core": [
        "../../packages/core/src/index.ts"
      ],
      "@elizaos/plugin-computeruse": [
        "../plugin-computeruse/src/index.ts"
      ],
      "@elizaos/app-core": [
        "../../packages/app-core/src/index.ts"
      ],
      "@elizaos/shared": [
        "../../packages/shared/src/index.ts"
      ],
      "@elizaos/ui": [
        "../../packages/ui/src/index.ts"
      ],
      "@elizaos/agent": [
        "../../packages/agent/src/index.ts"
      ]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.d.ts"
  ],
  "exclude": []
}
