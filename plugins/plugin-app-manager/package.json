{
  "name": "@elizaos/plugin-app-manager",
  "version": "2.0.0-beta.2",
  "type": "module",
  "description": "App lifecycle plugin: manages hosted-app launch / list / close, run state, and the /api/apps/* route surface. Extracted from @elizaos/agent (Phase 4G).",
  "main": "./dist/index.js",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "build": "bun run build:js && bun run build:types",
    "clean": "rm -rf dist",
    "build:js": "tsup --config ../tsup.plugin-packages.shared.ts",
    "build:types": "tsc --noCheck -p tsconfig.build.json"
  },
  "dependencies": {
    "@elizaos/agent": "workspace:*",
    "@elizaos/core": "workspace:*",
    "@elizaos/shared": "workspace:*"
  },
  "devDependencies": {
    "bun-types": "^1.3.12",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.0.17"
  },
  "publishConfig": {
    "access": "public"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ]
}
