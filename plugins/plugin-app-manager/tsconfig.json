{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "declaration": true,
    "declarationMap": true,
    "strict": true,
    "noImplicitAny": false,
    "strictNullChecks": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "ignoreDeprecations": "6.0",
    "forceConsistentCasingInFileNames": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "types": ["node"],
    "outDir": "./dist",
    "rootDir": "../..",
    "paths": {
      "@elizaos/core": ["../../packages/core/src/index.ts"],
      "@elizaos/shared": ["../../packages/shared/src/index.ts"],
      "@elizaos/plugin-registry": [
        "../../plugins/plugin-registry/src/index.ts"
      ],
      "@elizaos/plugin-app-manager": ["./src/index.ts"],
      "@elizaos/plugin-app-manager/*": ["./src/*"],
      "@elizaos/agent": ["../../packages/agent/src/index.ts"],
      "@elizaos/agent/config/*": ["../../packages/agent/src/config/*.ts"],
      "@elizaos/agent/utils/*": ["../../packages/agent/src/utils/*.ts"],
      "@elizaos/agent/services/*": ["../../packages/agent/src/services/*.ts"],
      "@elizaos/app-core": ["../../packages/app-core/src/index.ts"],
      "@elizaos/app-core/agent-bridge": ["../../packages/app-core/src/agent-bridge.ts"],
      "@elizaos/app-core/*": ["../../packages/app-core/src/*"],
      "@elizaos/plugin-capacitor-bridge": ["../../plugins/plugin-capacitor-bridge/src/index.ts"],
      "@elizaos/plugin-capacitor-bridge/*": ["../../plugins/plugin-capacitor-bridge/src/*"],
      "@elizaos/plugin-local-inference": ["../../plugins/plugin-local-inference/src/index.ts"],
      "@elizaos/plugin-local-inference/*": ["../../plugins/plugin-local-inference/src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "**/__tests__/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.e2e.test.ts"
  ]
}
