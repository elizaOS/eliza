{
  "name": "@elizaos/app-lifeops",
  "version": "2.0.0-beta.0",
  "type": "module",
  "description": "LifeOps app plugin: routines, goals, Google Workspace, Apple Reminders, Twilio, browser companion control, hosts-file blocking (self-control), and related agent surfaces.",
  "sideEffects": [
    "./src/widgets/index.ts",
    "./src/api/client-lifeops.ts",
    "./src/ui.ts",
    "./dist/widgets/index.js",
    "./dist/api/client-lifeops.js",
    "./dist/ui.js"
  ],
  "main": "./dist/index.js",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "default": "./dist/client.js"
    },
    "./platform": {
      "types": "./src/platform/index.ts",
      "import": "./dist/platform/index.js",
      "default": "./dist/platform/index.js"
    },
    "./components/*": {
      "types": "./src/components/*.tsx",
      "import": "./dist/components/*.js",
      "default": "./dist/components/*.js"
    },
    "./components/*/*": {
      "types": "./src/components/*/*.tsx",
      "import": "./dist/components/*/*.js",
      "default": "./dist/components/*/*.js"
    },
    "./components/*/*/*": {
      "types": "./src/components/*/*/*.tsx",
      "import": "./dist/components/*/*/*.js",
      "default": "./dist/components/*/*/*.js"
    },
    "./components/*/*/*/*": {
      "types": "./src/components/*/*/*/*.tsx",
      "import": "./dist/components/*/*/*/*.js",
      "default": "./dist/components/*/*/*/*.js"
    },
    "./inbox/types": {
      "types": "./dist/inbox/types.d.ts",
      "import": "./dist/inbox/types.js",
      "default": "./dist/inbox/types.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js",
      "default": "./dist/types/index.js"
    },
    "./types/app-blocker-settings-card": {
      "types": "./dist/types/app-blocker-settings-card.d.ts",
      "import": "./dist/types/app-blocker-settings-card.js",
      "default": "./dist/types/app-blocker-settings-card.js"
    },
    "./types/website-blocker-settings-card": {
      "types": "./dist/types/website-blocker-settings-card.d.ts",
      "import": "./dist/types/website-blocker-settings-card.js",
      "default": "./dist/types/website-blocker-settings-card.js"
    },
    "./ui": {
      "types": "./dist/ui.d.ts",
      "import": "./dist/ui.js",
      "default": "./dist/ui.js"
    },
    "./agent-lifeops": {
      "types": "./dist/agent-lifeops.d.ts",
      "import": "./dist/agent-lifeops.js",
      "default": "./dist/agent-lifeops.js"
    },
    "./plugin": {
      "types": "./dist/plugin.d.ts",
      "import": "./dist/plugin.js",
      "default": "./dist/plugin.js"
    },
    "./widgets": {
      "types": "./dist/widgets/index.d.ts",
      "import": "./dist/widgets/index.js",
      "default": "./dist/widgets/index.js"
    },
    "./selfcontrol": {
      "types": "./dist/website-blocker/public.d.ts",
      "import": "./dist/website-blocker/public.js",
      "default": "./dist/website-blocker/public.js"
    },
    "./selfcontrol/selfcontrol": {
      "types": "./dist/website-blocker/engine.d.ts",
      "import": "./dist/website-blocker/engine.js",
      "default": "./dist/website-blocker/engine.js"
    },
    "./website-blocker": {
      "types": "./dist/website-blocker/public.d.ts",
      "import": "./dist/website-blocker/public.js",
      "default": "./dist/website-blocker/public.js"
    },
    "./lifeops": {
      "types": "./dist/lifeops/index.d.ts",
      "import": "./dist/lifeops/index.js",
      "default": "./dist/lifeops/index.js"
    },
    "./lifeops/*": {
      "types": "./dist/lifeops/*.d.ts",
      "import": "./dist/lifeops/*.js",
      "default": "./dist/lifeops/*.js"
    },
    "./inbox/*": {
      "types": "./dist/inbox/*.d.ts",
      "import": "./dist/inbox/*.js",
      "default": "./dist/inbox/*.js"
    },
    "./actions/*": {
      "types": "./dist/actions/*.d.ts",
      "import": "./dist/actions/*.js",
      "default": "./dist/actions/*.js"
    },
    "./actions/*.js": {
      "types": "./dist/actions/*.d.ts",
      "import": "./dist/actions/*.js",
      "default": "./dist/actions/*.js"
    },
    "./api/client-lifeops": {
      "types": "./dist/api/client-lifeops.d.ts",
      "import": "./dist/api/client-lifeops.js",
      "default": "./dist/api/client-lifeops.js"
    },
    "./providers/*": {
      "types": "./dist/providers/*.d.ts",
      "import": "./dist/providers/*.js",
      "default": "./dist/providers/*.js"
    },
    "./routes/*": {
      "types": "./dist/routes/*.d.ts",
      "import": "./dist/routes/*.js",
      "default": "./dist/routes/*.js"
    },
    "./contracts": {
      "types": "./dist/contracts/index.d.ts",
      "import": "./dist/contracts/index.js",
      "default": "./dist/contracts/index.js"
    },
    "./contracts/lifeops": {
      "types": "./dist/contracts/lifeops.d.ts",
      "import": "./dist/contracts/lifeops.js",
      "default": "./dist/contracts/lifeops.js"
    },
    "./public": {
      "types": "./dist/public.d.ts",
      "import": "./dist/public.js",
      "default": "./dist/public.js"
    }
  },
  "scripts": {
    "test": "vitest run --config vitest.config.ts",
    "test:app-state": "vitest run --config vitest.config.ts eliza/plugins/app-lifeops/test/lifeops-app-state.test.ts",
    "test:integration": "cd ../../.. && vitest run --config eliza/test/vitest/integration.config.ts eliza/plugins/app-lifeops/test/life-smoke.integration.test.ts",
    "test:scenarios": "cd ../../.. && bun run scenarios:lifeops",
    "verify:live-schedule": "bun run ./scripts/verify-live-schedule-data.ts",
    "build": "bun run build:js && bun run build:types",
    "clean": "rm -rf dist",
    "build:js": "tsup --config ../tsup.plugin-packages.shared.ts",
    "build:types": "tsc -p tsconfig.build.json"
  },
  "dependencies": {
    "@capacitor/core": "8.3.1",
    "@elizaos/capacitor-appblocker": "workspace:*",
    "@elizaos/capacitor-mobile-signals": "workspace:*",
    "@elizaos/agent": "workspace:*",
    "@elizaos/core": "workspace:*",
    "@elizaos/native-activity-tracker": "workspace:*",
    "@elizaos/plugin-browser": "workspace:*",
    "@elizaos/plugin-calendly": "workspace:*",
    "@elizaos/plugin-discord": "workspace:*",
    "@elizaos/plugin-elizacloud": "workspace:*",
    "@elizaos/plugin-google": "workspace:*",
    "@elizaos/plugin-imessage": "workspace:*",
    "@elizaos/plugin-signal": "workspace:*",
    "@elizaos/plugin-telegram": "workspace:*",
    "@elizaos/plugin-whatsapp": "workspace:*",
    "@elizaos/plugin-x": "workspace:*",
    "@elizaos/scenario-schema": "workspace:*",
    "@elizaos/shared": "workspace:*",
    "@elizaos/ui": "workspace:*",
    "drizzle-orm": "0.45.2",
    "lucide-react": "^1.0.0",
    "react-plaid-link": "^4.0.1",
    "sharp": "^0.34.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.4.0",
    "@elizaos/scenario-schema": "workspace:*",
    "@types/jsdom": "^28.0.0",
    "jsdom": "^29.0.0",
    "tsup": "^8.5.1"
  },
  "peerDependencies": {
    "react": "*"
  },
  "agentConfig": {
    "pluginType": "elizaos:plugin:1.0.0",
    "pluginParameters": {}
  },
  "elizaos": {
    "app": {
      "heroImage": "assets/hero.png"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ]
}
