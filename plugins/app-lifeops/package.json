{
  "name": "@elizaos/app-lifeops",
  "version": "0.0.0",
  "type": "module",
  "description": "LifeOps app plugin: routines, goals, Google Workspace, Apple Reminders, Twilio, browser companion control, hosts-file blocking (self-control), and related agent surfaces.",
  "sideEffects": [
    "./src/widgets/index.ts",
    "./src/api/client-lifeops.ts"
  ],
  "main": "./src/index.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./inbox/types": "./src/inbox/types.ts",
    "./types": "./src/types/index.ts",
    "./types/app-blocker-settings-card": "./src/types/app-blocker-settings-card.ts",
    "./types/website-blocker-settings-card": "./src/types/website-blocker-settings-card.ts",
    "./ui": "./src/ui.ts",
    "./agent-lifeops": "./src/agent-lifeops.ts",
    "./plugin": "./src/plugin.ts",
    "./widgets": "./src/widgets/index.ts",
    "./selfcontrol": "./src/website-blocker/public.ts",
    "./selfcontrol/selfcontrol": "./src/website-blocker/engine.ts",
    "./website-blocker": "./src/website-blocker/public.ts",
    "./lifeops": "./src/lifeops/index.ts",
    "./lifeops/*": "./src/lifeops/*.ts",
    "./inbox/*": "./src/inbox/*.ts",
    "./actions/*": "./src/actions/*.ts",
    "./actions/*.js": "./src/actions/*.ts",
    "./api/client-lifeops": "./src/api/client-lifeops.ts",
    "./providers/*": "./src/providers/*.ts",
    "./routes/*": "./src/routes/*.ts",
    "./contracts": "./src/contracts/index.ts",
    "./contracts/lifeops": "./src/contracts/lifeops.ts",
    "./public": "./src/public.ts"
  },
  "scripts": {
    "test": "vitest run --config vitest.config.ts",
    "test:app-state": "vitest run --config vitest.config.ts eliza/plugins/app-lifeops/test/lifeops-app-state.test.ts",
    "test:integration": "cd ../../.. && vitest run --config eliza/test/vitest/integration.config.ts eliza/plugins/app-lifeops/test/life-smoke.integration.test.ts",
    "test:scenarios": "cd ../../.. && bun run scenarios:lifeops",
    "verify:live-schedule": "bun run ./scripts/verify-live-schedule-data.ts"
  },
  "dependencies": {
    "@capacitor/core": "8.3.1",
    "@elizaos/capacitor-appblocker": "workspace:*",
    "@elizaos/capacitor-mobile-signals": "workspace:*",
    "@elizaos/core": "workspace:*",
    "@elizaos/native-activity-tracker": "workspace:*",
    "@elizaos/plugin-browser-bridge": "workspace:*",
    "@elizaos/plugin-imessage": "workspace:*",
    "@elizaos/plugin-signal": "workspace:*",
    "@elizaos/plugin-telegram": "workspace:*",
    "@elizaos/plugin-whatsapp": "workspace:*",
    "@elizaos/scenario-schema": "workspace:*",
    "@elizaos/shared": "workspace:*",
    "@elizaos/ui": "workspace:*",
    "drizzle-orm": "0.45.2",
    "lucide-react": "^1.0.0",
    "react-plaid-link": "^4.0.1",
    "sharp": "^0.34.5",
    "telegram": "2.26.22"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.4.0",
    "@elizaos/scenario-schema": "workspace:*",
    "@types/jsdom": "^28.0.0",
    "jsdom": "^29.0.0"
  },
  "peerDependencies": {
    "@elizaos/agent": "workspace:*",
    "@elizaos/app-core": "workspace:*",
    "react": "*"
  },
  "agentConfig": {
    "pluginType": "elizaos:plugin:1.0.0",
    "pluginParameters": {}
  },
  "elizaos": {
    "app": {
      "heroImage": "assets/hero.png"
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
