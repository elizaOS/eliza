{
  "name": "@elizaos/app-workflow-builder",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "bunx @biomejs/biome check src",
    "test": "vitest run",
    "build": "tsup --config ../tsup.plugin-packages.shared.ts",
    "clean": "rm -rf dist"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./register": {
      "types": "./src/register.ts",
      "import": "./dist/register.js",
      "default": "./dist/register.js"
    }
  },
  "elizaos": {
    "app": {
      "displayName": "Workflow Builder",
      "category": "productivity",
      "heroImage": "assets/hero.png"
    }
  },
  "dependencies": {
    "@elizaos/app-core": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^6.0.0",
    "vitest": "^2.1.9",
    "tsup": "^8.5.1"
  },
  "types": "./src/index.ts",
  "files": [
    "dist"
  ]
}
