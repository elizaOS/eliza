{
  "name": "@elizaos/plugin-acp-root",
  "version": "2.0.0-alpha.1",
  "private": true,
  "description": "elizaOS ACP Plugin - Agent Client Protocol for IDE integration and gateway bridging",
  "type": "module",
  "main": "./typescript/dist/index.js",
  "module": "./typescript/dist/index.js",
  "types": "./typescript/dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./typescript/dist/index.d.ts",
      "import": "./typescript/dist/index.js",
      "default": "./typescript/dist/index.js"
    }
  },
  "files": [
    "typescript/dist",
    "typescript/src",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "ai",
    "agent",
    "acp",
    "agent-client-protocol",
    "ide-integration",
    "elizaos",
    "plugin"
  ],
  "author": "elizaOS Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/elizaos/eliza.git",
    "directory": "plugins/plugin-acp"
  },
  "scripts": {
    "build": "cd typescript && tsc",
    "dev": "cd typescript && tsc --watch",
    "test": "cd typescript && vitest run --passWithNoTests",
    "test:watch": "cd typescript && vitest",
    "lint": "biome check --apply --unsafe typescript/src/",
    "lint:fix": "biome check --apply typescript/src/",
    "typecheck": "cd typescript && tsc --noEmit",
    "clean": "rm -rf typescript/dist"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.14.0",
    "@elizaos/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "@elizaos/core": "workspace:*"
  },
  "agentConfig": {
    "pluginType": "elizaos:plugin:1.0.0",
    "pluginParameters": {
      "ACP_GATEWAY_URL": {
        "type": "string",
        "description": "Gateway WebSocket URL for ACP connections",
        "required": false,
        "default": "ws://127.0.0.1:18789"
      },
      "ACP_GATEWAY_TOKEN": {
        "type": "string",
        "description": "Gateway authentication token",
        "required": false
      },
      "ACP_GATEWAY_PASSWORD": {
        "type": "string",
        "description": "Gateway password for authentication",
        "required": false
      },
      "ACP_DEFAULT_SESSION_KEY": {
        "type": "string",
        "description": "Default session key to use",
        "required": false
      },
      "ACP_DEFAULT_SESSION_LABEL": {
        "type": "string",
        "description": "Default session label to resolve",
        "required": false
      },
      "ACP_VERBOSE": {
        "type": "boolean",
        "description": "Enable verbose logging",
        "required": false,
        "default": false
      }
    }
  }
}
