{
  "name": "@elizaos/plugin-line",
  "version": "2.0.0-alpha.1",
  "description": "LINE Messaging API plugin for elizaOS agents",
  "license": "MIT",
  "type": "module",
  "main": "./typescript/dist/index.js",
  "types": "./typescript/dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./typescript/dist/index.js",
      "types": "./typescript/dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "npm run build:ts && (npm run build:py || echo 'Python build skipped (e.g. externally-managed env)') && npm run build:rs",
    "build:ts": "cd typescript && npm run build",
    "build:py": "cd python && pip install -e .",
    "build:rs": "cd rust && cargo build --release",
    "test": "npm run test:ts && npm run test:py && npm run test:rs",
    "test:ts": "cd typescript && npm test",
    "test:py": "cd python && pytest",
    "test:rs": "cd rust && cargo test",
    "lint": "npm run lint:ts && npm run lint:py && npm run lint:rs",
    "lint:ts": "cd typescript && npm run lint",
    "lint:py": "cd python && ruff check --fix --unsafe-fixes .",
    "lint:rs": "cd rust && cargo clippy"
  },
  "keywords": [
    "elizaos",
    "plugin",
    "line",
    "messaging",
    "chat",
    "japan",
    "taiwan"
  ],
  "peerDependencies": {
    "@elizaos/core": "workspace:*"
  },
  "dependencies": {
    "@line/bot-sdk": "^10.5.0",
    "zod": "^4.3.6"
  },
  "agentConfig": {
    "pluginType": "elizaos:plugin:line:1.0.0",
    "pluginParameters": {
      "LINE_CHANNEL_ACCESS_TOKEN": {
        "type": "string",
        "description": "LINE channel access token from LINE Developers Console",
        "required": true,
        "encrypted": true
      },
      "LINE_CHANNEL_SECRET": {
        "type": "string",
        "description": "LINE channel secret for webhook signature verification",
        "required": true,
        "encrypted": true
      },
      "LINE_WEBHOOK_PATH": {
        "type": "string",
        "description": "Webhook endpoint path",
        "default": "/webhooks/line"
      },
      "LINE_DM_POLICY": {
        "type": "string",
        "description": "DM policy: open, pairing, allowlist, disabled",
        "default": "pairing",
        "enum": [
          "open",
          "pairing",
          "allowlist",
          "disabled"
        ]
      },
      "LINE_GROUP_POLICY": {
        "type": "string",
        "description": "Group message policy: open, allowlist, disabled",
        "default": "allowlist",
        "enum": [
          "open",
          "allowlist",
          "disabled"
        ]
      },
      "LINE_ALLOW_FROM": {
        "type": "string",
        "description": "Comma-separated user IDs for allowlist"
      },
      "LINE_ENABLED": {
        "type": "boolean",
        "description": "Enable or disable the LINE plugin",
        "default": true
      }
    }
  }
}
