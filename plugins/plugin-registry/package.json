{
  "name": "@elizaos/plugin-registry",
  "version": "2.0.0-beta.2",
  "description": "Plugin registry / discovery / install plugin: owns the plugin-management HTTP routes and the installer forwarder. Extracted from @elizaos/agent and @elizaos/app-core in Phase 4F.",
  "main": "dist/index.js",
  "type": "module",
  "types": "dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./*": {
      "import": "./dist/*.js",
      "default": "./dist/*.js",
      "types": "./dist/*.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && tsc --declaration --emitDeclarationOnly --noEmit false",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "echo \"no tests\" && exit 0"
  },
  "dependencies": {
    "@elizaos/core": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "agentConfig": {
    "pluginType": "elizaos:plugin:1.0.0",
    "pluginParameters": {}
  },
  "eliza": {
    "platforms": ["node"],
    "runtime": "node",
    "platformDetails": {
      "node": "Node.js via main entry point"
    }
  }
}
