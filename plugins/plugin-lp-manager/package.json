{
  "name": "@elizaos/plugin-lp-manager",
  "version": "2.0.0-alpha.536",
  "description": "A unified plugin for managing liquidity positions on Solana DEXs (Raydium, Orca, Meteora) and EVM DEXs (Uniswap, PancakeSwap, Aerodrome).",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsc --watch",
    "test": "tsup && vitest run --config vitest.config.ts --passWithNoTests",
    "clean": "rm -rf dist .turbo node_modules",
    "lint": "bunx @biomejs/biome check --write --unsafe .",
    "lint:check": "bunx @biomejs/biome check .",
    "format": "bunx @biomejs/biome format --write .",
    "format:check": "bunx @biomejs/biome format .",
    "typecheck": "tsc --noEmit --noCheck"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.31.0",
    "@elizaos/core": "workspace:*",
    "@elizaos/plugin-anthropic": "workspace:*",
    "@elizaos/plugin-discord": "workspace:*",
    "@elizaos/plugin-telegram": "workspace:*",
    "@meteora-ag/dlmm": "^1.0.0",
    "@orca-so/whirlpools": "^0.3.0",
    "@orca-so/whirlpools-client": "^0.3.0",
    "@orca-so/whirlpools-core": "^0.3.0",
    "@orca-so/whirlpools-sdk": "^0.13.0",
    "@pancakeswap/sdk": "^5.8.0",
    "@pancakeswap/v3-sdk": "^3.9.7",
    "@raydium-io/raydium-sdk": "^1.3.1-beta.58",
    "@solana/spl-token": "^0.4.6",
    "@solana/web3.js": "^1.98.4",
    "@uniswap/sdk-core": "^5.8.2",
    "@uniswap/smart-order-router": "^3.49.0",
    "@uniswap/v3-sdk": "^3.13.1",
    "bs58": "^6.0.0",
    "decimal.js": "^10.4.3",
    "uuid": "^14.0.0",
    "viem": "^2.48.8"
  },
  "peerDependencies": {
    "@elizaos/plugin-wallet": "workspace:*"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@types/decimal.js": "^7.4.0",
    "tsup": "8.5.0",
    "typescript": "^6.0.3",
    "vitest": "3.1.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "agentConfig": {
    "pluginParameters": {
      "SOLANA_RPC_URL": {
        "type": "string",
        "description": "RPC endpoint URL",
        "required": false,
        "sensitive": false
      },
      "SOLANA_COMMITMENT": {
        "type": "string",
        "description": "Transaction commitment level (e.g. confirmed, finalized)",
        "required": false,
        "sensitive": false
      },
      "SOLANA_PUBLIC_KEY": {
        "type": "string",
        "description": "Public key / wallet address",
        "required": false,
        "sensitive": false
      },
      "SOLANA_PRIVATE_KEY": {
        "type": "string",
        "description": "Private key for Solana",
        "required": true,
        "sensitive": true
      },
      "EVM_PRIVATE_KEY": {
        "type": "string",
        "description": "Private key for Evm",
        "required": true,
        "sensitive": true
      },
      "ETHEREUM_RPC_URL": {
        "type": "string",
        "description": "RPC endpoint URL",
        "required": false,
        "sensitive": false
      },
      "EVM_PROVIDER_MAINNET": {
        "type": "string",
        "description": "RPC provider URL for Evm",
        "required": false,
        "sensitive": false
      },
      "BASE_RPC_URL": {
        "type": "string",
        "description": "RPC endpoint URL",
        "required": false,
        "sensitive": false
      },
      "EVM_PROVIDER_BASE": {
        "type": "string",
        "description": "RPC provider URL for Evm",
        "required": false,
        "sensitive": false
      },
      "BSC_RPC_URL": {
        "type": "string",
        "description": "RPC endpoint URL",
        "required": false,
        "sensitive": false
      },
      "EVM_PROVIDER_BSC": {
        "type": "string",
        "description": "RPC provider URL for Evm",
        "required": false,
        "sensitive": false
      },
      "ARBITRUM_RPC_URL": {
        "type": "string",
        "description": "RPC endpoint URL",
        "required": false,
        "sensitive": false
      },
      "EVM_PROVIDER_ARBITRUM": {
        "type": "string",
        "description": "RPC provider URL for Evm",
        "required": false,
        "sensitive": false
      },
      "LP_SOLANA_DEXES": {
        "type": "string",
        "description": "Comma-separated DEX list to manage",
        "required": false,
        "sensitive": false
      },
      "LP_EVM_DEXES": {
        "type": "string",
        "description": "Comma-separated DEX list to manage",
        "required": false,
        "sensitive": false
      }
    }
  }
}
