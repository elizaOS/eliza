{
  "name": "@elizaos/plugin-raydium",
  "version": "1.0.2",
  "main": "dist/index.js",
  "type": "module",
  "types": "dist/index.d.ts",
  "dependencies": {
    "@elizaos/core": "workspace:*",
    "@raydium-io/raydium-sdk-v2": "^0.1.139-alpha",
    "@solana/spl-token": "^0.4.1",
    "bn.js": "^5.2.1",
    "bs58": "^5.0.0"
  },
  "devDependencies": {
    "@solana/web3.js": "^1.91.4",
    "@types/bn.js": "^5.1.5",
    "dotenv": "^16.5.0",
    "tsup": "8.5.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^2.0.4"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "lint": "bunx @biomejs/biome format --write ./src",
    "format": "bunx @biomejs/biome format --write ./src",
    "format:check": "bunx @biomejs/biome format ./src",
    "test": "vitest run --passWithNoTests"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/elizaos-plugins/plugin-raydium.git"
  },
  "agentConfig": {
    "pluginType": "elizaos:plugin:1.0.0",
    "pluginParameters": {
      "SOLANA_RPC_URL": {
        "type": "string",
        "description": "URL of the Solana RPC endpoint used to establish a connection to the Solana blockchain.",
        "required": true,
        "sensitive": false
      },
      "RAYDIUM_API_URL": {
        "type": "string",
        "description": "Base URL for the Raydium API, used to fetch information about pools and positions.",
        "required": true,
        "sensitive": false
      }
    }
  }
}
