{
  "name": "@elizaos/app-steward",
  "version": "2.0.0-beta.0",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./ui": {
      "types": "./dist/ui.d.ts",
      "import": "./dist/ui.js",
      "default": "./dist/ui.js"
    },
    "./plugin": {
      "types": "./dist/plugin.d.ts",
      "import": "./dist/plugin.js",
      "default": "./dist/plugin.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js",
      "default": "./dist/types/index.js"
    },
    "./types/*": {
      "types": "./dist/types/*.d.ts",
      "import": "./dist/types/*.js",
      "default": "./dist/types/*.js"
    },
    "./api/*": {
      "types": "./dist/api/*.d.ts",
      "import": "./dist/api/*.js",
      "default": "./dist/api/*.js"
    },
    "./services/*": {
      "types": "./dist/services/*.d.ts",
      "import": "./dist/services/*.js",
      "default": "./dist/services/*.js"
    },
    "./security/*": {
      "types": "./dist/security/*.d.ts",
      "import": "./dist/security/*.js",
      "default": "./dist/security/*.js"
    },
    "./routes/*": {
      "types": "./dist/routes/*.d.ts",
      "import": "./dist/routes/*.js",
      "default": "./dist/routes/*.js"
    },
    "./actions/*": {
      "types": "./dist/actions/*.d.ts",
      "import": "./dist/actions/*.js",
      "default": "./dist/actions/*.js"
    },
    "./browser-workspace-wallet": {
      "types": "./dist/browser-workspace-wallet.d.ts",
      "import": "./dist/browser-workspace-wallet.js",
      "default": "./dist/browser-workspace-wallet.js"
    },
    "./*": {
      "types": "./dist/*",
      "import": "./dist/*.js",
      "default": "./dist/*.js"
    }
  },
  "dependencies": {
    "@noble/curves": "2.2.0",
    "@simplewebauthn/browser": "^13.0.0",
    "@solana/web3.js": "1.98.4",
    "@stwd/sdk": "^0.8.1",
    "@elizaos/core": "workspace:*",
    "@elizaos/plugin-wallet": "workspace:*",
    "@elizaos/shared": "workspace:*",
    "@elizaos/ui": "workspace:*",
    "ethers": "^6.16.0",
    "lucide-react": "^1.0.0",
    "viem": "^2.48.8"
  },
  "elizaos": {
    "app": {
      "heroImage": "assets/hero.png"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "bun run build:js && bun run build:types",
    "clean": "rm -rf dist",
    "build:js": "tsup --config ../tsup.plugin-packages.shared.ts",
    "build:types": "tsc -p ../tsconfig.build.shared.json"
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "tsup": "^8.5.1"
  }
}
