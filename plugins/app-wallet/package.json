{
  "name": "@elizaos/app-wallet",
  "version": "2.0.0-beta.0",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./ui": {
      "types": "./dist/ui.d.ts",
      "import": "./dist/ui.js",
      "default": "./dist/ui.js"
    },
    "./plugin": {
      "types": "./dist/plugin.d.ts",
      "import": "./dist/plugin.js",
      "default": "./dist/plugin.js"
    },
    "./register": {
      "types": "./dist/register.d.ts",
      "import": "./dist/register.js",
      "default": "./dist/register.js"
    },
    "./inventory/ChainIcon": {
      "types": "./dist/inventory/ChainIcon.d.ts",
      "import": "./dist/inventory/ChainIcon.js",
      "default": "./dist/inventory/ChainIcon.js"
    },
    "./inventory/TokenLogo": {
      "types": "./dist/inventory/TokenLogo.d.ts",
      "import": "./dist/inventory/TokenLogo.js",
      "default": "./dist/inventory/TokenLogo.js"
    },
    "./state/*": {
      "types": "./dist/state/*.d.ts",
      "import": "./dist/state/*.js",
      "default": "./dist/state/*.js"
    },
    "./inventory/*": {
      "types": "./dist/inventory/*.d.ts",
      "import": "./dist/inventory/*.js",
      "default": "./dist/inventory/*.js"
    },
    "./widgets/*": {
      "types": "./dist/widgets/*.d.ts",
      "import": "./dist/widgets/*.js",
      "default": "./dist/widgets/*.js"
    },
    "./wallet-rpc": {
      "types": "./dist/wallet-rpc.d.ts",
      "import": "./dist/wallet-rpc.js",
      "default": "./dist/wallet-rpc.js"
    },
    "./*": {
      "types": "./dist/*",
      "import": "./dist/*.js",
      "default": "./dist/*.js"
    }
  },
  "dependencies": {
    "@elizaos/core": "workspace:*",
    "@elizaos/shared": "workspace:*",
    "@elizaos/ui": "workspace:*",
    "lucide-react": "^1.0.0"
  },
  "peerDependencies": {
    "@elizaos/app-core": "workspace:*",
    "@elizaos/plugin-wallet": "workspace:*",
    "react": ">=18.0.0"
  },
  "elizaos": {
    "app": {
      "heroImage": "assets/hero.png"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "bun run build:js && bun run build:types",
    "clean": "rm -rf dist",
    "build:js": "tsup --config ../tsup.plugin-packages.shared.ts",
    "build:types": "tsc -p tsconfig.build.json"
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "tsup": "^8.5.1"
  }
}
