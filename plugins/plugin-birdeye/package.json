{
    "name": "@elizaos/plugin-birdeye",
    "version": "1.0.2",
    "main": "dist/index.js",
    "type": "module",
    "types": "dist/index.d.ts",
    "dependencies": {
        "@elizaos/cloud-routing": "workspace:*",
        "@elizaos/core": "latest",
        "@coral-xyz/anchor": "^0.32.1",
        "@solana/spl-token": "0.4.14",
        "@solana/web3.js": "^1.98.4",
        "bignumber": "1.1.0",
        "bignumber.js": "^11.0.0",
        "bs58": "6.0.0",
        "fomo-sdk-solana": "1.3.2",
        "node-cache": "5.1.2",
        "pumpdotfun-sdk": "^1.4.2",
        "tsup": "^8.5.1",
        "vitest": "^4.0.0"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.14",
        "@elizaos/cli": "^1.4.2",
        "@types/node": "^22.19.17",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^6.0.3"
    },
    "scripts": {
        "build": "tsup --format esm --dts",
        "dev": "tsup --format esm --dts --watch",
        "test": "vitest run",
        "lint": "biome lint .",
        "format": "biome format . --write",
        "check": "biome check --apply ."
    },
    "peerDependencies": {
        "form-data": "4.0.5",
        "whatwg-url": "^16.0.0"
    },
    "agentConfig": {
        "pluginType": "elizaos:client:1.0.0",
        "pluginParameters": {
            "BIRDEYE_WALLET_ADDR": {
                "type": "string",
                "minLength": 1,
                "description": "If set, this provider will fetch the wallet's portfolio data from Birdeye and be able to respond to questions related to the wallet's holdings.",
                "optional": true
            }
        }
    }
}
