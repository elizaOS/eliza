{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./dist",
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "noEmit": false,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@elizaos/cloud-sdk": ["../../../cloud/packages/sdk/dist/index.d.ts"],
      "@elizaos/core": ["../packages/typescript/dist"]
    },
    "types": ["node", "bun-types"]
  },
  "include": ["index.ts", "index.node.ts", "index.browser.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "python",
    "rust",
    "build.ts",
    "vitest.config.ts",
    "**/__tests__/**",
    "**/*.test.ts"
  ]
}
