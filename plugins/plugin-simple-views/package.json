{
  "name": "@elizaos/plugin-simple-views",
  "version": "2.0.3-beta.6",
  "type": "module",
  "description": "Small agent-drivable Notes and Simple Calendar app views for view switching, split-pane, and capability QA.",
  "main": "./dist/index.js",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "eliza-source": {
        "types": "./src/index.ts",
        "import": "./src/index.ts",
        "default": "./src/index.ts"
      },
      "bun": {
        "types": "./src/index.ts",
        "import": "./src/index.ts",
        "default": "./src/index.ts"
      },
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./plugin": {
      "types": "./dist/plugin.d.ts",
      "eliza-source": {
        "types": "./src/plugin.ts",
        "import": "./src/plugin.ts",
        "default": "./src/plugin.ts"
      },
      "bun": {
        "types": "./src/plugin.ts",
        "import": "./src/plugin.ts",
        "default": "./src/plugin.ts"
      },
      "import": "./dist/plugin.js",
      "default": "./dist/plugin.js"
    },
    "./register": {
      "types": "./dist/register.d.ts",
      "eliza-source": {
        "types": "./src/register.ts",
        "import": "./src/register.ts",
        "default": "./src/register.ts"
      },
      "import": "./dist/register.js",
      "default": "./dist/register.js"
    },
    "./ui": {
      "types": "./dist/ui.d.ts",
      "eliza-source": {
        "types": "./src/ui.tsx",
        "import": "./src/ui.tsx",
        "default": "./src/ui.tsx"
      },
      "import": "./dist/ui.js",
      "default": "./dist/ui.js"
    },
    "./*.css": "./dist/*.css",
    "./*": {
      "types": "./dist/*.d.ts",
      "eliza-source": {
        "types": "./src/*.ts",
        "import": "./src/*.ts",
        "default": "./src/*.ts"
      },
      "import": "./dist/*.js",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "typecheck": "tsgo --noEmit -p tsconfig.json",
    "lint": "bunx @biomejs/biome check src",
    "test": "bunx vitest run --config ./vitest.config.ts",
    "build": "bun run build:js && bun run build:views && bun run build:types",
    "clean": "node ../../packages/scripts/rm-path-recursive.mjs dist",
    "build:js": "tsup --config tsup.config.ts",
    "build:views": "bunx --bun vite build --config vite.config.views.ts",
    "build:types": "tsc --noCheck -p tsconfig.build.json"
  },
  "dependencies": {
    "@elizaos/core": "workspace:*",
    "@elizaos/ui": "workspace:*",
    "lucide-react": "^1.0.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.5.1",
    "vite": "^8.0.0",
    "vitest": "^4.0.17"
  },
  "elizaos": {
    "app": {
      "displayName": "Simple Views",
      "category": "developer"
    },
    "appRegister": "register"
  },
  "publishConfig": {
    "access": "public"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "assets"
  ]
}
