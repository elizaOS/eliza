{
  "name": "@elizaos/plugin-directives",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/cjs/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "description": "Inline directive parsing for Eliza agents (@think, @model, @verbose, etc.)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/elizaos/eliza.git"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/cjs/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@elizaos/core": "workspace:*",
    "@elizaos/plugin-discord": "^1.3.8"
  },
  "devDependencies": {
    "@types/bun": "^1.2.22",
    "@types/node": "^24.5.2",
    "@types/uuid": "^10.0.0",
    "prettier": "3.6.2",
    "typescript": "^5.9.2"
  },
  "scripts": {
    "build": "bun run build.ts",
    "dev": "bun --hot build.ts",
    "test": "tsc --noEmit && bun test",
    "clean": "rm -rf dist .turbo node_modules .turbo-tsconfig.json tsconfig.tsbuildinfo",
    "format": "prettier --write ./src",
    "format:check": "prettier --check ./src",
    "lint": "prettier --write ./src"
  },
  "publishConfig": {
    "access": "public"
  },
  "agentConfig": {
    "pluginType": "elizaos:plugin:1.0.0",
    "pluginParameters": {
      "DEFAULT_THINKING": {
        "type": "string",
        "description": "Default thinking level (off, minimal, low, medium, high)",
        "required": false,
        "default": "low",
        "sensitive": false
      },
      "DEFAULT_VERBOSE": {
        "type": "string",
        "description": "Default verbose level (off, on, full)",
        "required": false,
        "default": "off",
        "sensitive": false
      },
      "ALLOW_ELEVATED": {
        "type": "boolean",
        "description": "Allow elevated permission directives",
        "required": false,
        "default": "true",
        "sensitive": false
      },
      "ALLOW_EXEC": {
        "type": "boolean",
        "description": "Allow exec directive for shell configuration",
        "required": false,
        "default": "false",
        "sensitive": false
      }
    }
  },
  "milaidy": {
    "platforms": [
      "node"
    ],
    "runtime": "node",
    "platformDetails": {
      "node": "Default export (Node.js)"
    }
  }
}
