{
  "name": "@elizaos/plugin-local-embedding",
  "version": "2.0.0-beta.1",
  "description": "Deprecated compatibility shim for the unified Eliza-1 local inference provider.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./*.css": "./dist/*.css",
    "./*": {
      "import": "./dist/*.js",
      "default": "./dist/*.js",
      "types": "./dist/*.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && tsc --project tsconfig.build.json",
    "dev": "tsup --watch",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo",
    "lint": "bunx @biomejs/biome check --write --unsafe .",
    "lint:check": "bunx @biomejs/biome check .",
    "format": "bunx @biomejs/biome format --write .",
    "format:check": "bunx @biomejs/biome format .",
    "typecheck": "tsc --noEmit --noCheck"
  },
  "dependencies": {
    "@elizaos/core": "2.0.0-beta.1",
    "@elizaos/plugin-local-inference": "2.0.0-beta.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@types/node": "^25.0.3",
    "@types/uuid": "^11.0.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  },
  "publishConfig": {
    "access": "public"
  }
}
