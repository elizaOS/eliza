{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"rootDir": "src",
		"outDir": "./dist",
		"sourceMap": true,
		"inlineSources": true,
		"declaration": true,
		"emitDeclarationOnly": true,
		"paths": {
			"@elizaos/core": ["../../packages/core/dist/index.d.ts"],
			"@elizaos/plugin-local-inference": ["../plugin-local-inference/dist/index.d.ts"]
		}
	},
	"include": ["src/**/*.ts"],
	"exclude": ["node_modules", "dist", "**/*.test.ts", "**/*.spec.ts"]
}
