{
  "compilerOptions": {
    "outDir": "dist",
    "lib": [
      "ESNext",
      "DOM"
    ],
    "target": "ESNext",
    "module": "Preserve",
    "moduleResolution": "Bundler",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": false,
    "allowImportingTsExtensions": true,
    "emitDeclarationOnly": true,
    "declaration": true,
    "resolveJsonModule": true,
    "noImplicitAny": false,
    "allowJs": true,
    "checkJs": false,
    "types": [
      "node",
      "vitest/globals"
    ],
    "noEmitOnError": false,
    "moduleDetection": "force",
    "allowArbitraryExtensions": true
  },
  "include": [
    "src/**/*.ts",
    "e2e/**/*.ts",
    "__tests__/**/*.ts"
  ]
}
