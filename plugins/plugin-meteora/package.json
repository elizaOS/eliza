{
  "name": "@elizaos/plugin-meteora",
  "version": "1.0.2",
  "main": "dist/index.js",
  "type": "module",
  "types": "dist/index.d.ts",
  "dependencies": {
    "@coral-xyz/anchor": "^0.31.1",
    "@elizaos/core": "workspace:*",
    "@meteora-ag/dlmm": "1.5.3",
    "@solana/web3.js": "1.98.2",
    "rpc-websockets": "^9.1.1"
  },
  "devDependencies": {
    "tsup": "8.5.0"
  },
  "scripts": {
    "build": "tsup --format esm --dts",
    "dev": "tsup --format esm --dts --watch",
    "clean": "rm -rf dist",
    "lint": "biome lint .",
    "lint:fix": "biome check --apply .",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "test": "../cli/dist/index.js test",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/elizaos-plugins/plugin-meteora.git"
  },
  "resolutions": {
    "@nrwl/devkit": "19.8.4",
    "@nrwl/tao": "19.8.4",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "@types/react": "19.1.5",
    "typedoc-plugin-markdown": "4.2.10",
    "typedoc": "0.27.9",
    "@solana/web3.js": "1.91.6",
    "rpc-websockets": "*"
  },
  "trustedDependencies": [],
  "agentConfig": {
    "pluginType": "elizaos:plugin:1.0.0",
    "pluginParameters": {
      "TEE_MODE": {
        "type": "string",
        "description": "Controls whether Trusted Execution Environment (TEE) mode is enabled and determines how the wallet keypair is loaded or derived.",
        "required": false,
        "default": "OFF",
        "sensitive": false
      },
      "WALLET_SECRET_SALT": {
        "type": "string",
        "description": "Salt value used to deterministically derive an Ed25519 keypair when TEE mode is enabled.",
        "required": false,
        "sensitive": false
      },
      "SOLANA_PRIVATE_KEY": {
        "type": "string",
        "description": "Base58 or base64 encoded private key for the Solana wallet; required when TEE mode is off and private key access is needed.",
        "required": false,
        "sensitive": true
      },
      "WALLET_PRIVATE_KEY": {
        "type": "string",
        "description": "Alternative environment variable for the Solana wallet private key; used as a fallback if SOLANA_PRIVATE_KEY is not set.",
        "required": false,
        "sensitive": true
      },
      "SOLANA_PUBLIC_KEY": {
        "type": "string",
        "description": "Public key for the Solana wallet; used when TEE mode is off and only the public key is needed.",
        "required": false,
        "sensitive": false
      },
      "WALLET_PUBLIC_KEY": {
        "type": "string",
        "description": "Alternative environment variable for the Solana wallet public key; used as a fallback if SOLANA_PUBLIC_KEY is not set.",
        "required": false,
        "sensitive": false
      }
    }
  }
}
