{
  "name": "@elizaos/plugin-matrix",
  "version": "2.0.0-alpha.1",
  "description": "Matrix messaging integration plugin for elizaOS agents",
  "type": "module",
  "main": "typescript/dist/index.js",
  "types": "typescript/dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./typescript/dist/index.js",
      "types": "./typescript/dist/index.d.ts"
    }
  },
  "files": [
    "typescript/dist",
    "python",
    "rust"
  ],
  "scripts": {
    "build": "cd typescript && bun run build",
    "test": "bun test",
    "lint": "biome lint .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "matrix-js-sdk": "^31.0.0",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@elizaos/core": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "^1.1.0",
    "typescript": "^5.3.0"
  },
  "keywords": [
    "elizaos",
    "plugin",
    "matrix",
    "chat",
    "decentralized",
    "encrypted"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/elizaos-plugins/plugin-matrix.git"
  },
  "agentConfig": {
    "pluginType": "elizaos:plugin:1.0.0",
    "pluginParameters": {
      "MATRIX_HOMESERVER": {
        "type": "string",
        "description": "Matrix homeserver URL (e.g., https://matrix.org)",
        "required": true,
        "sensitive": false
      },
      "MATRIX_USER_ID": {
        "type": "string",
        "description": "Matrix user ID (@user:homeserver.org)",
        "required": true,
        "sensitive": false
      },
      "MATRIX_ACCESS_TOKEN": {
        "type": "string",
        "description": "Matrix access token",
        "required": true,
        "sensitive": true
      },
      "MATRIX_DEVICE_ID": {
        "type": "string",
        "description": "Device ID for this session (optional, auto-generated if not provided)",
        "required": false,
        "sensitive": false
      },
      "MATRIX_ROOMS": {
        "type": "string",
        "description": "Comma-separated list of room IDs or aliases to auto-join",
        "required": false,
        "sensitive": false
      },
      "MATRIX_AUTO_JOIN": {
        "type": "boolean",
        "description": "Automatically accept room invites",
        "required": false,
        "sensitive": false
      },
      "MATRIX_ENCRYPTION": {
        "type": "boolean",
        "description": "Enable end-to-end encryption support",
        "required": false,
        "sensitive": false
      },
      "MATRIX_REQUIRE_MENTION": {
        "type": "boolean",
        "description": "Only respond when mentioned in rooms",
        "required": false,
        "sensitive": false
      }
    }
  }
}
