{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "incremental": false,
    "composite": false,
    "paths": {
      "@elizaos/contracts": ["../../packages/contracts/src/index.ts"],
      "@elizaos/contracts/*": ["../../packages/contracts/src/*"]
    }
  },
  "include": ["*.ts", "tsup.config.ts"],
  "exclude": [
    "dist",
    "node_modules",
    "**/__tests__/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.e2e.test.ts"
  ]
}
