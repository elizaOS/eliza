{
  "name": "@elizaos/plugin-smartglasses",
  "version": "2.0.0-beta.2",
  "type": "module",
  "description": "Even Realities G1/G2 smartglasses plugin for ElizaOS: display text, receive microphone audio, and route side-tap microphone controls.",
  "main": "./dist/index.js",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./register": {
      "types": "./dist/register.d.ts",
      "import": "./dist/register.js",
      "default": "./dist/register.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "bunx @biomejs/biome check src",
    "test": "bunx vitest run --config ./vitest.config.ts",
    "build": "bun run build:js && bun run build:views && bun run build:types",
    "clean": "rm -rf dist tsconfig.tsbuildinfo .turbo node_modules/.vite node_modules/.vite-temp",
    "build:js": "tsup --config ../tsup.plugin-packages.shared.ts",
    "build:views": "vite build --config vite.config.views.ts",
    "build:types": "tsc --noCheck -p tsconfig.build.json"
  },
  "dependencies": {
    "@elizaos/core": "workspace:*",
    "@elizaos/ui": "workspace:*",
    "lucide-react": "^1.0.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "optionalDependencies": {
    "@abandonware/noble": "^1.9.2-25"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.3",
    "@types/react-dom": "^19.2.3",
    "bun-types": "^1.3.14",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.0",
    "vitest": "^4.0.17"
  },
  "elizaos": {
    "plugin": {
      "capabilities": [
        "smartglasses",
        "wearable-display",
        "wearable-microphone"
      ]
    },
    "app": {
      "displayName": "Smartglasses",
      "category": "hardware",
      "heroImage": "assets/hero.png"
    }
  },
  "agentConfig": {
    "pluginType": "elizaos:plugin:1.0.0",
    "pluginParameters": {
      "SMARTGLASSES_TRANSPORT": {
        "type": "string",
        "description": "Preferred smartglasses transport. auto selects an injected transport, Even bridge, Web Bluetooth, then Noble BLE.",
        "required": false,
        "default": "auto",
        "enum": ["auto", "even-bridge", "web-bluetooth", "noble"],
        "sensitive": false
      },
      "SMARTGLASSES_SCAN_TIMEOUT_MS": {
        "type": "number",
        "description": "BLE scan timeout used by Noble-based G1 hardware smoke tests and direct Node/Bun connections.",
        "required": false,
        "default": 10000,
        "sensitive": false
      },
      "SMARTGLASSES_AUTO_INIT": {
        "type": "boolean",
        "description": "Send the G1 connection-ready init packets automatically after an Eliza-managed transport connects.",
        "required": false,
        "default": true,
        "sensitive": false
      },
      "SMARTGLASSES_INIT_MODE": {
        "type": "string",
        "description": "G1 connection-ready init packet mode. lens-specific sends 0x4D to left and 0xF4 to right; official sends 0x4D to both lenses as in EvenDemoApp.",
        "required": false,
        "default": "lens-specific",
        "enum": ["lens-specific", "official"],
        "sensitive": false
      }
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "types": "./dist/index.d.ts",
  "files": ["dist", "docs"]
}
