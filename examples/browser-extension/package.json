{
  "name": "@elizaos/example-browser-extension",
  "version": "1.0.0",
  "description": "Chat with any webpage using AI - Browser Extension powered by elizaOS",
  "private": true,
  "workspaces": [
    "chrome",
    "safari"
  ],
  "dependencies": {
    "@elizaos/core": "workspace:*",
    "@elizaos/plugin-anthropic": "workspace:*",
    "@elizaos/plugin-eliza-classic": "workspace:*",
    "@elizaos/plugin-google-genai": "workspace:*",
    "@elizaos/plugin-groq": "workspace:*",
    "@elizaos/plugin-inmemorydb": "workspace:*",
    "@elizaos/plugin-openai": "workspace:*"
  },
  "scripts": {
    "build": "npm run build:chrome",
    "build:chrome": "cd chrome && npm run build",
    "build:safari": "cd safari && npm run build",
    "dev": "cd chrome && npm run dev",
    "clean": "rm -rf chrome/dist safari/Chat\\ with\\ Webpage"
  }
}
