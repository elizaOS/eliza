{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Description": "elizaOS Per-User Container Stack - Production Ready v2 - ECS with Auto Scaling Group, Capacity Provider, and Monitoring",
  "Parameters": {
    "UserId": {
      "Type": "String",
      "Description": "Unique user ID for this deployment"
    },
    "ProjectName": {
      "Type": "String",
      "Description": "Project name for multi-project support"
    },
    "UserEmail": {
      "Type": "String",
      "Description": "User email for tagging",
      "Default": "unknown@example.com"
    },
    "ContainerImage": {
      "Type": "String",
      "Description": "ECR image URI for the container"
    },
    "ContainerPort": {
      "Type": "Number",
      "Default": 3000,
      "Description": "Container port"
    },
    "ContainerCpu": {
      "Type": "Number",
      "Default": 1792,
      "Description": "CPU units (1792 = 1.75 vCPU, 87.5% of t4g.small 2 vCPUs)"
    },
    "ContainerMemory": {
      "Type": "Number",
      "Default": 1792,
      "Description": "Memory in MB (1792 MB = 1.75 GiB, 87.5% of t4g.small 2 GiB)"
    },
    "SharedVPCId": {
      "Type": "String",
      "Description": "Shared VPC ID"
    },
    "SharedSubnetId": {
      "Type": "String",
      "Description": "Shared public subnet ID"
    },
    "SharedALBArn": {
      "Type": "String",
      "Description": "Shared ALB ARN"
    },
    "SharedListenerArn": {
      "Type": "String",
      "Description": "Shared ALB HTTPS Listener ARN"
    },
    "SharedALBSecurityGroupId": {
      "Type": "String",
      "Description": "Shared ALB Security Group ID"
    },
    "ECSExecutionRoleArn": {
      "Type": "String",
      "Description": "ECS Task Execution Role ARN"
    },
    "ECSTaskRoleArn": {
      "Type": "String",
      "Description": "ECS Task Role ARN"
    },
    "KeyName": {
      "Type": "String",
      "Description": "EC2 Key Pair for SSH access",
      "Default": ""
    },
    "ListenerRulePriority": {
      "Type": "Number",
      "Description": "ALB Listener Rule Priority (must be unique, 1-50000)",
      "MinValue": 1,
      "MaxValue": 50000
    },
    "SNSTopicArn": {
      "Type": "String",
      "Description": "SNS Topic ARN for alerts (optional)",
      "Default": ""
    },
    "Architecture": {
      "Type": "String",
      "Description": "CPU Architecture (arm64 for Graviton/t4g, x86_64 for Intel-AMD/t3)",
      "Default": "arm64",
      "AllowedValues": ["arm64", "amd64"]
    }
  },
  "Mappings": {
    "ArchitectureConfig": {
      "arm64": {
        "InstanceType": "t4g.small",
        "AMIParameter": "/aws/service/ecs/optimized-ami/amazon-linux-2/arm64/recommended/image_id",
        "CpuArchitecture": "ARM64"
      },
      "amd64": {
        "InstanceType": "t3.small",
        "AMIParameter": "/aws/service/ecs/optimized-ami/amazon-linux-2/recommended/image_id",
        "CpuArchitecture": "X86_64"
      }
    }
  },
  "Conditions": {
    "HasKeyPair": {
      "Fn::Not": [{ "Fn::Equals": [{ "Ref": "KeyName" }, ""] }]
    },
    "HasSNSTopic": {
      "Fn::Not": [{ "Fn::Equals": [{ "Ref": "SNSTopicArn" }, ""] }]
    }
  },
  "Resources": {
    "UserSecurityGroup": {
      "Type": "AWS::EC2::SecurityGroup",
      "Properties": {
        "GroupName": {
          "Fn::Sub": "elizaos-${UserId}-${ProjectName}-sg"
        },
        "GroupDescription": {
          "Fn::Sub": "Security group for user ${UserId} project ${ProjectName} ECS instance"
        },
        "VpcId": { "Ref": "SharedVPCId" },
        "SecurityGroupIngress": [
          {
            "IpProtocol": "tcp",
            "FromPort": { "Ref": "ContainerPort" },
            "ToPort": { "Ref": "ContainerPort" },
            "SourceSecurityGroupId": { "Ref": "SharedALBSecurityGroupId" },
            "Description": "Allow traffic from ALB"
          },
          {
            "IpProtocol": "tcp",
            "FromPort": { "Ref": "ContainerPort" },
            "ToPort": { "Ref": "ContainerPort" },
            "CidrIp": "0.0.0.0/0",
            "Description": "Allow direct public access to container port"
          }
        ],
        "SecurityGroupEgress": [
          {
            "IpProtocol": "tcp",
            "FromPort": 443,
            "ToPort": 443,
            "CidrIp": "0.0.0.0/0",
            "Description": "HTTPS to AWS services and internet"
          },
          {
            "IpProtocol": "tcp",
            "FromPort": 80,
            "ToPort": 80,
            "CidrIp": "0.0.0.0/0",
            "Description": "HTTP for package downloads"
          },
          {
            "IpProtocol": "udp",
            "FromPort": 53,
            "ToPort": 53,
            "CidrIp": "0.0.0.0/0",
            "Description": "DNS (UDP) for name resolution"
          },
          {
            "IpProtocol": "tcp",
            "FromPort": 53,
            "ToPort": 53,
            "CidrIp": "0.0.0.0/0",
            "Description": "DNS (TCP) for large responses/fallback"
          },
          {
            "IpProtocol": "udp",
            "FromPort": 123,
            "ToPort": 123,
            "CidrIp": "0.0.0.0/0",
            "Description": "NTP for time sync"
          }
        ],
        "Tags": [
          {
            "Key": "Name",
            "Value": { "Fn::Sub": "elizaos-${UserId}-${ProjectName}-sg" }
          },
          { "Key": "UserId", "Value": { "Ref": "UserId" } },
          { "Key": "UserEmail", "Value": { "Ref": "UserEmail" } },
          { "Key": "Project", "Value": "elizaOS" },
          { "Key": "Environment", "Value": "production" },
          { "Key": "BillingEntity", "Value": "elizaOS" },
          { "Key": "CostCenter", "Value": { "Ref": "UserId" } },
          { "Key": "ManagedBy", "Value": "CloudFormation" }
        ]
      }
    },
    "ECSCluster": {
      "Type": "AWS::ECS::Cluster",
      "Properties": {
        "ClusterName": {
          "Fn::Sub": "elizaos-${UserId}-${ProjectName}"
        },
        "ClusterSettings": [
          {
            "Name": "containerInsights",
            "Value": "enabled"
          }
        ],
        "Tags": [
          {
            "Key": "Name",
            "Value": { "Fn::Sub": "elizaos-${UserId}-${ProjectName}" }
          },
          { "Key": "UserId", "Value": { "Ref": "UserId" } },
          { "Key": "UserEmail", "Value": { "Ref": "UserEmail" } },
          { "Key": "Project", "Value": "elizaOS" },
          { "Key": "Environment", "Value": "production" },
          { "Key": "BillingEntity", "Value": "elizaOS" },
          { "Key": "CostCenter", "Value": { "Ref": "UserId" } },
          { "Key": "ManagedBy", "Value": "CloudFormation" }
        ]
      }
    },
    "InstanceProfile": {
      "Type": "AWS::IAM::InstanceProfile",
      "Properties": {
        "InstanceProfileName": {
          "Fn::Sub": "elizaos-${UserId}-${ProjectName}-profile"
        },
        "Roles": ["elizaos-ecs-instance-role"]
      }
    },
    "EC2Instance": {
      "Type": "AWS::EC2::Instance",
      "DependsOn": "ECSCluster",
      "CreationPolicy": {
        "ResourceSignal": {
          "Timeout": "PT10M"
        }
      },
      "Properties": {
        "ImageId": {
          "Fn::Sub": [
            "{{resolve:ssm:${AMIParameter}}}",
            {
              "AMIParameter": {
                "Fn::FindInMap": [
                  "ArchitectureConfig",
                  { "Ref": "Architecture" },
                  "AMIParameter"
                ]
              }
            }
          ]
        },
        "InstanceType": {
          "Fn::FindInMap": [
            "ArchitectureConfig",
            { "Ref": "Architecture" },
            "InstanceType"
          ]
        },
        "IamInstanceProfile": { "Ref": "InstanceProfile" },
        "KeyName": {
          "Fn::If": [
            "HasKeyPair",
            { "Ref": "KeyName" },
            { "Ref": "AWS::NoValue" }
          ]
        },
        "SubnetId": { "Ref": "SharedSubnetId" },
        "SecurityGroupIds": [{ "Ref": "UserSecurityGroup" }],
        "BlockDeviceMappings": [
          {
            "DeviceName": "/dev/xvda",
            "Ebs": {
              "VolumeSize": 35,
              "VolumeType": "gp3",
              "DeleteOnTermination": true,
              "Encrypted": true,
              "Iops": 3000
            }
          }
        ],
        "UserData": {
          "Fn::Base64": {
            "Fn::Sub": "#!/bin/bash -xe\necho ECS_CLUSTER=elizaos-${UserId}-${ProjectName} >> /etc/ecs/ecs.config\necho ECS_ENABLE_CONTAINER_METADATA=true >> /etc/ecs/ecs.config\necho ECS_AVAILABLE_LOGGING_DRIVERS='[\"json-file\",\"awslogs\"]' >> /etc/ecs/ecs.config\nyum install -y aws-cfn-bootstrap\n/opt/aws/bin/cfn-signal -e $? --stack ${AWS::StackName} --resource EC2Instance --region ${AWS::Region}\n"
          }
        },
        "Tags": [
          {
            "Key": "Name",
            "Value": { "Fn::Sub": "elizaos-${UserId}-${ProjectName}" }
          },
          { "Key": "UserId", "Value": { "Ref": "UserId" } },
          { "Key": "ProjectName", "Value": { "Ref": "ProjectName" } },
          { "Key": "UserEmail", "Value": { "Ref": "UserEmail" } },
          { "Key": "Project", "Value": "elizaOS" },
          { "Key": "Environment", "Value": "production" },
          { "Key": "BillingEntity", "Value": "elizaOS" },
          { "Key": "CostCenter", "Value": { "Ref": "UserId" } },
          { "Key": "ManagedBy", "Value": "CloudFormation" }
        ]
      }
    },

    "TargetGroup": {
      "Type": "AWS::ElasticLoadBalancingV2::TargetGroup",
      "Properties": {
        "Name": {
          "Fn::Join": [
            "",
            [
              "eliza-",
              {
                "Fn::Select": [0, { "Fn::Split": ["-", { "Ref": "UserId" }] }]
              },
              "-",
              {
                "Fn::Select": [
                  0,
                  { "Fn::Split": ["-", { "Ref": "ProjectName" }] }
                ]
              }
            ]
          ]
        },
        "Protocol": "HTTP",
        "Port": { "Ref": "ContainerPort" },
        "VpcId": { "Ref": "SharedVPCId" },
        "TargetType": "instance",
        "HealthCheckEnabled": true,
        "HealthCheckPath": "/health",
        "HealthCheckProtocol": "HTTP",
        "HealthCheckIntervalSeconds": 15,
        "HealthCheckTimeoutSeconds": 5,
        "HealthyThresholdCount": 2,
        "UnhealthyThresholdCount": 2,
        "Matcher": {
          "HttpCode": "200,201"
        },
        "Tags": [
          { "Key": "UserId", "Value": { "Ref": "UserId" } },
          { "Key": "Project", "Value": "elizaOS" },
          { "Key": "BillingEntity", "Value": "elizaOS" },
          { "Key": "CostCenter", "Value": { "Ref": "UserId" } },
          { "Key": "ManagedBy", "Value": "CloudFormation" }
        ]
      }
    },
    "UnhealthyTargetAlarm": {
      "Type": "AWS::CloudWatch::Alarm",
      "Condition": "HasSNSTopic",
      "Properties": {
        "AlarmName": {
          "Fn::Sub": "elizaos-${UserId}-${ProjectName}-unhealthy-targets"
        },
        "AlarmDescription": "Alert when targets are unhealthy",
        "MetricName": "UnHealthyHostCount",
        "Namespace": "AWS/ApplicationELB",
        "Statistic": "Average",
        "Period": 60,
        "EvaluationPeriods": 2,
        "Threshold": 1,
        "ComparisonOperator": "GreaterThanOrEqualToThreshold",
        "Dimensions": [
          {
            "Name": "TargetGroup",
            "Value": { "Fn::GetAtt": ["TargetGroup", "TargetGroupFullName"] }
          }
        ],
        "AlarmActions": [{ "Ref": "SNSTopicArn" }],
        "TreatMissingData": "notBreaching"
      }
    },
    "HighCPUAlarm": {
      "Type": "AWS::CloudWatch::Alarm",
      "Condition": "HasSNSTopic",
      "Properties": {
        "AlarmName": { "Fn::Sub": "elizaos-${UserId}-${ProjectName}-high-cpu" },
        "AlarmDescription": "Alert when CPU utilization is high",
        "MetricName": "CPUUtilization",
        "Namespace": "AWS/ECS",
        "Statistic": "Average",
        "Period": 300,
        "EvaluationPeriods": 2,
        "Threshold": 80,
        "ComparisonOperator": "GreaterThanThreshold",
        "Dimensions": [
          {
            "Name": "ServiceName",
            "Value": { "Fn::GetAtt": ["ECSService", "Name"] }
          },
          {
            "Name": "ClusterName",
            "Value": { "Ref": "ECSCluster" }
          }
        ],
        "AlarmActions": [{ "Ref": "SNSTopicArn" }],
        "TreatMissingData": "notBreaching"
      }
    },
    "HighMemoryAlarm": {
      "Type": "AWS::CloudWatch::Alarm",
      "Condition": "HasSNSTopic",
      "Properties": {
        "AlarmName": {
          "Fn::Sub": "elizaos-${UserId}-${ProjectName}-high-memory"
        },
        "AlarmDescription": "Alert when memory utilization is high",
        "MetricName": "MemoryUtilization",
        "Namespace": "AWS/ECS",
        "Statistic": "Average",
        "Period": 300,
        "EvaluationPeriods": 2,
        "Threshold": 80,
        "ComparisonOperator": "GreaterThanThreshold",
        "Dimensions": [
          {
            "Name": "ServiceName",
            "Value": { "Fn::GetAtt": ["ECSService", "Name"] }
          },
          {
            "Name": "ClusterName",
            "Value": { "Ref": "ECSCluster" }
          }
        ],
        "AlarmActions": [{ "Ref": "SNSTopicArn" }],
        "TreatMissingData": "notBreaching"
      }
    },
    "ListenerRule": {
      "Type": "AWS::ElasticLoadBalancingV2::ListenerRule",
      "Properties": {
        "ListenerArn": { "Ref": "SharedListenerArn" },
        "Priority": { "Ref": "ListenerRulePriority" },
        "Conditions": [
          {
            "Field": "host-header",
            "HostHeaderConfig": {
              "Values": [
                {
                  "Fn::Join": [
                    "",
                    [
                      {
                        "Fn::Select": [
                          "0",
                          { "Fn::Split": ["-", { "Ref": "UserId" }] }
                        ]
                      },
                      "-",
                      { "Ref": "ProjectName" },
                      ".containers.elizacloud.ai"
                    ]
                  ]
                }
              ]
            }
          }
        ],
        "Actions": [
          {
            "Type": "forward",
            "TargetGroupArn": { "Ref": "TargetGroup" }
          }
        ]
      }
    },
    "LogGroup": {
      "Type": "AWS::Logs::LogGroup",
      "Properties": {
        "LogGroupName": { "Fn::Sub": "/ecs/elizaos-${UserId}-${ProjectName}" },
        "RetentionInDays": 7
      }
    },
    "TaskDefinition": {
      "Type": "AWS::ECS::TaskDefinition",
      "DependsOn": "LogGroup",
      "Properties": {
        "Family": {
          "Fn::Sub": "elizaos-${UserId}-${ProjectName}"
        },
        "NetworkMode": "bridge",
        "RequiresCompatibilities": ["EC2"],
        "RuntimePlatform": {
          "CpuArchitecture": {
            "Fn::FindInMap": [
              "ArchitectureConfig",
              { "Ref": "Architecture" },
              "CpuArchitecture"
            ]
          },
          "OperatingSystemFamily": "LINUX"
        },
        "Cpu": { "Ref": "ContainerCpu" },
        "Memory": { "Ref": "ContainerMemory" },
        "ExecutionRoleArn": { "Ref": "ECSExecutionRoleArn" },
        "TaskRoleArn": { "Ref": "ECSTaskRoleArn" },
        "ContainerDefinitions": [
          {
            "Name": "agent",
            "Image": { "Ref": "ContainerImage" },
            "Essential": true,
            "PortMappings": [
              {
                "ContainerPort": { "Ref": "ContainerPort" },
                "HostPort": { "Ref": "ContainerPort" },
                "Protocol": "tcp"
              }
            ],
            "LogConfiguration": {
              "LogDriver": "awslogs",
              "Options": {
                "awslogs-group": {
                  "Fn::Sub": "/ecs/elizaos-${UserId}-${ProjectName}"
                },
                "awslogs-region": { "Ref": "AWS::Region" },
                "awslogs-stream-prefix": "ecs"
              }
            },
            "HealthCheck": {
              "Command": [
                "CMD-SHELL",
                {
                  "Fn::Sub": "curl -f http://localhost:${ContainerPort}/health || exit 1"
                }
              ],
              "Interval": 30,
              "Timeout": 5,
              "Retries": 3,
              "StartPeriod": 60
            }
          }
        ],
        "Tags": [
          { "Key": "UserId", "Value": { "Ref": "UserId" } },
          { "Key": "Project", "Value": "elizaOS" },
          { "Key": "BillingEntity", "Value": "elizaOS" },
          { "Key": "CostCenter", "Value": { "Ref": "UserId" } },
          { "Key": "ManagedBy", "Value": "CloudFormation" }
        ]
      }
    },
    "ECSService": {
      "Type": "AWS::ECS::Service",
      "DependsOn": ["EC2Instance", "ListenerRule", "TargetGroup"],
      "Properties": {
        "ServiceName": {
          "Fn::Sub": "elizaos-${UserId}-${ProjectName}"
        },
        "Cluster": { "Ref": "ECSCluster" },
        "TaskDefinition": { "Ref": "TaskDefinition" },
        "DesiredCount": 1,
        "LaunchType": "EC2",
        "LoadBalancers": [
          {
            "TargetGroupArn": { "Ref": "TargetGroup" },
            "ContainerName": "agent",
            "ContainerPort": { "Ref": "ContainerPort" }
          }
        ],
        "HealthCheckGracePeriodSeconds": 300,
        "DeploymentConfiguration": {
          "MaximumPercent": 100,
          "MinimumHealthyPercent": 0,
          "DeploymentCircuitBreaker": {
            "Enable": false,
            "Rollback": false
          }
        },
        "PlacementStrategies": [
          {
            "Type": "binpack",
            "Field": "cpu"
          }
        ],
        "Tags": [
          { "Key": "UserId", "Value": { "Ref": "UserId" } },
          { "Key": "Project", "Value": "elizaOS" },
          { "Key": "BillingEntity", "Value": "elizaOS" },
          { "Key": "CostCenter", "Value": { "Ref": "UserId" } },
          { "Key": "ManagedBy", "Value": "CloudFormation" }
        ]
      }
    }
  },
  "Outputs": {
    "ClusterName": {
      "Description": "ECS Cluster Name",
      "Value": { "Ref": "ECSCluster" }
    },
    "ClusterArn": {
      "Description": "ECS Cluster ARN",
      "Value": { "Fn::GetAtt": ["ECSCluster", "Arn"] }
    },
    "EC2InstanceId": {
      "Description": "EC2 Instance ID",
      "Value": { "Ref": "EC2Instance" }
    },
    "EC2InstancePublicIP": {
      "Description": "EC2 Instance Public IP",
      "Value": { "Fn::GetAtt": ["EC2Instance", "PublicIp"] }
    },
    "EC2InstancePublicDNS": {
      "Description": "EC2 Instance Public DNS Name",
      "Value": { "Fn::GetAtt": ["EC2Instance", "PublicDnsName"] }
    },
    "DirectAccessUrl": {
      "Description": "Direct access URL via EC2 public DNS (bypasses ALB)",
      "Value": {
        "Fn::Sub": "http://${EC2Instance.PublicDnsName}:${ContainerPort}"
      }
    },
    "ServiceArn": {
      "Description": "ECS Service ARN",
      "Value": { "Ref": "ECSService" }
    },
    "TaskDefinitionArn": {
      "Description": "ECS Task Definition ARN",
      "Value": { "Ref": "TaskDefinition" }
    },
    "TargetGroupArn": {
      "Description": "Target Group ARN",
      "Value": { "Ref": "TargetGroup" }
    },
    "ContainerUrl": {
      "Description": "Container URL",
      "Value": {
        "Fn::Join": [
          "",
          [
            "https://",
            {
              "Fn::Select": ["0", { "Fn::Split": ["-", { "Ref": "UserId" }] }]
            },
            "-",
            { "Ref": "ProjectName" },
            ".containers.elizacloud.ai"
          ]
        ]
      }
    }
  }
}
