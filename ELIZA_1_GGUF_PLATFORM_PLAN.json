{
  "platformTargets": {
    "android-adreno-vulkan": {
      "backend": "vulkan",
      "command": "cd packages/inference/verify && make android-vulkan-smoke",
      "id": "android-adreno-vulkan",
      "notes": "Physical Qualcomm Adreno device.",
      "recordable": true,
      "runner": "packages/inference/verify/android_vulkan_smoke.sh"
    },
    "android-mali-vulkan": {
      "backend": "vulkan",
      "command": "cd packages/inference/verify && make android-vulkan-smoke",
      "id": "android-mali-vulkan",
      "notes": "Physical Arm Mali device.",
      "recordable": true,
      "runner": "packages/inference/verify/android_vulkan_smoke.sh"
    },
    "darwin-arm64-metal": {
      "backend": "metal",
      "command": "make -C packages/inference/verify dispatch-smoke",
      "id": "darwin-arm64-metal",
      "notes": "Apple Silicon desktop/laptop Metal graph dispatch.",
      "recordable": true,
      "runner": "packages/inference/verify/metal-runtime-dispatch-evidence.json"
    },
    "ios-arm64-metal": {
      "backend": "metal",
      "command": "node packages/app-core/scripts/ios-xcframework/run-physical-device-smoke.mjs",
      "id": "ios-arm64-metal",
      "notes": "Physical iPhone/iPad only; simulator is diagnostic.",
      "recordable": true,
      "runner": "packages/app-core/scripts/ios-xcframework/run-physical-device-smoke.mjs"
    },
    "linux-aarch64-cuda": {
      "backend": "cuda",
      "command": "cd packages/inference/verify && ELIZA_DFLASH_SMOKE_MODEL=/models/eliza-1-smoke.gguf ./gh200_runner.sh --report hardware-results/gh200.json",
      "id": "linux-aarch64-cuda",
      "notes": "GH200/H100/H200-class aarch64 Linux.",
      "recordable": true,
      "runner": "packages/inference/verify/gh200_runner.sh"
    },
    "linux-x64-cpu": {
      "backend": "cpu",
      "command": "cd packages/inference/verify && ELIZA_DFLASH_SMOKE_MODEL=/models/eliza-1-smoke.gguf ./runtime_graph_smoke.sh --target linux-x64-cpu --backend-pattern 'AVX|AVX2|CPU|ggml_backend_cpu|llama'",
      "id": "linux-x64-cpu",
      "notes": "Native Linux CPU fallback.",
      "recordable": true,
      "runner": "packages/inference/verify/runtime_graph_smoke.sh"
    },
    "linux-x64-cuda": {
      "backend": "cuda",
      "command": "cd packages/inference/verify && ELIZA_DFLASH_SMOKE_MODEL=/models/eliza-1-smoke.gguf ./cuda_runner.sh --report hardware-results/cuda.json",
      "id": "linux-x64-cuda",
      "notes": "Linux x64 NVIDIA CUDA.",
      "recordable": true,
      "runner": "packages/inference/verify/cuda_runner.sh"
    },
    "linux-x64-rocm": {
      "backend": "rocm",
      "command": "cd packages/inference/verify && ELIZA_DFLASH_SMOKE_MODEL=/models/eliza-1-smoke.gguf ./rocm_runner.sh --report hardware-results/rocm.json",
      "id": "linux-x64-rocm",
      "notes": "Linux x64 AMD ROCm/HIP.",
      "recordable": true,
      "runner": "packages/inference/verify/rocm_runner.sh"
    },
    "linux-x64-vulkan": {
      "backend": "vulkan",
      "command": "cd packages/inference/verify && ./linux_vulkan_smoke.sh",
      "id": "linux-x64-vulkan",
      "notes": "Native Linux Intel/AMD/NVIDIA Vulkan; software ICDs are diagnostic.",
      "recordable": true,
      "runner": "packages/inference/verify/linux_vulkan_smoke.sh"
    },
    "windows-arm64-cpu": {
      "backend": "cpu",
      "command": "pwsh -File packages/inference/verify/windows_runner.ps1 -Backend cpu -Model C:\\models\\eliza-1-smoke.gguf -Report C:\\temp\\eliza-arm64-cpu.json",
