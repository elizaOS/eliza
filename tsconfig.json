{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
    "forceConsistentCasingInFileNames": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "allowSyntheticDefaultImports": true,
    "incremental": true,
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "strict": true,
    "jsx": "react-jsx",
    "paths": {
      "@elizaos/ui": ["./packages/ui/src/index.ts"],
      "@elizaos/ui/*": ["./packages/ui/src/*"],
      "@elizaos/core": ["./packages/core/src/index.node.ts"],
      "@elizaos/core/testing": ["./packages/core/src/testing/index.ts"],
      "@elizaos/core/*": ["./packages/core/src/*"],
      "@elizaos/shared": ["./packages/shared/src/index.ts"],
      "@elizaos/shared/*": ["./packages/shared/src/*"],
      "@elizaos/app-wallet": ["./plugins/app-wallet/src/index.ts"],
      "@elizaos/app-wallet/*": ["./plugins/app-wallet/src/*"]
    }
  },
  "exclude": [
    "**/node_modules/**",
    "**/dist/**",
    "**/cypress/**",
    "**/*.cy.tsx",
    "**/*.cy.ts",
    "**/scripts/**",
    "examples/code/**",
    "examples/avatar/**",
    "examples/vrm/**",
    "examples/supabase/**",
    "examples/polymarket/**",
    "examples/react/**",
    "examples/next/**",
    "examples/farcaster-miniapp/**",
    "packages/elizaos/examples/**",
    "plugins/plugin-lp-manager/**",
    "plugins/plugin-local-ai/**",
    "plugins/plugin-vision/**",
    "plugins/plugin-github/**",
    "plugins/plugin-wallet/src/chains/evm/**",
    "plugins/plugin-sql/**",
    "plugins/plugin-minecraft/**",
    "plugins/plugin-linear/**",
    "**/build.ts"
  ]
}
