{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "ignoreDeprecations": "6.0",
    "experimentalDecorators": true,
    "useUnknownInCatchVariables": true,
    "types": ["vite/client", "bun-types"],
    "baseUrl": "../..",
    "paths": {
      "@elizaos/app-core": ["./packages/app-core/src/index.ts"],
      "@elizaos/app-core/platform/native-plugin-entrypoints": [
        "./packages/app-core/src/platform/native-plugin-entrypoints.ts"
      ],
      "@elizaos/app-core/*": ["./packages/app-core/src/*"],
      "@elizaos/app-elizamaker": ["./apps/app-elizamaker/src/index.ts"],
      "@elizaos/app-elizamaker/*": ["./apps/app-elizamaker/src/*"],
      "@elizaos/app-task-coordinator": [
        "./apps/app-task-coordinator/src/index.ts"
      ],
      "@elizaos/app-task-coordinator/*": [
        "./apps/app-task-coordinator/src/*"
      ],
      "@elizaos/app-companion": ["./apps/app-companion/src/index.ts"],
      "@elizaos/app-companion/*": ["./apps/app-companion/src/*"],
      "@elizaos/app-lifeops": ["./apps/app-lifeops/src/index.ts"],
      "@elizaos/app-lifeops/*": ["./apps/app-lifeops/src/*"],
      "@elizaos/app-shopify": ["./apps/app-shopify/src/index.ts"],
      "@elizaos/app-shopify/*": ["./apps/app-shopify/src/*"],
      "@elizaos/app-steward": ["./apps/app-steward/src/index.ts"],
      "@elizaos/app-steward/*": ["./apps/app-steward/src/*"],
      "@elizaos/app-training": ["./apps/app-training/src/index.ts"],
      "@elizaos/app-training/*": ["./apps/app-training/src/*"],
      "@elizaos/app-vincent": ["./apps/app-vincent/src/index.ts"],
      "@elizaos/app-vincent/*": ["./apps/app-vincent/src/*"],
      "@elizaos/agent": ["./packages/agent/src/index.ts"],
      "@elizaos/agent/*": ["./packages/agent/src/*"],
      "@elizaos/core": ["./packages/typescript/src/index.ts"],
      "@elizaos/core/*": ["./packages/typescript/src/*"],
      "@elizaos/shared": ["./packages/shared/src/index.ts"],
      "@elizaos/shared/*": ["./packages/shared/src/*"],
      "@elizaos/capacitor-agent": [
        "./packages/native-plugins/agent/src/index.ts"
      ],
      "@elizaos/capacitor-desktop": [
        "./packages/native-plugins/desktop/src/index.ts"
      ],
      "@elizaos/capacitor-llama": [
        "./packages/native-plugins/llama/src/index.ts"
      ],
      "@elizaos/native-activity-tracker": [
        "./packages/native-plugins/activity-tracker/src/index.ts"
      ],
      "@elizaos/capacitor-appblocker": [
        "./packages/native-plugins/appblocker/src/index.ts"
      ],
      "@elizaos/capacitor-mobile-signals": [
        "./packages/native-plugins/mobile-signals/src/index.ts"
      ],
      "@elizaos/ui": ["./packages/ui/src/index.ts"],
      "@elizaos/ui/*": ["./packages/ui/src/*"],
      "react": ["./node_modules/@types/react/index.d.ts"],
      "react/jsx-runtime": [
        "./node_modules/@types/react/jsx-runtime.d.ts"
      ],
      "react/jsx-dev-runtime": [
        "./node_modules/@types/react/jsx-dev-runtime.d.ts"
      ],
      "react-dom": ["./node_modules/@types/react-dom/index.d.ts"],
      "react-dom/client": ["./node_modules/@types/react-dom/client.d.ts"],
      "@elizaos/*": ["./node_modules/@elizaos/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "../../packages/app-core/src/ambient-modules.d.ts",
    "../../packages/app-core/src/platform/capacitor-plugin-modules.d.ts",
    "../../packages/agent/src/external-modules.d.ts"
  ],
  "exclude": ["node_modules", "dist", "ios", "android", "electrobun"]
}
