{
  "name": "@elizaos/app-lifeops",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "LifeOps app plugin: routines, goals, Google Workspace, Apple Reminders, Twilio, browser companion control, hosts-file blocking (self-control), and related agent surfaces.",
  "main": "./src/index.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": "./src/index.ts",
    "./ui": "./src/ui.ts",
    "./agent-lifeops": "./src/agent-lifeops.ts",
    "./plugin": "./src/plugin.ts",
    "./selfcontrol": "./src/selfcontrol/index.ts",
    "./selfcontrol/selfcontrol": "./src/selfcontrol/selfcontrol.ts",
    "./lifeops": "./src/lifeops/index.ts",
    "./lifeops/*": "./src/lifeops/*.ts",
    "./inbox/*": "./src/inbox/*.ts",
    "./actions/*": "./src/actions/*.ts",
    "./providers/*": "./src/providers/*.ts",
    "./routes/*": "./src/routes/*.ts"
  },
  "scripts": {
    "test": "cd ../../.. && vitest run --config test/vitest/default.config.ts eliza/apps/app-lifeops/src/lifeops-plugin.test.ts eliza/apps/app-lifeops/test/lifeops-google-helpers.test.ts eliza/apps/app-lifeops/test/life-goal-extractor.test.ts eliza/apps/app-lifeops/test/lifeops-app-state.test.ts",
    "test:app-state": "cd ../../.. && vitest run --config test/vitest/default.config.ts eliza/apps/app-lifeops/test/lifeops-app-state.test.ts",
    "test:integration": "cd ../../.. && vitest run --config test/vitest/integration.config.ts eliza/apps/app-lifeops/test/life-smoke.integration.test.ts"
  },
  "dependencies": {
    "@elizaos/app-core": "workspace:*",
    "@elizaos/agent": "workspace:*",
    "@elizaos/core": "workspace:*",
    "@elizaos/shared": "workspace:*",
    "drizzle-orm": "^0.45.1",
    "lucide-react": "^0.575.0",
    "sharp": "^0.34.5"
  },
  "agentConfig": {
    "pluginType": "elizaos:plugin:1.0.0",
    "pluginParameters": {}
  }
}
