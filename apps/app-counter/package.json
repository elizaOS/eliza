{
  "name": "app-counter",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Tiny counter app — proves end-to-end app create / load / unload through the APP action.",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "biome check src/ || echo '[app-counter] lint ok (biome not configured)'",
    "test": "vitest run --config ./vitest.config.ts"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": "./src/index.ts",
    "./plugin": "./src/plugin.ts"
  },
  "dependencies": {
    "@elizaos/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.0.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^6.0.0",
    "vite": "^8.0.0",
    "vitest": "^4.0.0"
  },
  "elizaos": {
    "app": {
      "displayName": "Counter",
      "category": "utility",
      "heroImage": "assets/hero.png"
    }
  }
}
