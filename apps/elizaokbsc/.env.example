MOLTBOOK_AUTO_ENGAGE=false
MOLTBOOK_MIN_QUALITY_SCORE=7

MOLTBOOK_AUTONOMOUS_MODE=false
MOLTBOOK_AUTONOMY_INTERVAL_MS=900000
MOLTBOOK_AUTONOMY_MAX_STEPS=0
MOLTBOOK_MODEL=gpt-4o-mini
MOLTBOOK_PERSONALITY=A community-native ElizaOS agent representing ElizaOK on BNB Chain.
