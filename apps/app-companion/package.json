{
  "name": "@elizaos/app-companion",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Companion app package with the VRM scene runtime and avatar utilities.",
  "main": "./src/index.ts",
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "biome check src/",
    "test": "bunx vitest run",
    "test:e2e": "node test/run-storybook-e2e.mjs",
    "storybook": "storybook dev -p 6007",
    "build-storybook": "storybook build"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": "./src/index.ts",
    "./ui": "./src/ui.ts",
    "./plugin": "./src/plugin.ts",
    "./register": "./src/register.ts",
    "./assets.json": "./assets.json",
    "./components/avatar/VrmEngine": "./src/components/avatar/VrmEngine.ts",
    "./components/companion/shell-control-styles": "./src/components/companion/shell-control-styles.ts",
    "./components/*": "./src/components/*",
    "./types/*": "./src/types/*",
    "./emotes": "./src/emotes/index.ts",
    "./emotes/*": "./src/emotes/*.ts"
  },
  "dependencies": {
    "@elizaos/app-task-coordinator": "workspace:*",
    "@elizaos/ui": "workspace:*",
    "@elizaos/core": "workspace:*",
    "lucide-react": "^0.575.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.5",
    "@types/node": "^25.0.6",
    "@types/react-dom": "^19.0.0",
    "@storybook/addon-a11y": "^8.6.0",
    "@storybook/addon-essentials": "^8.6.0",
    "@storybook/addon-themes": "^8.6.0",
    "@playwright/test": "^1.58.2",
    "@storybook/react": "^8.6.0",
    "@storybook/react-vite": "^8.6.0",
    "@types/react": "^19.0.0",
    "@types/three": "^0.182.0",
    "storybook": "^8.6.0",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@pixiv/three-vrm": "^3.4.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.182.0"
  },
  "elizaos": {
    "app": {
      "heroImage": "assets/hero.webp"
    }
  }
}
