{
  "name": "@elizaos/cloud-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && bun run build:ssr && bun run prerender",
    "build:client": "vite build",
    "build:ssr": "vite build --ssr src/entry-server.tsx --outDir dist-ssr",
    "prerender": "node scripts/prerender.mjs",
    "preview": "vite preview --port 3000 --strictPort",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write src",
    "verify": "bun run lint && bun run typecheck && bun run build"
  },
  "dependencies": {
    "@elizaos/cloud-ui": "workspace:*",
    "@stwd/react": "^0.7.2",
    "@mdx-js/rollup": "^3.1.0",
    "@tailwindcss/vite": "^4.1.18",
    "@types/mdx": "^2.0.13",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "buffer": "^6.0.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-helmet-async": "^2.0.5",
    "react-router-dom": "^6.28.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-mdx-frontmatter": "^5.0.0",
    "typescript": "^6.0.0",
    "vite": "^5.4.10"
  },
  "devDependencies": {}
}
