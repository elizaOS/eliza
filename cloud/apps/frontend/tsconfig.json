{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["dom", "dom.iterable", "esnext"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "allowImportingTsExtensions": true,
    "types": ["vite/client", "node"],
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "paths": {
      "@/lib/*": ["../../packages/lib/*"],
      "@/db/*": ["../../packages/db/*"],
      "@/types/*": ["../../packages/types/*"],
      "@/components/*": ["../../packages/ui/src/components/*"],
      "@/packages/*": ["../../packages/*"],
      "@elizaos/billing": ["../../packages/billing/src/index.ts"],
      "@elizaos/cloud-ui": ["../../packages/ui/src/index.ts"],
      "@elizaos/core": ["../../../packages/core/src/index.node.ts"],
      "@elizaos/core/*": ["../../../packages/core/src/*"],
      "@elizaos/plugin-sql": ["../../../plugins/plugin-sql/src/index.ts"],
      "@/*": ["./src/*"]
    }
  },
  "include": ["src", "vite.config.ts"],
  "exclude": ["node_modules", "dist", "src/legacy"]
}
