{
  "name": "@elizaos/cloud-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "dev": "bun run ../../packages/scripts/sync-api-dev-vars.ts && wrangler dev --port ${API_DEV_PORT:-8787} --local",
    "build": "tsc --noEmit",
    "deploy": "wrangler deploy",
    "codegen": "node src/_generate-router.mjs",
    "typecheck": "tsc --noEmit",
    "test:audit": "node test/_audit-coverage.mjs",
    "test:e2e": "bun test --max-concurrency=1 --preload ./test/e2e/preload.ts test/e2e --timeout 120000",
    "test:e2e:foundation": "bun test --preload ./test/e2e/preload.ts test/e2e/agent-token-flow.test.ts --timeout 120000"
  },
  "dependencies": {
    "@ai-sdk/gateway": "^3.0.37",
    "@elizaos/cloud-rtmp-relay": "workspace:*",
    "@cloudflare/workers-types": "^4.20250109.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@neondatabase/serverless": "^1.1.0",
    "@upstash/redis": "^1.36.1",
    "drizzle-orm": "^0.45.1",
    "hono": "4.12.16",
    "mcp-handler": "^1.0.7",
    "jose": "^5.9.6",
    "stripe": "^20.2.0",
    "typescript": "^6.0.0",
    "wrangler": "^4.0.0",
    "zod": "^4.4.1"
  },
  "devDependencies": {}
}
