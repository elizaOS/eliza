{
  "name": "@elizaos/cloud",
  "version": "0.1.0",
  "workspaces": [
    "../packages/*",
    "../packages/native-plugins/*",
    "../plugins/*",
    "apps/*",
    "packages/*",
    "packages/services/*",
    "services/*",
    "examples/*"
  ],
  "scripts": {
    "postinstall": "find node_modules -path '*/thread-stream/test' -type d -exec rm -rf {} + 2>/dev/null || true; find node_modules -path '*/thread-stream/bench.js' -delete 2>/dev/null || true; find node_modules -path '*/thread-stream/LICENSE' -delete 2>/dev/null || true; find node_modules -path '*/thread-stream/README.md' -delete 2>/dev/null || true; node packages/scripts/postinstall.mjs",
    "setup": "bun run packages/scripts/setup.ts",
    "setup:check": "bun run packages/scripts/setup.ts --check",
    "dev": "concurrently -n api,web -c blue,magenta \"bun run dev:api\" \"bun run dev:web\"",
    "dev:full": "concurrently -n db,api,web -c yellow,blue,magenta \"bun run pglite:server\" \"bun run dev:api\" \"bun run dev:web\"",
    "dev:api": "bun run --cwd apps/api dev",
    "dev:web": "bun run --cwd apps/frontend dev",
    "dev:stack": "bun run setup:check && bun run dev",
    "dev:web:linked": "DEV_LINKED=1 bun run --cwd apps/frontend dev",
    "pglite:server": "bun run packages/scripts/dev/pglite-server.ts",
    "generate:llms": "tsx packages/scripts/generate-llms-txt.ts",
    "generate:jwt-keys": "bun run packages/scripts/generate-jwt-keys.ts",
    "build:sdk": "bun run --cwd packages/sdk build",
    "build:linked-core": "if [ ! -d ../packages/core ]; then exit 0; fi; if [ ! -e ../node_modules ] && [ ! -L ../node_modules ]; then ln -s cloud/node_modules ../node_modules; fi; bun run --cwd ../packages/core prebuild && bun run --cwd ../packages/core build:node",
    "build:linked-shared": "if [ ! -d ../packages/shared ]; then exit 0; fi; bun run --cwd ../packages/shared build",
    "build:linked-workflows": "if [ ! -d ../packages/workflows ]; then exit 0; fi; bun run --cwd ../packages/workflows build",
    "build:linked-billing": "if [ ! -d packages/billing ]; then exit 0; fi; bun run --cwd packages/billing build",
    "build:linked-plugin-sql": "if [ ! -d ../plugins/plugin-sql ]; then exit 0; fi; bun run --cwd ../plugins/plugin-sql build",
    "build:linked-plugin-elevenlabs": "if [ ! -d ../plugins/plugin-elevenlabs ]; then exit 0; fi; bun run --cwd ../plugins/plugin-elevenlabs build",
    "build:linked-plugin-workflow": "if [ ! -d ../plugins/plugin-workflow ]; then exit 0; fi; bun run --cwd ../plugins/plugin-workflow build",
    "build:linked-plugin-openai": "if [ ! -d ../plugins/plugin-openai ]; then exit 0; fi; bun run --cwd ../plugins/plugin-openai build",
    "build:linked-plugin-elizacloud": "if [ ! -d ../plugins/plugin-elizacloud ]; then exit 0; fi; bun run --cwd ../plugins/plugin-elizacloud build",
    "build:linked-workspaces": "bun run build:linked-core && bun run build:linked-shared && bun run build:linked-workflows && bun run build:linked-billing && bun run build:sdk && bun run build:linked-plugin-sql && bun run build:linked-plugin-elevenlabs && bun run build:linked-plugin-workflow && bun run build:linked-plugin-openai && bun run build:linked-plugin-elizacloud",
    "build:web": "bun run build:linked-billing && bun run generate:llms && bun run --cwd apps/frontend build",
    "build:api": "tsc --noEmit --project apps/api/tsconfig.json",
    "build": "bun run build:web && bun run build:api",
    "build:deploy": "NODE_OPTIONS=\"${NODE_OPTIONS:---max-old-space-size=6144}\" bun run build",
    "preview": "bun run --cwd apps/frontend preview",
    "start": "bun run build:web && concurrently -n api,web -c blue,magenta \"bun run dev:api\" \"bun run preview\"",
    "lint": "biome check --write .",
    "lint:check": "biome check .",
    "deps:circular": "madge --circular --extensions ts,tsx --ts-config tsconfig.json ./packages/lib",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "verify": "bun run lint:check && bun run deps:circular && bun run typecheck",
    "typecheck": "bun run packages/scripts/typecheck-split.ts && bun run typecheck:packages && bun ./node_modules/typescript/lib/tsc.js --noEmit --project tsconfig.test.json && bun run --cwd packages/ui typecheck && bun run --cwd packages/sdk typecheck && bun run --cwd packages/billing typecheck && bun run --cwd apps/frontend typecheck && bun run --cwd apps/api typecheck && bun run --cwd services/agent-server typecheck && bun run --cwd services/container-control-plane typecheck && bun run --cwd services/gateway-discord typecheck && bun run --cwd services/gateway-webhook typecheck && bun run --cwd services/operator typecheck && bun run --cwd services/rtmp-relay typecheck",
    "typecheck:packages": "bun run --cwd packages/db typecheck && bun run --cwd packages/lib typecheck && bun run --cwd packages/types typecheck",
    "typecheck:full": "bun ./node_modules/typescript/lib/tsc.js --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run packages/scripts/migrate-with-diagnostics.ts",
    "db:migrate:drizzle": "drizzle-kit migrate",
    "db:copy-to-new": "bun run packages/scripts/migrate-database.ts",
    "db:studio": "drizzle-kit studio",
    "db:local:reset": "rm -rf .eliza/.pgdata",
    "db:local:seed": "tsx packages/scripts/seed-local-dev.ts",
    "db:audit": "bun run packages/scripts/audit-migrations.ts",
    "db:check-migrations": "bun run packages/scripts/check-migration-journal.ts",
    "db:repair-journal": "bun run packages/scripts/repair-drizzle-journal.ts",
    "seed:credit-packs": "tsx packages/scripts/seed-credit-packs.ts",
    "stripe:webhook": "stripe listen --forward-to localhost:8787/api/stripe/webhook",
    "billing:set-email": "tsx packages/scripts/set-billing-email.ts",
    "bootstrapper:build": "cd bootstrapper && ./build.sh",
    "cache:clear": "tsx packages/scripts/clear-cache.ts",
    "eliza-app:cleanup": "bun run packages/scripts/cleanup-eliza-app-user.ts",
    "steward:backfill-users": "bun run packages/scripts/backfill-steward-users.ts",
    "mcp:inspector": "bunx @modelcontextprotocol/inspector@latest",
    "admin:promote": "bun run packages/scripts/promote-admin.ts",
    "admin:list": "bun run packages/scripts/promote-admin.ts --list",
    "admin:revoke": "bun run packages/scripts/promote-admin.ts --revoke",
    "eliza1:cost-reconciliation": "bun ./scripts/eliza1/cost-reconciliation.ts",
    "eliza1:dashboard-alerts": "bun ./scripts/eliza1/dashboard-alerts.ts",
    "vast:doctor": "bun run scripts/vast/doctor.ts",
    "vast:smoke": "bun run scripts/vast/smoke.ts",
    "test:unit": "SKIP_DB_DEPENDENT=1 SKIP_SERVER_CHECK=true bun test --preload ./packages/tests/load-env.ts packages/tests/unit",
    "test:repo-unit:bulk": "find packages/tests/unit -name '*.test.ts' ! -path 'packages/tests/unit/credits.test.ts' ! -path 'packages/tests/unit/docker-infrastructure.test.ts' ! -path 'packages/tests/unit/eliza-app/discord-auth.test.ts' ! -path 'packages/tests/unit/eliza-agent-web-ui.test.ts' ! -path 'packages/tests/unit/oauth/secrets-adapter-utils.test.ts' ! -path 'packages/tests/unit/market-price-preview-route.test.ts' | sort | xargs -n 1 env SKIP_DB_DEPENDENT=1 SKIP_SERVER_CHECK=true bun test --max-concurrency=1 --preload ./packages/tests/load-env.ts && SKIP_DB_DEPENDENT=1 SKIP_SERVER_CHECK=true bun test --max-concurrency=1 --preload ./packages/tests/load-env.ts packages/lib/services/gateway-discord/__tests__ services/gateway-discord/tests/hash-router.test.ts services/gateway-discord/tests/leader-election.test.ts services/gateway-discord/tests/voice-message-handler.test.ts",
    "test:repo-unit:special": "SKIP_DB_DEPENDENT=1 SKIP_SERVER_CHECK=true bun test --preload ./packages/tests/load-env.ts packages/tests/unit/credits.test.ts packages/tests/unit/eliza-app/discord-auth.test.ts packages/tests/unit/eliza-agent-web-ui.test.ts",
    "test:repo-unit:isolated": "SKIP_DB_DEPENDENT=1 SKIP_SERVER_CHECK=true bun test --preload ./packages/tests/load-env.ts packages/tests/unit/docker-infrastructure.test.ts && SKIP_DB_DEPENDENT=1 SKIP_SERVER_CHECK=true bun test --preload ./packages/tests/load-env.ts packages/tests/unit/oauth/secrets-adapter-utils.test.ts && SKIP_DB_DEPENDENT=1 SKIP_SERVER_CHECK=true bun test --preload ./packages/tests/load-env.ts packages/tests/unit/market-price-preview-route.test.ts",
    "test:integration:db": "SKIP_SERVER_CHECK=true bun test --max-concurrency=1 --preload ./packages/tests/load-env.ts packages/tests/integration/db/idempotency.test.ts packages/tests/integration/db/message-router-service.test.ts packages/tests/integration/db/twilio-automation-service.test.ts",
    "test:integration": "node packages/scripts/run-integration-tests.mjs",
    "test:properties": "bun test --max-concurrency=1 --preload ./packages/tests/load-env.ts packages/tests/properties --timeout 300000",
    "test:runtime": "bun run build:linked-workspaces && bun test --max-concurrency=1 --preload ./packages/tests/load-env.ts packages/tests/runtime --timeout 120000",
    "test:mcp": "bun test --preload ./packages/tests/load-env.ts packages/tests/runtime/mcp-loading.test.ts --timeout 120000",
    "test:oauth:manual": "./packages/tests/manual/oauth-manual-test.sh",
    "test:e2e:api": "bun test --max-concurrency=1 --preload ./packages/tests/e2e/preload.ts packages/tests/e2e/api --timeout 120000",
    "test:e2e:auth": "bun test --max-concurrency=1 --preload ./packages/tests/e2e/preload.ts packages/tests/e2e/auth --timeout 120000",
    "test:e2e:cron": "bun test --max-concurrency=1 --preload ./packages/tests/e2e/preload.ts packages/tests/e2e/cron --timeout 120000",
    "test:e2e:v1": "bun test --max-concurrency=1 --preload ./packages/tests/e2e/preload.ts packages/tests/e2e/v1 --timeout 120000",
    "test:e2e:worker": "bun run build:sdk && node packages/scripts/run-api-worker-e2e.mjs",
    "test:e2e:smoke": "node packages/scripts/run-e2e-smoke.mjs",
    "test:e2e:miniapp": "bun test --max-concurrency=1 --preload ./packages/tests/e2e/preload.ts packages/tests/e2e/v1/miniapp-lifecycle.test.ts packages/tests/e2e/v1/app-monetization.test.ts packages/tests/e2e/v1/agent-publishing.test.ts packages/tests/e2e/v1/credits-billing.test.ts packages/tests/e2e/v1/affiliate-miniapp.test.ts --timeout 120000",
    "test:api:e2e": "bun run --cwd apps/api test:e2e",
    "test:e2e:bundle": "bun run test:e2e:api && bun run test:e2e:auth && bun run test:e2e:cron && bun run test:e2e:v1 && bun run test:api:e2e && bun run test:e2e:worker",
    "test:e2e:all": "bun run test:e2e:bundle && bun run test:e2e:smoke && bun run test:playwright",
    "test:secrets": "node packages/scripts/check-secret-hygiene.mjs",
    "test:repo-unit": "bun run test:secrets && bun run test:repo-unit:bulk && bun run test:repo-unit:special && bun run test:repo-unit:isolated",
    "test": "bun run test:repo-unit && bun run test:integration && bun run test:properties && bun run test:runtime && bun run test:mcp",
    "test:full": "bun run test && CLOUD_FULL_SUITE=1 bun run test:e2e:all",
    "test:playwright": "playwright test",
    "test:playwright:auth": "PLAYWRIGHT_REAL_AUTH=true playwright test packages/tests/playwright/auth-real.spec.ts --grep @auth-real --headed",
    "cf:bootstrap": "bash packages/scripts/cf-bootstrap.sh",
    "provisioning-worker:bootstrap": "node packages/scripts/bootstrap-provisioning-worker-host.mjs",
    "deploy:api": "bun run --cwd apps/api deploy",
    "deploy:web": "bun run build:web && cd apps/frontend && bunx wrangler pages deploy dist --project-name=eliza-cloud",
    "deploy": "bun run deploy:api && bun run deploy:web",
    "cf:secrets:put:staging": "node packages/scripts/cf-secrets-migrate.mjs --env staging",
    "cf:secrets:put:prod": "node packages/scripts/cf-secrets-migrate.mjs --env production",
    "cf:tail": "bash packages/scripts/cf-tail.sh"
  },
