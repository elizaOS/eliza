{
  "name": "@elizaos/cloud-ui",
  "version": "2.0.0-beta.2",
  "description": "Compatibility wrapper for the consolidated @elizaos/ui design system.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node scripts/build-compat.mjs",
    "prepack": "bun run build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "biome check package.json tsconfig.json src/index.ts src/index.css scripts/build-compat.mjs",
    "lint:fix": "biome check --write package.json tsconfig.json src/index.ts src/index.css scripts/build-compat.mjs",
    "test": "bun run typecheck"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json",
    "./index.css": "./dist/index.css",
    "./styles": "./dist/index.css",
    "./styles/*.css": "./dist/styles/*.css",
    "./components/*": {
      "types": "./dist/components/*.d.ts",
      "import": "./dist/components/*.js",
      "default": "./dist/components/*.js"
    },
    "./lib/*": {
      "types": "./dist/lib/*.d.ts",
      "import": "./dist/lib/*.js",
      "default": "./dist/lib/*.js"
    },
    "./runtime/*": {
      "types": "./dist/runtime/*.d.ts",
      "import": "./dist/runtime/*.js",
      "default": "./dist/runtime/*.js"
    },
    "./types/*": {
      "types": "./dist/types/*.d.ts",
      "import": "./dist/types/*.js",
      "default": "./dist/types/*.js"
    }
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@elizaos/ui": "workspace:*"
  }
}
