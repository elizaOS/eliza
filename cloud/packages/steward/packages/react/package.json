{
  "name": "@stwd/react",
  "version": "0.7.2",
  "description": "Embeddable React components for Steward agent wallet management",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./wallet": {
      "types": "./dist/wallet.d.ts",
      "import": "./dist/wallet.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && cp src/styles.css dist/styles.css",
    "dev": "tsc --watch",
    "test": "bun test src/__tests__"
  },
  "dependencies": {
    "@stwd/sdk": "^0.8.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "wagmi": "^2.0.0",
    "viem": "^2.0.0",
    "@rainbow-me/rainbowkit": "^2.0.0",
    "@tanstack/react-query": "^5.0.0",
    "@solana/wallet-adapter-react": "^0.15.0",
    "@solana/wallet-adapter-react-ui": "^0.9.0",
    "@solana/wallet-adapter-wallets": "^0.19.0",
    "@solana/web3.js": "^1.90.0",
    "bs58": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "wagmi": {
      "optional": true
    },
    "viem": {
      "optional": true
    },
    "@rainbow-me/rainbowkit": {
      "optional": true
    },
    "@tanstack/react-query": {
      "optional": true
    },
    "@solana/wallet-adapter-react": {
      "optional": true
    },
    "@solana/wallet-adapter-react-ui": {
      "optional": true
    },
    "@solana/wallet-adapter-wallets": {
      "optional": true
    },
    "@solana/web3.js": {
      "optional": true
    },
    "bs58": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "typescript": "^5.8.0",
    "wagmi": "^2.0.0",
    "viem": "^2.0.0",
    "@rainbow-me/rainbowkit": "^2.0.0",
    "@tanstack/react-query": "^5.0.0",
    "@solana/wallet-adapter-react": "^0.15.0",
    "@solana/wallet-adapter-react-ui": "^0.9.0",
    "@solana/wallet-adapter-wallets": "^0.19.0",
    "@solana/web3.js": "^1.90.0",
    "bs58": "^5.0.0"
  },
  "keywords": [
    "steward",
    "agent",
    "wallet",
    "react",
    "components",
    "web3",
    "policy"
  ],
