{
  "name": "@stwd/api",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./app": "./src/app.ts",
    "./worker": "./src/worker.ts"
  },
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "tsc --noEmit",
    "start": "bun src/index.ts",
    "test": "bun test src/__tests__/",
    "wrangler:dev": "wrangler dev",
    "wrangler:deploy": "wrangler deploy",
    "wrangler:dry-run": "wrangler deploy --dry-run --outdir=dist"
  },
  "dependencies": {
    "@stwd/auth": "workspace:*",
    "@stwd/db": "workspace:*",
    "@stwd/redis": "workspace:*",
    "@stwd/policy-engine": "workspace:*",
    "@stwd/shared": "workspace:*",
    "@stwd/vault": "workspace:*",
    "@stwd/webhooks": "workspace:*",
    "bs58": "^6.0.0",
    "hono": "^4.7.0",
    "siwe": "^3.0.0",
    "viem": "^2.30.0"
  },
  "peerDependencies": {
    "drizzle-orm": "^0.45.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "@types/node": "^25.5.0",
    "wrangler": "^4.0.0"
  },
  "description": "Hono REST API for Steward — agents, policies, approvals, and transaction signing"
}
