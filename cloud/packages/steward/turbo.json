      "dependsOn": ["^build"],
      "outputs": []
    },
    "@stwd/proxy#build": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "@stwd/vault#build": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "@stwd/webhooks#build": {
      "dependsOn": ["^build"],
