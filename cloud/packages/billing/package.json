{
  "name": "@elizaos/billing",
  "version": "2.0.0-beta.1",
  "description": "Shared billing utilities for Eliza Cloud gateway services (platform markup arithmetic).",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "node ../../../scripts/rm-path-recursive.mjs dist && tsc -p tsconfig.json",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "22.19.17",
    "typescript": "^6.0.3",
    "vitest": "^4.0.0"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ]
}
