{
  "name": "@elizaos/cloud-lib",
  "version": "0.1.0",
  "description": "Shared Eliza Cloud application libraries, DTO types, and internal services.",
  "type": "module",
  "private": true,
  "exports": {
    "./package.json": "./package.json",
    "./types": "./types.ts",
    "./types/*": "./types/*.ts",
    "./blog": "./blog.ts",
    "./pricing": "./pricing.ts",
    "./pricing-constants": "./pricing-constants.ts",
    "./promotion-pricing": "./promotion-pricing.ts",
    "./utils": "./utils.ts",
    "./utils/*": "./utils/*.ts",
    "./constants/*": "./constants/*.ts",
    "./config/*": "./config/*.ts",
    "./hooks/*": "./hooks/*.ts",
    "./providers/*": "./providers/*.tsx",
    "./internal/api/*": "./api/*.ts",
    "./internal/auth/*": "./auth/*.ts",
    "./internal/cache/*": "./cache/*.ts",
    "./internal/runtime/*": "./runtime/*.ts",
    "./internal/services/*": "./services/*.ts"
  },
  "scripts": {
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit --project tsconfig.json"
  },
  "dependencies": {
    "@elizaos/cloud-db": "workspace:*",
    "@elizaos/cloud-types": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "22.19.17",
    "@types/react": "^19.2.14",
    "typescript": "^6.0.0"
  }
}
