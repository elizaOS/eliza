{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "tsBuildInfoFile": ".tsbuildinfo"
  },
  "include": ["**/*.ts", "**/*.tsx", "../types/**/*.d.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "**/__tests__/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.stories.ts",
    "**/*.stories.tsx"
  ]
}
