# Sensitive Variables Example
# Copy this file to secrets.tfvars and fill in the values
# NEVER commit secrets.tfvars to version control

# GitHub Container Registry credentials
ghcr_username = "your-github-username"
ghcr_token    = "ghp_xxxxxxxxxxxxxxxxxxxx"

# Application secrets
eliza_cloud_url          = "https://your-eliza-cloud-url.com"
gateway_bootstrap_secret = "your-bootstrap-secret"
redis_url                = "https://your-redis-url.upstash.io"
redis_token              = "your-redis-token"
blob_token               = "your-blob-token"

# EKS administrative access (keep these values out of tracked tfvars files)
cluster_admin_arns = [
  "arn:aws:iam::123456789012:role/eks-cluster-admin"
]

# Restrict the public EKS API endpoint to trusted networks only
cluster_endpoint_public_access_cidrs = ["203.0.113.0/24"]

# Eliza App Discord bot (optional - for hybrid bot mode)
eliza_app_discord_bot_token      = "your-eliza-app-discord-bot-token"
eliza_app_discord_application_id = "your-eliza-app-discord-application-id"
