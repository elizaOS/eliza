{
  "name": "@elizaos/agent",
  "version": "2.0.0-alpha.0",
  "private": true,
  "type": "module",
  "description": "Local dev harness (stdin REPL) for @elizaos/core, similar to v1-develop agent/. Build core first: bun run build:core",
  "files": [
    "typescript",
    "python",
    "rust"
  ],
  "scripts": {
    "start": "bun run typescript/index.ts",
    "dev": "bun run --watch typescript/index.ts"
  },
  "dependencies": {
    "@elizaos/core": "workspace:*",
    "@elizaos/plugin-local-ai": "alpha",
    "@elizaos/plugin-ollama": "alpha",
    "@elizaos/plugin-openai": "alpha",
    "@elizaos/plugin-sql": "alpha"
  }
}
